# Copy this file to scripts/.env and fill it in. scripts/.env is git-ignored.

# Your store's myshopify domain (no protocol, no trailing slash)
SHOPIFY_STORE=nootropix.myshopify.com

# Admin API access token from a custom app installed on the store.
# The token starts with `shpat_` (NOT `shpss_` — that's the API secret).
#
# Required scopes for the simplified claim-only import:
#   - write_metaobjects   (create / upsert evidence_claim metaobjects)
SHOPIFY_ADMIN_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional — pin the Admin API version. Defaults to 2025-01 if unset.
# SHOPIFY_API_VERSION=2025-01
