{% comment %}
  Renders animate highlight

  Accepts:
  - class: {String} Class name (optional)
  - style: {String} Style (optional)

  Usage:
  {% render 'animate-highlight' %}
{% endcomment %}

{% liquid
  assign stroke_width = section.settings.highlight_stroke_width | default: 4
%}

{% capture type1 %}
  <span class="xo-animate-highlight xo-animate-highlight--1" style="{{ style }}">
    <svg preserveAspectRatio="none" width="307" height="19" viewBox="0 0 307 19" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M3.5 15.4997C43 9.49971 158.4 -0.900293 304 5.49971" stroke="currentColor" stroke-width="{{ stroke_width }}" stroke-linecap="round" stroke-dashoffset="0" stroke-dasharray="0 302" xo-next-stroke-dasharray="302 302"></path>
    </svg>
  </span>
{% endcapture %}

{% capture type2 %}
  <span xo-abs="full" style="--inset: -2rem; {{ style }}" class="xo-animate-highlight xo-animate-highlight--2">
    <svg preserveAspectRatio="none" width="193" height="95" viewBox="0 0 193 95" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M80.4963 3.50076C-5.50594 -2.49995 -36.7037 92.7007 80.4963 91.5007C121.831 91.3338 201.1 79.6001 187.5 34C177.211 -0.5 96.5001 2.66667 59.5001 15.5" stroke="currentColor" stroke-width="{{ stroke_width }}" stroke-linecap="round" stroke-dashoffset="0" stroke-dasharray="0 474" xo-next-stroke-dasharray="474 474" />
    </svg>
  </span>
{% endcapture %}

{% capture type3 %}
  <span class="xo-animate-highlight xo-animate-highlight--3" style="{{ style }}">
    <svg preserveAspectRatio="none" width="322" height="11" viewBox="0 0 322 11" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M2.5 4.5L321.5 2L43 8.5H309.5" stroke="currentColor" stroke-width="{{ stroke_width }}" stroke-linecap="square" stroke-dashoffset="0" stroke-dasharray="0 865" xo-next-stroke-dasharray="865 865"/>
    </svg>
  </span>
{% endcapture %}

{% capture type4 %}
  <span class="xo-animate-highlight xo-animate-highlight--4" style="{{ style }}">
    <svg preserveAspectRatio="none" width="176" height="29" viewBox="0 0 176 29" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M3.5 24.0004C18.5 15.667 40.5 4.5 55.5 8.50038C66.9019 11.5412 66.5 30.5001 82 24.0004C97.5 17.5007 129.5 -0.999324 143 5.00068C156.5 11.0007 165.5 12.4996 173 10.5" stroke="currentColor" stroke-width="{{ stroke_width }}" stroke-linecap="round" stroke-dashoffset="0" stroke-dasharray="0 186" xo-next-stroke-dasharray="186 186"/>
    </svg>
  </span>
{% endcapture %}

{% capture type5 %}
  <span class="xo-animate-highlight xo-animate-highlight--5" style="{{ style }}">
    <span class="xo-animate-highlight__anim xo-animate-highlight__anim--1"></span>
  </span>
{% endcapture %}

{% capture type6 %}
  <span class="xo-animate-highlight xo-animate-highlight--6" style="{{ style }}">
    <span class="xo-animate-highlight__anim xo-animate-highlight__anim--1"></span>
  </span>
{% endcapture %}

{% case section.settings.highlight %}
  {% when 'type-1' %}
    {{ type1 }}
  {% when 'type-2' %}
    {{ type2 }}
  {% when 'type-3' %}
    {{ type3 }}
  {% when 'type-4' %}
    {{ type4 }}
  {% when 'type-5' %}
    {{ type5 }}
  {% when 'type-6' %}
    {{ type6 }}
  {% else %}
    {{ type1 }}
{% endcase %}
