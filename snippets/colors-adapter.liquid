{% style %}
  {% for scheme in settings.color_schemes -%}
    {% assign scheme_classes = scheme_classes | append: ', .color-' | append: scheme.id %}
    {% if forloop.index == 1 -%}
    :root,
    {%- endif %}
    .color-{{ scheme.id }} {
    --color-background: {{ scheme.settings.background.red }},{{ scheme.settings.background.green }},{{
    scheme.settings.background.blue }};
    --color-background-2: {{ scheme.settings.background_2.red }},{{ scheme.settings.background_2.green }},{{
    scheme.settings.background_2.blue }};
    {% if scheme.settings.background_gradient != empty %}
    --gradient-background: {{ scheme.settings.background_gradient }};
    {% else %}
    --gradient-background: {{ scheme.settings.background }};
    {% endif %}
    --color-accent: {{ scheme.settings.accent.red }},{{ scheme.settings.accent.green }},{{ scheme.settings.accent.blue }};
    --color-accent-2: {{ scheme.settings.accent_2.red }},{{ scheme.settings.accent_2.green }},{{ scheme.settings.accent_2.blue }};
    --color-accent-3: {{ scheme.settings.accent_3.red }},{{ scheme.settings.accent_3.green }},{{ scheme.settings.accent_3.blue }};
    --color-accent-4: {{ scheme.settings.accent_4.red }},{{ scheme.settings.accent_4.green }},{{ scheme.settings.accent_4.blue }};
    --color-foreground: {{ scheme.settings.text.red }},{{ scheme.settings.text.green }},{{ scheme.settings.text.blue }};
    --color-foreground-2: {{ scheme.settings.text_2.red }},{{ scheme.settings.text_2.green }},{{ scheme.settings.text_2.blue }};
    --color-foreground-3: {{ scheme.settings.text_3.red }},{{ scheme.settings.text_3.green }},{{ scheme.settings.text_3.blue }};
    --color-foreground-4: {{ scheme.settings.text_4.red }},{{ scheme.settings.text_4.green }},{{ scheme.settings.text_4.blue }};
    --color-foreground-5: {{ scheme.settings.text_5.red }},{{ scheme.settings.text_5.green }},{{ scheme.settings.text_5.blue }};
    --color-shadow: {{ scheme.settings.shadow.red }},{{ scheme.settings.shadow.green }},{{ scheme.settings.shadow.blue }};
    --color-border: {{ scheme.settings.border.red }},{{ scheme.settings.border.green }},{{ scheme.settings.border.blue }};
    --color-support-error: {{ scheme.settings.support_error.red }},{{ scheme.settings.support_error.green }},{{ scheme.settings.support_error.blue }};
    --color-button: {{ scheme.settings.button.red }},{{ scheme.settings.button.green }},{{ scheme.settings.button.blue }};
    --color-button-text: {{ scheme.settings.button_label.red }},{{ scheme.settings.button_label.green }},{{
    scheme.settings.button_label.blue }};
    --color-secondary-button: {{ scheme.settings.secondary_button.red }},{{ scheme.settings.secondary_button.green }},{{
    scheme.settings.secondary_button.blue }};
    --color-secondary-button-text: {{ scheme.settings.secondary_button_label.red }},{{
    scheme.settings.secondary_button_label.green }},{{ scheme.settings.secondary_button_label.blue }};
    --color-tertiary-button: {{ scheme.settings.tertiary_button.red }},{{ scheme.settings.tertiary_button.green }},{{
    scheme.settings.tertiary_button.blue }};
    --color-tertiary-button-text: {{ scheme.settings.tertiary_button_label.red }},{{
    scheme.settings.tertiary_button_label.green }},{{ scheme.settings.tertiary_button_label.blue }};
    --color-gray-button: {{ scheme.settings.gray_button.red }},{{ scheme.settings.gray_button.green }},{{
    scheme.settings.gray_button.blue }};
    --color-gray-button-text: {{ scheme.settings.gray_button_label.red }},{{ scheme.settings.gray_button_label.green }},{{
    scheme.settings.gray_button_label.blue }};
    --color-dark-button: {{ scheme.settings.dark_button.red }},{{ scheme.settings.dark_button.green }},{{
    scheme.settings.dark_button.blue }};
    --color-dark-button-text: {{ scheme.settings.dark_button_label.red }},{{ scheme.settings.dark_button_label.green }},{{
    scheme.settings.dark_button_label.blue }};
    --color-light-button: {{ scheme.settings.light_button.red }},{{ scheme.settings.light_button.green }},{{
    scheme.settings.light_button.blue }};
    --color-light-button-text: {{ scheme.settings.light_button_label.red }},{{ scheme.settings.light_button_label.green
    }},{{ scheme.settings.light_button_label.blue }};
    --color-link: {{ scheme.settings.button_label.red }},{{ scheme.settings.button_label.green }},{{
    scheme.settings.button_label.blue }};
    --color-badge-foreground: {{ scheme.settings.text.red }},{{ scheme.settings.text.green }},{{ scheme.settings.text.blue
    }};
    --color-badge-background: {{ scheme.settings.background.red }},{{ scheme.settings.background.green }},{{
    scheme.settings.background.blue }};
    --color-badge-border: {{ scheme.settings.text.red }},{{ scheme.settings.text.green }},{{ scheme.settings.text.blue }};
    --color-layer: {{ scheme.settings.layer.red }},{{ scheme.settings.layer.green }},{{ scheme.settings.layer.blue }};
    --color-error: {{ scheme.settings.error.red }},{{ scheme.settings.error.green }},{{ scheme.settings.error.blue }};
    --color-success: {{ scheme.settings.success.red }},{{ scheme.settings.success.green }},{{ scheme.settings.success.blue }};
    --color-waring: {{ scheme.settings.waring.red }},{{ scheme.settings.waring.green }},{{ scheme.settings.waring.blue }};
    --color-overlay: {{ scheme.settings.overlay.red }},{{ scheme.settings.overlay.green }},{{ scheme.settings.overlay.blue }};
    --color-overlay-2: {{ scheme.settings.overlay_2.red }},{{ scheme.settings.overlay_2.green }},{{ scheme.settings.overlay_2.blue }};
    --color-blur: {{ scheme.settings.blur.red }},{{ scheme.settings.blur.green }},{{ scheme.settings.blur.blue }};
    --color-badge-sale-background: {{ scheme.settings.badge_sale_background.red }},{{ scheme.settings.badge_sale_background.green }},{{ scheme.settings.badge_sale_background.blue }};
    --color-badge-sale-label: {{ scheme.settings.badge_sale_label.red }},{{ scheme.settings.badge_sale_label.green }},{{ scheme.settings.badge_sale_label.blue }};
    --color-badge-new-background: {{ scheme.settings.badge_new_background.red }},{{ scheme.settings.badge_new_background.green }},{{ scheme.settings.badge_new_background.blue }};
    --color-badge-new-label: {{ scheme.settings.badge_new_label.red }},{{ scheme.settings.badge_new_label.green }},{{ scheme.settings.badge_new_label.blue }};
    --color-badge-sold-out-background: {{ scheme.settings.badge_sold_out_background.red }},{{ scheme.settings.badge_sold_out_background.green }},{{ scheme.settings.badge_sold_out_background.blue }};
    --color-badge-sold-out-label: {{ scheme.settings.badge_sold_out_label.red }},{{ scheme.settings.badge_sold_out_label.green }},{{ scheme.settings.badge_sold_out_label.blue }};
    --payment-terms-background-color: rgb({{ scheme.settings.background.rgb }});
    }
  {% endfor %}


  :where({{ scheme_classes | prepend: 'body' }}) {
    color: color-mix(in srgb, rgba(var(--color-foreground)) var(--font-body-color-opacity), transparent);
    background-color: color-mix(in srgb, rgba(var(--color-background)) 100%, transparent);
  }
{% endstyle %}
