<script>
  window.settings = {
    {%- if settings.animate_duration %}
      animate_duration: {{ settings.animate_duration }},
    {%- endif -%}
    {%- if settings.animate_effect %}
      animate_effect: '{{ settings.animate_effect }}',
    {%- endif -%}
    {%- if settings.animate_strength %}
      animate_strength: {{ settings.animate_strength }},
    {%- endif -%}
    {%- if settings.modal_animate %}
      modal_animate: '{{ settings.modal_animate }}',
    {%- endif -%}
    {%- if settings.modal_easing %}
      modal_easing: '{{ settings.modal_easing }}',
    {%- endif -%}
    {%- if settings.modal_duration %}
      modal_duration: {{ settings.modal_duration }},
    {%- endif -%}
    {%- if settings.drawer_easing %}
      drawer_easing: '{{ settings.drawer_easing }}',
    {%- endif -%}
    {%- if settings.drawer_duration %}
      drawer_duration: {{ settings.drawer_duration }},
    {%- endif -%}
    {%- if settings.image_lazyload %}
      image_lazyload: {{ settings.image_lazyload }},
    {%- endif -%}
    {% if settings.color_schemes %}
      color_scheme_ids: [
        {% for scheme in settings.color_schemes -%}
          "{{ scheme.id }}",
        {% endfor -%}
      ],
    {% endif %}
    {% if settings.dark_mode_mapping %}
      dark_mode_mapping: `{{ settings.dark_mode_mapping }}`,
    {% endif %}
    {% if settings.quick_link %}
      quick_link: {{ settings.quick_link }},
    {% endif %}
    {% if settings.cart_free_shipping_min_amount %}
      cart_free_shipping_min_amount: {{ settings.cart_free_shipping_min_amount }},
    {% endif %}
  }
</script>
