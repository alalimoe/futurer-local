{% comment %}
  Render a product bundle content

  @param {object} product - Product
  @param {string} bundle_style - Bundle style

  @example
  {% render 'product-bundle-content', product: product, bundle_style: bundle_style %}
{% endcomment %}

{% liquid
  assign bundle_style = bundle_style | default: 'style-1'

  case bundle_style
    when 'style-1'
      render 'product-bundle-content-style-1', product: product
    when 'style-2'
      render 'product-bundle-content-style-2', product: product
    else
      render 'product-bundle-content-style-1', product: product
  endcase
%}
