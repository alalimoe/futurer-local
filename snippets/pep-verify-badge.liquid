{% doc %}
  @param {string} class - Wrapper CSS class (e.g. pp__verify, pcb__verify, qt__verify)
  @param {string} [label] - Visible badge text (default: Verified)
  @param {string} [title] - Optional title attribute on the wrapper
{% enddoc %}
{%- liquid
  assign badge_label = label | default: 'Verified'
-%}
<span class="{{ class }}" {% if title != blank %}title="{{ title | escape }}"{% endif %}>
  <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M9.5 12.5l2 2 4-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
  {{- badge_label -}}
</span>
