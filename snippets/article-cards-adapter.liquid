{% style %}
  :root {
    --article-card-image-padding: {{ settings.article_card_image_padding | divided_by: 10.0 }}rem;
    --article-card-content-padding-vertical: {{ settings.article_card_content_padding_vertical | divided_by: 10.0 }}rem;
    --article-card-content-padding-horizontal: {{ settings.article_card_content_padding_horizontal | divided_by: 10.0 }}rem;
    --article-card-text-alignment: {{ settings.article_card_text_alignment }};
    --article-card-border-width: {{ settings.article_card_border_thickness | divided_by: 10.0 }}rem;
    --article-card-border-opacity: {{ settings.article_card_border_opacity | divided_by: 100.0 }};
    --article-card-shadow-opacity: {{ settings.article_card_shadow_opacity | divided_by: 100.0 }};
    --article-card-shadow-visible: {% if settings.article_card_shadow_opacity > 0 %}1{% else %}0{% endif %};
    --article-card-shadow-horizontal-offset: {{ settings.article_card_shadow_horizontal_offset | divided_by: 10.0 }}rem;
    --article-card-shadow-vertical-offset: {{ settings.article_card_shadow_vertical_offset | divided_by: 10.0 }}rem;
    --article-card-shadow-blur-radius: {{ settings.article_card_shadow_blur | divided_by: 10.0 }}rem;
  }
{% endstyle %}
