{% comment %}
  Renders action-remove

  Accepts:
  - class: {String} Container class name (optional)
  - icon_size: {String} Icon size (optional)

  Usage:
  {% render 'action-remove' %}
{% endcomment %}

{% liquid
  assign icon_size = icon_size | default: '1.6rem'
  assign container_class = 'xo-action-remove'
  if class
    assign container_class = container_class | append: ' ' | append: class
  endif
%}

<div class="{{ container_class }}">
  <span class="xo-action-remove__icon">
    <svg width="{{ icon_size }}" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
