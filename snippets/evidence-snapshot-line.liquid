{%- comment -%}
  Evidence Snapshot — 1-line teaser under product titles
  Supports evidence.snapshots (List) for stacked products, falls back to evidence.snapshot (One).
  Collects up to 3 headlines across all snapshots (combined).
{%- endcomment -%}

{%- assign snapshots = product.metafields.evidence.snapshots.value -%}
{%- assign use_list = true -%}
{%- if snapshots == blank or snapshots.size == 0 -%}
  {%- assign use_list = false -%}
{%- endif -%}
{%- unless use_list -%}
  {%- assign snapshot = product.metafields.evidence.snapshot.value | default: product.metafields.evidence.snapshot -%}
{%- endunless -%}

{%- assign collected = '' -%}
{%- assign count = 0 -%}

{%- if use_list -%}
  {%- for snap in snapshots -%}
    {%- if count >= 3 -%}{%- break -%}{%- endif -%}
    {%- assign claims = snap.claims_list.value | default: snap.claims_list -%}
    {%- if claims and claims.size > 0 -%}
      {%- assign flagged = claims | where: 'show_in_snapshot', true -%}
      {%- if flagged.size > 0 -%}
        {%- assign working = flagged -%}
      {%- else -%}
        {%- assign working = claims -%}
      {%- endif -%}
      {%- assign has_priority = false -%}
      {%- for c in working -%}
        {%- assign p = c.priority.value | default: c.priority -%}
        {%- if p != blank -%}{%- assign has_priority = true -%}{%- break -%}{%- endif -%}
      {%- endfor -%}
      {%- if has_priority -%}
        {%- assign working = working | sort: 'priority' -%}
      {%- endif -%}
      {%- for c in working -%}
        {%- if count >= 3 -%}{%- break -%}{%- endif -%}
        {%- assign headline = c.headline.value | default: c.headline | default: '' -%}
        {%- if headline != '' -%}
          {%- capture collected -%}{{ collected }}{% if count > 0 %} • {% endif %}{{ headline }}{%- endcapture -%}
          {%- assign count = count | plus: 1 -%}
        {%- endif -%}
      {%- endfor -%}
    {%- endif -%}
  {%- endfor -%}
{%- else -%}
  {%- assign claims = snapshot.claims_list.value | default: snapshot.claims_list -%}
  {%- if claims and claims.size > 0 -%}
    {%- assign flagged = claims | where: 'show_in_snapshot', true -%}
    {%- if flagged.size > 0 -%}
      {%- assign working = flagged -%}
    {%- else -%}
      {%- assign working = claims -%}
    {%- endif -%}
    {%- assign has_priority = false -%}
    {%- for c in working -%}
      {%- assign p = c.priority.value | default: c.priority -%}
      {%- if p != blank -%}{%- assign has_priority = true -%}{%- break -%}{%- endif -%}
    {%- endfor -%}
    {%- if has_priority -%}
      {%- assign working = working | sort: 'priority' -%}
    {%- endif -%}
    {%- assign top3 = working | slice: 0, 3 -%}
    {%- for c in top3 -%}
      {%- assign headline = c.headline.value | default: c.headline | default: '' -%}
      {%- if headline != '' -%}
        {%- capture collected -%}{{ collected }}{% if forloop.index0 > 0 %} • {% endif %}{{ headline }}{%- endcapture -%}
      {%- endif -%}
    {%- endfor -%}
  {%- endif -%}
{%- endif -%}

{%- if collected != '' -%}
  <div class="es-line" aria-label="Top evidence-backed benefits">
    <span class="es-line__labels">{{ collected }}</span>
    <a class="es-line__more" href="{{ product.url }}#evidence-snapshot" aria-label="See study references">[See references ▸]</a>
  </div>
{%- endif -%}
