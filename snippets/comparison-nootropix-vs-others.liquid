{%- comment -%}
  Comparison table: Nootropix vs iHerb vs Amazon US
  Edit values in one place; the snippet can be reused on other pages.
{%- endcomment -%}

<table class="table table--bordered table--striped comparison-table">
  <thead>
    <tr>
      <th aria-hidden="true"></th>
      <th>Nootropix</th>
      <th>iHerb (UAE)</th>
      <th>Amazon US</th>
    </tr>
  </thead>

  <tbody>
    <tr>
      <td><strong>Delivery time 🇦🇪</strong></td>
      <td><span class="highlight">4 h (Dubai)</span></td>
      <td>5-10 days</td>
      <td>10-20 days</td>
    </tr>
    <tr>
      <td><strong>Customs risk</strong></td>
      <td>None — shipped locally</td>
      <td>Moderate (≈20 % held)</td>
      <td>High (≈45 % held)</td>
    </tr>
    <tr>
      <td><strong>Shipping fee</strong></td>
      <td><strong>FREE &gt; 300 AED</strong></td>
      <td>35–55 AED</td>
      <td>60–90 AED<br><small>(plus duties)</small></td>
    </tr>
    <tr>
      <td><strong>COA on every batch</strong></td>
      <td>✓ Yes</td>
      <td>✕ Not guaranteed</td>
      <td>✕ Not guaranteed</td>
    </tr>
  </tbody>
</table>

<style>
  /* Mobile stacking */
  @media (max-width: 768px){
    .comparison-table{
      font-size: .85rem;
    }
  }
  .comparison-table .highlight{
    color: var(--color-accent);
    font-weight: 700;
  }
</style>
<script type="application/ld+json">
{
  "@context":"https://schema.org",
  "@type":"Product",
  "name":"Nootropix Same-Day Delivery",
  "description":"4-hour courier delivery of premium nootropics within Dubai.",
  "brand":"Nootropix",
  "offers":{
    "@type":"Offer",
    "price":"0.00",
    "priceCurrency":"AED",
    "availability":"https://schema.org/InStock",
    "itemCondition":"https://schema.org/NewCondition",
    "url":"https://{{ shop.domain }}/pages/buy-nootropics-dubai"
  }
}
</script>
