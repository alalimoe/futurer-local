<div class="premium-bnpl-box">
  <div class="premium-bnpl-box__label">
    <svg width="18" height="18" viewBox="0 0 16 16" fill="none" aria-hidden="true">
      <rect x="1" y="3" width="14" height="10" rx="2" stroke="currentColor" stroke-width="1.5"/>
      <path d="M1 6.5h14" stroke="currentColor" stroke-width="1.5"/>
    </svg>
    <span>{{ 'products.bnpl.eyebrow' | t }}</span>
  </div>
  <p class="premium-bnpl-box__tagline">{{ 'products.bnpl.tagline' | t }}</p>
  <div class="premium-bnpl-box__merged">
    <div class="premium-bnpl-box__col premium-bnpl-box__col--tabby">
      {% render 'tabby-installments' %}
    </div>
    <span class="premium-bnpl-box__divider" aria-hidden="true"></span>
    <div class="premium-bnpl-box__col premium-bnpl-box__col--tamara">
      {% render 'tamara' %}
    </div>
  </div>
</div>

{% stylesheet %}
  .premium-bnpl-box {
    margin: 1.6rem 0;
    padding: 1.6rem 1.6rem 1.8rem;
    border-radius: var(--general-radius-2, 1.5rem);
    background: color-mix(in srgb, rgba(var(--color-foreground)) 2.5%, rgba(var(--color-background)));
    border: 0.1rem solid color-mix(in srgb, rgba(var(--color-foreground)) 8%, transparent);
    transition: border-color 0.3s var(--out-soft, ease), background-color 0.3s var(--out-soft, ease);
  }

  .premium-bnpl-box:hover {
    border-color: color-mix(in srgb, rgba(var(--color-foreground)) 14%, transparent);
    background: color-mix(in srgb, rgba(var(--color-foreground)) 4%, rgba(var(--color-background)));
  }

  .premium-bnpl-box__label {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    font-size: 1.1rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 55%, transparent);
    margin: 0 0 0.8rem;
  }

  .premium-bnpl-box__label svg {
    flex-shrink: 0;
    color: rgba(var(--color-accent));
  }

  .premium-bnpl-box__tagline {
    margin: 0 0 1.2rem;
    font-size: calc(var(--font-body-scale, 1) * 1.4rem);
    line-height: 1.45;
    font-weight: 600;
    color: rgba(var(--color-foreground));
  }

  .premium-bnpl-box__merged {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 0;
    padding: 1.2rem 1.4rem;
    border-radius: var(--general-radius-1, 1rem);
    background: rgba(var(--color-background));
    border: 0.1rem solid color-mix(in srgb, rgba(var(--color-foreground)) 8%, transparent);
  }

  .premium-bnpl-box__col {
    display: flex;
    align-items: center;
    width: 100%;
    min-width: 0;
  }

  .premium-bnpl-box__divider {
    display: block;
    width: 100%;
    height: 0.1rem;
    margin: 1rem 0;
    flex-shrink: 0;
    background: color-mix(in srgb, rgba(var(--color-foreground)) 8%, transparent);
    border: none;
  }

  @media (min-width: 768px) {
    .premium-bnpl-box__merged {
      flex-direction: row;
      align-items: center;
      gap: clamp(1.2rem, 2vw, 2rem);
      padding: 1.4rem 1.6rem;
    }

    .premium-bnpl-box__col {
      flex: 1;
      width: auto;
    }

    .premium-bnpl-box__divider {
      width: 0.1rem;
      height: auto;
      min-height: 3.2rem;
      align-self: stretch;
      margin: 0;
    }
  }

  .premium-bnpl-box #TabbyPromo,
  .premium-bnpl-box #TabbyPromo > div,
  .premium-bnpl-box tamara-widget,
  .premium-bnpl-box .tamara-widget-container {
    border: none !important;
    background: transparent !important;
    box-shadow: none !important;
    padding: 0 !important;
    margin: 0 !important;
  }

  .premium-bnpl-box tamara-widget::part(container),
  .premium-bnpl-box tabby-promo::part(container) {
    border: none !important;
    background: transparent !important;
    box-shadow: none !important;
    padding: 0 !important;
    margin: 0 !important;
  }

  @media (prefers-reduced-motion: reduce) {
    .premium-bnpl-box {
      transition: none;
    }
  }
{% endstylesheet %}
