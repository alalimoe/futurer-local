{%- comment -%}
  Unified Premium BNPL Container — Wraps Tabby + Tamara in a single, fluid frosted-glass box.
{%- endcomment -%}

<div class="premium-bnpl-box">
  <div class="premium-bnpl-box__label">
    <svg width="18" height="18" viewBox="0 0 16 16" fill="none" aria-hidden="true">
      <rect x="1" y="3" width="14" height="10" rx="2" stroke="currentColor" stroke-width="1.5"/>
      <path d="M1 6.5h14" stroke="currentColor" stroke-width="1.5"/>
    </svg>
    <span>Buy now, pay later</span>
  </div>

  <div class="premium-bnpl-box__widgets">
    <div class="premium-bnpl-box__widget">
      {% render 'tabby-installments' %}
    </div>
    <div class="premium-bnpl-box__widget">
      {% render 'tamara' %}
    </div>
  </div>
</div>

<style>
  .premium-bnpl-box {
    margin: 16px 0;
    padding: 18px 20px;
    border-radius: 16px;
    background: rgba(249, 250, 251, 0.65);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.8);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.03);
    transition: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
  }

  .premium-bnpl-box:hover {
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.06);
    transform: translateY(-2px);
  }

  .premium-bnpl-box__label {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 11px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #6B7280;
    margin-bottom: 12px;
  }

  .premium-bnpl-box__label svg {
    flex-shrink: 0;
    color: var(--nx-accent, #FBBF24);
  }

  .premium-bnpl-box__widgets {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .premium-bnpl-box__widget {
    display: flex;
    align-items: center;
    width: 100%;
  }

  .premium-bnpl-box__widget:not(:last-child) {
    border-bottom: 1px solid rgba(0, 0, 0, 0.04);
    padding-bottom: 12px;
    margin-bottom: 12px;
  }

  .premium-bnpl-box #TabbyPromo,
  .premium-bnpl-box #TabbyPromo > div,
  .premium-bnpl-box tamara-widget,
  .premium-bnpl-box .tamara-widget-container {
    border: none !important;
    background: transparent !important;
    box-shadow: none !important;
    padding: 0 !important;
    margin: 0 !important;
  }

  .premium-bnpl-box tamara-widget::part(container),
  .premium-bnpl-box tabby-promo::part(container) {
    border: none !important;
    background: transparent !important;
    box-shadow: none !important;
    padding: 0 !important;
    margin: 0 !important;
  }

  @media (prefers-reduced-motion: reduce) {
    .premium-bnpl-box { transition: none; transform: none; }
  }
</style>
