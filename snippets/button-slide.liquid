{% comment %}
  Renders a button-slide

  Accepts:
  - slide_direction: {String} Direction when hover (left | right) (required)
  - btn_size: {String} Button size (rem) (required)
  - icon: {String} Icon name (required)
  - icon_size: {String} Icon size (required)

  Usage:
  {% render 'button-slide' %}
{% endcomment %}

{% liquid
  assign container_class = 'button-slide'
  assign container_style = '--btn-size: ' | append: size
  if direction
    assign container_class = container_class | append: ' button-slide--' | append: direction
  endif
  if type == 'boxes'
    assign container_class = container_class | append: ' button-slide--boxed'
  endif
  if style
    assign container_class = container_class | append: ' button-slide--' | append: style
  endif
  if settings.enable_border_radius
    assign container_class = container_class | append: ' button-slide--radius'
  endif
%}

<div class="{{ container_class }}" style="{{ container_style }}">
  {% if text != null %}
    <span class="button-slide__text">{{ text }}</span>
  {% endif %}
  {% if text != null %}
    <div class="button-slide__wrapper">
  {% endif %}
  <div class="button-slide__icon-before">
    {% render 'icon', name: icon, size: icon_size %}
  </div>
  <div class="button-slide__icon-after">
    {% render 'icon', name: icon, size: icon_size %}
  </div>
  {% if text != null %}
    </div>
  {% endif %}
</div>
