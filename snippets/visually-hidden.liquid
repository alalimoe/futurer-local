{% comment %}
  Visually hidden for a11y: Provide text for screen readers only

  Accepts:
  - content: {String} Content of visually hidden
  - tag_name: {String} Tag name of visually hidden (Optional)
  - inline: {Boolean} Inline variant (Optional). Default: true

  Usage:
  {% render 'visually-hidden', content: 'Content' %}
{% endcomment %}

{%- assign tag_name = tag_name | default: 'div' -%}
{% if inline == null %}
  {%- assign inline = true -%}
{% endif %}

<{{ tag_name }} class="xo-visually-hidden{% if inline %} xo-visually-hidden--inline{% endif %}">{{ content }}</{{ tag_name }}>
