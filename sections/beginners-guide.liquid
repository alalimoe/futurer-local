{% comment %}
Beginner's Guide Section
Template: templates/page.beginners-guide.json
Assets expected: assets/beginners-guide.css, assets/beginners-guide.js
This section renders a complete long-form guide with IDs for a sticky TOC & progress bar.
Replace placeholder links (e.g., #, /products/...) with your actual handles.
{% endcomment %}

{{ 'beginners-guide.css' | asset_url | stylesheet_tag }}
<script src="{{ 'beginners-guide.js' | asset_url }}" defer></script>

<section class="guide" data-guide>
  {% if section.settings.show_progress %}
    <div class="guide-progress" aria-hidden="true">
      <div class="guide-progress__bar" id="guideProgressBar"></div>
    </div>
  {% endif %}

  <div class="guide-layout">
    {% if section.settings.show_sticky_toc %}
    <aside class="guide-toc" id="guideTOC" aria-label="On this page">
      <div class="guide-toc__title">On this page</div>
      <nav class="guide-toc__nav" id="guideTOCNav">
        <!-- Auto-populated by JS -->
      </nav>
    </aside>
    {% endif %}

    <main class="guide-content" id="guideMain">
      <!-- Reading mode controls -->
      {% if section.settings.enable_reading_modes %}
      <div class="guide-modes" role="group" aria-label="Reading mode">
        <button class="btn btn--sm" data-mode="default">Default</button>
        <button class="btn btn--sm" data-mode="adhd">ADHD‑friendly</button>
        <button class="btn btn--sm" data-mode="listen" data-listen>Listen</button>
      </div>
      {% endif %}

      <!-- HERO -->
