{% comment %} Simple signup band (can be swapped to your form app snippet) {% endcomment %}

{%- style -%}
  .xo-section--{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    font-family: var(--font-body-family);
  }

  .xo-section--{{ section.id }} .nlb-wrap {
    display: flex;
    gap: 16px;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
  }

  .xo-section--{{ section.id }} .nlb-heading {
    font-family: var(--font-heading-family);
    font-weight: 600;
    font-size: clamp(1.1rem, 2vw, 1.35rem);
    letter-spacing: -0.02em;
    color: rgba(var(--color-foreground));
    margin: 0;
  }

  .xo-section--{{ section.id }} .nlb-subtext {
    color: color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent);
    line-height: 1.5;
    font-size: clamp(0.85rem, 1.2vw, 0.9375rem);
    margin: 4px 0 0;
  }

  .xo-section--{{ section.id }} .nlb-form {
    display: flex;
    gap: 8px;
  }

  .xo-section--{{ section.id }} .nlb-input {
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
    border-radius: var(--button-radius);
    padding: 10px 14px;
    min-height: 44px;
    box-sizing: border-box;
    font-family: var(--font-body-family);
    font-size: clamp(0.85rem, 1.2vw, 0.9375rem);
    background: rgba(var(--color-background));
    color: rgba(var(--color-foreground));
    transition: border-color 0.3s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .nlb-input:focus {
    outline: none;
    border-color: rgba(var(--color-accent));
  }

  .xo-section--{{ section.id }} .nlb-input:focus-visible {
    outline: 2px solid rgba(var(--color-accent));
    outline-offset: 2px;
  }

  .xo-section--{{ section.id }} .nlb-input::placeholder {
    color: color-mix(in srgb, rgba(var(--color-foreground)) 40%, transparent);
  }

  .xo-section--{{ section.id }} .nlb-btn {
    border: 2px solid rgba(var(--color-accent));
    border-radius: var(--button-radius);
    background: transparent;
    color: rgba(var(--color-foreground));
    font-weight: 600;
    padding: 10px 18px;
    min-height: 44px;
    cursor: pointer;
    font-size: clamp(0.85rem, 1.2vw, 0.9375rem);
    font-family: var(--font-body-family);
    transition: background 0.3s var(--out-soft, ease), transform 0.3s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .nlb-btn:hover {
    background: rgba(var(--color-accent));
    transform: translateY(-1px);
  }

  .xo-section--{{ section.id }} .nlb-btn:active {
    transform: scale(0.97);
  }

  .xo-section--{{ section.id }} .nlb-btn:focus-visible {
    outline: 2px solid rgba(var(--color-accent));
    outline-offset: 2px;
  }

  @media (prefers-reduced-motion: reduce) {
    .xo-section--{{ section.id }} .nlb-input,
    .xo-section--{{ section.id }} .nlb-btn {
      transition: none;
    }

    .xo-section--{{ section.id }} .nlb-btn:hover {
      transform: none;
    }
  }
{%- endstyle -%}

<section {% render 'section-attr' %}>
  <xo-container>
    <div class="nlb-wrap">
      <div class="nlb-left">
        <div class="nlb-heading">{{ section.settings.heading }}</div>
        <div class="nlb-subtext">{{ section.settings.subtext }}</div>
      </div>
      <div class="nlb-right">
        <form class="nlb-form" method="post" action="{{ routes.predictive_search_url | default: '/' }}" onsubmit="return false;">
          <input class="nlb-input" type="email" placeholder="{{ section.settings.placeholder }}" aria-label="Email" autocomplete="email">
          <button class="nlb-btn" type="button">{{ section.settings.cta }}</button>
        </form>
      </div>
    </div>
  </xo-container>
</section>

{% schema %}
{
  "name": "Newsletter signup band",
  "tag": "section",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "default" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Be the first to know" },
    { "type": "text", "id": "subtext", "label": "Subtext", "default": "Get research updates, product drops, and COA postings." },
    { "type": "text", "id": "placeholder", "label": "Placeholder", "default": "you@lab.edu" },
    { "type": "text", "id": "cta", "label": "CTA", "default": "Subscribe" },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding top", "default": 24 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding bottom", "default": 24 }
  ],
  "blocks": [
    { "type": "@app" }
  ],
  "presets": [{ "name": "Newsletter signup band" }]
}
{% endschema %}
