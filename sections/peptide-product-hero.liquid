{% comment %}
  Peptide PDP hero: media carousel + buy box + specs; xo-product variant sync.
{% endcomment %}

{%- liquid
  assign selected_variant = product.selected_or_first_available_variant
  assign variant_images = product.images | where: 'attached_to_variant?', true | map: 'src'

  assign media_column = section.settings.media_column | plus: 0
  assign content_column = 12 | minus: media_column

  assign subtitle_mf = product.metafields.npx.subtitle
  assign benefits_mf = product.metafields.npx.benefits

  assign benefit1 = product.metafields.pdp.benefit_1
  assign benefit2 = product.metafields.pdp.benefit_2
  assign benefit3 = product.metafields.pdp.benefit_3

  assign pdp_headline_mf = product.metafields.pdp.headline
  assign pdp_intro_mf = product.metafields.pdp.first_paragraph

  assign microcopy_price_mf = product.metafields.pdp.microcopy_price
  assign ship_promise_mf = product.metafields.pdp.shipping_promise
  assign return_promise_mf = product.metafields.pdp.return_promise
  assign delivery_promise_mf = product.metafields.pdp.delivery_promise
  if ship_promise_mf == blank and delivery_promise_mf
    assign ship_promise_mf = delivery_promise_mf
  endif

  assign pdp_assay_mf = product.metafields.pdp.assay_percent
  assign pdp_impurity_mf = product.metafields.pdp.impurity_max
  assign pdp_lab_mf = product.metafields.pdp.lab_name
  assign pdp_disclaimer_mf = product.metafields.pdp.disclaimer

  assign highlight_mf = product.metafields.pep.pdp_highlight
  assign batch_microcopy_mf = product.metafields.pep.batch_microcopy
  assign shipping_note_mf = product.metafields.peptide.shipping_note

  assign pdp_coa_override = product.metafields.pdp.coa_url
  assign coa_pdf_mf = product.metafields.pep.coa_pdf
  assign coa_files_mf = product.metafields.peptide.coa_file

  assign coa_url = nil
  if pdp_coa_override and pdp_coa_override != blank
    assign coa_url = pdp_coa_override
  elsif coa_pdf_mf and coa_pdf_mf.value and coa_pdf_mf.value.url
    assign coa_url = coa_pdf_mf.value.url
  elsif coa_files_mf and coa_files_mf.value and coa_files_mf.value.size > 0
    assign first_file = coa_files_mf.value.first
    if first_file and first_file.url
      assign coa_url = first_file.url
    endif
  endif

  assign pep_ref = product.metafields.pep.reference
  assign pep = nil
  if pep_ref and pep_ref.value
    assign pep = pep_ref.value
  endif

  assign hplc_mf = product.metafields.pep.hplc_image
  assign ms_mf = product.metafields.pep.ms_image
  assign hplc_img = nil
  if hplc_mf and hplc_mf.value
    assign hplc_img = hplc_mf.value
  elsif pep and pep.hplc_image
    assign hplc_img = pep.hplc_image
  endif
  assign ms_img = nil
  if ms_mf and ms_mf.value
    assign ms_img = ms_mf.value
  elsif pep and pep.ms_image
    assign ms_img = pep.ms_image
  endif

  assign formula_display = nil
  if product.metafields.peptide.molecular_formula
    assign formula_display = product.metafields.peptide.molecular_formula
  elsif pep and pep.molecular_formula
    assign formula_display = pep.molecular_formula
  elsif product.metafields.pep.formula
    assign formula_display = product.metafields.pep.formula
  endif

  assign mw_display = nil
  if product.metafields.peptide.molecular_weight
    assign mw_display = product.metafields.peptide.molecular_weight
  elsif pep and pep.molecular_weight__g_mol
    assign mw_display = pep.molecular_weight__g_mol
  elsif pep and pep.molecular_weight_g_mol
    assign mw_display = pep.molecular_weight_g_mol
  elsif product.metafields.pep.mw
    assign mw_display = product.metafields.pep.mw
  endif

  assign purity_pct = nil
  if product.metafields.pep.purity_pct
    assign purity_pct = product.metafields.pep.purity_pct
  elsif pep and pep.purity_pct
    assign purity_pct = pep.purity_pct
  endif

  assign ref_code = selected_variant.sku | default: product.sku | default: product.id
  assign cas = nil
  if product.metafields.pep.cas
    assign cas = product.metafields.pep.cas
  elsif pep and pep.cas
    assign cas = pep.cas
  elsif pep and pep.cas_number
    assign cas = pep.cas_number
  endif

  assign title_common = product.title
  if pep and pep.title__common
    assign title_common = pep.title__common
  endif

  assign atc_label = section.settings.atc_label | default: 'Add to Cart'
  assign sold_out_text = 'products.product.sold_out' | t | default: 'Sold Out'

  assign bc_collection = nil
  assign pc_handle = product.metafields.pdp.primary_collection
  if pc_handle and collections[pc_handle]
    assign bc_collection = collections[pc_handle]
  endif
  if bc_collection == nil and product.collections.size > 0
    assign bc_collection = product.collections.first
  endif
-%}

{{ 'product-info-media-carousel.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .xo-section--{{ section.id }} .pp__info {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }

  .xo-section--{{ section.id }} .pp__breadcrumbs {
    font-size: calc(var(--font-body-scale, 1) * 1.3rem);
    color: color-mix(in srgb, rgba(var(--color-foreground)) 55%, transparent);
  }
  .xo-section--{{ section.id }} .pp__breadcrumbs a {
    color: inherit;
    text-decoration: none;
    transition: color 0.3s var(--out-soft, ease);
  }
  .xo-section--{{ section.id }} .pp__breadcrumbs a:hover {
    color: rgba(var(--color-foreground));
  }
  .xo-section--{{ section.id }} .pp__breadcrumbs a:focus-visible {
    outline: 2px solid rgba(var(--color-accent));
    outline-offset: 2px;
    border-radius: 4px;
  }

  .xo-section--{{ section.id }} .xo-product-variant .xo-field-radio__label,
  .xo-section--{{ section.id }} .xo-product-variant__inner-name .xo-product-variant__value-selected {
    text-transform: lowercase;
  }

  .xo-section--{{ section.id }} .pp__ref {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    font-size: calc(var(--font-body-scale, 1) * 1.2rem);
    color: color-mix(in srgb, rgba(var(--color-foreground)) 55%, transparent);
  }
  .xo-section--{{ section.id }} .pp__ref-chip {
    border: 2px solid rgba(var(--color-accent));
    border-radius: var(--general-radius-4);
    padding: 0.2rem 0.8rem;
    font-weight: 600;
    font-size: calc(var(--font-body-scale, 1) * 1.2rem);
    letter-spacing: 0.03em;
    color: rgba(var(--color-foreground));
    background: color-mix(in srgb, rgba(var(--color-accent)) 8%, transparent);
  }

  .xo-section--{{ section.id }} .pp__title {
    font-family: var(--font-heading-family, sans-serif);
    font-weight: 600;
    font-size: clamp(2.4rem, 3vw, 3.2rem);
    line-height: 1.3;
    letter-spacing: -0.02em;
    color: rgba(var(--color-foreground));
    margin: 0;
  }

  .xo-section--{{ section.id }} .pp__subtitle {
    color: color-mix(in srgb, rgba(var(--color-foreground)) 65%, transparent);
    font-size: calc(var(--font-body-scale, 1) * 1.5rem);
    margin: 0;
  }

  .xo-section--{{ section.id }} .pp__highlight {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    background: color-mix(in srgb, rgba(var(--color-accent)) 8%, transparent);
    border-radius: var(--general-radius-1);
    padding: 1.2rem 1.4rem;
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 8%, transparent);
  }
  .xo-section--{{ section.id }} .pp__highlight-dot {
    width: 0.8rem;
    height: 0.8rem;
    border-radius: 50%;
    margin-top: 0.5rem;
    flex-shrink: 0;
    background: rgba(var(--color-accent));
  }

  .xo-section--{{ section.id }} .pp__chips {
    display: flex;
    gap: 0.8rem;
    flex-wrap: wrap;
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .xo-section--{{ section.id }} .pp__chips li {
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 12%, transparent);
    border-radius: var(--button-radius);
    padding: 0.8rem 1.4rem;
    background: rgba(var(--color-background));
    color: rgba(var(--color-foreground));
    font-size: calc(var(--font-body-scale, 1) * 1.4rem);
    transition: border-color 0.3s var(--out-soft, ease);
  }
  .xo-section--{{ section.id }} .pp__chips li:hover {
    border-color: color-mix(in srgb, rgba(var(--color-accent)) 50%, transparent);
  }

  .xo-section--{{ section.id }} .pp__buy-form {
    display: flex;
    align-items: stretch;
    gap: 1rem;
  }
  .xo-section--{{ section.id }} .pp__buy-form .xo-quantity {
    flex-shrink: 0;
  }
  .xo-section--{{ section.id }} .pp__buy-atc {
    flex: 1;
    min-width: 0;
  }

  .xo-section--{{ section.id }} .pp__payments {
    opacity: 0.95;
  }

  .xo-section--{{ section.id }} .pp__per-mg {
    color: color-mix(in srgb, rgba(var(--color-foreground)) 55%, transparent);
    font-size: calc(var(--font-body-scale, 1) * 1.3rem);
  }

  .xo-section--{{ section.id }} .pp__microcopy {
    list-style: none;
    padding: 0;
    margin: 0;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 55%, transparent);
    font-size: calc(var(--font-body-scale, 1) * 1.3rem);
    line-height: 1.6;
  }

  .xo-section--{{ section.id }} .pp__meta {
    border-top: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 8%, transparent);
    padding-top: 1.2rem;
    font-size: calc(var(--font-body-scale, 1) * 1.2rem);
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }
  .xo-section--{{ section.id }} .pp__meta-kv {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.6rem;
  }
  @media (min-width: 768px) {
    .xo-section--{{ section.id }} .pp__meta-kv {
      grid-template-columns: 1fr 1fr;
    }
  }
  .xo-section--{{ section.id }} .pp__meta-row {
    display: flex;
    gap: 0.6rem;
    align-items: baseline;
    color: rgba(var(--color-foreground));
  }
  .xo-section--{{ section.id }} .pp__meta-row .label {
    font-weight: 500;
  }

  .xo-section--{{ section.id }} .pp__verify {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.2rem 0.8rem;
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 12%, transparent);
    border-radius: var(--button-radius);
    background: color-mix(in srgb, rgba(var(--color-accent)) 8%, transparent);
    font-size: calc(var(--font-body-scale, 1) * 1.1rem);
    font-weight: 600;
    color: rgba(var(--color-foreground));
  }
  .xo-section--{{ section.id }} .pp__verify svg {
    width: 1.2rem;
    height: 1.2rem;
  }

  .xo-section--{{ section.id }} .pp__coa-row {
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }
  .xo-section--{{ section.id }} .pp__coa-row a {
    text-decoration: none;
    font-weight: 600;
    color: rgba(var(--color-foreground));
    position: relative;
  }
  .xo-section--{{ section.id }} .pp__coa-row a::after {
    content: "";
    position: absolute;
    left: 50%;
    right: 50%;
    bottom: -2px;
    height: 1px;
    background: currentColor;
    transition: left 0.2s ease, right 0.2s ease;
  }
  .xo-section--{{ section.id }} .pp__coa-row a:hover::after {
    left: 0;
    right: 0;
  }
  .xo-section--{{ section.id }} .pp__coa-row a:focus-visible {
    outline: 2px solid rgba(var(--color-accent));
    outline-offset: 2px;
    border-radius: 4px;
  }

  .xo-section--{{ section.id }} .pp__meta-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
  }
  .xo-section--{{ section.id }} .pp__chip {
    padding: 0.5rem 1rem;
    border-radius: var(--badge-radius);
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 12%, transparent);
    background: rgba(var(--color-background));
    font-weight: 500;
    color: rgba(var(--color-foreground));
    font-size: calc(var(--font-body-scale, 1) * 1.2rem);
    text-decoration: none;
    transition: border-color 0.3s var(--out-soft, ease);
  }
  .xo-section--{{ section.id }} .pp__chip:hover {
    border-color: color-mix(in srgb, rgba(var(--color-accent)) 50%, transparent);
  }
  .xo-section--{{ section.id }} .pp__chip:focus-visible {
    outline: 2px solid rgba(var(--color-accent));
    outline-offset: 2px;
  }
  .xo-section--{{ section.id }} .pp__chip--purity {
    border: 2px solid rgba(var(--color-accent));
    background: color-mix(in srgb, rgba(var(--color-accent)) 8%, transparent);
  }

  .xo-section--{{ section.id }} .pp__disclaimer {
    color: color-mix(in srgb, rgba(var(--color-foreground)) 50%, transparent);
    font-size: calc(var(--font-body-scale, 1) * 1.2rem);
  }

  .xo-section--{{ section.id }} .pp__qc {
    margin-top: 0.4rem;
  }
  .xo-section--{{ section.id }} .pp__qc-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    margin-top: 0.8rem;
  }
  .xo-section--{{ section.id }} .pp__qc-img {
    width: 100%;
    height: auto;
    border-radius: var(--general-radius-1);
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 8%, transparent);
  }

  @media (prefers-reduced-motion: reduce) {
    .xo-section--{{ section.id }} .pp__chips li,
    .xo-section--{{ section.id }} .pp__chip,
    .xo-section--{{ section.id }} .pp__coa-row a::after {
      transition: none;
    }
  }
{%- endstyle -%}

<section {% render 'section-attr' %}>
  <xo-product
    xo-selected-or-first-available-variant-id="{{ selected_variant.id }}"
    xo-product-information
    xo-product-id="{{ product.id }}"
    xo-section-id="{{ section.id }}"
    class="pp-hero"
  >
    <xo-container>
      {% if section.settings.show_breadcrumbs %}
        <nav class="pp__breadcrumbs" aria-label="Breadcrumb">
          <a href="{{ routes.root_url }}">Home</a>
          <span aria-hidden="true"> / </span>
          {% if bc_collection %}
            <a href="{{ bc_collection.url }}">{{ bc_collection.title }}</a>
          {% else %}
            <a href="{{ routes.all_products_collection_url }}">Shop</a>
          {% endif %}
          <span aria-hidden="true"> / </span>
          <span aria-current="page">{{ product.title }}</span>
        </nav>
      {% endif %}

      <xo-grid>
        <div style="--xs: 12; --md: 12; --lg: {{ media_column }}">
          <xo-product-will-change xo-unique-id="product-info-media-carousel-{{ section.id }}">
            {% render 'product-info-media-carousel',
              enable_image_zoom: section.settings.enable_image_zoom,
              variant_images: variant_images
            %}
          </xo-product-will-change>
        </div>

        <div style="--xs: 12; --md: 12; --lg: {{ content_column }}">
          <div class="pp__info">

            <div class="pp__ref" title="Internal reference code">
              <span class="pp__ref-chip">REF</span>
              <span>{{ ref_code }}</span>
            </div>

            <xo-animate xo-cascade>
              <h1 class="pp__title">{{ title_common }}</h1>
            </xo-animate>

            {% if pdp_headline_mf %}
              <p class="pp__subtitle">{{ pdp_headline_mf }}</p>
            {% elsif subtitle_mf %}
              <p class="pp__subtitle">{{ subtitle_mf | metafield_tag }}</p>
            {% endif %}

            {% if pdp_intro_mf %}
              <div class="pp__highlight">
                <span class="pp__highlight-dot" aria-hidden="true"></span>
                <span>{{ pdp_intro_mf | newline_to_br }}</span>
              </div>
            {% elsif highlight_mf %}
              <div class="pp__highlight">
                <span class="pp__highlight-dot" aria-hidden="true"></span>
                <span>{{ highlight_mf | metafield_tag }}</span>
              </div>
            {% endif %}

            {% if section.settings.show_chips %}
              <ul class="pp__chips">
                {%- assign chips_out = false -%}
                {% if benefits_mf and benefits_mf.value and benefits_mf.value.size > 0 %}
                  {% for b in benefits_mf.value %}
                    {%- assign t = b | strip -%}
                    {% if t != blank %}
                      {%- assign chips_out = true -%}
                      <li>{{ t }}</li>
                    {% endif %}
                  {% endfor %}
                {% endif %}
                {% if chips_out == false %}
                  {% if benefit1 %}<li>{{ benefit1 }}</li>{% endif %}
                  {% if benefit2 %}<li>{{ benefit2 }}</li>{% endif %}
                  {% if benefit3 %}<li>{{ benefit3 }}</li>{% endif %}
                {% endif %}
              </ul>
            {% endif %}

            {% unless product.has_only_default_variant %}
              <xo-product-variants>
                {%- for option in product.options_with_values -%}
                  {% render 'product-variant', option: option, style: 'boxed', product: product %}
                {%- endfor -%}
              </xo-product-variants>
            {% endunless %}

            <xo-product-will-change xo-unique-id="product-price-{{ section.id }}" xo-morph-selector="[xo-price]">
              {% render 'price', product: product, use_variant: true, larger: true %}
            </xo-product-will-change>

            <div class="pp__payments">
              {% render 'tabby-installments' %}
            </div>

            {% if section.settings.show_price_per_mg %}
              {%- liquid
                assign strength_mg = selected_variant.metafields.pdp.strength_mg.value | plus: 0.0
                assign unit_count = selected_variant.metafields.pdp.unit_count.value | default: 1 | plus: 0.0
                assign denom = strength_mg | times: unit_count
              -%}
              {% if denom > 0 %}
                <xo-product-will-change xo-unique-id="product-per-mg-{{ section.id }}">
                  <div class="pp__per-mg">
                    {%- assign per_mg_cents = selected_variant.price | times: 1.0 | divided_by: denom -%}
                    ≈ {{ per_mg_cents | round | money }} / mg
                  </div>
                </xo-product-will-change>
              {% endif %}
            {% endif %}

            <div class="pp__buy-form">
              {% render 'quantity', size: 'md', variant: selected_variant, product: product, is_cart: false %}
              <div class="pp__buy-atc">
                {% form 'product', product, xo-buy-ignore: 'true' %}
                  <xo-product-will-change xo-unique-id="product-add-button-{{ section.id }}">
                    <xo-cart-add
                      {% unless selected_variant.available %}xo-disabled{% endunless %}
                      {% if settings.cart_type == 'page' %}xo-cart-redirection{% endif %}
                    >
                      {% if selected_variant.available %}
                        {% render 'button', style: 'primary', text: atc_label, size: 'md', block: true, text_unavailable: sold_out_text %}
                      {% else %}
                        {% render 'button', style: 'primary', text: sold_out_text, size: 'md', block: true, text_unavailable: sold_out_text %}
                      {% endif %}
                    </xo-cart-add>
                  </xo-product-will-change>
                {% endform %}
              </div>
            </div>

            {% if section.settings.show_buy_now %}
              {% render 'buy-button', show_dynamic_checkout: true %}
            {% endif %}

            <div class="pp__payments">
              {% render 'tamara' %}
            </div>

            {% if section.settings.enable_microcopy %}
              <ul class="pp__microcopy">
                {% if batch_microcopy_mf %}<li>{{ batch_microcopy_mf | metafield_tag }}</li>{% endif %}
                {% if microcopy_price_mf %}<li>{{ microcopy_price_mf }}</li>{% endif %}
                {% if ship_promise_mf %}<li>{{ ship_promise_mf }}</li>{% endif %}
                {% if return_promise_mf %}<li>{{ return_promise_mf }}</li>{% endif %}
                {% if shipping_note_mf %}<li>{{ shipping_note_mf | metafield_tag }}</li>{% endif %}
                {% if section.settings.microcopy_fallback != blank %}
                  {%- assign lines = section.settings.microcopy_fallback | split: '\n' -%}
                  {% for line in lines %}
                    {%- assign t = line | strip -%}
                    {% if t != blank %}<li>{{ t }}</li>{% endif %}
                  {% endfor %}
                {% endif %}
              </ul>
            {% endif %}

            <div class="pp__meta">
              <div class="pp__meta-kv" aria-label="Specifications">
                {% if formula_display %}
                  <div class="pp__meta-row">
                    <span class="label">Formula:</span>
                    <span class="value">{{ formula_display }}</span>
                  </div>
                {% endif %}
                {% if mw_display %}
                  <div class="pp__meta-row">
                    <span class="label">M.W.:</span>
                    <span class="value">{{ mw_display }}{% unless mw_display contains 'g/mol' %} g/mol{% endunless %}</span>
                  </div>
                {% endif %}
                {% if cas %}
                  <div class="pp__meta-row">
                    <span class="label">CAS #:</span>
                    <span class="value">{{ cas }}</span>
                  </div>
                {% endif %}
              </div>

              {% if coa_url %}
                <div class="pp__coa-row">
                  {% render 'pep-verify-badge', class: 'pp__verify', label: 'Verified', title: 'Batch verified' %}
                  <a href="{{ coa_url }}" target="_blank" rel="noopener">View Verified COA</a>
                </div>
              {% endif %}

              {% if pdp_assay_mf or pdp_impurity_mf or pdp_lab_mf %}
                <div class="pp__meta-row">
                  <span class="label">Verification:</span>
                  <span class="value">
                    {% if pdp_assay_mf %}Assay {{ pdp_assay_mf }}%{% endif %}
                    {% if pdp_impurity_mf %}{% if pdp_assay_mf %} · {% endif %}Impurities ≤ {{ pdp_impurity_mf }}%{% endif %}
                    {% if pdp_lab_mf %}{% if pdp_assay_mf or pdp_impurity_mf %} · {% endif %}Lab: {{ pdp_lab_mf }}{% endif %}
                  </span>
                </div>
              {% endif %}

              <div class="pp__meta-chips">
                <a href="#coa" class="pp__chip pp__chip--purity">
                  {% if purity_pct %}{{ purity_pct }}% HPLC{% else %}PURITY{% endif %}
                </a>
                <span class="pp__chip">HPLC tested</span>
                <span class="pp__chip">RUO</span>
              </div>

              <div class="pp__disclaimer">
                {{ pdp_disclaimer_mf | default: 'For laboratory research use only (RUO). Not for human or veterinary use.' }}
              </div>
            </div>

            {% if section.settings.show_coa_link and coa_url or hplc_img or ms_img %}
              <div class="pp__qc" id="coa">
                {% if section.settings.show_coa_link and coa_url %}
                  {% render 'button',
                    text: section.settings.coa_label,
                    link: coa_url,
                    style: 'link',
                    open_in_new_tab: true
                  %}
                {% endif %}
                {% if hplc_img or ms_img %}
                  <div class="pp__qc-grid">
                    {% if hplc_img %}
                      <img
                        class="pp__qc-img"
                        src="{{ hplc_img | image_url: width: 800 }}"
                        alt="HPLC chromatogram"
                        width="800"
                        height="{{ 800 | divided_by: hplc_img.aspect_ratio | round }}"
                        loading="lazy"
                      >
                    {% endif %}
                    {% if ms_img %}
                      <img
                        class="pp__qc-img"
                        src="{{ ms_img | image_url: width: 800 }}"
                        alt="Mass spectrometry spectrum"
                        width="800"
                        height="{{ 800 | divided_by: ms_img.aspect_ratio | round }}"
                        loading="lazy"
                      >
                    {% endif %}
                  </div>
                {% endif %}
              </div>
            {% endif %}

          </div>
        </div>
      </xo-grid>
    </xo-container>

    {% render 'product-data', product: product %}
  </xo-product>
</section>

