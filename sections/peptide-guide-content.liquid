{% schema %}
{
  "name": "Peptide Guide Content",
  "tag": "section",
  "class": "section-peptide-guide-content",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "YouTube Embed URL",
      "default": "https://www.youtube.com/embed/YOUR_VIDEO_ID"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max Width (px)",
      "min": 700,
      "max": 1200,
      "step": 10,
      "default": 900
    },
    {
      "type": "range",
      "id": "padding_y",
      "label": "Vertical Padding (px)",
      "min": 20,
      "max": 160,
      "step": 4,
      "default": 40
    },
    {
      "type": "header",
      "content": "Step-by-Step Images"
    },
    {
      "type": "image_picker",
      "id": "img_supplies",
      "label": "Supplies (Flat Lay)"
    },
    {
      "type": "image_picker",
      "id": "img_step1",
      "label": "Step 1: Sanitize & Prep"
    },
    {
      "type": "image_picker",
      "id": "img_step2",
      "label": "Step 2: Equalize Pressure & Draw"
    },
    {
      "type": "image_picker",
      "id": "img_step3",
      "label": "Step 3: The Gentle Trickle"
    },
    {
      "type": "image_picker",
      "id": "img_step4",
      "label": "Step 4: Swirl, Do Not Shake"
    },
    {
      "type": "image_picker",
      "id": "img_storage",
      "label": "Storage Best Practices"
    }
  ],
  "presets": [{"name": "Peptide Guide Content"}]
}
{% endschema %}

{%- assign s = section.settings -%}
{%- assign sid = section.id -%}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "HowTo",
      "name": "How to Reconstitute Peptides",
      "description": "A step-by-step protocol for safely reconstituting lyophilized peptides with bacteriostatic water.",
      "totalTime": "PT5M",
      "supply": [
        { "@type": "HowToSupply", "name": "Peptide Vial (lyophilized powder)" },
        { "@type": "HowToSupply", "name": "Bacteriostatic Water" },
        { "@type": "HowToSupply", "name": "Alcohol Prep Pads" },
        { "@type": "HowToSupply", "name": "Mixing Syringe (3mL–5mL)" },
        { "@type": "HowToSupply", "name": "Dosing Syringe (insulin syringe)" }
      ],
      "tool": [
        { "@type": "HowToTool", "name": "Clean, well-lit workspace" }
      ],
      "step": [
        {
          "@type": "HowToStep",
          "position": 1,
          "name": "Maintain a Sterile Environment",
          "text": "Wash hands with antibacterial soap, disinfect your work surface with 70% isopropyl alcohol, and wipe rubber stoppers of both vials with alcohol prep pads. Allow stoppers to air-dry completely."
        },
        {
          "@type": "HowToStep",
          "position": 2,
          "name": "Sanitize & Prep",
          "text": "Remove the protective plastic caps from both vials. Vigorously wipe both rubber stoppers with alcohol pads and let them air-dry completely."
        },
        {
          "@type": "HowToStep",
          "position": 3,
          "name": "Equalize Pressure & Draw",
          "text": "Draw the exact volume of bacteriostatic water into your mixing syringe. Pro tip: inject an equal volume of air into the BAC water vial first to prevent vacuum lock."
        },
        {
          "@type": "HowToStep",
          "position": 4,
          "name": "The Gentle Trickle",
          "text": "Insert the needle into the peptide vial at a 45-degree angle so the water drips gently down the inner glass wall. Never blast water directly onto the powder."
        },
        {
          "@type": "HowToStep",
          "position": 5,
          "name": "Swirl, Do Not Shake",
          "text": "Withdraw the needle. Gently roll the vial between your fingertips or swirl it in a slow circle until the solution is completely clear. Never shake the vial."
        }
      ]
    },
    {
      "@type": "VideoObject",
      "name": "How to Reconstitute Peptides Safely",
      "description": "A 3-minute video covering prep and hygiene, drawing bacteriostatic water, and the trickle method for safe mixing.",
      "thumbnailUrl": "https://img.youtube.com/vi/{{ s.video_url | split: '/embed/' | last | split: '?' | first }}/maxresdefault.jpg",
      "uploadDate": "2024-01-01",
      "embedUrl": "{{ s.video_url }}"
    }
  ]
}
</script>

<div class="pgc-wrapper" id="pgc-{{ sid }}">
  <div class="pgc-container">

    <div id="pc-video-section" class="pgc-section">
      <h2 class="pgc-h2">Video Tutorial: How to Reconstitute Safely</h2>
      <div class="pgc-video-box">
        <div class="pgc-video-embed">
          <iframe width="100%" height="100%" src="{{ s.video_url }}" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen loading="lazy" title="How to Reconstitute Peptides — Video Tutorial"></iframe>
        </div>
        <div class="pgc-video-summary">
          <p class="pgc-summary-title">In this 3-minute video, we cover:</p>
          <ul class="pgc-ul">
            <li><strong>Prep and hygiene:</strong> Essential steps before you begin.</li>
            <li><strong>Drawing bacteriostatic water:</strong> Preventing annoying vacuum seals.</li>
            <li><strong>The 'trickle' method:</strong> Safe mixing without destroying the bonds.</li>
          </ul>
        </div>
      </div>
    </div>

    <div id="pc-guide-section" class="pgc-section">

      <div class="pgc-intro-card">
        <h2 class="pgc-h2 pgc-h2--flush">Peptides Calculator + Reconstitution (Complete Guide)</h2>
        <p class="pgc-p">Reconstituting lyophilized peptides for the first time can feel intimidating, particularly when navigating volumetric calculations and sterile protocols. However, peptide preparation is a precise, straightforward process when following evidence-based guidelines.</p>
        <p class="pgc-p">This comprehensive protocol breaks down reconstitution efficiently. Paired with our interactive Peptide Dosage Calculator, you will have the exact metrics needed to prepare, measure, and store your compounds with clinical accuracy—eliminating guesswork entirely.</p>

        <hr class="pgc-divider">

        <h3 class="pgc-h3">What is Peptide Reconstitution?</h3>
        <p class="pgc-p">Peptide reconstitution is the laboratory process of restoring freeze-dried (lyophilized) peptides to an active liquid state by dissolving them in a sterile diluent, typically bacteriostatic water.</p>
        <p class="pgc-p">Because peptides consist of delicate molecular bonds, they are preserved through lyophilization—a process of rapid freezing and vacuuming that yields the solid powder found in your vial. Reconstitution safely restores these peptides from their dormant state.</p>
        <p class="pgc-p">Bacteriostatic water (BAC water) is the industry-standard diluent. It contains a sterile preservative (0.9% benzyl alcohol) that prevents bacterial proliferation without degrading the compound itself.</p>
        <div class="pgc-formula-badge">&#128300; <strong>Scientific Principle:</strong> Lyophilized Powder + Bacteriostatic Water = Active Peptide Solution.</div>
      </div>

      <div class="pgc-text-block">
        <h2 class="pgc-h2">Preparation & Safety Protocols</h2>
        <p class="pgc-p">Before initiating the reconstitution process, establishing a sterile environment is paramount to prevent contamination and preserve peptide efficacy.</p>
        <p class="pgc-p">Conduct your preparation in a clean, well-lit workspace. Rushing the protocol can lead to calculation errors or compromised sterility. Precision and patience are essential.</p>
        <p class="pgc-p-small pgc-p-disclaimer"><em>(Medical Disclaimer: Always consult a licensed medical professional before beginning any new research protocol or wellness routine, especially if managing pre-existing conditions.)</em></p>
      </div>

      <div class="pgc-step-card pgc-step-card--neutral">
        <h3 class="pgc-h3">Step 0: Maintain a Sterile Environment</h3>
        <p class="pgc-p">To minimize contamination risks, adhere to strict sterilization practices:</p>
        <ul class="pgc-ul pgc-ul--flush">
          <li>Wash your hands thoroughly with antibacterial soap and warm water.</li>
          <li>Disinfect your primary work surface using &#8805;70% isopropyl alcohol wipes.</li>
          <li>Wipe the rubber stoppers of both vials (peptide and bacteriostatic water) with fresh alcohol prep pads.</li>
          <li><strong>Crucial:</strong> Allow the stoppers to air-dry completely. Never blow on them or touch them once sanitized.</li>
        </ul>
      </div>

      <h2 class="pgc-h2">Step-by-Step Reconstitution Protocol</h2>

      <div class="pgc-step-row">
        <div class="pgc-step-content">
          <h3 class="pgc-h3">What You Will Need (Supplies)</h3>
          <p class="pgc-p">Verify you have the following essential items prepared:</p>
          <ul class="pgc-ul">
            <li><strong>Peptide Vial:</strong> Your lyophilized compound.</li>
            <li><strong>Bacteriostatic Water:</strong> The sterile diluent.</li>
            <li><strong>Alcohol Prep Pads:</strong> For strict sanitization.</li>
            <li><strong>Mixing Syringe:</strong> A larger capacity syringe (3mL - 5mL) used strictly for transferring the diluent.</li>
            <li><strong>Dosing Syringe:</strong> A precision insulin syringe (e.g., 1mL/100-Unit) for accurate protocol measurement.</li>
          </ul>
        </div>
        <div class="pgc-step-media">
          {% if s.img_supplies != blank %}
            <img
              src="{{ s.img_supplies | image_url: width: 800 }}"
              srcset="{{ s.img_supplies | image_url: width: 400 }} 400w,
                      {{ s.img_supplies | image_url: width: 600 }} 600w,
                      {{ s.img_supplies | image_url: width: 800 }} 800w"
              sizes="(max-width: 800px) 100vw, 50vw"
              width="{{ s.img_supplies.width }}"
              height="{{ s.img_supplies.height }}"
              loading="lazy"
              decoding="async"
              alt="{{ s.img_supplies.alt | default: 'Peptide supplies flat lay' | escape }}"
              class="pgc-step-img">
          {% else %}
            <div class="pgc-placeholder">[ Insert Original Picture: Flat lay of all the supplies on a clean table ]</div>
          {% endif %}
        </div>
      </div>

      <div class="pgc-step-row pgc-reverse">
        <div class="pgc-step-content">
          <div class="pgc-badge">Step 1</div>
          <h3 class="pgc-h3">Sanitize & Prep</h3>
          <p class="pgc-p">Remove the protective plastic caps from both vials. Vigorously wipe both rubber stoppers with alcohol pads.</p>
          <p class="pgc-p pgc-p-bold">Crucial: Allow them to air-dry completely.</p>
        </div>
        <div class="pgc-step-media">
          {% if s.img_step1 != blank %}
            <img
              src="{{ s.img_step1 | image_url: width: 800 }}"
              srcset="{{ s.img_step1 | image_url: width: 400 }} 400w,
                      {{ s.img_step1 | image_url: width: 600 }} 600w,
                      {{ s.img_step1 | image_url: width: 800 }} 800w"
              sizes="(max-width: 800px) 100vw, 50vw"
              width="{{ s.img_step1.width }}"
              height="{{ s.img_step1.height }}"
              loading="lazy"
              decoding="async"
              alt="{{ s.img_step1.alt | default: 'Wiping the vial top with alcohol' | escape }}"
              class="pgc-step-img">
          {% else %}
            <div class="pgc-placeholder">[ Insert Original Picture: Wiping the top of the vial ]</div>
          {% endif %}
        </div>
      </div>

      <div class="pgc-step-row">
        <div class="pgc-step-content">
          <div class="pgc-badge">Step 2</div>
          <h3 class="pgc-h3">Equalize Pressure & Draw</h3>
          <p class="pgc-p">Draw the exact volume of bacteriostatic water required into your mixing syringe.</p>
          <div class="pgc-tip-box">
            <strong>Pro Tip:</strong> To prevent a vacuum lock, pull air into your syringe equal to your required water volume. Inject this air into the upright BAC water vial first, making it effortless to withdraw the liquid.
          </div>
        </div>
        <div class="pgc-step-media">
          {% if s.img_step2 != blank %}
            <img
              src="{{ s.img_step2 | image_url: width: 800 }}"
              srcset="{{ s.img_step2 | image_url: width: 400 }} 400w,
                      {{ s.img_step2 | image_url: width: 600 }} 600w,
                      {{ s.img_step2 | image_url: width: 800 }} 800w"
              sizes="(max-width: 800px) 100vw, 50vw"
              width="{{ s.img_step2.width }}"
              height="{{ s.img_step2.height }}"
              loading="lazy"
              decoding="async"
              alt="{{ s.img_step2.alt | default: 'Drawing bacteriostatic water into syringe' | escape }}"
              class="pgc-step-img">
          {% else %}
            <div class="pgc-placeholder">[ Insert Original Picture: Syringe drawing water from the BAC vial ]</div>
          {% endif %}
        </div>
      </div>

      <div class="pgc-step-row pgc-reverse">
        <div class="pgc-step-content">
          <div class="pgc-badge">Step 3</div>
          <h3 class="pgc-h3">The Gentle Trickle</h3>
          <p class="pgc-p">Insert the needle into the peptide vial. <strong>Angle the needle at 45 degrees</strong> so the water drips gently down the inner glass wall.</p>
          <p class="pgc-p">Peptides are highly fragile; forcefully blasting water directly onto the powder can damage the molecular structure.</p>
        </div>
        <div class="pgc-step-media">
          {% if s.img_step3 != blank %}
            <img
              src="{{ s.img_step3 | image_url: width: 800 }}"
              srcset="{{ s.img_step3 | image_url: width: 400 }} 400w,
                      {{ s.img_step3 | image_url: width: 600 }} 600w,
                      {{ s.img_step3 | image_url: width: 800 }} 800w"
              sizes="(max-width: 800px) 100vw, 50vw"
              width="{{ s.img_step3.width }}"
              height="{{ s.img_step3.height }}"
              loading="lazy"
              decoding="async"
              alt="{{ s.img_step3.alt | default: 'Injecting water gently down the glass wall' | escape }}"
              class="pgc-step-img">
          {% else %}
            <div class="pgc-placeholder">[ Insert Original Picture: Syringe injecting water down the side of the peptide vial ]</div>
          {% endif %}
        </div>
      </div>

      <div class="pgc-step-row">
        <div class="pgc-step-content">
          <div class="pgc-badge">Step 4</div>
          <h3 class="pgc-h3">Swirl, Do Not Shake</h3>
          <p class="pgc-p">Withdraw the needle. Gently roll the vial between your fingertips or swirl it in a slow, continuous circle until the solution is completely clear.</p>
          <p class="pgc-p pgc-p-danger">Never violently shake the vial.</p>
        </div>
        <div class="pgc-step-media">
          {% if s.img_step4 != blank %}
            <img
              src="{{ s.img_step4 | image_url: width: 800 }}"
              srcset="{{ s.img_step4 | image_url: width: 400 }} 400w,
                      {{ s.img_step4 | image_url: width: 600 }} 600w,
                      {{ s.img_step4 | image_url: width: 800 }} 800w"
              sizes="(max-width: 800px) 100vw, 50vw"
              width="{{ s.img_step4.width }}"
              height="{{ s.img_step4.height }}"
              loading="lazy"
              decoding="async"
              alt="{{ s.img_step4.alt | default: 'Gently swirling the peptide vial' | escape }}"
              class="pgc-step-img">
          {% else %}
            <div class="pgc-placeholder">[ Insert Original Picture: Gently swirling the peptide vial ]</div>
          {% endif %}
        </div>
      </div>

      <div class="pgc-calc-callout">
        <h3 class="pgc-h3 pgc-h3--center">Calculate Your Exact Dose</h3>
        <p class="pgc-p">With your peptide fully dissolved, the final step is drawing your precise dose. Because you have combined a specific volume of bacteriostatic water (mL) with a specific mass of lyophilized powder (mg), determining your exact dose requires converting milligrams to micrograms and mapping it to syringe units.</p>
        <p class="pgc-p"><strong>Manual calculations often lead to critical dosing errors.</strong> To eliminate this risk, utilize the Interactive Peptide Dosage Calculator at the top of this page. Simply input Total Peptide (mg), BAC Water Added (mL), and Target Dose (mcg). The calculator instantly outputs the exact tick mark required. No manual math, no estimation.</p>
        <a href="#pc-calculator-section" class="pgc-btn pgc-btn--ghost">Jump Back to Calculator</a>
      </div>

      <div class="pgc-step-row pgc-reverse pgc-step-row--extra-top">
        <div class="pgc-step-content">
          <h3 class="pgc-h3">Storage: Preserving Efficacy</h3>
          <p class="pgc-p">Once reconstituted, peptide storage requirements change fundamentally. Active peptides are highly sensitive to temperature fluctuations and UV light degradation.</p>
          <ul class="pgc-ul">
            <li><strong>Before Mixing (Lyophilized Powder):</strong> Store unmixed vials in a cool, dark environment. For optimal long-term preservation (months to years), store them in a freezer.</li>
            <li><strong>After Mixing (Active Liquid):</strong> Refrigerate immediately. Once bacteriostatic water is introduced, peptides degrade rapidly at room temperature. Keep mixed vials refrigerated (36°F - 46°F) in a dark container. When stored correctly, reconstituted peptides maintain maximum potency for 3 to 4 weeks.</li>
          </ul>
        </div>
        <div class="pgc-step-media">
          {% if s.img_storage != blank %}
            <img
              src="{{ s.img_storage | image_url: width: 800 }}"
              srcset="{{ s.img_storage | image_url: width: 400 }} 400w,
                      {{ s.img_storage | image_url: width: 600 }} 600w,
                      {{ s.img_storage | image_url: width: 800 }} 800w"
              sizes="(max-width: 800px) 100vw, 50vw"
              width="{{ s.img_storage.width }}"
              height="{{ s.img_storage.height }}"
              loading="lazy"
              decoding="async"
              alt="{{ s.img_storage.alt | default: 'Reconstituted peptides stored in refrigerator' | escape }}"
              class="pgc-step-img">
          {% else %}
            <div class="pgc-placeholder">[ Insert Original Picture: Reconstituted peptides stored in fridge ]</div>
          {% endif %}
        </div>
      </div>

      <h2 class="pgc-h2 pgc-h2--extra-top">3 Mistakes to Avoid</h2>
      <p class="pgc-p">Even in a sterile environment, procedural errors occur. Adhere to these golden rules:</p>

      <div class="pgc-mistakes-grid">
        <div class="pgc-mistake-card">
          <div class="pgc-bad"><span class="pgc-icon">&#10005;</span> <strong>DON'T shake the vial.</strong></div>
          <p class="pgc-p-small">Shaking shears delicate peptide bonds.</p>
          <div class="pgc-good"><span class="pgc-icon">&#10003;</span> <strong>DO:</strong> Swirl the vial gently.</div>
        </div>

        <div class="pgc-mistake-card">
          <div class="pgc-bad"><span class="pgc-icon">&#10005;</span> <strong>DON'T use plain water.</strong></div>
          <p class="pgc-p-small">Standard distilled or bottled water lacks preservatives, allowing rapid bacterial growth.</p>
          <div class="pgc-good"><span class="pgc-icon">&#10003;</span> <strong>DO:</strong> Use strictly Bacteriostatic (BAC) Water.</div>
        </div>

        <div class="pgc-mistake-card">
          <div class="pgc-bad"><span class="pgc-icon">&#10005;</span> <strong>DON'T reuse needles.</strong></div>
          <p class="pgc-p-small">Reusing needles dulls the tip, causing tissue trauma, and exponentially increases infection risk.</p>
          <div class="pgc-good"><span class="pgc-icon">&#10003;</span> <strong>DO:</strong> Use a sterile, brand-new dosing syringe for every application.</div>
        </div>
      </div>
    </div>

    <div id="pc-faq-section" class="pgc-section pgc-section--extra-top">
      <h2 class="pgc-h2">Beginner FAQ: Common Concerns</h2>

      <div class="pgc-faq">
        <details class="pgc-faq-item">
          <summary>Why did the water get sucked into the peptide vial automatically?</summary>
          <div class="pgc-faq-content">
            <p class="pgc-p">This is caused by a natural vacuum effect created during the lyophilization process. It indicates a highly secure, factory-tight seal. Firmly hold the syringe plunger to control the water flow, preventing it from blasting the delicate powder.</p>
          </div>
        </details>

        <details class="pgc-faq-item">
          <summary>Why is my mixture cloudy, or why isn't the powder dissolving?</summary>
          <div class="pgc-faq-content">
            <p class="pgc-p">Certain complex peptides require more time to fully dissolve. Place the vial in the refrigerator for 10 to 15 minutes, then gently swirl it again. Do not shake the vial out of impatience.</p>
          </div>
        </details>

        <details class="pgc-faq-item">
          <summary>Does it matter exactly how much bacteriostatic water I use?</summary>
          <div class="pgc-faq-content">
            <p class="pgc-p">No. The total mass of active peptide (mg) in the vial remains identical regardless of the water volume used. Adding more water simply dilutes the concentration, requiring a larger draw volume to achieve the same target dose. Our calculator automatically adjusts for your specific water volume.</p>
          </div>
        </details>
      </div>
    </div>

    <div class="pgc-section pgc-conclusion">
      <h3 class="pgc-h3 pgc-h3--center">Conclusion & Next Steps</h3>
      <p class="pgc-p">You are now equipped with the clinical knowledge to prep, mix, measure, and store your peptides safely. While it may feel complex initially, this protocol takes under two minutes once familiarized. Remember: precision and sterile technique are paramount.</p>
      <p class="pgc-p pgc-p-accent"><strong>Bookmark this page for instant access to the Peptide Dosage Calculator and protocol guide.</strong></p>
    </div>

  </div>
</div>

{%- style -%}
  #pgc-{{ sid }} {
    --pgc-bg: {{ s.bg_color }};
    --pgc-max: {{ s.max_width | default: 900 }}px;
    --pgc-py: {{ s.padding_y | default: 40 }}px;
    --pgc-text: var(--color-text-primary);
    --pgc-muted: var(--color-text-secondary);
    --pgc-accent: var(--color-accent-primary);
    --pgc-accent-dark: var(--color-warning-text);
    --pgc-font: var(--font-body-family, sans-serif);
    --pgc-heading: var(--font-heading-family, sans-serif);
    --pgc-radius: var(--nx-radius, 14px);
    --pgc-shadow-sm: var(--shadow-sm, 0 2px 8px rgba(0,0,0,0.04));
    --pgc-shadow-md: var(--shadow-md, 0 12px 30px rgba(0,0,0,0.06));
    --pgc-transition: var(--transition-premium);
    background-color: var(--pgc-bg);
    content-visibility: auto;
  }

  .pgc-wrapper { padding: var(--pgc-py) 20px 100px; font-family: var(--pgc-font); color: var(--pgc-text); line-height: 1.6; }
  .pgc-container { max-width: var(--pgc-max); margin: 0 auto; }
  .pgc-section { margin-bottom: 60px; scroll-margin-top: 40px; }
  .pgc-section--extra-top { margin-top: 80px; }

  .pgc-h2 { font-size: 32px; font-weight: 800; letter-spacing: -0.5px; padding-bottom: 16px; margin-bottom: 32px; color: var(--pgc-text); font-family: var(--pgc-heading); position: relative; }
  .pgc-h2::after { content: ''; position: absolute; bottom: 0; left: 0; width: 60px; height: 3px; background: var(--pgc-accent); border-radius: 2px; }
  .pgc-h2--flush { padding: 0; margin-bottom: 16px; }
  .pgc-h2--flush::after { display: none; }
  .pgc-h2--extra-top { margin-top: 60px; }

  .pgc-h3 { font-size: 22px; font-weight: 700; margin: 0 0 16px; color: var(--pgc-text); display: flex; align-items: center; gap: 12px; font-family: var(--pgc-heading); }
  .pgc-h3--center { justify-content: center; }
  .pgc-p { font-size: 16px; line-height: 1.7; color: var(--pgc-muted); margin: 0 0 16px; }
  .pgc-p-small { font-size: 14px; line-height: 1.6; color: var(--pgc-muted); margin: 0 0 16px; }
  .pgc-p-bold { font-weight: 700; color: var(--pgc-text); }
  .pgc-p-danger { color: var(--color-error); font-weight: 700; }
  .pgc-p-disclaimer { opacity: 0.8; }
  .pgc-p-accent { color: var(--pgc-accent-dark); }

  .pgc-ul { padding-left: 20px; color: var(--pgc-muted); line-height: 1.7; margin: 0 0 24px; font-size: 16px; }
  .pgc-ul li { margin-bottom: 10px; }
  .pgc-ul strong { color: var(--pgc-text); }
  .pgc-ul--flush { margin-bottom: 0; }

  .pgc-divider { border: none; height: 1px; background: rgba(15,23,42,0.06); margin: 32px 0; }

  .pgc-intro-card { background: var(--color-surface-primary); padding: 40px; border-radius: var(--pgc-radius); margin-bottom: 48px; box-shadow: var(--pgc-shadow-sm); }
  .pgc-formula-badge { display: inline-block; background: var(--color-surface-secondary); color: var(--pgc-text); padding: 12px 20px; border-radius: 8px; font-size: 15px; margin-top: 8px; box-shadow: var(--pgc-shadow-sm); }

  .pgc-tip-box { background: var(--color-warning-bg); padding: 16px; border-radius: 8px; color: var(--pgc-accent-dark); font-size: 15px; margin-top: 16px; box-shadow: var(--pgc-shadow-sm); position: relative; padding-left: 28px; }
  .pgc-tip-box::before { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 4px; background: var(--pgc-accent); border-radius: 4px 0 0 4px; }

  .pgc-step-card { background: var(--color-surface-primary); padding: 32px; border-radius: var(--pgc-radius); margin-bottom: 40px; box-shadow: var(--pgc-shadow-sm); position: relative; }
  .pgc-step-card--neutral { background: var(--color-surface-secondary); padding-left: 36px; }
  .pgc-step-card--neutral::before { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 4px; background: var(--pgc-text); border-radius: 4px 0 0 4px; }

  .pgc-badge { display: inline-block; background: var(--pgc-text); color: var(--color-text-inverse); font-size: 12px; font-weight: 800; padding: 4px 12px; border-radius: 6px; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 12px; }

  .pgc-btn { display: inline-flex; align-items: center; justify-content: center; padding: 12px 24px; border-radius: 8px; font-weight: 600; font-size: 15px; cursor: pointer; transition: var(--pgc-transition); margin-top: 10px; min-height: var(--touch-min, 44px); text-decoration: none; text-align: center; }
  .pgc-btn--ghost { background: transparent; color: var(--pgc-accent-dark); box-shadow: inset 0 0 0 1.5px var(--pgc-accent-dark); }
  .pgc-btn--ghost:hover { background: var(--pgc-accent-dark); color: var(--color-text-inverse); transform: translateY(-2px); box-shadow: var(--pgc-shadow-md); }
  .pgc-btn--ghost:active { transform: scale(0.98); }

  .pgc-video-box { display: flex; flex-direction: column; gap: 24px; }
  .pgc-video-embed { position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden; border-radius: 16px; box-shadow: var(--pgc-shadow-md); }
  .pgc-video-embed iframe { position: absolute; top: 0; left: 0; width: 100%; height: 100%; }
  .pgc-video-summary { background: var(--color-surface-secondary); padding: 24px; border-radius: 12px; box-shadow: var(--pgc-shadow-sm); position: relative; padding-left: 28px; }
  .pgc-video-summary::before { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 4px; background: var(--pgc-accent); border-radius: 4px 0 0 4px; }
  .pgc-summary-title { font-weight: 700; color: var(--pgc-text); margin: 0 0 12px; font-size: 16px; }
  .pgc-video-summary .pgc-ul { margin-bottom: 0; }

  .pgc-step-row { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; align-items: center; margin-bottom: 60px; }
  .pgc-step-row.pgc-reverse { direction: rtl; }
  .pgc-step-row.pgc-reverse > * { direction: ltr; }
  .pgc-step-row--extra-top { margin-top: 60px; }

  .pgc-step-media { overflow: hidden; border-radius: 16px; }
  .pgc-step-img { width: 100%; height: auto; border-radius: 16px; box-shadow: var(--pgc-shadow-md); display: block; transition: var(--pgc-transition); }
  .pgc-step-media:hover .pgc-step-img { transform: scale(1.03); }
  .pgc-placeholder { background: var(--color-surface-secondary); border-radius: 16px; padding: 60px 20px; text-align: center; color: var(--color-text-tertiary); font-weight: 600; font-size: 14px; aspect-ratio: 4/3; display: flex; align-items: center; justify-content: center; box-shadow: inset 0 2px 8px rgba(0,0,0,0.04); }

  .pgc-mistakes-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 32px; }
  .pgc-mistakes-grid:hover .pgc-mistake-card:not(:hover) { opacity: 0.6; }
  .pgc-mistake-card { background: var(--color-surface-primary); padding: 24px; border-radius: var(--pgc-radius); display: flex; flex-direction: column; box-shadow: var(--pgc-shadow-sm); transition: var(--pgc-transition); }
  .pgc-mistake-card:hover { transform: translateY(-4px); box-shadow: var(--pgc-shadow-md); }
  .pgc-bad { color: var(--color-error); font-weight: 700; font-size: 15px; display: flex; align-items: flex-start; gap: 8px; margin-bottom: 8px; }
  .pgc-good { color: var(--color-success); font-weight: 700; font-size: 15px; display: flex; align-items: flex-start; gap: 8px; margin-top: auto; padding-top: 16px; }
  .pgc-icon { font-weight: 900; font-size: 16px; margin-top: 2px; }

  .pgc-calc-callout { background: var(--color-warning-bg); padding: 40px; border-radius: var(--pgc-radius); text-align: center; margin: 60px 0; box-shadow: var(--pgc-shadow-sm); }
  .pgc-calc-callout .pgc-h3 { color: var(--pgc-accent-dark); }
  .pgc-calc-callout .pgc-p { color: var(--pgc-accent-dark); }

  .pgc-faq-item { padding: 24px 0; }
  .pgc-faq-item + .pgc-faq-item { box-shadow: inset 0 1px 0 rgba(15,23,42,0.06); }
  .pgc-faq-item summary { font-size: 18px; font-weight: 700; color: var(--pgc-text); cursor: pointer; list-style: none; display: flex; justify-content: space-between; align-items: center; }
  .pgc-faq-item summary::-webkit-details-marker { display: none; }
  .pgc-faq-item summary::after { content: '+'; font-size: 24px; color: var(--pgc-accent); font-weight: 400; transition: var(--pgc-transition); }
  .pgc-faq-item[open] summary::after { transform: rotate(45deg); color: var(--pgc-text); }
  .pgc-faq-content { margin-top: 16px; padding-left: 20px; position: relative; }
  .pgc-faq-content::before { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 2px; background: var(--pgc-accent); border-radius: 1px; }

  .pgc-conclusion { background: var(--color-surface-secondary); padding: 40px; border-radius: var(--pgc-radius); margin-top: 60px; text-align: center; box-shadow: var(--pgc-shadow-sm); }

  .pgc-wrapper :focus-visible { outline: 2px solid var(--color-accent-primary); outline-offset: 2px; }

  @media (prefers-reduced-motion: reduce) {
    .pgc-wrapper *, .pgc-wrapper *::before, .pgc-wrapper *::after { animation-duration: 0.01ms !important; transition-duration: 0.01ms !important; }
  }

  @media(max-width: 800px) {
    .pgc-wrapper { padding: var(--pgc-py) 20px 80px; }
    .pgc-intro-card { padding: 24px; }
    .pgc-h2 { font-size: 26px; }
    .pgc-step-row { grid-template-columns: 1fr; gap: 24px; margin-bottom: 48px; }
    .pgc-step-row.pgc-reverse { direction: ltr; }
    .pgc-step-row.pgc-reverse > * { direction: ltr; }
    .pgc-mistakes-grid { grid-template-columns: 1fr; }
    .pgc-calc-callout { padding: 24px; }
    .pgc-faq-item summary { font-size: 16px; }
  }
{%- endstyle -%}
