{% comment %}
SECTION: Related / Complementary peptides
Data: product.metafields.pep.complementary_peptides (list.product_reference)
{% endcomment %}

{%- liquid
  assign comp = product.metafields.pep.complementary_peptides
  assign items = nil
  if comp and comp.value
    assign items = comp.value
  endif
-%}

{%- style -%}
  .xo-section--{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    font-family: var(--font-body-family);
  }

  .xo-section--{{ section.id }} .rp-heading {
    font-family: var(--font-heading-family);
    font-size: clamp(1.1rem, 2vw, 1.35rem);
    margin: 0 0 14px;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: rgba(var(--color-foreground));
  }

  .xo-section--{{ section.id }} .rp-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 14px;
  }

  @media (max-width: 992px) {
    .xo-section--{{ section.id }} .rp-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .xo-section--{{ section.id }} .rp-grid {
      grid-template-columns: 1fr;
    }
  }

  .xo-section--{{ section.id }} .rp-card {
    background: rgba(var(--color-background));
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
    border-radius: var(--general-radius-3, 2rem);
    padding: 14px;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    transition: border-color 0.3s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .rp-card:hover {
    border-color: rgba(var(--color-accent));
  }

  .xo-section--{{ section.id }} .rp-card:focus-visible {
    outline: 2px solid rgba(var(--color-accent));
    outline-offset: 2px;
  }

  .xo-section--{{ section.id }} .rp-card img {
    width: 100%;
    height: auto;
    border-radius: var(--general-radius-small, 1rem);
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 6%, transparent);
    transition: transform 0.55s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .rp-card:hover img {
    transform: scale(1.03);
  }

  .xo-section--{{ section.id }} .rp-title {
    font-family: var(--font-heading-family);
    font-weight: 600;
    margin-top: 10px;
    line-height: 1.3;
    font-size: clamp(0.85rem, 1.2vw, 0.9375rem);
    color: rgba(var(--color-foreground));
  }

  .xo-section--{{ section.id }} .rp-price {
    color: color-mix(in srgb, rgba(var(--color-foreground)) 75%, transparent);
    margin-top: 4px;
    font-weight: 600;
    font-family: var(--font-heading-family);
  }

  @media (prefers-reduced-motion: reduce) {
    .xo-section--{{ section.id }} .rp-card,
    .xo-section--{{ section.id }} .rp-card img {
      transition: none;
    }

    .xo-section--{{ section.id }} .rp-card:hover,
    .xo-section--{{ section.id }} .rp-card:hover img {
      transform: none;
    }
  }
{%- endstyle -%}

{% if items and items.size > 0 %}
<section {% render 'section-attr' %}>
  <xo-container>
    <h2 class="rp-heading">{{ section.settings.heading }}</h2>
    <div class="rp-grid">
      {% for p in items %}
        <a class="rp-card" href="{{ p.url }}">
          {% if p.featured_image %}
            <img src="{{ p.featured_image | image_url: width: 600 }}" alt="{{ p.title | escape }}" width="600" height="{{ 600 | divided_by: p.featured_image.aspect_ratio | round }}" loading="lazy">
          {% endif %}
          <div class="rp-title">{{ p.title }}</div>
          {% if p.price %}<div class="rp-price">{{ p.price | money }}</div>{% endif %}
        </a>
      {% endfor %}
    </div>
  </xo-container>
</section>
{% endif %}

{% schema %}
{
  "name": "Related peptides",
  "tag": "section",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "default" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Pairs well with" },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding top", "default": 24 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding bottom", "default": 24 }
  ],
  "blocks": [
    { "type": "@app" }
  ],
  "presets": [{ "name": "Related peptides" }]
}
{% endschema %}
