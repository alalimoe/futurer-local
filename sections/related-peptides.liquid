{% comment %}
SECTION: Related / Complementary peptides
Data: product.metafields.pep.complementary_peptides (list.product_reference)
{% endcomment %}

{%- liquid
  assign comp = product.metafields.pep.complementary_peptides
  assign items = nil
  if comp and comp.value
    assign items = comp.value
  endif
-%}

{% if items and items.size > 0 %}
<section class="pep-related">
  <div class="container">
    <h2 class="h">{{ section.settings.heading }}</h2>
    <div class="grid">
      {% for p in items %}
        <a class="card" href="{{ p.url }}">
          {% if p.featured_image %}
            <img src="{{ p.featured_image | image_url: width: 600 }}" alt="{{ p.title | escape }}" width="600" height="{{ 600 | divided_by: p.featured_image.aspect_ratio | round }}" loading="lazy">
          {% endif %}
          <div class="title">{{ p.title }}</div>
          {% if p.price %}<div class="price">{{ p.price | money }}</div>{% endif %}
        </a>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

<style>
.pep-related{padding:24px var(--page-gutter);background:#FAFAFB;border-top:none;border-bottom:none;font-family:var(--font-body-family,sans-serif)}
.pep-related .container{max-width:var(--container-width-max);margin:0 auto}
.pep-related .h{font-family:var(--font-heading-family,sans-serif);font-size:clamp(1.1rem,2vw,1.35rem);margin:0 0 14px;font-weight:800;letter-spacing:-0.02em;color:var(--nx-text,#111)}
.pep-related .grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px}
@media(max-width:1000px){.pep-related .grid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:600px){.pep-related .grid{grid-template-columns:1fr}}
.pep-related .card{
  background:#fff;border:none;border-radius:14px;padding:14px;text-decoration:none;color:inherit;
  box-shadow:var(--shadow-sm);display:flex;flex-direction:column;
  transition:all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
}
.pep-related .card:hover{box-shadow:var(--shadow-md);transform:translateY(-4px)}
.pep-related .card:focus-visible{outline:2px solid var(--nx-accent,#FBBF24);outline-offset:2px}
.pep-related .card img{width:100%;height:auto;border-radius:10px;border:none;transition:transform 0.55s cubic-bezier(0.25, 0.46, 0.45, 0.94)}
.pep-related .card:hover img{transform:scale(1.03)}
.pep-related .title{font-family:var(--font-heading-family,sans-serif);font-weight:800;margin-top:10px;line-height:1.3;font-size:clamp(0.85rem,1.2vw,0.9375rem)}
.pep-related .price{color:var(--nx-text,#111);margin-top:4px;font-weight:700;font-family:var(--font-heading-family,sans-serif)}
@media(prefers-reduced-motion:reduce){.pep-related .card,.pep-related .card img{transition:none}.pep-related .card:hover,.pep-related .card:hover img{transform:none}}
</style>

{% schema %}
{
  "name": "Related peptides",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Pairs well with" }
  ],
  "presets": [{ "name": "Related peptides" }]
}
{% endschema %}
