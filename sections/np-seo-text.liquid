<section class="np-surface">
  <div class="np-wrap">
    <details class="np-disclosure">
      <summary>{{ section.settings.title }}</summary>
      <div class="np-disclosure__content rte">
        {{ section.settings.body }}
      </div>
    </details>
  </div>
</section>

{% schema %}
{
  "name":"SEO Text",
  "settings":[
    { "type":"text", "id":"title", "label":"Title", "default":"About this topic" },
    { "type":"richtext", "id":"body", "label":"Body", "default":"<p>Add an indexable paragraph to explain your category, keywords, and readers’ value.</p>" }
  ],
  "presets":[{ "name":"NP • SEO Text" }]
}
{% endschema %}
