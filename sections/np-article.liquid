{%- style -%}
  .xo-section--{{ section.id }} {
    --max-width: {{ section.settings.max_width }}px;
    --content-gap: {{ section.settings.content_gap | divided_by: 10.0 }}rem;
    --toc-width: {{ section.settings.toc_width }}px;
    --sticky-offset: {{ section.settings.sticky_offset }}px;

    --line-height: {{ section.settings.line_height }};
    --title-size: {{ section.settings.title_size | divided_by: 10.0 }}rem;
    --body-size: {{ section.settings.body_size | divided_by: 10.0 }}rem;
    --meta-size: {{ section.settings.meta_size | divided_by: 10.0 }}rem;
    --h1: {{ section.settings.title_size | divided_by: 10.0 }}rem;
    --h2: {{ section.settings.h2_size | divided_by: 10.0 }}rem;
    --h3: {{ section.settings.h3_size | divided_by: 10.0 }}rem;

    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  .np-reading-progress-container {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 4px;
    background-color: transparent;
    z-index: 9999;
    pointer-events: none;
  }

  .np-reading-progress-bar {
    height: 100%;
    width: 100%;
    background-color: rgba(var(--color-accent));
    transform-origin: left;
    transform: scaleX(0);
    will-change: transform;
    border-top-right-radius: 2px;
    border-bottom-right-radius: 2px;
  }

  @media (prefers-reduced-motion: no-preference) {
    @keyframes npFadeInUp {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .np-animate-in {
      animation: npFadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .np-animate-in {
      animation: none;
    }

    .xo-section--{{ section.id }} *,
    .xo-section--{{ section.id }} *::before,
    .xo-section--{{ section.id }} *::after {
      transition-duration: 0.01ms !important;
      animation-duration: 0.01ms !important;
    }
  }

  .xo-section--{{ section.id }} .np-container {
    max-width: var(--max-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: {% if section.settings.show_toc %}var(--toc-width) 1fr{% else %}1fr{% endif %};
    gap: var(--content-gap);
    align-items: start;
  }

  .np-back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 55%, transparent);
    text-decoration: none;
    margin-bottom: 2rem;
    transition: color 0.3s ease;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .np-back-link:hover { color: rgba(var(--color-foreground)); }
  .np-back-link svg { width: 16px; height: 16px; transition: transform 0.3s ease; }
  .np-back-link:hover svg { transform: translateX(-4px); }

  .xo-section--{{ section.id }} .np-hero {
    margin: 0 0 3.5rem 0;
    border-radius: var(--general-radius-1, 1rem);
    overflow: hidden;
    position: relative;
    background-color: rgba(var(--color-background-2));
  }

  .xo-section--{{ section.id }} .np-hero img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
    transition: transform 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .xo-section--{{ section.id }} .np-hero:hover img { transform: scale(1.02); }

  .xo-section--{{ section.id }} .np-toc-wrapper {
    position: sticky;
    top: var(--sticky-offset);
    background: rgba(var(--color-background-2));
    border: none;
    border-radius: var(--general-radius-1, 1rem);
    padding: 2rem;
    max-height: calc(100vh - var(--sticky-offset) - 2rem);
    overflow-y: auto;
  }

  .xo-section--{{ section.id }} .np-toc-wrapper::-webkit-scrollbar { width: 4px; }
  .xo-section--{{ section.id }} .np-toc-wrapper::-webkit-scrollbar-thumb {
    background: color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
    border-radius: 4px;
  }

  .xo-section--{{ section.id }} .np-toc__title {
    font-size: 1.125rem;
    color: rgba(var(--color-foreground));
    margin: 0 0 1.5rem 0;
    padding-bottom: 1rem;
    border-bottom: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 600;
  }

  .xo-section--{{ section.id }} .np-toc__list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.5rem; }

  .xo-section--{{ section.id }} .np-toc__link {
    display: flex;
    align-items: center;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 55%, transparent);
    font-size: 0.95rem;
    font-weight: 500;
    text-decoration: none;
    padding: 0.25rem 0 0.25rem 1rem;
    position: relative;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    min-height: var(--touch-min, 44px);
  }

  .xo-section--{{ section.id }} .np-toc__link::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    height: 0%;
    width: 2px;
    background-color: rgba(var(--color-accent));
    transition: height 0.3s ease;
  }

  .xo-section--{{ section.id }} .np-toc__link:hover { color: rgba(var(--color-foreground)); }

  .xo-section--{{ section.id }} .np-toc__link.active { color: rgba(var(--color-foreground)); font-weight: 600; }
  .xo-section--{{ section.id }} .np-toc__link.active::before { height: 100%; }

  .xo-section--{{ section.id }} .np-toc__link:focus-visible {
    outline: 2px solid rgba(var(--color-foreground));
    outline-offset: 2px;
    border-radius: 4px;
  }

  .xo-section--{{ section.id }} .np-header { margin-bottom: 4rem; text-align: {{ section.settings.text_alignment }}; }

  .xo-section--{{ section.id }} .np-title {
    font-size: var(--title-size);
    color: rgba(var(--color-foreground));
    line-height: 1.1;
    margin: 0 0 1.5rem 0;
    letter-spacing: -0.02em;
    font-weight: 600;
  }

  .xo-section--{{ section.id }} .np-meta-container {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: {% if section.settings.text_alignment == 'center' %}center{% else %}flex-start{% endif %};
    gap: 1.5rem;
  }

  .xo-section--{{ section.id }} .np-meta {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
    font-size: var(--meta-size);
    color: color-mix(in srgb, rgba(var(--color-foreground)) 55%, transparent);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .xo-section--{{ section.id }} .np-meta__dot { color: rgba(var(--color-accent)); font-weight: 600; }

  .np-share-btn {
    background: transparent;
    border: 2px solid rgba(var(--color-accent));
    border-radius: var(--button-radius);
    padding: 0.5rem 1.2rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: rgba(var(--color-foreground));
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
    min-height: var(--touch-min, 44px);
    min-width: var(--touch-min, 44px);
  }

  .np-share-btn:hover {
    border-color: rgba(var(--color-accent));
    color: rgba(var(--color-foreground));
    background: rgba(var(--color-background-2));
  }

  .xo-section--{{ section.id }} .np-excerpt {
    font-size: calc(var(--body-size) * 1.15);
    color: color-mix(in srgb, rgba(var(--color-foreground)) 55%, transparent);
    margin-top: 2rem;
    line-height: 1.6;
    font-weight: 400;
    max-width: 800px;
    {% if section.settings.text_alignment == 'center' %}margin-left: auto; margin-right: auto;{% endif %}
  }

  .xo-section--{{ section.id }} .np-body {
    font-size: var(--body-size);
    line-height: var(--line-height);
  }

  .xo-section--{{ section.id }} .np-body h2,
  .xo-section--{{ section.id }} .np-body h3 {
    color: rgba(var(--color-foreground));
    margin: 3.5rem 0 1.5rem 0;
    line-height: 1.2;
    scroll-margin-top: calc(var(--sticky-offset) + 2rem);
    font-weight: 600;
  }

  .xo-section--{{ section.id }} .np-body h2 { font-size: var(--h2); letter-spacing: -0.01em; }
  .xo-section--{{ section.id }} .np-body h3 { font-size: var(--h3); }

  .xo-section--{{ section.id }} .np-body p { margin-bottom: 1.75rem; color: rgba(var(--color-foreground)); }

  .xo-section--{{ section.id }} .np-body a {
    color: rgba(var(--color-foreground));
    text-decoration: underline;
    text-decoration-color: rgba(var(--color-accent));
    text-decoration-thickness: 2px;
    text-underline-offset: 4px;
    transition: all 0.3s ease;
    font-weight: 600;
  }

  .xo-section--{{ section.id }} .np-body a:hover {
    color: rgba(var(--color-accent));
    text-decoration-color: rgba(var(--color-accent));
    background-color: color-mix(in srgb, rgba(var(--color-accent)) 10%, transparent);
  }

  .xo-section--{{ section.id }} .np-body blockquote {
    position: relative;
    border-left: none;
    margin: 3rem 0;
    padding: 2.5rem 3rem;
    font-style: italic;
    color: rgba(var(--color-foreground));
    background: rgba(var(--color-background-2));
    border-radius: var(--general-radius-1, 1rem);
    font-size: calc(var(--body-size) * 1.2);
    box-shadow: inset 4px 0 0 rgba(var(--color-accent));
  }

  .xo-section--{{ section.id }} .np-body img {
    border-radius: var(--general-radius-1, 1rem);
    margin: 3rem 0;
    width: 100%;
    height: auto;
  }

  .xo-section--{{ section.id }} .np-body ul,
  .xo-section--{{ section.id }} .np-body ol { margin: 2rem 0; padding-left: 1rem; }
  .xo-section--{{ section.id }} .np-body li { margin-bottom: 0.75rem; position: relative; }

  .xo-section--{{ section.id }} .np-body ul { list-style: none; }
  .xo-section--{{ section.id }} .np-body ul li::before {
    content: "";
    position: absolute;
    left: -1.25rem;
    top: 0.6em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: rgba(var(--color-accent));
  }

  @media (max-width: 992px) {
    .xo-section--{{ section.id }} .np-container { grid-template-columns: 1fr; gap: 3rem; }
    .xo-section--{{ section.id }} .np-toc-wrapper {
      position: relative;
      top: 0;
      order: -1;
      max-height: none;
      padding: 1.5rem;
      border-radius: var(--general-radius-1, 1rem);
    }
    .xo-section--{{ section.id }} .np-title { font-size: calc(var(--title-size) * 0.75); }
    .xo-section--{{ section.id }} .np-body h2 { font-size: calc(var(--h2) * 0.85); }
    .xo-section--{{ section.id }} .np-body blockquote { padding: 1.5rem 2rem; font-size: calc(var(--body-size) * 1.1); }
  }

  @media (max-width: 768px) {
    .xo-section--{{ section.id }} .np-header { margin-bottom: 2.5rem; }
    .xo-section--{{ section.id }} .np-body p { margin-bottom: 1.25rem; }
    .xo-section--{{ section.id }} .np-body img { margin: 2rem 0; }
    .xo-section--{{ section.id }} .np-body blockquote { padding: 1.25rem 1.5rem; margin: 2rem 0; }
  }
{%- endstyle -%}

<div class="np-reading-progress-container" aria-hidden="true">
  <div class="np-reading-progress-bar" id="np-progress-bar-{{ section.id }}"></div>
</div>

<section {% render 'section-attr' %}>
  <xo-container>
    <div class="np-container np-animate-in">

      {% if section.settings.show_toc %}
        <aside class="np-toc-wrapper" aria-label="Table of contents">
          <h3 class="np-toc__title">{{ section.settings.toc_title }}</h3>
          <nav>
            <ul class="np-toc__list" id="np-toc-list-{{ section.id }}">
            </ul>
          </nav>
        </aside>
      {% endif %}

      <article class="np-content" itemscope itemtype="https://schema.org/BlogPosting">

        <a href="{{ blog.url }}" class="np-back-link">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          Back to {{ blog.title }}
        </a>

        <header class="np-header">
          <h1 class="np-title" itemprop="headline">{{ article.title | escape }}</h1>

          <div class="np-meta-container">
            <div class="np-meta">
              {% if section.settings.show_author %}
                <span class="np-meta__item" itemprop="author" itemscope itemtype="https://schema.org/Person">
                  <span itemprop="name">{{ article.author }}</span>
                </span>
              {% endif %}

              {% if section.settings.show_date %}
                {% if section.settings.show_author %}<span class="np-meta__dot">&middot;</span>{% endif %}
                <time class="np-meta__item" datetime="{{ article.published_at | date: '%Y-%m-%d' }}" itemprop="datePublished">
                  {{ article.published_at | date: "%B %e, %Y" }}
                </time>
              {% endif %}

              {% if section.settings.show_reading_time %}
                {% assign words = article.content | strip_html | split: ' ' | size %}
                {% assign minutes = words | divided_by: 200 | ceil %}
                {% if minutes == 0 %}{% assign minutes = 1 %}{% endif %}
                {% if section.settings.show_date or section.settings.show_author %}<span class="np-meta__dot">&middot;</span>{% endif %}
                <span class="np-meta__item">{{ minutes }} min read</span>
              {% endif %}
            </div>

            <button class="np-share-btn" id="np-share-{{ section.id }}" aria-label="Share this article" aria-live="polite">
              <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"></path></svg>
              <span class="np-share-text">Share</span>
            </button>
          </div>

          {% if article.excerpt != blank and section.settings.show_excerpt %}
            <p class="np-excerpt" itemprop="description">{{ article.excerpt | strip_html | escape }}</p>
          {% endif %}
        </header>

        {% if section.settings.show_featured_image and article.image %}
          <figure class="np-hero" itemprop="image" itemscope itemtype="https://schema.org/ImageObject">
            {%- assign hero_alt = article.image.alt | default: article.title | escape -%}
            {{ article.image | image_url: width: 2000 | image_tag: 
              loading: 'eager', 
              fetchpriority: 'high',
              sizes: '(max-width: 768px) 100vw, (max-width: 1200px) 70vw, 1200px',
              widths: '400, 600, 800, 1200, 1600, 2000',
              alt: hero_alt, 
              class: 'np-hero-img' 
            }}
            <meta itemprop="url" content="{{ article.image | image_url: width: 2000 }}">
          </figure>
        {% endif %}

        <div class="np-body rte" id="np-body-{{ section.id }}" itemprop="articleBody">
          {{ article.content }}
        </div>
      </article>

    </div>
  </xo-container>
</section>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "{{ shop.url }}{{ article.url }}"
  },
  "headline": {{ article.title | json }},
  {% if article.image %}
  "image": [
    "{{ article.image | image_url: width: 2000 }}"
  ],
  {% endif %}
  "datePublished": "{{ article.published_at | date: '%Y-%m-%dT%H:%M:%SZ' }}",
  "dateModified": "{{ article.updated_at | date: '%Y-%m-%dT%H:%M:%SZ' }}",
  "author": {
    "@type": "Person",
    "name": {{ article.author | json }}
  },
  "publisher": {
    "@type": "Organization",
    "name": {{ shop.name | json }},
    "logo": {
      "@type": "ImageObject",
      "url": "https:{{ settings.logo | image_url: width: 600 }}"
    }
  },
  "description": {{ article.excerpt_or_content | strip_html | truncatewords: 30 | json }}
}
</script>

<script>
  (function() {
    class NootropixPremiumArticle {
      constructor(sectionId) {
        this.sectionId = sectionId;
        this.body = document.getElementById(`np-body-${sectionId}`);
        this.tocList = document.getElementById(`np-toc-list-${sectionId}`);
        this.progressBar = document.getElementById(`np-progress-bar-${sectionId}`);
        this.shareButton = document.getElementById(`np-share-${sectionId}`);
        this.headings = this.body ? Array.from(this.body.querySelectorAll('h2, h3')) : [];
        
        this.init();
      }

      init() {
        if (this.headings.length > 0 && this.tocList) {
          this.buildTOC();
          this.initScrollSpy();
        } else if (this.tocList) {
          const tocWrapper = document.querySelector('.np-toc-wrapper');
          if (tocWrapper) tocWrapper.style.display = 'none';
        }

        if (this.progressBar) this.initProgressBar();
        if (this.shareButton) this.initShare();
      }

      buildTOC() {
        this.headings.forEach((heading, index) => {
          if (!heading.id) heading.id = `np-heading-${this.sectionId}-${index}`;
          
          const li = document.createElement('li');
          const a = document.createElement('a');
          a.className = 'np-toc__link';
          a.href = `#${heading.id}`;
          a.textContent = heading.textContent.trim();
          
          if (heading.tagName.toLowerCase() === 'h3') {
            a.style.paddingLeft = '2rem';
            a.style.fontSize = '0.85rem';
          }

          a.addEventListener('click', (e) => {
            e.preventDefault();
            heading.scrollIntoView({ behavior: 'smooth', block: 'start' });
            history.pushState(null, '', a.href);
          });

          li.appendChild(a);
          this.tocList.appendChild(li);
        });
      }

      initScrollSpy() {
        const tocLinks = this.tocList.querySelectorAll('.np-toc__link');
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              const index = this.headings.indexOf(entry.target);
              tocLinks.forEach(link => {
                link.classList.remove('active');
                link.removeAttribute('aria-current');
              });
              if (tocLinks[index]) {
                tocLinks[index].classList.add('active');
                tocLinks[index].setAttribute('aria-current', 'true');
              }
            }
          });
        }, { rootMargin: '-15% 0px -80% 0px', threshold: 0 });

        this.headings.forEach(heading => observer.observe(heading));
      }

      initProgressBar() {
        let isTicking = false;
        const updateProgress = () => {
          const scrollTop = window.scrollY || document.documentElement.scrollTop;
          const docHeight = document.documentElement.scrollHeight - window.innerHeight;
          const scrollPercent = docHeight > 0 ? scrollTop / docHeight : 0;
          this.progressBar.style.transform = `scaleX(${Math.min(scrollPercent, 1)})`;
          isTicking = false;
        };

        window.addEventListener('scroll', () => {
          if (!isTicking) {
            window.requestAnimationFrame(updateProgress);
            isTicking = true;
          }
        }, { passive: true });
      }

      initShare() {
        this.shareButton.addEventListener('click', async () => {
          const shareData = {
            title: document.title,
            text: 'Check out this article from {{ shop.name | escape }}',
            url: window.location.href
          };
          const textSpan = this.shareButton.querySelector('.np-share-text');
          const originalText = textSpan.innerHTML;

          if (navigator.share) {
            try { 
              await navigator.share(shareData); 
            } 
            catch (err) { 
              console.log('Share canceled or failed', err); 
            }
          } else {
            navigator.clipboard.writeText(window.location.href);
            textSpan.innerHTML = 'Link Copied!';
            this.shareButton.style.borderColor = 'var(--color-accent)';
            this.shareButton.style.color = 'rgba(var(--color-foreground))';
            
            setTimeout(() => { 
              textSpan.innerHTML = originalText; 
              this.shareButton.style = '';
            }, 2500);
          }
        });
      }
    }

    document.addEventListener('DOMContentLoaded', () => {
      new NootropixPremiumArticle('{{ section.id }}');
    });
  })();
</script>

{% schema %}
{
  "name": "NP Premium Article",
  "settings": [
    { "type": "header", "content": "Layout & Sizing" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "default" },
    { "type": "range", "id": "max_width", "min": 1000, "max": 1600, "step": 50, "unit": "px", "label": "Max Width", "default": 1200 },
    { "type": "range", "id": "content_gap", "min": 30, "max": 100, "step": 5, "unit": "px", "label": "Column Gap", "default": 60 },
    { "type": "select", "id": "text_alignment", "label": "Header Text Alignment", "options": [{"value": "left", "label": "Left"}, {"value": "center", "label": "Center"}], "default": "center" },
    { "type": "range", "id": "sticky_offset", "min": 0, "max": 150, "step": 5, "unit": "px", "label": "Sticky Header Offset", "default": 40 },

    { "type": "header", "content": "Table of Contents" },
    { "type": "checkbox", "id": "show_toc", "label": "Enable Sticky TOC", "default": true },
    { "type": "text", "id": "toc_title", "label": "TOC Heading", "default": "In this article" },
    { "type": "range", "id": "toc_width", "min": 200, "max": 400, "step": 10, "unit": "px", "label": "TOC Column Width", "default": 280 },

    { "type": "header", "content": "Typography Options" },
    { "type": "range", "id": "title_size", "min": 24, "max": 64, "step": 2, "unit": "px", "label": "H1 Title Size", "default": 48 },
    { "type": "range", "id": "h2_size", "min": 20, "max": 48, "step": 2, "unit": "px", "label": "H2 Size", "default": 32 },
