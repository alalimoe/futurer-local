{% comment %}
  Peptide research tabs: overview, structure, research accordion. Anchor id peptide-research for sticky nav.
{% endcomment %}

{%- liquid
  assign pep_ref = product.metafields.pep.reference
  assign pep = nil
  if pep_ref and pep_ref.value
    assign pep = pep_ref.value
  endif

  assign sections_ref = product.metafields.pep.sections
  assign sections = nil
  if sections_ref and sections_ref.value
    assign sections = sections_ref.value
  endif

  assign formula_display = nil
  if pep and pep.molecular_formula
    assign formula_display = pep.molecular_formula
  endif

  assign mw_display = nil
  if pep and pep.molecular_weight
    assign mw_display = pep.molecular_weight
  endif
-%}

{%- style -%}
  .xo-section--{{ section.id }} .xo-container {
    font-family: var(--font-body-family);
  }

  .xo-section--{{ section.id }} .pr-tabbar {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    border-bottom: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
    margin-bottom: 12px;
    overflow: auto;
    padding-bottom: 10px;
  }

  .xo-section--{{ section.id }} .pr-tab {
    border: 1.5px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
    border-radius: var(--button-radius);
    background: rgba(var(--color-background));
    padding: 8px 14px;
    min-height: 44px;
    box-sizing: border-box;
    font-weight: 600;
    font-size: clamp(1.3rem, 1.2vw, 1.5rem);
    color: rgba(var(--color-foreground));
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    transition: border-color 0.3s var(--out-soft, ease), transform 0.3s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .pr-tab:hover {
    border-color: rgba(var(--color-accent));
    transform: translateY(-1px);
  }

  .xo-section--{{ section.id }} .pr-tab:focus-visible {
    outline: 2px solid rgba(var(--color-accent));
    outline-offset: 2px;
  }

  .xo-section--{{ section.id }} .pr-tab[aria-selected="true"] {
    border-color: rgba(var(--color-accent));
    background: color-mix(in srgb, rgba(var(--color-accent)) 8%, transparent);
  }

  .xo-section--{{ section.id }} .pr-pane {
    display: none;
    padding-top: 12px;
  }

  .xo-section--{{ section.id }} .pr-pane.is-active {
    display: block;
  }

  .xo-section--{{ section.id }} .pr-card {
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
    border-radius: var(--general-radius-3, 2rem);
    background: rgba(var(--color-background));
    padding: 14px;
    color: rgba(var(--color-foreground));
  }

  .xo-section--{{ section.id }} .pr-subhead {
    font-family: var(--font-heading-family);
    margin: 12px 0 6px;
    font-weight: 600;
    font-size: clamp(0.9rem, 1.3vw, 1rem);
    color: rgba(var(--color-foreground));
  }

  .xo-section--{{ section.id }} .pr-bullets {
    margin: 8px 0 0 18px;
    color: rgba(var(--color-foreground));
  }

  .xo-section--{{ section.id }} .pr-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
    margin-top: 6px;
  }

  @media (max-width: 768px) {
    .xo-section--{{ section.id }} .pr-grid {
      grid-template-columns: 1fr;
    }
  }

  .xo-section--{{ section.id }} .pr-struct {
    background: rgba(var(--color-background));
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
    border-radius: var(--general-radius-1, 1rem);
    padding: 12px;
    transition: border-color 0.3s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .pr-struct:hover {
    border-color: rgba(var(--color-accent));
  }

  .xo-section--{{ section.id }} .pr-label {
    font-weight: 600;
    color: rgba(var(--color-foreground));
  }

  .xo-section--{{ section.id }} .pr-value {
    margin-top: 4px;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 75%, transparent);
    word-break: break-word;
  }

  .xo-section--{{ section.id }} .pr-pubchem a {
    position: relative;
    text-decoration: none;
    font-weight: 600;
    color: rgba(var(--color-foreground));
  }

  .xo-section--{{ section.id }} .pr-pubchem a:focus-visible {
    outline: 2px solid rgba(var(--color-accent));
    outline-offset: 2px;
    border-radius: 4px;
  }

  .xo-section--{{ section.id }} .pr-pubchem a::after {
    content: "";
    position: absolute;
    left: 50%;
    right: 50%;
    bottom: -2px;
    height: 1px;
    background: currentColor;
    transition: left 0.18s var(--out-soft, ease), right 0.18s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .pr-pubchem a:hover::after {
    left: 0;
    right: 0;
  }

  .xo-section--{{ section.id }} .pr-acc .qa {
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
    border-radius: var(--general-radius-1, 1rem);
    background: rgba(var(--color-background));
    margin-bottom: 10px;
    padding: 0;
    overflow: hidden;
    transition: border-color 0.3s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .pr-acc .qa:hover {
    border-color: rgba(var(--color-accent));
  }

  .xo-section--{{ section.id }} .pr-acc summary {
    list-style: none;
    cursor: pointer;
    padding: 12px 14px;
    min-height: 44px;
    font-family: var(--font-heading-family);
    font-weight: 600;
    font-size: clamp(0.9rem, 1.3vw, 1rem);
    color: rgba(var(--color-foreground));
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .xo-section--{{ section.id }} .pr-acc summary::-webkit-details-marker {
    display: none;
  }

  .xo-section--{{ section.id }} .pr-acc summary:focus-visible {
    outline: 2px solid rgba(var(--color-accent));
    outline-offset: 2px;
    border-radius: var(--general-radius-1, 1rem);
  }

  .xo-section--{{ section.id }} .pr-acc .caret {
    transition: transform 0.2s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .pr-acc details[open] .caret {
    transform: rotate(180deg);
  }

  .xo-section--{{ section.id }} .pr-acc .a {
    padding: 0 14px 14px;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 75%, transparent);
    line-height: 1.6;
    font-size: clamp(0.85rem, 1.2vw, 0.9375rem);
  }

  .xo-section--{{ section.id }} .pr-acc .fig img {
    width: 100%;
    height: auto;
    border-radius: var(--general-radius-small, 1rem);
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
    background: rgba(var(--color-background));
  }

  .xo-section--{{ section.id }} .pr-acc .cap {
    font-size: clamp(0.8rem, 1.1vw, 0.85rem);
    color: color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent);
    margin-top: 4px;
  }

  .xo-section--{{ section.id }} .pr-acc .src {
    margin-top: 8px;
  }

  .xo-section--{{ section.id }} .pr-warn {
    margin-top: 14px;
    border: 1px solid color-mix(in srgb, rgba(var(--color-error)) 30%, transparent);
    background: color-mix(in srgb, rgba(var(--color-error)) 5%, transparent);
    border-radius: var(--general-radius-1, 1rem);
    padding: 12px 14px;
    color: rgba(var(--color-error));
  }

  @media (prefers-reduced-motion: no-preference) {
    .xo-section--{{ section.id }} .pr-mw span {
      opacity: 0;
      display: inline-block;
      transform: translateY(2px);
    }

    .xo-section--{{ section.id }} .pr-mw.is-in span {
      animation: prChar-{{ section.id }} 320ms ease-out forwards;
    }

    @keyframes prChar-{{ section.id }} {
      to {
        opacity: 1;
        transform: none;
      }
    }

    .xo-section--{{ section.id }} .pr-tabbar.is-in {
      border-bottom-color: color-mix(in srgb, rgba(var(--color-accent)) 30%, transparent);
      transition: border-color 0.7s var(--out-soft, ease);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .xo-section--{{ section.id }} .pr-tab,
    .xo-section--{{ section.id }} .pr-struct,
    .xo-section--{{ section.id }} .pr-acc .qa {
      transition: none;
    }

    .xo-section--{{ section.id }} .pr-tab:hover,
    .xo-section--{{ section.id }} .pr-struct:hover,
    .xo-section--{{ section.id }} .pr-acc .qa:hover {
      transform: none;
    }
  }
{%- endstyle -%}

<section id="peptide-research" {% render 'section-attr' %}>
  <xo-container>
    <div class="pr-tabbar" role="tablist" aria-label="Peptide research">
      <button class="pr-tab" role="tab" aria-selected="true" aria-controls="pr-tab-overview-{{ section.id }}" id="pr-tabbtn-overview-{{ section.id }}" data-tab="overview">{{ section.settings.tab_label_overview }}</button>
      <button class="pr-tab" role="tab" aria-selected="false" aria-controls="pr-tab-structure-{{ section.id }}" id="pr-tabbtn-structure-{{ section.id }}" data-tab="structure">{{ section.settings.tab_label_structure }}</button>
      <button class="pr-tab" role="tab" aria-selected="false" aria-controls="pr-tab-research-{{ section.id }}" id="pr-tabbtn-research-{{ section.id }}" data-tab="research">{{ section.settings.tab_label_research }}</button>
    </div>

    <!-- OVERVIEW -->
    <div id="pr-tab-overview-{{ section.id }}" class="pr-pane is-active" role="tabpanel" aria-labelledby="pr-tabbtn-overview-{{ section.id }}">
      <div class="pr-card">
        {% if pep and pep.summary %}{{ pep.summary | metafield_tag }}{% endif %}
        {% if pep and pep.mechanism %}
          <h3 class="pr-subhead">{{ section.settings.mechanism_heading }}</h3>
          {{ pep.mechanism | metafield_tag }}
        {% endif %}
        {% if pep and pep.research_applications %}
          {% assign apps = pep.research_applications %}
          {% if apps.size > 0 %}
            <h3 class="pr-subhead">{{ section.settings.applications_heading }}</h3>
            <ul class="pr-bullets">
              {% for a in apps %}
                {% assign t = a | strip %}{% if t != blank %}<li>{{ t }}</li>{% endif %}
              {% endfor %}
            </ul>
          {% endif %}
        {% endif %}
      </div>
    </div>

    <!-- STRUCTURE -->
    <div id="pr-tab-structure-{{ section.id }}" class="pr-pane" role="tabpanel" aria-labelledby="pr-tabbtn-structure-{{ section.id }}">
      <div class="pr-grid">
        <div class="pr-struct">
          <div class="pr-label">Sequence</div>
          <div class="pr-value">{% if pep and pep.sequence %}{{ pep.sequence }}{% else %}—{% endif %}</div>
        </div>

        <div class="pr-struct">
          <div class="pr-label">Molecular Formula</div>
          <div class="pr-value pr-mw" id="pr-mw-formula-{{ section.id }}">
            {% if formula_display %}
              {% assign chars = formula_display | split: '' %}
              {% for ch in chars %}<span>{{ ch }}</span>{% endfor %}
            {% else %}—{% endif %}
          </div>
        </div>

        <div class="pr-struct">
          <div class="pr-label">Molecular Weight (g/mol)</div>
          <div class="pr-value">{% if mw_display %}{{ mw_display }}{% else %}—{% endif %}</div>
        </div>

        <div class="pr-struct pr-pubchem">
          <div class="pr-label">PubChem</div>
          <div class="pr-value">
            {% if pep and pep.pubchem_url %}
              <a href="{{ pep.pubchem_url }}" target="_blank" rel="noopener">
                CID{% if pep.pubchem_cid %} {{ pep.pubchem_cid }}{% endif %}
              </a>
            {% else %}—{% endif %}
          </div>
        </div>
      </div>
    </div>

    <!-- RESEARCH (accordion of pep_section) -->
    <div id="pr-tab-research-{{ section.id }}" class="pr-pane" role="tabpanel" aria-labelledby="pr-tabbtn-research-{{ section.id }}">
      {% if sections and sections.size > 0 %}
        {% assign ordered = sections | sort: 'order' %}
        <div class="pr-acc">
        {% for s in ordered %}
          {% assign hd = s.heading %}
          {% assign bd = s.body %}
          <details class="qa" {% if forloop.first %}open{% endif %}>
            <summary>
              <span>{{ hd | default: 'Section ' | append: forloop.index }}</span>
              <svg class="caret" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </summary>
            <div class="a">
              {% if s.figure_image %}
                <div class="fig">
                  <img src="{{ s.figure_image | image_url: width: 1200 }}" alt="{{ s.figure_caption | default: hd | escape }}" width="1200" height="{{ 1200 | divided_by: s.figure_image.aspect_ratio | round }}" loading="lazy">
                  {% if s.figure_caption %}<div class="cap">{{ s.figure_caption }}</div>{% endif %}
                </div>
              {% endif %}
              {% if bd %}{{ bd | metafield_tag }}{% endif %}
              {% if s.source_link %}
                <div class="src"><a href="{{ s.source_link }}" target="_blank" rel="noopener">Source</a></div>
              {% endif %}
            </div>
          </details>
        {% endfor %}
        </div>
      {% else %}
        <div class="pr-card"><p>{{ section.settings.research_fallback }}</p></div>
      {% endif %}
    </div>

    {% if product.metafields.pep.warnings %}
      <div class="pr-warn">{{ product.metafields.pep.warnings }}</div>
    {% elsif pep and pep.warnings %}
      <div class="pr-warn">{{ pep.warnings }}</div>
    {% endif %}
  </xo-container>
</section>

<script>
document.addEventListener('DOMContentLoaded', function(){
  var wrap = document.querySelector('.xo-section--{{ section.id }}');
  if(!wrap) return;

  var tabbar = wrap.querySelector('.pr-tabbar');
  var tabBtns = wrap.querySelectorAll('.pr-tab');
  var panes = {
    overview: wrap.querySelector('[id="pr-tab-overview-{{ section.id }}"]'),
    structure: wrap.querySelector('[id="pr-tab-structure-{{ section.id }}"]'),
    research: wrap.querySelector('[id="pr-tab-research-{{ section.id }}"]')
  };

  function activate(tabKey){
    tabBtns.forEach(function(b){
      var on = (b.dataset.tab === tabKey);
      b.setAttribute('aria-selected', on ? 'true':'false');
    });
    Object.keys(panes).forEach(function(k){ panes[k].classList.toggle('is-active', k===tabKey); });
  }

  tabBtns.forEach(function(btn){
    btn.addEventListener('click', function(){ activate(btn.dataset.tab); btn.focus(); });
    btn.addEventListener('keydown', function(e){
      if(e.key === 'ArrowRight' || e.key === 'ArrowLeft'){
        var i = Array.prototype.indexOf.call(tabBtns, btn);
        var next = e.key === 'ArrowRight' ? (i+1)%tabBtns.length : (i-1+tabBtns.length)%tabBtns.length;
        tabBtns[next].click();
        e.preventDefault();
      }
    });
  });

  try{
    if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      var io = new IntersectionObserver(function(entries){
        entries.forEach(function(e){
          if(e.isIntersecting){
            tabbar.classList.add('is-in');
            var mw = wrap.querySelector('.pr-mw');
            if(mw){
              var spans = mw.querySelectorAll('span');
              spans.forEach(function(s, idx){ s.style.animationDelay = (idx * 18) + 'ms'; });
              mw.classList.add('is-in');
            }
            io.disconnect();
          }
        });
      }, { threshold: 0.35 });
      io.observe(tabbar);
    }
  }catch(e){}
});
</script>

{% schema %}
{
  "name": "Peptide research tabs",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "background-1" },

    { "type": "text", "id": "tab_label_overview", "label": "Overview tab label", "default": "Overview" },
    { "type": "text", "id": "tab_label_structure", "label": "Structure tab label", "default": "Structure" },
    { "type": "text", "id": "tab_label_research", "label": "Research tab label", "default": "Research" },

    { "type": "text", "id": "mechanism_heading", "label": "Mechanism heading", "default": "Mechanism (preclinical)" },
    { "type": "text", "id": "applications_heading", "label": "Applications heading", "default": "Research applications" },
    { "type": "text", "id": "research_fallback", "label": "Research fallback", "default": "Research sections will appear here when attached via pep.sections." },

    { "type": "range", "id": "padding_top_desktop", "label": "Desktop top padding", "min": 0, "max": 100, "step": 4, "default": 28, "unit": "px" },
    { "type": "range", "id": "padding_bottom_desktop", "label": "Desktop bottom padding", "min": 0, "max": 100, "step": 4, "default": 28, "unit": "px" },
    { "type": "range", "id": "padding_top_mobile", "label": "Mobile top padding", "min": 0, "max": 80, "step": 4, "default": 24, "unit": "px" },
    { "type": "range", "id": "padding_bottom_mobile", "label": "Mobile bottom padding", "min": 0, "max": 80, "step": 4, "default": 24, "unit": "px" }
  ],
  "blocks": [
    { "type": "@app" }
  ],
  "presets": [{ "name": "Peptide research tabs" }]
}
{% endschema %}
