{% comment %}
───────────────────────────────────────────────
SECTION: Peptide Research Tabs (refined)
Data sources:
- product.metafields.pep.reference → pep_peptide (metaobject)
- product.metafields.pep.sections  → list of pep_section (ordered by 'order')
Fields used:
  pep_peptide.summary (rich), mechanism (rich), research_applications (list)
  sequence, molecular_formula, molecular_weight, pubchem_cid, pubchem_url
  warnings (fallback)
Notes:
- Use metafield_tag on rich text to avoid JSON-looking output.
- Adds kinetic cues & keyboard-friendly tabs.
───────────────────────────────────────────────
{% endcomment %}

{%- liquid
  assign pep_ref = product.metafields.pep.reference
  assign pep = nil
  if pep_ref and pep_ref.value
    assign pep = pep_ref.value
  endif

  assign sections_ref = product.metafields.pep.sections
  assign sections = nil
  if sections_ref and sections_ref.value
    assign sections = sections_ref.value
  endif

  # handy values
  assign formula_display = nil
  if pep and pep.molecular_formula
    assign formula_display = pep.molecular_formula
  endif

  assign mw_display = nil
  if pep and pep.molecular_weight
    assign mw_display = pep.molecular_weight
  endif
-%}

<section id="peptide-research" class="pep-research npx-pr">
  <style>
    /* ====== Tokens aligned with hero ====== */
    #peptide-research{
      --pr-maxw: {{ section.settings.max_width | default: 1200 }}px;
      --pr-border:#E7E9ED;
      --pr-bg:#FAFAFB;
      --pr-card:#FFFFFF;
      --pr-text:#111111;
      --pr-muted:#6B7280;
      --pr-accent: {{ section.settings.accent_color | default: '#FBBF24' }};
      --pr-radius: var(--nx-radius);
      --pr-shadow: 0 1px 6px rgba(16,24,40,.06);
    }

    .npx-pr{padding:26px var(--page-gutter);background:var(--pr-bg);font-family:var(--font-body-family,sans-serif)}
    .npx-pr .pr-container{max-width:var(--pr-maxw);margin:0 auto}

    /* ====== Tabbar ====== */
    .pr-tabbar{
      display:flex;gap:10px;flex-wrap:wrap;
      box-shadow:inset 0 -1px 0 rgba(0,0,0,0.06);margin-bottom:12px;overflow:auto;padding-bottom:10px;
    }
    .pr-tab{
      border:1.5px solid var(--pr-border);border-radius:var(--nx-radius-pill);background:#fff;
      padding:8px 14px;min-height:44px;box-sizing:border-box;
      font-weight:700;font-size:clamp(0.8rem,1.2vw,0.875rem);cursor:pointer;
      display:inline-flex;align-items:center;
      box-shadow:var(--shadow-xs);
      transition:var(--transition-premium);
    }
    .pr-tab:hover{border-color:var(--pr-accent);box-shadow:var(--shadow-sm-hover);transform:translateY(-1px)}
    .pr-tab:focus-visible{outline:2px solid var(--pr-accent);outline-offset:2px}
    .pr-tab[aria-selected="true"]{
      border-color:var(--pr-accent);
      box-shadow:0 0 0 3px color-mix(in srgb, var(--pr-accent) 18%, transparent);
    }

    /* ====== Panes / cards ====== */
    .pr-pane{display:none;padding-top:12px}
    .pr-pane.is-active{display:block}
    .pr-card{
      border:none;border-radius:var(--pr-radius);background:var(--pr-card);
      padding:14px; box-shadow:var(--shadow-sm);
    }
    .pr-subhead{font-family:var(--font-heading-family,sans-serif);margin:12px 0 6px;font-weight:800;font-size:clamp(0.9rem,1.3vw,1rem);color:var(--pr-text)}
    .pr-bullets{margin:8px 0 0 18px}

    /* ====== Structure grid ====== */
    .pr-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:12px;margin-top:6px}
    @media(max-width:860px){ .pr-grid{grid-template-columns:1fr} }
    .pr-struct{
      background:#fff;border:none;border-radius:var(--nx-radius-md);padding:12px;
      box-shadow:var(--shadow-sm);transition:var(--transition-premium);
    }
    .pr-struct:hover{box-shadow:var(--shadow-sm-hover);transform:translateY(-1px)}
    .pr-label{font-weight:700;color:var(--pr-text)}
    .pr-value{margin-top:4px;color:var(--pr-text);opacity:0.85;word-break:break-word}
    .pr-pubchem a{ position:relative; text-decoration:none; font-weight:600; color:var(--pr-text); }
    .pr-pubchem a:focus-visible{outline:2px solid var(--pr-accent);outline-offset:2px;border-radius:4px}
    .pr-pubchem a::after{content:""; position:absolute; left:50%; right:50%; bottom:-2px; height:1px; background: currentColor; transition:left .18s ease,right .18s ease;}
    .pr-pubchem a:hover::after{ left:0; right:0; }

    /* ====== Research accordion ====== */
    .pr-acc .qa{
      border:none;border-radius:var(--nx-radius-md);background:#fff;margin-bottom:10px;
      padding:0; overflow:hidden;box-shadow:var(--shadow-sm);
      transition:var(--transition-premium);
    }
    .pr-acc .qa:hover{box-shadow:var(--shadow-md-hover);transform:translateY(-1px)}
    .pr-acc summary{
      list-style:none;cursor:pointer;padding:12px 14px;min-height:44px;
      font-family:var(--font-heading-family,sans-serif);font-weight:700;font-size:clamp(0.9rem,1.3vw,1rem);
      color:var(--pr-text);display:flex;align-items:center;justify-content:space-between;
    }
    .pr-acc summary::-webkit-details-marker{display:none}
    .pr-acc summary:focus-visible{outline:2px solid var(--pr-accent);outline-offset:2px;border-radius:var(--nx-radius-md)}
    .pr-acc .caret{transition:transform .2s ease}
    .pr-acc details[open] .caret{transform:rotate(180deg)}
    .pr-acc .a{padding:0 14px 14px;color:var(--pr-text);opacity:0.85;line-height:1.6;font-size:clamp(0.85rem,1.2vw,0.9375rem)}
    .pr-acc .fig img{width:100%;height:auto;border-radius:var(--nx-radius-sm);border:none;background:#fff;box-shadow:var(--shadow-sm)}
    .pr-acc .cap{font-size:clamp(0.8rem,1.1vw,0.85rem);color:var(--pr-muted);margin-top:4px}
    .pr-acc .src{margin-top:8px}

    .pr-warn{
      margin-top:14px;border:none;background:#FFF7F2;border-radius:var(--nx-radius-md);padding:12px 14px;color:#7A2E0E;
      box-shadow:inset 0 0 0 1px rgba(255,214,204,0.6);
    }

    /* ====== Micro-motions (respect reduced motion) ====== */
    @media (prefers-reduced-motion: no-preference){
      .pr-mw span{ opacity:0; display:inline-block; transform: translateY(2px); }
      .pr-mw.is-in span{ animation: prChar 320ms ease-out forwards; }
      @keyframes prChar{ to{opacity:1; transform:none} }

      .pr-tabbar.is-in{ box-shadow:0 0 0 2px color-mix(in srgb, var(--pr-accent) 12%, transparent) inset; transition: box-shadow .7s ease; }
    }
    @media(prefers-reduced-motion:reduce){
      .pr-tab,.pr-struct,.pr-acc .qa{transition:none}
      .pr-tab:hover,.pr-struct:hover,.pr-acc .qa:hover{transform:none}
    }
  </style>

  <div class="pr-container">

    <!-- Tabs -->
    <div class="pr-tabbar" role="tablist" aria-label="Peptide research">
      <button class="pr-tab" role="tab" aria-selected="true"  aria-controls="pr-tab-overview"  id="pr-tabbtn-overview"  data-tab="overview">{{ section.settings.tab_label_overview }}</button>
      <button class="pr-tab" role="tab" aria-selected="false" aria-controls="pr-tab-structure" id="pr-tabbtn-structure" data-tab="structure">{{ section.settings.tab_label_structure }}</button>
      <button class="pr-tab" role="tab" aria-selected="false" aria-controls="pr-tab-research"  id="pr-tabbtn-research"  data-tab="research">{{ section.settings.tab_label_research }}</button>
    </div>

    <!-- OVERVIEW -->
    <div id="pr-tab-overview" class="pr-pane is-active" role="tabpanel" aria-labelledby="pr-tabbtn-overview">
      <div class="pr-card">
        {% if pep and pep.summary %}{{ pep.summary | metafield_tag }}{% endif %}
        {% if pep and pep.mechanism %}
          <h3 class="pr-subhead">{{ section.settings.mechanism_heading }}</h3>
          {{ pep.mechanism | metafield_tag }}
        {% endif %}
        {% if pep and pep.research_applications %}
          {% assign apps = pep.research_applications %}
          {% if apps.size > 0 %}
            <h3 class="pr-subhead">{{ section.settings.applications_heading }}</h3>
            <ul class="pr-bullets">
              {% for a in apps %}
                {% assign t = a | strip %}{% if t != blank %}<li>{{ t }}</li>{% endif %}
              {% endfor %}
            </ul>
          {% endif %}
        {% endif %}
      </div>
    </div>

    <!-- STRUCTURE -->
    <div id="pr-tab-structure" class="pr-pane" role="tabpanel" aria-labelledby="pr-tabbtn-structure">
      <div class="pr-grid">
        <div class="pr-struct">
          <div class="pr-label">Sequence</div>
          <div class="pr-value">{% if pep and pep.sequence %}{{ pep.sequence }}{% else %}—{% endif %}</div>
        </div>

        <div class="pr-struct">
          <div class="pr-label">Molecular Formula</div>
          <div class="pr-value pr-mw" id="pr-mw-formula">
            {% if formula_display %}
              {% assign chars = formula_display | split: '' %}
              {% for ch in chars %}<span>{{ ch }}</span>{% endfor %}
            {% else %}—{% endif %}
          </div>
        </div>

        <div class="pr-struct">
          <div class="pr-label">Molecular Weight (g/mol)</div>
          <div class="pr-value">{% if mw_display %}{{ mw_display }}{% else %}—{% endif %}</div>
        </div>

        <div class="pr-struct pr-pubchem">
          <div class="pr-label">PubChem</div>
          <div class="pr-value">
            {% if pep and pep.pubchem_url %}
              <a href="{{ pep.pubchem_url }}" target="_blank" rel="noopener">
                CID{% if pep.pubchem_cid %} {{ pep.pubchem_cid }}{% endif %}
              </a>
            {% else %}—{% endif %}
          </div>
        </div>
      </div>
    </div>

    <!-- RESEARCH (accordion of pep_section) -->
    <div id="pr-tab-research" class="pr-pane" role="tabpanel" aria-labelledby="pr-tabbtn-research">
      {% if sections and sections.size > 0 %}
        {% assign ordered = sections | sort: 'order' %}
        <div class="pr-acc">
        {% for s in ordered %}
          {% assign hd = s.heading %}
          {% assign bd = s.body %}
          <details class="qa" {% if forloop.first %}open{% endif %}>
            <summary>
              <span>{{ hd | default: 'Section ' | append: forloop.index }}</span>
              <svg class="caret" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </summary>
            <div class="a">
              {% if s.figure_image %}
                <div class="fig">
                  <img src="{{ s.figure_image | image_url: width: 1200 }}" alt="{{ s.figure_caption | default: hd | escape }}" width="1200" height="{{ 1200 | divided_by: s.figure_image.aspect_ratio | round }}" loading="lazy">
                  {% if s.figure_caption %}<div class="cap">{{ s.figure_caption }}</div>{% endif %}
                </div>
              {% endif %}
              {% if bd %}{{ bd | metafield_tag }}{% endif %}
              {% if s.source_link %}
                <div class="src"><a href="{{ s.source_link }}" target="_blank" rel="noopener">Source</a></div>
              {% endif %}
            </div>
          </details>
        {% endfor %}
        </div>
      {% else %}
        <div class="pr-card"><p>{{ section.settings.research_fallback }}</p></div>
      {% endif %}
    </div>

    {% if product.metafields.pep.warnings %}
      <div class="pr-warn">{{ product.metafields.pep.warnings }}</div>
    {% elsif pep and pep.warnings %}
      <div class="pr-warn">{{ pep.warnings }}</div>
    {% endif %}
  </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function(){
  var wrap = document.getElementById('peptide-research');
  if(!wrap) return;

  var tabbar = wrap.querySelector('.pr-tabbar');
  var tabBtns = wrap.querySelectorAll('.pr-tab');
  var panes = {
    overview: wrap.querySelector('#pr-tab-overview'),
    structure: wrap.querySelector('#pr-tab-structure'),
    research: wrap.querySelector('#pr-tab-research')
  };

  function activate(tabKey){
    tabBtns.forEach(function(b){
      var on = (b.dataset.tab === tabKey);
      b.setAttribute('aria-selected', on ? 'true':'false');
    });
    Object.keys(panes).forEach(function(k){ panes[k].classList.toggle('is-active', k===tabKey); });
  }

  tabBtns.forEach(function(btn){
    btn.addEventListener('click', function(){ activate(btn.dataset.tab); btn.focus(); });
    btn.addEventListener('keydown', function(e){
      if(e.key === 'ArrowRight' || e.key === 'ArrowLeft'){
        var i = Array.prototype.indexOf.call(tabBtns, btn);
        var next = e.key === 'ArrowRight' ? (i+1)%tabBtns.length : (i-1+tabBtns.length)%tabBtns.length;
        tabBtns[next].click();
        e.preventDefault();
      }
    });
  });

  // Micro-motions (once)
  try{
    if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      var io = new IntersectionObserver(function(entries){
        entries.forEach(function(e){
          if(e.isIntersecting){
            tabbar.classList.add('is-in');
            var mw = wrap.querySelector('.pr-mw');
            if(mw){
              var spans = mw.querySelectorAll('span');
              spans.forEach(function(s, idx){ s.style.animationDelay = (idx * 18) + 'ms'; });
              mw.classList.add('is-in');
            }
            io.disconnect();
          }
        });
      }, { threshold: 0.35 });
      io.observe(tabbar);
    }
  }catch(e){}
});
</script>

{% schema %}
{
  "name": "Peptide research tabs",
  "settings": [
    { "type": "range", "id": "max_width", "min": 800, "max": 1600, "step": 10, "unit": "px", "label": "Container max width", "default": 1200 },
    { "type": "color", "id": "accent_color", "label": "Accent color", "default": "#FBBF24" },

    { "type": "text", "id": "tab_label_overview", "label": "Overview tab label", "default": "Overview" },
    { "type": "text", "id": "tab_label_structure", "label": "Structure tab label", "default": "Structure" },
    { "type": "text", "id": "tab_label_research", "label": "Research tab label", "default": "Research" },

    { "type": "text", "id": "mechanism_heading", "label": "Mechanism heading", "default": "Mechanism (preclinical)" },
    { "type": "text", "id": "applications_heading", "label": "Applications heading", "default": "Research applications" },
    { "type": "text", "id": "research_fallback", "label": "Research fallback", "default": "Research sections will appear here when attached via pep.sections." }
  ],
  "presets": [{ "name": "Peptide research tabs" }]
}
{% endschema %}
