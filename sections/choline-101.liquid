   STACKS — equal-height grid cards
   ═══════════════════════════════════════════════ */
#choline-101-{{ sid }} .c1-stacks .c1-stack-card {
  background: var(--c1-bg);
  border: none;
  border-radius: var(--c1-radius);
  padding: 18px;
  box-shadow: var(--c1-shadow-rest);
  transition: var(--c1-transition);
}
#choline-101-{{ sid }} .c1-stacks .c1-stack-card:hover {
  box-shadow: var(--c1-shadow-hover);
  transform: translateY(-2px);
}

/* ═══════════════════════════════════════════════
   NATIVE RESPONSIVE TABLE — dosing
   ═══════════════════════════════════════════════ */
#choline-101-{{ sid }} .c1-table-wrap {
  border-radius: var(--c1-radius);
  overflow: hidden;
  box-shadow: var(--c1-shadow-rest);
}
#choline-101-{{ sid }} .c1-table {
  width: 100%;
  border-collapse: collapse;
}
#choline-101-{{ sid }} .c1-table thead {
  background: var(--c1-bg-alt);
}
#choline-101-{{ sid }} .c1-table th {
  text-align: left;
  padding: 12px 14px;
  font-weight: 700;
  font-size: 14px;
  color: var(--c1-text);
  line-height: 1.4;
}
#choline-101-{{ sid }} .c1-table td {
  padding: 14px;
  font-size: 15px;
  line-height: 1.6;
  color: var(--c1-text);
  border-top: 1px solid rgba(0, 0, 0, 0.04);
}
#choline-101-{{ sid }} .c1-table tbody tr {
  transition: var(--c1-transition);
}
#choline-101-{{ sid }} .c1-table tbody tr:hover {
  background: var(--c1-accent-glass);
}

@media (max-width: 767px) {
  #choline-101-{{ sid }} .c1-table thead { display: none; }
  #choline-101-{{ sid }} .c1-table tbody tr {
    display: block;
    padding: 14px;
    border-top: 1px solid rgba(0, 0, 0, 0.04);
  }
  #choline-101-{{ sid }} .c1-table tbody tr:first-child { border-top: none; }
  #choline-101-{{ sid }} .c1-table td {
    display: block;
    padding: 3px 0;
    border-top: none;
  }
  #choline-101-{{ sid }} .c1-table td::before {
    content: attr(data-label) ": ";
    font-weight: 700;
    color: var(--c1-text);
  }
}

/* ═══════════════════════════════════════════════
   ROUTINE STEPS — numbered indicators
   ═══════════════════════════════════════════════ */
#choline-101-{{ sid }} .c1-steps {
  list-style: none;
  counter-reset: c1step;
  margin: 0;
  padding: 0;
}
#choline-101-{{ sid }} .c1-steps li {
  counter-increment: c1step;
  position: relative;
  padding-left: 42px;
  margin: 14px 0;
  line-height: 1.6;
}
#choline-101-{{ sid }} .c1-steps li::before {
  content: counter(c1step);
  position: absolute;
  left: 0;
  top: 0;
  width: 28px;
  height: 28px;
  border-radius: 50%;
  background: var(--c1-accent-glass);
  border: 1.5px solid var(--c1-accent);
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  font-size: 13px;
  color: var(--c1-text);
  line-height: 1;
}

/* ═══════════════════════════════════════════════
   FAQ — animated disclosure, chevron rotation
   ═══════════════════════════════════════════════ */
#choline-101-{{ sid }} .c1-faq {
  border-radius: 10px;
  margin: 8px 0;
  box-shadow: var(--c1-shadow-rest);
  overflow: hidden;
  transition: var(--c1-transition);
}
#choline-101-{{ sid }} .c1-faq:hover {
  box-shadow: var(--c1-shadow-hover);
}
#choline-101-{{ sid }} .c1-faq__q {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  padding: 14px 18px;
  font-weight: 600;
  font-size: 15px;
  line-height: 1.5;
  color: var(--c1-text);
  cursor: pointer;
  list-style: none;
  min-height: var(--touch-min, 44px);
}
#choline-101-{{ sid }} .c1-faq__q::-webkit-details-marker { display: none; }
#choline-101-{{ sid }} .c1-faq__q::marker { content: ""; }

#choline-101-{{ sid }} .c1-faq__chevron {
  flex-shrink: 0;
  width: 20px;
  height: 20px;
  position: relative;
  transition: transform 0.35s cubic-bezier(0.25, 0.8, 0.25, 1);
}
#choline-101-{{ sid }} .c1-faq__chevron::before,
#choline-101-{{ sid }} .c1-faq__chevron::after {
  content: "";
  position: absolute;
  top: 50%;
  width: 10px;
  height: 2px;
  background: var(--c1-muted);
  border-radius: 1px;
  transition: transform 0.35s cubic-bezier(0.25, 0.8, 0.25, 1);
}
#choline-101-{{ sid }} .c1-faq__chevron::before {
  left: 1px;
  transform: translateY(-50%) rotate(45deg);
}
#choline-101-{{ sid }} .c1-faq__chevron::after {
  right: 1px;
  transform: translateY(-50%) rotate(-45deg);
}
#choline-101-{{ sid }} .c1-faq[open] .c1-faq__chevron::before {
  transform: translateY(-50%) rotate(-45deg);
}
#choline-101-{{ sid }} .c1-faq[open] .c1-faq__chevron::after {
  transform: translateY(-50%) rotate(45deg);
}

#choline-101-{{ sid }} .c1-faq__answer {
  display: grid;
  grid-template-rows: 0fr;
  transition: grid-template-rows 0.35s cubic-bezier(0.25, 0.8, 0.25, 1);
}
#choline-101-{{ sid }} .c1-faq[open] .c1-faq__answer {
  grid-template-rows: 1fr;
}
#choline-101-{{ sid }} .c1-faq__inner {
  overflow: hidden;
}
#choline-101-{{ sid }} .c1-faq__inner p {
  padding: 0 18px 16px;
  margin: 0;
  color: var(--c1-muted);
  line-height: 1.6;
  font-size: 15px;
}

/* ═══════════════════════════════════════════════
   SAFETY — subtle background
   ═══════════════════════════════════════════════ */
#choline-101-{{ sid }} .c1-safety {
  background: var(--c1-bg-alt);
}
#choline-101-{{ sid }} .c1-safety p {
  color: var(--c1-muted);
  line-height: 1.6;
  margin: 0;
}

/* ═══════════════════════════════════════════════
   SHOP PILLS — ghost pill buttons, fill on hover
   ═══════════════════════════════════════════════ */
#choline-101-{{ sid }} .c1-pills {
  list-style: none;
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  padding: 0;
  margin: 0;
}
#choline-101-{{ sid }} .c1-pill {
  display: inline-flex;
  align-items: center;
  padding: 9px 16px;
  border-radius: 999px;
  border: 1.5px solid var(--c1-accent);
  color: var(--c1-text);
  background: transparent;
  text-decoration: none;
  font-weight: 600;
  font-size: 14px;
  min-height: var(--touch-min, 44px);
  transition: var(--c1-transition);
}
#choline-101-{{ sid }} .c1-pill:hover {
  background: var(--c1-accent);
  color: var(--color-text-primary);
  transform: scale(1.03);
  box-shadow: 0 4px 16px rgba(251, 191, 36, 0.25);
}
#choline-101-{{ sid }} .c1-pill:active {
  transform: scale(0.98);
}

/* ═══════════════════════════════════════════════
   SHIPPING FOOTER
   ═══════════════════════════════════════════════ */
#choline-101-{{ sid }} .c1-ship {
  background: var(--c1-bg-alt);
  font-size: 0.93rem;
}
#choline-101-{{ sid }} .c1-ship p {
  margin: 0;
  line-height: 1.6;
  color: var(--c1-muted);
}

/* ═══════════════════════════════════════════════
   ACCESSIBILITY — focus-visible + reduced motion
   ═══════════════════════════════════════════════ */
#choline-101-{{ sid }} :focus-visible {
  outline: 2px solid var(--c1-accent);
  outline-offset: 2px;
}

@media (prefers-reduced-motion: reduce) {
  #choline-101-{{ sid }} *,
  #choline-101-{{ sid }} *::before,
  #choline-101-{{ sid }} *::after {
    animation-duration: 0.01ms !important;
    transition-duration: 0.01ms !important;
  }
}
{%- endstyle -%}

