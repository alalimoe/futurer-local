#choline-101-{{ sid }} {
  --c1-max: {{ s.max_width | default: 1080 }}px;
  --c1-py: {{ s.padding_y | default: 64 }}px;
  --c1-accent: var(--color-accent-primary, #FBBF24);
  --c1-accent-hover: var(--color-accent-hover, #D97706);
  --c1-accent-glass: rgba(251, 191, 36, 0.08);
  --c1-text: var(--color-text-main, #111827);
  --c1-muted: var(--color-text-muted, #4b5563);
  --c1-bg: {{ s.background_color | default: '#ffffff' }};
  --c1-bg-alt: var(--color-bg-secondary, #f9fafb);
  --c1-radius: var(--radius-premium, 14px);
  --c1-transition: var(--transition-premium, all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1));
  --c1-shadow-rest: var(--shadow-sm, 0 2px 8px rgba(0, 0, 0, 0.04));
  --c1-shadow-hover: var(--shadow-md, 0 12px 30px rgba(0, 0, 0, 0.06));
  --c1-font: var(--font-body-family, sans-serif);
  --c1-font-heading: var(--font-heading-family, sans-serif);
  --c1-gap: 16px;

  background: var(--c1-bg);
  color: var(--c1-text);
  font-family: var(--c1-font);
  line-height: 1.6;
  content-visibility: auto;
  contain-intrinsic-size: 1px 2400px;
}

/* ── Layout ── */
#choline-101-{{ sid }} .c1-inner {
  max-width: var(--c1-max);
  margin: 0 auto;
  padding: var(--c1-py) var(--page-gutter);
}

