{%- style -%}
  .xo-section--{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .xo-section--{{ section.id }} .uar-inner {
    max-width: 750px;
    margin: 0 auto;
  }

  .xo-section--{{ section.id }} .uar-heading {
    font-family: var(--font-heading-family);
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    font-weight: 600;
    color: rgba(var(--color-foreground));
    margin: 0 0 40px;
    text-align: center;
    letter-spacing: -0.02em;
  }

  .xo-section--{{ section.id }} .uar-item {
    border-bottom: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
  }

  .xo-section--{{ section.id }} .uar-item:first-child {
    border-top: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
  }

  .xo-section--{{ section.id }} .uar-q {
    padding: 20px 0;
    font-weight: 600;
    font-size: 1rem;
    color: rgba(var(--color-foreground));
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    list-style: none;
    transition: color 0.2s var(--out-soft, ease);
    min-height: 44px;
  }

  .xo-section--{{ section.id }} .uar-q::-webkit-details-marker {
    display: none;
  }

  .xo-section--{{ section.id }} .uar-q:hover {
    color: rgba(var(--color-accent));
  }

  .xo-section--{{ section.id }} .uar-chevron {
    width: 22px;
    height: 22px;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent);
    transition: transform 0.3s var(--out-soft, ease);
    flex-shrink: 0;
  }

  .xo-section--{{ section.id }} .uar-item[open] .uar-chevron {
    transform: rotate(180deg);
    color: rgba(var(--color-accent));
  }

  .xo-section--{{ section.id }} .uar-a {
    padding: 0 0 24px;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent);
    font-size: 0.9375rem;
    line-height: 1.8;
    animation: uarSlide--{{ section.id }} 0.3s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .uar-a-inner {
    border-right: 2px solid rgba(var(--color-accent));
    padding-right: 16px;
  }

  @keyframes uarSlide--{{ section.id }} {
    from { opacity: 0; transform: translateY(-4px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .xo-section--{{ section.id }} :focus-visible {
    outline: 2px solid rgba(var(--color-accent));
    outline-offset: 2px;
  }

  @media (prefers-reduced-motion: reduce) {
    .xo-section--{{ section.id }} *,
    .xo-section--{{ section.id }} *::before,
    .xo-section--{{ section.id }} *::after {
      animation-duration: 0.01ms !important;
      transition-duration: 0.01ms !important;
    }
  }
{%- endstyle -%}

{%- assign uar_faqs = section.blocks | where: "type", "faq" -%}
{% if uar_faqs.size > 0 %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "inLanguage": "ar",
  "mainEntity": [
    {%- for block in uar_faqs -%}
    {
      "@type": "Question",
      "name": {{ block.settings.question | json }},
      "acceptedAnswer": {
        "@type": "Answer",
        "text": {{ block.settings.answer | strip_html | json }}
      }
    }{%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
  ]
}
</script>
{% endif %}

<section id="uae-arabic" {% render 'section-attr' %}>
  <xo-container>
    <div class="uar-inner" lang="ar" dir="rtl">
      {% if section.settings.heading != blank %}
        <h2 class="uar-heading">{{ section.settings.heading }}</h2>
      {% endif %}

      {% if uar_faqs.size > 0 %}
        <div class="uar-faq">
          {% for block in uar_faqs %}
            <details class="uar-item" {{ block.shopify_attributes }}>
              <summary class="uar-q">
                {{ block.settings.question }}
                <span class="uar-chevron"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg></span>
              </summary>
              <div class="uar-a"><div class="uar-a-inner">{{ block.settings.answer }}</div></div>
            </details>
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </xo-container>
</section>

{% schema %}
{
  "name": "UAE Arabic FAQ",
  "tag": "section",
  "class": "section-uae-arabic",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "default" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "بالعربي" },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding top", "default": 80 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding bottom", "default": 80 }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "سؤال",
      "settings": [
        { "type": "text", "id": "question", "label": "السؤال" },
        { "type": "textarea", "id": "answer", "label": "الجواب" }
      ]
    },
    { "type": "@app" }
  ],
  "presets": [
    {
      "name": "UAE Arabic FAQ",
      "blocks": [
        { "type": "faq", "settings": { "question": "ما هي النوتروبيكس؟", "answer": "مكملات تدعم التركيز والذاكرة والمزاج. ليست بديلاً عن الاستشارة الطبية." } },
        { "type": "faq", "settings": { "question": "سرعة التوصيل داخل دبي؟", "answer": "تسليم في نفس اليوم داخل حدود المدينة (توصيل خلال ٤ ساعات لطلبيات قبل ٥ العصر)" } }
      ]
    }
  ]
}
{% endschema %}
