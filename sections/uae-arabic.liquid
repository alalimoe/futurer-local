{% schema %}
{
  "name": "UAE Arabic FAQ",
  "tag": "section",
  "class": "section-uae-arabic",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "بالعربي" },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#f9fafb" },
    { "type": "color", "id": "accent_color", "label": "Accent", "default": "#FBBF24" }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "سؤال",
      "settings": [
        { "type": "text", "id": "question", "label": "السؤال" },
        { "type": "textarea", "id": "answer", "label": "الجواب" }
      ]
    }
  ],
  "presets": [
    {
      "name": "UAE Arabic FAQ",
      "blocks": [
        { "type": "faq", "settings": { "question": "ما هي النوتروبيكس؟", "answer": "مكملات تدعم التركيز والذاكرة والمزاج. ليست بديلاً عن الاستشارة الطبية." } },
        { "type": "faq", "settings": { "question": "سرعة التوصيل داخل دبي؟", "answer": "تسليم في نفس اليوم داخل حدود المدينة (توصيل خلال ٤ ساعات لطلبيات قبل ٥ العصر)" } }
      ]
    }
  ]
}
{% endschema %}

{%- assign uar_faqs = section.blocks | where: "type", "faq" -%}
{% if uar_faqs.size > 0 %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "inLanguage": "ar",
  "mainEntity": [
    {%- for block in uar_faqs -%}
    {
      "@type": "Question",
      "name": {{ block.settings.question | json }},
      "acceptedAnswer": {
        "@type": "Answer",
        "text": {{ block.settings.answer | strip_html | json }}
      }
    }{%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
  ]
}
</script>
{% endif %}

<div class="uar-wrapper" id="uae-arabic" lang="ar" dir="rtl">
  <div class="uar-inner">
    {% if section.settings.heading != blank %}
      <h2 class="uar-heading">{{ section.settings.heading }}</h2>
    {% endif %}

    {% if uar_faqs.size > 0 %}
      <div class="uar-faq">
        {% for block in uar_faqs %}
          <details class="uar-item" {{ block.shopify_attributes }}>
            <summary class="uar-q">
              {{ block.settings.question }}
              <span class="uar-chevron"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg></span>
            </summary>
            <div class="uar-a"><div class="uar-a-inner">{{ block.settings.answer }}</div></div>
          </details>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</div>

<style>
  .uar-wrapper {
    --uar-bg: {{ section.settings.bg_color }};
    --uar-accent: {{ section.settings.accent_color }};
    --uar-text: var(--color-text-main, #111827);
    --uar-muted: var(--color-text-muted, #4b5563);
    --uar-border: var(--nx-pill-border, #E5E7EB);
    --uar-radius: var(--nx-radius, 14px);
    --uar-font: var(--font-body-family, sans-serif);
    --uar-font-heading: var(--font-heading-family, sans-serif);
    --uar-transition: var(--transition-smooth, all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1));
    background: var(--uar-bg); padding: 80px var(--page-gutter); font-family: var(--uar-font);
  }
  .uar-inner { max-width: 750px; margin: 0 auto; }
  .uar-heading {
    font-family: var(--uar-font-heading); font-size: clamp(1.75rem, 3vw, 2.25rem);
    font-weight: 800; color: var(--uar-text); margin: 0 0 40px; text-align: center; letter-spacing: -0.02em;
  }

  .uar-item { border-bottom: 1px solid var(--uar-border); }
  .uar-item:first-child { border-top: 1px solid var(--uar-border); }
  .uar-q {
    padding: 20px 0; font-weight: 700; font-size: 1rem; color: var(--uar-text);
    display: flex; justify-content: space-between; align-items: center;
    cursor: pointer; list-style: none; transition: color 0.2s; min-height: var(--touch-min, 44px);
  }
  .uar-q::-webkit-details-marker { display: none; }
  .uar-q:hover { color: var(--uar-accent); }
  .uar-chevron { width: 22px; height: 22px; color: var(--uar-muted); transition: transform 0.3s ease; flex-shrink: 0; }
  .uar-item[open] .uar-chevron { transform: rotate(180deg); color: var(--uar-accent); }
  .uar-a { padding: 0 0 24px; color: var(--uar-muted); font-size: 0.9375rem; line-height: 1.8; animation: uarSlide 0.3s ease-out; }
  .uar-a-inner { border-right: 2px solid var(--uar-accent); padding-right: 16px; }
  @keyframes uarSlide { from { opacity: 0; transform: translateY(-4px); } to { opacity: 1; transform: translateY(0); } }

  .uar-wrapper :focus-visible { outline: 2px solid var(--uar-accent); outline-offset: 2px; }
  @media (prefers-reduced-motion: reduce) { .uar-wrapper *, .uar-wrapper *::before, .uar-wrapper *::after { animation-duration: 0.01ms !important; transition-duration: 0.01ms !important; } }
  @media (max-width: 640px) { .uar-wrapper { padding: 56px var(--page-gutter); } }
</style>
