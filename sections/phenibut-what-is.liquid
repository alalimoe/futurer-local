{% comment %}
  What is Phenibut — Premium refactored section
  - Short definition + "The Basics" + "Scientific Overview" (toggle)
  - Optional molecule image, premium design tokens, accessibility
{% endcomment %}

{%- style -%}
.xo-section--{{ section.id }} {
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
  font-family: var(--font-body-family);
}
.xo-section--{{ section.id }} .phb-what-is__container {
  max-width: {{ section.settings.max_width }}px; margin: 0 auto;
  padding: 0 var(--page-gap);
  display: grid; grid-template-columns: 1.15fr 0.85fr;
  gap: 40px; align-items: start;
}
.xo-section--{{ section.id }} .phb-what-is__title {
  font-family: var(--font-heading-family);
  font-size: clamp(22px, 4.2vw, 36px); line-height: 1.2;
  margin: 0 0 12px; color: rgba(var(--color-foreground)); font-weight: 600;
}
.xo-section--{{ section.id }} .phb-what-is__definition {
  color: rgba(var(--color-foreground)); font-size: clamp(16px, 2.2vw, 18px);
  line-height: 1.6; margin-bottom: 14px;
}
.xo-section--{{ section.id }} .phb-what-is__split {
  display: grid; grid-template-columns: 1fr 1fr; gap: 28px;
}
.xo-section--{{ section.id }} .phb-wi-card {
  background: rgba(var(--color-background)); border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
  border-radius: var(--general-radius-1, 1rem); padding: 16px 16px 14px;
}
.xo-section--{{ section.id }} .phb-wi-card__title {
  font-family: var(--font-heading-family);
  font-size: 18px; font-weight: 600; margin: 0 0 8px; color: rgba(var(--color-foreground));
}
.xo-section--{{ section.id }} .phb-wi-card__list {
  padding-left: 18px; margin: 0; display: grid; gap: 6px;
  color: rgba(var(--color-foreground)); font-size: 16px; line-height: 1.5;
}
.xo-section--{{ section.id }} .phb-wi-card__li { list-style: disc; }
.xo-section--{{ section.id }} .phb-wi-accordion { margin: 0; }
.xo-section--{{ section.id }} .phb-wi-accordion__summary {
  display: flex; align-items: center; justify-content: space-between;
  cursor: pointer; user-select: none; list-style: none;
}
.xo-section--{{ section.id }} .phb-wi-accordion__summary::-webkit-details-marker { display: none; }
.xo-section--{{ section.id }} .phb-wi-accordion__summary:focus-visible {
  outline: 2px solid rgba(var(--color-accent)); outline-offset: 2px;
}
.xo-section--{{ section.id }} .phb-wi-accordion__chev { transition: transform 0.3s var(--out-soft, ease); }
.xo-section--{{ section.id }} .phb-wi-accordion[open] .phb-wi-accordion__chev { transform: rotate(180deg); }
.xo-section--{{ section.id }} .phb-wi-accordion__body {
  margin-top: 10px; color: rgba(var(--color-foreground)); font-size: 16px; line-height: 1.6;
}
.xo-section--{{ section.id }} .phb-wi-accordion__body p { margin: 0 0 10px; }
.xo-section--{{ section.id }} .phb-wi-accordion__body ul { padding-left: 18px; margin: 6px 0 10px; }
.xo-section--{{ section.id }} .phb-wi-accordion__body li { list-style: disc; }
.xo-section--{{ section.id }} .phb-what-is__right { display: flex; justify-content: center; align-items: center; }
.xo-section--{{ section.id }} .phb-what-is__img {
  width: 100%; max-width: 440px; height: auto; object-fit: contain;
  border-radius: var(--general-radius-1, 1rem);
}
.xo-section--{{ section.id }} .phb-what-is__note {
  margin-top: 10px; font-size: 13px; color: color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent);
}
.xo-section--{{ section.id }} :focus-visible { outline: 2px solid rgba(var(--color-accent)); outline-offset: 2px; }
@media (max-width: 768px) {
  .xo-section--{{ section.id }} .phb-what-is__container { grid-template-columns: 1fr; gap: 20px; }
  .xo-section--{{ section.id }} .phb-what-is__split { grid-template-columns: 1fr; }
  .xo-section--{{ section.id }} .phb-what-is__right { display: {% if section.settings.hide_image_mobile %}none{% else %}flex{% endif %}; }
  .xo-section--{{ section.id }} .phb-what-is__title {
    text-align: {% if section.settings.center_on_mobile %}center{% else %}left{% endif %};
  }
  .xo-section--{{ section.id }} .phb-what-is__definition {
    text-align: {% if section.settings.center_on_mobile %}center{% else %}left{% endif %};
  }
}
@media (prefers-reduced-motion: reduce) {
  .xo-section--{{ section.id }} *,
  .xo-section--{{ section.id }} *::before,
  .xo-section--{{ section.id }} *::after {
    animation-duration: 0.01ms !important;
    transition-duration: 0.01ms !important;
  }
}
{%- endstyle -%}

<section {% render 'section-attr' %} aria-labelledby="phb-whatis-title-{{ section.id }}">
  <xo-container>
    <div class="phb-what-is__container">
      <div class="phb-what-is__left">
        <h2 id="phb-whatis-title-{{ section.id }}" class="phb-what-is__title">
          {{ section.settings.heading | escape }}
        </h2>

        {% if section.settings.definition != blank %}
          <div class="phb-what-is__definition">{{ section.settings.definition }}</div>
        {% endif %}

        <div class="phb-what-is__split">
          {% if section.settings.show_basics %}
            <article class="phb-wi-card" aria-labelledby="phb-basics-title-{{ section.id }}">
              <h3 id="phb-basics-title-{{ section.id }}" class="phb-wi-card__title">The Basics</h3>
              <ul class="phb-wi-card__list">
                {% for block in section.blocks %}
                  {% if block.type == 'bullet' %}
                    <li class="phb-wi-card__li" {{ block.shopify_attributes }}>{{ block.settings.text | escape }}</li>
                  {% endif %}
                {% endfor %}
              </ul>
            </article>
          {% endif %}

          <article class="phb-wi-card" aria-labelledby="phb-sci-title-{{ section.id }}">
            <details {% unless section.settings.scientific_collapsed %}open{% endunless %} class="phb-wi-accordion">
              <summary class="phb-wi-accordion__summary">
                <h3 id="phb-sci-title-{{ section.id }}" class="phb-wi-card__title">Scientific Overview</h3>
                <span class="phb-wi-accordion__chev" aria-hidden="true">▾</span>
              </summary>
              <div class="phb-wi-accordion__body">
                {{ section.settings.scientific_body }}
              </div>
            </details>
          </article>
        </div>

        {% if section.settings.show_note and section.settings.note_text != blank %}
          <p class="phb-what-is__note">{{ section.settings.note_text }}</p>
        {% endif %}
      </div>

      {% if section.settings.molecule_image != blank %}
        <div class="phb-what-is__right{% if section.settings.hide_image_mobile %} phb-what-is__right--hide-m{% endif %}">
          <img
            src="{{ section.settings.molecule_image | image_url: width: 960 }}"
            srcset="
              {{ section.settings.molecule_image | image_url: width: 480 }} 480w,
              {{ section.settings.molecule_image | image_url: width: 700 }} 700w,
              {{ section.settings.molecule_image | image_url: width: 960 }} 960w
            "
            sizes="(max-width: 768px) 0px, 440px"
            alt="{% unless section.settings.molecule_decorative %}{{ section.settings.molecule_alt | escape }}{% endunless %}"
            {% if section.settings.molecule_decorative %}role="presentation" aria-hidden="true"{% endif %}
            width="960"
            height="{{ 960 | divided_by: section.settings.molecule_image.aspect_ratio | round }}"
            loading="lazy" decoding="async" class="phb-what-is__img"
          >
        </div>
      {% endif %}
    </div>
  </xo-container>
</section>

{% schema %}
{
  "name": "What is Phenibut",
  "tag": "section",
  "class": "section-what-is-phenibut",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "default" },
    { "type": "text", "id": "anchor_id", "label": "Anchor ID (for TOC/links)", "default": "what-is-phenibut" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "What is Phenibut?" },
    { "type": "richtext", "id": "definition", "label": "Short definition", "default": "<p>Phenibut is a derivative of the neurotransmitter GABA. It's designed to support calm, social ease, and sleep quality when used <strong>occasionally</strong> and responsibly. It commonly comes as <strong>FAA</strong> (free amino acid) and <strong>HCl</strong> forms.</p>" },
    { "type": "checkbox", "id": "show_basics", "label": "Show \"The Basics\"", "default": true },
    { "type": "richtext", "id": "scientific_body", "label": "Scientific Overview (body)", "default": "<p><strong>Compound:</strong> β‑phenyl‑γ‑aminobutyric acid. The phenyl ring helps it cross the blood–brain barrier more readily than GABA itself. Primary action is at <strong>GABA‑B receptors</strong>, which can moderate excitability and promote relaxation. Onset is typically 1–3 hours with effects that may last several hours; timing varies by form and individual. Common forms: <strong>HCl</strong> (highly water‑soluble; faster to mix) and <strong>FAA</strong> (free amino acid; neutral taste when encapsulated). Avoid combining with alcohol, benzodiazepines, or other sedatives.</p><ul><li><strong>Mechanism:</strong> GABA‑B receptor agonism (with minimal GABA‑A activity).</li><li><strong>Rationale:</strong> Phenyl group increases lipophilicity (BBB permeability).</li><li><strong>Forms:</strong> FAA vs HCl differ mainly in solubility and handling; potency per mg can feel similar when dosed equivalently.</li></ul><p><em>Informational only. Not medical advice.</em></p>" },
    { "type": "checkbox", "id": "scientific_collapsed", "label": "Start \"Scientific Overview\" collapsed", "default": true },
    { "type": "image_picker", "id": "molecule_image", "label": "Infographic / Molecule image" },
    { "type": "text", "id": "molecule_alt", "label": "Image alt text", "default": "Phenibut molecule diagram" },
    { "type": "checkbox", "id": "molecule_decorative", "label": "Mark image decorative (hides from screen readers)", "default": false },
    { "type": "checkbox", "id": "hide_image_mobile", "label": "Hide image on mobile", "default": false },
    { "type": "range", "id": "max_width", "label": "Max content width (px)", "min": 720, "max": 1400, "step": 20, "default": 1200 },
    { "type": "checkbox", "id": "center_on_mobile", "label": "Center text on mobile", "default": false },
    { "type": "checkbox", "id": "show_note", "label": "Show disclaimer note", "default": true },
    { "type": "textarea", "id": "note_text", "label": "Disclaimer note text", "default": "This content is educational and not medical advice. Phenibut is for adult, occasional use only. Do not combine with alcohol or sedatives. Use responsibly." },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding top", "default": 40 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding bottom", "default": 40 }
  ],
  "blocks": [
    {
      "type": "bullet",
      "name": "Basics bullet",
      "settings": [
        { "type": "text", "id": "text", "label": "Bullet text", "default": "Helps you feel calm and at ease." }
      ]
    },
    { "type": "@app" }
  ],
  "max_blocks": 8,
  "presets": [
    { "name": "What is Phenibut" }
  ]
}
{% endschema %}
