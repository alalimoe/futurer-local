{%- style -%}
  .xo-section--{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .xo-section--{{ section.id }} .ft__wrap {
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 8%, transparent);
    border-radius: var(--general-radius-3, 2rem);
    padding: 20px;
  }

  .xo-section--{{ section.id }} .ft__title {
    margin: 0 0 10px;
    font-size: clamp(1.1rem, 2vw, 1.35rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    color: rgba(var(--color-foreground));
  }

  .xo-section--{{ section.id }} .ft__tabs {
    display: inline-flex;
    gap: 8px;
    margin-bottom: 14px;
  }

  .xo-section--{{ section.id }} .ft__tab {
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 12%, transparent);
    background: rgba(var(--color-background));
    border-radius: var(--button-radius);
    padding: 8px 14px;
    min-height: 44px;
    box-sizing: border-box;
    cursor: pointer;
    font-size: clamp(0.8rem, 1.2vw, 0.875rem);
    display: inline-flex;
    align-items: center;
    color: rgba(var(--color-foreground));
    transition: border-color 0.3s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .ft__tab:hover {
    border-color: rgba(var(--color-accent));
  }

  .xo-section--{{ section.id }} .ft__tab:focus-visible {
    outline: 2px solid rgba(var(--color-accent));
    outline-offset: 2px;
  }

  .xo-section--{{ section.id }} .ft__tab--active {
    border-color: rgba(var(--color-accent));
    font-weight: 600;
    background: color-mix(in srgb, rgba(var(--color-accent)) 8%, transparent);
  }

  .xo-section--{{ section.id }} .ft__panel[hidden] {
    display: none;
  }

  .xo-section--{{ section.id }} .ft__label {
    display: block;
    margin-bottom: 6px;
    font-size: clamp(0.8rem, 1.2vw, 0.875rem);
    color: color-mix(in srgb, rgba(var(--color-foreground)) 55%, transparent);
  }

  .xo-section--{{ section.id }} .ft__row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 8px;
    align-items: center;
  }

  .xo-section--{{ section.id }} .ft__input {
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 12%, transparent);
    border-radius: var(--general-radius-1, 1rem);
    padding: 10px 14px;
    width: 100%;
    min-height: 44px;
    box-sizing: border-box;
    font-size: clamp(0.85rem, 1.3vw, 0.9375rem);
    background: rgba(var(--color-background));
    color: rgba(var(--color-foreground));
    transition: border-color 0.3s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .ft__input:focus {
    outline: none;
    border-color: rgba(var(--color-accent));
  }

  .xo-section--{{ section.id }} .ft__input:focus-visible {
    outline: 2px solid rgba(var(--color-accent));
    outline-offset: 2px;
  }

  .xo-section--{{ section.id }} .ft__input::placeholder {
    opacity: 0.5;
  }

  .xo-section--{{ section.id }} .ft__btn {
    border: none;
    border-radius: var(--general-radius-1, 1rem);
    padding: 10px 16px;
    min-height: 44px;
    background: rgba(var(--color-foreground));
    color: rgba(var(--color-background));
    font-size: clamp(0.8rem, 1.2vw, 0.875rem);
    font-weight: 600;
    cursor: pointer;
    white-space: nowrap;
    transition: opacity 0.3s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .ft__btn:hover {
    opacity: 0.85;
  }

  .xo-section--{{ section.id }} .ft__btn:focus-visible {
    outline: 2px solid rgba(var(--color-accent));
    outline-offset: 2px;
  }

  .xo-section--{{ section.id }} .ft__hint {
    font-size: clamp(0.65rem, 1vw, 0.75rem);
    color: color-mix(in srgb, rgba(var(--color-foreground)) 55%, transparent);
    margin-top: 8px;
  }

  @media (prefers-reduced-motion: reduce) {
    .xo-section--{{ section.id }} .ft__tab,
    .xo-section--{{ section.id }} .ft__input,
    .xo-section--{{ section.id }} .ft__btn {
      transition: none;
    }
  }
{%- endstyle -%}

<section {% render 'section-attr' %}>
  <xo-container>
    <div class="ft__wrap">
      <h2 class="ft__title">{{ section.settings.heading }}</h2>

      <div class="ft__tabs" role="tablist" aria-label="Tracking type">
        <button class="ft__tab ft__tab--active" data-tab="local" role="tab" aria-selected="true">Dubai / UAE (Quiqup)</button>
        <button class="ft__tab" data-tab="intl" role="tab" aria-selected="false">International (DHL)</button>
      </div>

      <div class="ft__panel ft__panel--active" data-panel="local" role="tabpanel">
        <label for="ftLocalRef-{{ section.id }}" class="ft__label">Enter your Quiqup reference or order number</label>
        <div class="ft__row">
          <input id="ftLocalRef-{{ section.id }}" type="text" class="ft__input" placeholder="{{ section.settings.local_placeholder }}">
          <button class="ft__btn" data-track="local">Track with Quiqup</button>
        </div>
        <p class="ft__hint">We'll open Quiqup's tracking page in a new tab. If asked, paste your reference number to see live status.</p>
      </div>

      <div class="ft__panel" data-panel="intl" role="tabpanel" hidden>
        <label for="ftIntlRef-{{ section.id }}" class="ft__label">Enter your DHL waybill / tracking number</label>
        <div class="ft__row">
          <input id="ftIntlRef-{{ section.id }}" type="text" class="ft__input" placeholder="{{ section.settings.intl_placeholder }}">
          <button class="ft__btn" data-track="intl">Track with DHL</button>
        </div>
        <p class="ft__hint">You'll be taken to DHL's tracking page with your number applied.</p>
      </div>
    </div>
  </xo-container>
</section>

<script>
  (function(){
    var section = document.querySelector('.xo-section--{{ section.id }}');
    if (!section) return;

    var tabs = section.querySelectorAll('.ft__tab');
    var panels = section.querySelectorAll('.ft__panel');

    tabs.forEach(function(t){
      t.addEventListener('click', function(){
        var key = t.getAttribute('data-tab');
        tabs.forEach(function(x){
          var active = x.getAttribute('data-tab') === key;
          x.classList.toggle('ft__tab--active', active);
          x.setAttribute('aria-selected', active);
        });
        panels.forEach(function(p){
          var active = p.getAttribute('data-panel') === key;
          p.toggleAttribute('hidden', !active);
        });
      });
    });

    section.querySelector('[data-track="local"]')?.addEventListener('click', function(){
      var ref = section.querySelector('[id^="ftLocalRef"]').value.trim();
      if (ref) { navigator.clipboard?.writeText(ref).catch(function(){}); }
      window.open('https://track-parcel.quiqup.com/', '_blank', 'noopener');
    });

    section.querySelector('[data-track="intl"]')?.addEventListener('click', function(){
      var id = section.querySelector('[id^="ftIntlRef"]').value.trim();
      if (!id) return;
      window.open('https://www.dhl.com/global-en/home/tracking/tracking-express.html?submit=1&tracking-id=' + encodeURIComponent(id), '_blank', 'noopener');
    });
  })();
</script>

{% schema %}
{
  "name": "FAQ Tracking Widget",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "default" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Track your delivery" },
    { "type": "text", "id": "local_placeholder", "label": "Local placeholder", "default": "e.g., QUIQUP-REF-1234" },
    { "type": "text", "id": "intl_placeholder", "label": "International placeholder", "default": "e.g., DHL 10-digit waybill" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding top", "default": 8 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding bottom", "default": 16 }
  ],
  "presets": [{ "name": "FAQ Tracking Widget" }]
}
{% endschema %}
