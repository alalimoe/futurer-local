{% comment %} Labs — B2B benefits grid (4-up) {% endcomment %}
{%- assign sid = section.id | replace:'_','' | downcase -%}
<style>
#lbg-{{ sid }}{ --b:#E7E9ED; --text:#111; }
#lbg-{{ sid }} .g-wrap{ padding:24px var(--page-gutter); border-top:1px solid var(--b); background:#FAFAFB; }
#lbg-{{ sid }} .g-container{ max-width:{{ section.settings.maxw | default:1200 }}px; margin:0 auto; }
#lbg-{{ sid }} .g-title{ margin:0 0 10px; font-weight:800; color:var(--text); }
#lbg-{{ sid }} .g-grid{ display:grid; gap:14px; grid-template-columns:repeat(2,1fr); }
@media(max-width:780px){ #lbg-{{ sid }} .g-grid{ grid-template-columns:1fr; } }
#lbg-{{ sid }} .card{ border:1px solid var(--b); border-radius:var(--nx-radius); background:#fff; padding:14px; display:flex; gap:10px; }
#lbg-{{ sid }} .ico{ width:28px; height:28px; color:var(--color-text-primary); flex:0 0 28px; }
#lbg-{{ sid }} .name{ margin:0 0 4px; font-weight:800; }
#lbg-{{ sid }} .txt{ color:#374151; }
</style>

<section id="lbg-{{ sid }}" class="pdp-section" aria-label="B2B benefits">
  <div class="g-wrap">
    <div class="g-container">
      <h2 class="g-title">{{ section.settings.title | default: 'B2B Benefits' }}</h2>
      <div class="g-grid">
        {% for i in (1..4) %}
          {% assign t_key = 't' | append:i %}
          {% assign d_key = 'd' | append:i %}
          {% assign t = section.settings[t_key] %}
          {% assign d = section.settings[d_key] %}
          <article class="card">
            <span class="ico" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.6"/><path d="M12 7v5l3 3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg></span>
            <div>
              <h3 class="name">{{ t }}</h3>
              <p class="txt">{{ d }}</p>
            </div>
          </article>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name":"Labs · Benefits grid",
  "settings":[
    { "type":"range","id":"maxw","min":800,"max":1600,"step":10,"unit":"px","label":"Max width","default":1200 },
    { "type":"text","id":"title","label":"Heading","default":"B2B Benefits" },
    { "type":"text","id":"t1","label":"Card 1 title","default":"Batch Documentation" },
    { "type":"text","id":"d1","label":"Card 1 summary","default":"Access downloadable COAs, FTIR & HPLC data." },
    { "type":"text","id":"t2","label":"Card 2 title","default":"Cold Chain Integrity" },
    { "type":"text","id":"d2","label":"Card 2 summary","default":"Temperature-controlled shipping ensures stability." },
    { "type":"text","id":"t3","label":"Card 3 title","default":"Volume Discounts" },
    { "type":"text","id":"d3","label":"Card 3 summary","default":"Save on 10+ vials or recurring orders." },
    { "type":"text","id":"t4","label":"Card 4 title","default":"Lab Partnerships" },
    { "type":"text","id":"d4","label":"Card 4 summary","default":"Custom peptides & formulations available on request." }
  ],
  "presets":[{ "name":"Labs · Benefits grid" }]
}
{% endschema %}
