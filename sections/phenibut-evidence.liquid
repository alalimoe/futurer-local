{% comment %}
  Evidence Snapshot — XO theme design system
  - Simple/Scientific toggle, reference chips, reduced-motion
{% endcomment %}

{%- style -%}
  .xo-section--{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .xo-section--{{ section.id }} .phb-evidence__title {
    font-size: clamp(22px, 4.2vw, 36px);
    line-height: 1.2;
    margin: 0;
    color: rgba(var(--color-foreground));
    font-weight: 600;
  }

  .xo-section--{{ section.id }} .phb-evidence__tldr {
    color: rgba(var(--color-foreground));
    line-height: 1.7;
    margin-top: 14px;
  }

  .xo-section--{{ section.id }} .phb-evidence__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin: 18px 0 0;
    list-style: none;
    padding: 0;
  }

  .xo-section--{{ section.id }} .phb-evidence__chip {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 10px;
    border-radius: var(--button-radius, 10rem);
    background: rgba(var(--color-background-2));
    color: rgba(var(--color-foreground));
    text-decoration: none;
    font-weight: 600;
    font-size: 14px;
    transition: opacity 0.3s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .phb-evidence__chip:hover {
    opacity: 0.85;
  }

  .xo-section--{{ section.id }} .phb-evidence__chip:focus-visible {
    outline: 2px solid rgba(var(--color-accent));
    outline-offset: 2px;
  }

  .xo-section--{{ section.id }} .phb-evidence__note {
    font-size: 13px;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent);
    margin-top: 4px;
  }

  @media (prefers-reduced-motion: reduce) {
    .xo-section--{{ section.id }} *,
    .xo-section--{{ section.id }} *::before,
    .xo-section--{{ section.id }} *::after {
      animation-duration: 0.01ms !important;
      transition-duration: 0.01ms !important;
    }
  }
{%- endstyle -%}

<section {% render 'section-attr' %} aria-labelledby="phb-evidence-title-{{ section.id }}">
  <xo-container>
    <h2 id="phb-evidence-title-{{ section.id }}" class="phb-evidence__title">{{ section.settings.heading | escape }}</h2>

    <div class="phb-evidence__tldr">
      {% if section.settings.phrasing_mode == 'simple' %}
        {{ section.settings.simple_copy }}
      {% else %}
        {{ section.settings.scientific_copy }}
      {% endif %}
    </div>

    {% if section.blocks.size > 0 %}
      <ul class="phb-evidence__chips" role="list">
        {% for block in section.blocks %}
          {% if block.type == 'ref' %}
            <li {{ block.shopify_attributes }}>
              <a class="phb-evidence__chip" href="{{ block.settings.href | escape }}" target="_blank" rel="noopener noreferrer">
                {{ block.settings.label | escape }}
              </a>
            </li>
          {% endif %}
        {% endfor %}
      </ul>
    {% endif %}

    {% if section.settings.note != blank %}
      <p class="phb-evidence__note">{{ section.settings.note }}</p>
    {% endif %}
  </xo-container>
</section>

{% schema %}
{
  "name": "Evidence",
  "tag": "section",
  "class": "section-phenibut-evidence",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "default" },
    { "type": "text", "id": "anchor_id", "label": "Anchor ID", "default": "evidence" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Evidence Snapshot" },
    { "type": "radio", "id": "phrasing_mode", "label": "Phrasing", "default": "simple", "options": [ { "value": "simple", "label": "Simple" }, { "value": "scientific", "label": "Scientific" } ] },
    { "type": "richtext", "id": "simple_copy", "label": "Simple copy", "default": "<p>Small human studies and user reports suggest calming effects and improved sleep when used occasionally and responsibly.</p>" },
    { "type": "richtext", "id": "scientific_copy", "label": "Scientific copy", "default": "<p>Phenibut (β‑phenyl‑GABA) is reported to act as a GABA‑B agonist; limited clinical literature suggests anxiolytic and sleep‑modulating properties. Evidence quality varies; careful dosing is essential.</p>" },
    { "type": "text", "id": "note", "label": "Footnote", "default": "Educational only; not medical advice." },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding top", "default": 40 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding bottom", "default": 40 }
  ],
  "blocks": [
    { "type": "ref", "name": "Reference chip", "settings": [
      { "type": "text", "id": "label", "label": "Label", "default": "PubMed" },
      { "type": "text", "id": "href", "label": "URL", "default": "https://pubmed.ncbi.nlm.nih.gov/" }
    ] },
    { "type": "@app" }
  ],
  "max_blocks": 12,
  "presets": [ { "name": "Evidence" } ]
}
{% endschema %}
