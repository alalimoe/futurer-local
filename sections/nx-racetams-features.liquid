{% comment %} Nootropix — Product Features (Premium) {% endcomment %}
{%- assign sid = section.id -%}

{%- style -%}
#nx-feat-{{ sid }} {
  --nx-accent: var(--color-accent-primary, #FBBF24);
  --nx-accent-hover: var(--color-accent-hover, #D97706);
  --nx-accent-dark: var(--color-accent-dark, #92400e);
  --nx-accent-glass: rgba(251, 191, 36, 0.06);
  --nx-text: var(--color-text-main, #111827);
  --nx-muted: var(--color-text-muted, #4b5563);
  --nx-radius: var(--radius-premium, 14px);
  --nx-transition: var(--transition-premium, all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1));
  --nx-shadow-rest: var(--shadow-sm, 0 2px 8px rgba(0,0,0,0.04));
  --nx-shadow-hover: var(--shadow-md, 0 12px 30px rgba(0,0,0,0.06));
  --nx-gold-glow: var(--shadow-gold-glow, 0 4px 14px rgba(251,191,36,0.25));
  --nx-font: var(--font-body-family, sans-serif);
  --nx-font-heading: var(--font-heading-family, sans-serif);

  max-width: var(--container-width-large);
  margin: 0 auto;
  padding: 8px var(--page-gutter);
  font-family: var(--nx-font);
  color: var(--nx-text);
  content-visibility: auto;
}

#nx-feat-{{ sid }} h2 {
  font-family: var(--nx-font-heading);
  font-size: clamp(22px, 3vw, 30px);
  font-weight: 700;
  line-height: 1.2;
  margin: 0 0 20px;
}

#nx-feat-{{ sid }} .nx-grid {
  display: grid;
  gap: 20px;
}
@media (min-width: 860px) {
  #nx-feat-{{ sid }} .nx-grid { grid-template-columns: 1fr 1fr; }
}

#nx-feat-{{ sid }} .nx-card {
  border: 1px solid transparent;
  border-radius: var(--nx-radius);
  padding: 20px 22px;
  background: #fff;
  box-shadow: var(--nx-shadow-rest);
  transition: var(--nx-transition);
  display: flex;
  flex-direction: column;
}
#nx-feat-{{ sid }} .nx-grid:hover .nx-card:not(:hover) {
  opacity: 0.65;
}
#nx-feat-{{ sid }} .nx-card:hover {
  transform: translateY(-4px);
  box-shadow: var(--nx-shadow-hover);
}

#nx-feat-{{ sid }} .nx-card h3 {
  font-family: var(--nx-font-heading);
  font-size: 18px;
  font-weight: 700;
  margin: 0 0 4px;
  color: var(--nx-text);
}

#nx-feat-{{ sid }} .nx-tags {
  font-size: 11px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: var(--nx-accent-dark);
  margin-bottom: 8px;
}

#nx-feat-{{ sid }} .nx-card p {
  color: var(--nx-muted);
  font-size: 14px;
  line-height: 1.7;
  margin: 0 0 12px;
}

#nx-feat-{{ sid }} .nx-card ul {
  list-style: none;
  padding: 0;
  margin: 0 0 auto;
  display: flex;
  flex-direction: column;
  gap: 6px;
}

#nx-feat-{{ sid }} .nx-card li {
  font-size: 13px;
  color: var(--nx-muted);
  padding: 6px 10px;
  border-radius: var(--nx-radius-sm);
  background: rgba(249, 250, 251, 0.65);
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
}
#nx-feat-{{ sid }} .nx-card li strong { color: var(--nx-text); }

#nx-feat-{{ sid }} .nx-btnrow {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
  margin-top: 16px;
}

#nx-feat-{{ sid }} .nx-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8px 14px;
  border-radius: var(--nx-radius-md);
  font-size: 13px;
  font-weight: 600;
  text-decoration: none;
  min-height: 40px;
  border: 1.5px solid var(--nx-accent);
  background: transparent;
  color: var(--nx-text);
  transition: var(--nx-transition);
}
#nx-feat-{{ sid }} .nx-btn:hover {
  background: var(--nx-accent);
  color: var(--color-text-primary);
  transform: translateY(-1px);
  box-shadow: var(--nx-gold-glow);
}
#nx-feat-{{ sid }} .nx-btn:active { transform: scale(0.98); }

#nx-feat-{{ sid }} .nx-btn.primary {
  background: var(--nx-accent);
  border-color: var(--nx-accent);
  color: var(--color-text-primary);
  box-shadow: var(--nx-gold-glow);
}
#nx-feat-{{ sid }} .nx-btn.primary:hover {
  background: var(--nx-accent-hover);
  border-color: var(--nx-accent-hover);
  box-shadow: 0 8px 24px rgba(251,191,36,0.35);
}

#nx-feat-{{ sid }} a:focus-visible {
  outline: 2px solid var(--nx-accent);
  outline-offset: 2px;
}

@media (prefers-reduced-motion: reduce) {
  #nx-feat-{{ sid }},
  #nx-feat-{{ sid }} * {
    transition: none !important;
    animation: none !important;
    transform: none !important;
  }
  #nx-feat-{{ sid }} .nx-grid:hover .nx-card:not(:hover) { opacity: 1; }
}
{%- endstyle -%}

<section id="nx-feat-{{ sid }}" aria-label="Products in focus">
  <h2>Products in Focus</h2>
  <div class="nx-grid">
    {% for block in section.blocks %}
      {%- assign cap = block.settings.caps_product -%}
      {%- assign pow = block.settings.powder_product -%}
      <article class="nx-card" {{ block.shopify_attributes }}>
        <h3>{{ block.settings.title }}</h3>
        <div class="nx-tags">{{ block.settings.best_for }}</div>
        <p>{{ block.settings.body }}</p>
        <ul>
          {% if block.settings.solubility != blank %}<li><strong>Solubility:</strong> {{ block.settings.solubility }}</li>{% endif %}
          {% if block.settings.onset != blank %}<li><strong>Onset/Duration:</strong> {{ block.settings.onset }}</li>{% endif %}
          {% if block.settings.stack_tip != blank %}<li><strong>Stack tip:</strong> {{ block.settings.stack_tip }}</li>{% endif %}
          {% if block.settings.athlete_note %}<li><strong>Athlete note:</strong> Check federation rules before use.</li>{% endif %}
        </ul>
        <div class="nx-btnrow">
          {% if cap != blank %}<a class="nx-btn primary" href="{{ cap.url }}">Shop Capsules</a>{% endif %}
          {% if pow != blank %}<a class="nx-btn" href="{{ pow.url }}">Shop Powder</a>{% endif %}
        </div>
      </article>
    {% endfor %}
  </div>
</section>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Racetam Products in Focus",
  "numberOfItems": {{ section.blocks.size }},
  "itemListElement": [
    {%- for block in section.blocks -%}
    {
      "@type": "ListItem",
      "position": {{ forloop.index }},
      "name": {{ block.settings.title | json }},
      "description": {{ block.settings.body | json }}
    }{%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
  ]
}
</script>

{% schema %}
{
  "name": "NX — Product Features",
  "settings": [],
  "blocks": [
    {
      "type": "racetam",
      "name": "Racetam Feature",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Aniracetam" },
        { "type": "text", "id": "best_for", "label": "Best for (tagline)", "default": "Fast focus + mood support; creative sprints" },
        { "type": "textarea", "id": "body", "label": "Body", "default": "Quick switch-on without harshness. Great for brainstorming, writing, and social cognition." },
        { "type": "text", "id": "solubility", "label": "Solubility", "default": "Fat-soluble (take with light dietary fat)" },
        { "type": "text", "id": "onset", "label": "Onset/Duration", "default": "30-60 min / 2-4 h" },
        { "type": "text", "id": "stack_tip", "label": "Stack tip", "default": "Pair with CDP-Choline; L-Theanine for extra composure" },
        { "type": "checkbox", "id": "athlete_note", "label": "Show athlete note (Phenylpiracetam class)", "default": false },
        { "type": "product", "id": "caps_product", "label": "Capsules product (optional)" },
        { "type": "product", "id": "powder_product", "label": "Powder product (optional)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "NX — Product Features (In-Stock)",
      "blocks": [
        { "type": "racetam", "settings": { "title": "Aniracetam", "best_for": "Fast focus + mood support", "body": "Noticeable clarity and smoother mood tone. Ideal for creative ideation and short sprints.", "solubility": "Fat-soluble", "onset": "30-60 min / 2-4 h", "stack_tip": "Pair with CDP-Choline" } },
        { "type": "racetam", "settings": { "title": "Fasoracetam", "best_for": "Calm, clean focus", "body": "Composed attention without a buzzy feel. Good for reading and analysis.", "solubility": "Water-soluble", "onset": "30-60 min / 2-4 h", "stack_tip": "Alpha-GPC or CDP-Choline" } },
        { "type": "racetam", "settings": { "title": "Phenylpiracetam Hydrazide", "best_for": "Peak-demand days", "body": "Clean drive and task initiation when stakes are high. Use selectively.", "solubility": "Varies by user", "onset": "30-60 min / 3-5 h", "stack_tip": "Pair with Alpha-GPC", "athlete_note": true } },
        { "type": "racetam", "settings": { "title": "Pramiracetam", "best_for": "Long study blocks & retention", "body": "Lock-in feel for complex material over hours.", "solubility": "More lipophilic", "onset": "60-120 min / 5-8+ h", "stack_tip": "Pair with CDP-Choline; consider Lion's Mane" } },
        { "type": "racetam", "settings": { "title": "Aniracetam Powder", "best_for": "Flexible dosing for creative sprints", "body": "Powder format for fine-tuning dose and timing.", "solubility": "Fat-soluble", "onset": "30-60 min / 2-4 h", "stack_tip": "CDP-Choline" } },
        { "type": "racetam", "settings": { "title": "Phenylpiracetam Hydrazide Powder", "best_for": "Peak-day titration", "body": "Powder format helps match dose to task intensity.", "solubility": "—", "onset": "30-60 min / 3-5 h", "stack_tip": "Alpha-GPC", "athlete_note": true } },
        { "type": "racetam", "settings": { "title": "Pramiracetam Powder", "best_for": "Extended study blocks", "body": "Powder format for longer sessions and retention.", "solubility": "Lipophilic", "onset": "60-120 min / 5-8+ h", "stack_tip": "CDP-Choline" } }
      ]
    }
  ]
}
{% endschema %}
