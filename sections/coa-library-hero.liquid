{%- style -%}
  .xo-section--{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .xo-section--{{ section.id }} .clh-inner {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }

  .xo-section--{{ section.id }} .clh-trust {
    display: flex;
    justify-content: center;
    gap: 10px;
    flex-wrap: wrap;
    margin-bottom: 24px;
  }

  .xo-section--{{ section.id }} .clh-trust-pill {
    display: inline-flex;
    align-items: center;
    font-size: 0.8125rem;
    font-weight: 600;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent);
    background: rgba(var(--color-background));
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
    border-radius: var(--button-radius, 10rem);
    padding: 6px 14px;
  }

  .xo-section--{{ section.id }} .clh-title {
    font-size: calc(var(--font-size-h1) * var(--scale-h1, 1));
    font-weight: 600;
    letter-spacing: -0.02em;
    color: rgba(var(--color-foreground));
    margin: 0 0 20px;
    line-height: 1.1;
  }

  .xo-section--{{ section.id }} .clh-subtitle {
    font-size: clamp(1rem, 1.5vw, 1.1875rem);
    line-height: 1.7;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent);
    margin: 0 0 32px;
    max-width: 660px;
    margin-inline: auto;
  }

  .xo-section--{{ section.id }} .clh-bullets {
    list-style: none;
    padding: 0;
    margin: 0 auto 36px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    max-width: 520px;
    text-align: left;
  }

  .xo-section--{{ section.id }} .clh-bullet {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 1rem;
    color: rgba(var(--color-foreground));
    line-height: 1.5;
  }

  .xo-section--{{ section.id }} .clh-bullet-icon {
    flex-shrink: 0;
    color: rgba(var(--color-accent));
    margin-top: 2px;
  }

  .xo-section--{{ section.id }} .clh-ctas {
    display: flex;
    justify-content: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .xo-section--{{ section.id }} .clh-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 0.75rem 1.5rem;
    font-size: 0.9375rem;
    font-weight: 600;
    border-radius: var(--button-radius, 10rem);
    text-decoration: none;
    transition: opacity 0.3s var(--out-soft, ease), border-color 0.3s var(--out-soft, ease);
    cursor: pointer;
    border: none;
  }

  .xo-section--{{ section.id }} .clh-btn--primary {
    background: rgba(var(--color-accent));
    color: rgba(var(--color-foreground));
  }

  .xo-section--{{ section.id }} .clh-btn--primary:hover {
    opacity: 0.85;
  }

  .xo-section--{{ section.id }} .clh-btn--secondary {
    background: rgba(var(--color-background));
    color: rgba(var(--color-foreground));
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
  }

  .xo-section--{{ section.id }} .clh-btn--secondary:hover {
    border-color: rgba(var(--color-accent));
  }

  .xo-section--{{ section.id }} :focus-visible {
    outline: 2px solid rgba(var(--color-accent));
    outline-offset: 2px;
  }

  @media (max-width: 768px) {
    .xo-section--{{ section.id }} .clh-inner {
      padding: 0;
    }

    .xo-section--{{ section.id }} .clh-ctas {
      flex-direction: column;
      align-items: center;
    }

    .xo-section--{{ section.id }} .clh-btn {
      width: 100%;
      max-width: 320px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .xo-section--{{ section.id }} .clh-btn {
      transition: none;
    }
  }
{%- endstyle -%}

{%- comment -%} ── JSON-LD: WebPage + BreadcrumbList ── {%- endcomment -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "name": {{ section.settings.heading | json }},
      "description": {{ section.settings.subheading | json }},
      "url": "{{ request.origin }}{{ request.path }}",
      "publisher": {
        "@type": "Organization",
        "name": "Nootropix",
        "url": "{{ shop.url }}"
      },
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": "{{ shop.url }}" },
          { "@type": "ListItem", "position": 2, "name": "Quality & Trust", "item": "{{ shop.url }}/pages/quality-coa-library" },
          { "@type": "ListItem", "position": 3, "name": {{ section.settings.heading | json }}, "item": "{{ request.origin }}{{ request.path }}" }
        ]
      }
    }
  ]
}
</script>

<section {% render 'section-attr' %}>
  <xo-container>
    <div class="clh-inner">

      {%- comment -%} ── Trust strip ── {%- endcomment -%}
      {% if section.settings.trust_1 != blank or section.settings.trust_2 != blank or section.settings.trust_3 != blank %}
        <div class="clh-trust">
          {% if section.settings.trust_1 != blank %}<span class="clh-trust-pill">{{ section.settings.trust_1 }}</span>{% endif %}
          {% if section.settings.trust_2 != blank %}<span class="clh-trust-pill">{{ section.settings.trust_2 }}</span>{% endif %}
          {% if section.settings.trust_3 != blank %}<span class="clh-trust-pill">{{ section.settings.trust_3 }}</span>{% endif %}
        </div>
      {% endif %}

      <h1 class="clh-title">{{ section.settings.heading }}</h1>

      {% if section.settings.subheading != blank %}
        <p class="clh-subtitle">{{ section.settings.subheading }}</p>
      {% endif %}

      {%- comment -%} ── Bullet points ── {%- endcomment -%}
      {% if section.settings.bullet_1 != blank or section.settings.bullet_2 != blank or section.settings.bullet_3 != blank %}
        <ul class="clh-bullets">
          {% if section.settings.bullet_1 != blank %}
            <li class="clh-bullet">
              <svg class="clh-bullet-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              {{ section.settings.bullet_1 }}
            </li>
          {% endif %}
          {% if section.settings.bullet_2 != blank %}
            <li class="clh-bullet">
              <svg class="clh-bullet-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              {{ section.settings.bullet_2 }}
            </li>
          {% endif %}
          {% if section.settings.bullet_3 != blank %}
            <li class="clh-bullet">
              <svg class="clh-bullet-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              {{ section.settings.bullet_3 }}
            </li>
          {% endif %}
        </ul>
      {% endif %}

      {%- comment -%} ── CTA buttons ── {%- endcomment -%}
      {% if section.settings.cta_primary_text != blank or section.settings.cta_secondary_text != blank or section.settings.cta_tertiary_text != blank %}
        <div class="clh-ctas">
          {% if section.settings.cta_primary_text != blank %}
            <a href="{{ section.settings.cta_primary_url | default: '#coa-library' }}" class="clh-btn clh-btn--primary">{{ section.settings.cta_primary_text }}</a>
          {% endif %}
          {% if section.settings.cta_secondary_text != blank %}
            <a href="{{ section.settings.cta_secondary_url | default: '#' }}" class="clh-btn clh-btn--secondary">{{ section.settings.cta_secondary_text }}</a>
          {% endif %}
          {% if section.settings.cta_tertiary_text != blank %}
            <a href="{{ section.settings.cta_tertiary_url | default: '#' }}" class="clh-btn clh-btn--secondary">{{ section.settings.cta_tertiary_text }}</a>
          {% endif %}
        </div>
      {% endif %}

    </div>
  </xo-container>
</section>

{% schema %}
{
  "name": "COA Library Hero",
  "tag": "section",
  "class": "section-coa-library-hero",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "default"
    },
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Quality & COA Library" },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "We don't ask you to \"trust us.\" We show you the batch/lot and the COA — so quality claims are verifiable, not just marketing."
    },
    { "type": "header", "content": "Bullets" },
    { "type": "text", "id": "bullet_1", "label": "Bullet 1", "default": "Batch/lot traceability (match your label to the report)" },
    { "type": "text", "id": "bullet_2", "label": "Bullet 2", "default": "Third-party analytical documentation (methods + results)" },
    { "type": "text", "id": "bullet_3", "label": "Bullet 3", "default": "UAE-aware handling (shipping heat + storage guidance)" },
    { "type": "header", "content": "Trust Signals" },
    { "type": "text", "id": "trust_1", "label": "Trust Signal 1", "default": "Independent Lab Tested" },
    { "type": "text", "id": "trust_2", "label": "Trust Signal 2", "default": "Batch-Matched Reports" },
    { "type": "text", "id": "trust_3", "label": "Trust Signal 3", "default": "UAE-Optimized Storage" },
    { "type": "header", "content": "Call to Action" },
    { "type": "text", "id": "cta_primary_text", "label": "Primary CTA Text", "default": "Browse COAs" },
    { "type": "url", "id": "cta_primary_url", "label": "Primary CTA URL" },
    { "type": "text", "id": "cta_secondary_text", "label": "Secondary CTA Text", "default": "How to Read a COA" },
    { "type": "url", "id": "cta_secondary_url", "label": "Secondary CTA URL" },
    { "type": "text", "id": "cta_tertiary_text", "label": "Tertiary CTA Text", "default": "Request a COA" },
    { "type": "url", "id": "cta_tertiary_url", "label": "Tertiary CTA URL" },
    { "type": "header", "content": "Spacing" },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 64
    }
  ],
  "blocks": [
    { "type": "@app" }
  ],
  "presets": [{ "name": "COA Library Hero" }]
}
{% endschema %}
