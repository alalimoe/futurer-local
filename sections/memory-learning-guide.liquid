{% comment %}
  =============================================
  Section: Memory & Learning Guide
  File: sections/memory-learning-guide.liquid
  Purpose: Education-first LP — CRO / SEO / UX / A11y
  Theme: Futurer 2.x (OS 2.0) — cascades from global tokens
  =============================================
{% endcomment %}

{%- assign s = section.settings -%}
{%- assign sid = section.id -%}

{%- comment -%} ── Product resolution (picker → handle → known fallback) ── {%- endcomment -%}
{%- assign product_cdp = s.cdp_product -%}
{%- if product_cdp == blank and s.cdp_handle != blank -%}
  {%- assign product_cdp = all_products[s.cdp_handle] -%}
{%- endif -%}
{%- if product_cdp == blank -%}
  {%- assign product_cdp = all_products['cdp-citicoline'] -%}
{%- endif -%}

{%- assign product_racetam = s.racetam_product -%}
{%- if product_racetam == blank and s.racetam_handle != blank -%}
  {%- assign product_racetam = all_products[s.racetam_handle] -%}
{%- endif -%}
{%- if product_racetam == blank -%}
  {%- assign product_racetam = all_products['piracetam'] -%}
{%- endif -%}

{%- assign product_lion = s.lion_product -%}
{%- if product_lion == blank and s.lion_handle != blank -%}
  {%- assign product_lion = all_products[s.lion_handle] -%}
{%- endif -%}
{%- if product_lion == blank -%}
  {%- assign product_lion = all_products['lions-mane-mushroom'] -%}
{%- endif -%}

{%- assign product_alpha = s.alpha_product -%}
{%- if product_alpha == blank and s.alpha_handle != blank -%}
  {%- assign product_alpha = all_products[s.alpha_handle] -%}
{%- endif -%}

{%- assign product_anira = s.anira_product -%}
{%- if product_anira == blank and s.anira_handle != blank -%}
  {%- assign product_anira = all_products[s.anira_handle] -%}
{%- endif -%}

{%- assign product_bacopa = s.bacopa_product -%}
{%- if product_bacopa == blank and s.bacopa_handle != blank -%}
  {%- assign product_bacopa = all_products[s.bacopa_handle] -%}
{%- endif -%}

{%- assign alt_stack = s.alt_stack_product -%}
{%- if alt_stack == blank and s.alt_stack_handle != blank -%}
  {%- assign alt_stack = all_products[s.alt_stack_handle] -%}
{%- endif -%}

{%- comment -%} ── JSON-LD: Article ── {%- endcomment -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": {{ s.hero_title | default: "Remember More. Learn Better." | json }},
  "description": {{ s.hero_subtitle | strip_html | truncate: 160 | json }},
  "author": { "@type": "Organization", "name": "Nootropix" },
  "publisher": {
    "@type": "Organization",
    "name": "Nootropix",
    "url": {{ shop.url | json }},
    "logo": {
      "@type": "ImageObject",
      "url": {{ shop.url | append: '/cdn/shop/files/nootropix-logo.png' | json }}
    }
  },
  "datePublished": {{ s.date_published | default: "2025-06-01" | json }},
  "dateModified": {{ page.updated_at | date: "%Y-%m-%d" | default: "2025-06-01" | json }},
  "mainEntityOfPage": {{ canonical_url | json }},
  "about": ["Memory", "Learning", "Nootropics", "CDP-Choline", "Piracetam", "Lion's Mane"]
}
</script>

{%- comment -%} ── JSON-LD: ItemList (3 primary stack products) ── {%- endcomment -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Memory & Learning Stack",
  "numberOfItems": 3,
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "CDP-Choline (Citicoline)", "description": "A choline donor that supports acetylcholine — key for attention and memory processes." },
    { "@type": "ListItem", "position": 2, "name": "Piracetam / Aniracetam", "description": "Common in study routines among nootropics enthusiasts for learning support." },
    { "@type": "ListItem", "position": 3, "name": "Lion's Mane Mushroom", "description": "A daily staple for long-term brain support; often chosen for memory and learning habits." }
  ]
}
</script>

{%- comment -%} ── JSON-LD: FAQPage (dynamic from blocks) ── {%- endcomment -%}
{%- assign faq_blocks = section.blocks | where: 'type', 'faq' -%}
{% if faq_blocks.size > 0 %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {%- for block in faq_blocks -%}
        {
          "@type": "Question",
          "name": {{ block.settings.q | json }},
          "acceptedAnswer": { "@type": "Answer", "text": {{ block.settings.a | json }} }
        }{%- unless forloop.last -%},{%- endunless -%}
      {%- endfor -%}
    ]
  }
  </script>
{% endif %}

{%- comment -%} ── JSON-LD: HowTo ── {%- endcomment -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "Memory & Learning Routine",
  "step": [
    { "@type": "HowToStep", "name": "Choline donor", "text": "Take one choline donor (CDP-Choline or Alpha-GPC) per label, ideally in the morning or pre-study." },
    { "@type": "HowToStep", "name": "Learning support", "text": "Take one racetam (Piracetam or Aniracetam) per label during your study block." },
    { "@type": "HowToStep", "name": "Long-term support", "text": "Take Lion's Mane or Bacopa daily with food for ongoing support." }
  ]
}
</script>

{%- comment -%} ── JSON-LD: BreadcrumbList (dynamic URLs) ── {%- endcomment -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Guides", "item": {{ shop.url | append: '/pages/guides' | json }} },
    { "@type": "ListItem", "position": 2, "name": "Memory & Learning Guide", "item": {{ canonical_url | json }} }
  ]
}
</script>

<section id="memory-guide-{{ sid }}" class="ml-section" aria-labelledby="ml-title-{{ sid }}">
  <div class="ml-inner">

    {%- comment -%} ── HERO ── {%- endcomment -%}
    <header class="ml-hero">
      <div class="ml-hero-grid">
        <div class="ml-hero-content">
          <h1 id="ml-title-{{ sid }}" class="ml-hero-title">{{ s.hero_title | default: "Remember More. Learn Better." }}</h1>
          <p class="ml-hero-sub">{{ s.hero_subtitle | default: "Understand how memories form — then build a simple Memory & Learning Stack that supports encoding, consolidation, and recall." }}</p>
          <div class="ml-hero-actions">
            <a href="#memory-stack" class="btn btn--primary" aria-label="Jump to Memory & Learning Stack">Build Your Memory Stack</a>
            <span class="ml-hero-note">Education first. No hype — just clarity.</span>
          </div>
        </div>
        <div class="ml-hero-aside">
          {% if s.hero_image != blank %}
            <div class="ml-hero-img-wrap">
              <img src="{{ s.hero_image | image_url: width: 900 }}" alt="{{ s.hero_image.alt | default: 'Nootropix Memory & Learning illustration' }}" loading="eager" fetchpriority="high" width="900" height="{{ 900 | divided_by: s.hero_image.aspect_ratio | round }}">
            </div>
          {% else %}
            <div class="ml-science-card">
              <span class="ml-chip">How memory works</span>
              <p class="ml-science-text">New information is <em>encoded</em>, then <em>consolidated</em> during rest and sleep, and later <em>recalled</em>. Daily habits and the right nutrients can support each phase.</p>
              <ul class="ml-check-list">
                <li>Choline donors support acetylcholine — important for attention and memory.</li>
                <li>Some people choose racetams in study routines for learning support.</li>
                <li>Lion's Mane is often used long-term for brain support.</li>
                <li>Sleep &amp; spaced repetition make the gains stick.</li>
              </ul>
            </div>
          {% endif %}
        </div>
      </div>
    </header>

    {%- comment -%} ── EDUCATION ── {%- endcomment -%}
    <div class="ml-edu-grid" aria-label="Education">
      <div class="ml-card">
        <span class="ml-kicker">Why memory feels slippery</span>
        <h2 class="ml-heading">It's not a failing — it's friction.</h2>
        <p class="ml-body-muted">Overload, poor sleep, and stress make it harder to encode new info. Your brain isn't broken — it's buffering. The fix: reduce noise, support attention chemistry, and protect consolidation time.</p>
        <div class="ml-banner">
          <strong>Make it stick:</strong> short active recall sessions (2-5 minutes), spaced reviews, and consistent sleep. Supplements work best on that foundation.
        </div>
      </div>
      <div class="ml-card">
        <span class="ml-kicker">How this guide helps</span>
        <h3 class="ml-heading">A simple 3-part Memory Stack</h3>
        <p class="ml-body-muted">Attention in &rarr; learning during &rarr; memory kept.</p>
        <ul class="ml-check-list">
          <li><strong>Memory Chemistry:</strong> CDP-Choline (Citicoline) to support acetylcholine for attention and memory tasks.</li>
          <li><strong>Learning Support:</strong> Piracetam (or Aniracetam) is commonly used by enthusiasts during study periods.</li>
          <li><strong>Long-Term Support:</strong> Lion's Mane — chosen by many for ongoing brain support habits.</li>
        </ul>
      </div>
    </div>

    {%- comment -%} ── 3-PRODUCT STACK GRID ── {%- endcomment -%}
    <section id="memory-stack" class="ml-stack-section" aria-label="The Memory & Learning Stack">
      <span class="ml-kicker">Your Stack</span>
      <h2 class="ml-heading">The Memory &amp; Learning Stack</h2>
      <p class="ml-body-muted">Start simple. Notice how you feel. Personalize from there.</p>

      <div class="ml-stack-grid">
        {%- comment -%} Card 1: CDP-Choline {%- endcomment -%}
        <article class="ml-product-card">
          <span class="ml-chip">Memory Chemistry</span>
          <h3 class="ml-product-title">CDP-Choline (Citicoline)</h3>
          <p class="ml-product-desc">A choline donor that supports acetylcholine — key for attention and memory processes.</p>
          {% if product_cdp != blank and product_cdp.featured_image %}
            <div class="ml-product-img">
              <img src="{{ product_cdp.featured_image | image_url: width: 600 }}" alt="{{ product_cdp.title }}" loading="lazy" width="600" height="600">
            </div>
          {% endif %}
          <div class="ml-product-footer">
            {% if product_cdp != blank %}
              <div class="ml-product-ctas">
                <a class="btn btn--ghost" href="{{ product_cdp.url }}" aria-label="View {{ product_cdp.title }}">View Product</a>
                <form method="post" action="{{ routes.cart_add_url }}">
                  <input type="hidden" name="id" value="{{ product_cdp.selected_or_first_available_variant.id }}">
                  <button type="submit" class="btn btn--primary">Add to Cart</button>
                </form>
              </div>
              <div class="ml-product-meta">From {{ product_cdp.price | money }}</div>
            {% else %}
              <div class="ml-product-ctas">
                <a class="btn btn--ghost" href="{{ routes.collections_url }}/cholinergics">Browse cholinergics</a>
              </div>
            {% endif %}
          </div>
        </article>

        {%- comment -%} Card 2: Racetam {%- endcomment -%}
        <article class="ml-product-card">
          <span class="ml-chip">Learning Support</span>
          <h3 class="ml-product-title">{{ s.racetam_title | default: "Piracetam" }}</h3>
          <p class="ml-product-desc">Common in study routines among nootropics enthusiasts. Choose Piracetam or Aniracetam based on personal preference and local regulations.</p>
          {% if product_racetam != blank and product_racetam.featured_image %}
            <div class="ml-product-img">
              <img src="{{ product_racetam.featured_image | image_url: width: 600 }}" alt="{{ product_racetam.title }}" loading="lazy" width="600" height="600">
            </div>
          {% endif %}
          <div class="ml-product-footer">
            {% if product_racetam != blank %}
              <div class="ml-product-ctas">
                <a class="btn btn--ghost" href="{{ product_racetam.url }}" aria-label="View {{ product_racetam.title }}">View Product</a>
                <form method="post" action="{{ routes.cart_add_url }}">
                  <input type="hidden" name="id" value="{{ product_racetam.selected_or_first_available_variant.id }}">
                  <button type="submit" class="btn btn--primary">Add to Cart</button>
                </form>
              </div>
              <div class="ml-product-meta">From {{ product_racetam.price | money }}</div>
            {% else %}
              <div class="ml-product-ctas">
                <a class="btn btn--ghost" href="{{ routes.collections_url }}/racetams">Browse racetams</a>
              </div>
            {% endif %}
          </div>
        </article>

        {%- comment -%} Card 3: Lion's Mane {%- endcomment -%}
        <article class="ml-product-card">
          <span class="ml-chip">Long-Term Support</span>
          <h3 class="ml-product-title">Lion's Mane Mushroom</h3>
          <p class="ml-product-desc">A daily staple for long-term brain support; often chosen for memory and learning habits.</p>
          {% if product_lion != blank and product_lion.featured_image %}
            <div class="ml-product-img">
              <img src="{{ product_lion.featured_image | image_url: width: 600 }}" alt="{{ product_lion.title }}" loading="lazy" width="600" height="600">
            </div>
          {% endif %}
          <div class="ml-product-footer">
            {% if product_lion != blank %}
              <div class="ml-product-ctas">
                <a class="btn btn--ghost" href="{{ product_lion.url }}" aria-label="View {{ product_lion.title }}">View Product</a>
                <form method="post" action="{{ routes.cart_add_url }}">
                  <input type="hidden" name="id" value="{{ product_lion.selected_or_first_available_variant.id }}">
                  <button type="submit" class="btn btn--primary">Add to Cart</button>
                </form>
              </div>
              <div class="ml-product-meta">From {{ product_lion.price | money }}</div>
            {% else %}
              <div class="ml-product-ctas">
                <a class="btn btn--ghost" href="{{ routes.collections_url }}/mushroom-extracts">Browse mushroom extracts</a>
              </div>
            {% endif %}
          </div>
        </article>
      </div>
    </section>

    {%- comment -%} ── QUICK ADD BUILDER + ALT STACK ── {%- endcomment -%}
    <div class="ml-builder-grid">
      <div class="ml-card ml-builder-main">
        <span class="ml-kicker">Quick build (no bundle)</span>
        <h2 class="ml-heading">Add Selected to Cart</h2>
        <p class="ml-body-muted">Choose one from each group below. You can always adjust quantities in the cart.</p>

        <form id="ml-multi-add-{{ sid }}" class="ml-builder-form" data-cart-url="{{ routes.cart_add_url }}.js">
          <fieldset class="ml-group">
            <legend>Choline donor</legend>
            {% if product_cdp != blank %}
              <label class="ml-radio-label">
                <input type="radio" name="choline" value="{{ product_cdp.selected_or_first_available_variant.id }}">
                <span class="ml-radio-text">{{ product_cdp.title }} — {{ product_cdp.price | money }}</span>
              </label>
            {% endif %}
            {% if product_alpha != blank %}
              <label class="ml-radio-label">
                <input type="radio" name="choline" value="{{ product_alpha.selected_or_first_available_variant.id }}">
                <span class="ml-radio-text">{{ product_alpha.title }} — {{ product_alpha.price | money }}</span>
              </label>
            {% endif %}
            {% if product_cdp == blank and product_alpha == blank %}
              <p class="ml-help">No choline donors assigned. <a href="{{ routes.collections_url }}/cholinergics">Browse cholinergics</a>.</p>
            {% else %}
              <p class="ml-help">Tip: pick one choline donor at a time.</p>
            {% endif %}
          </fieldset>

          <fieldset class="ml-group">
            <legend>Learning support</legend>
            {% if product_racetam != blank %}
              <label class="ml-radio-label">
                <input type="radio" name="racetam" value="{{ product_racetam.selected_or_first_available_variant.id }}">
                <span class="ml-radio-text">{{ product_racetam.title }} — {{ product_racetam.price | money }}</span>
              </label>
            {% endif %}
            {% if product_anira != blank %}
              <label class="ml-radio-label">
                <input type="radio" name="racetam" value="{{ product_anira.selected_or_first_available_variant.id }}">
                <span class="ml-radio-text">{{ product_anira.title }} — {{ product_anira.price | money }}</span>
              </label>
            {% endif %}
            {% if product_racetam == blank and product_anira == blank %}
              <p class="ml-help">No racetams assigned. <a href="{{ routes.collections_url }}/racetams">Browse racetams</a>.</p>
            {% endif %}
          </fieldset>

          <fieldset class="ml-group">
            <legend>Long-term support</legend>
            {% if product_lion != blank %}
              <label class="ml-radio-label">
                <input type="radio" name="longterm" value="{{ product_lion.selected_or_first_available_variant.id }}">
                <span class="ml-radio-text">{{ product_lion.title }} — {{ product_lion.price | money }}</span>
              </label>
            {% endif %}
            {% if product_bacopa != blank %}
              <label class="ml-radio-label">
                <input type="radio" name="longterm" value="{{ product_bacopa.selected_or_first_available_variant.id }}">
                <span class="ml-radio-text">{{ product_bacopa.title }} — {{ product_bacopa.price | money }}</span>
              </label>
            {% endif %}
            {% if product_lion == blank and product_bacopa == blank %}
              <p class="ml-help">No long-term picks assigned. <a href="{{ routes.collections_url }}/plant-extracts">Browse plant extracts</a>.</p>
            {% endif %}
          </fieldset>

          <div class="ml-builder-actions">
            <button type="submit" class="btn btn--primary">Add Selected</button>
            <a class="btn btn--ghost" href="{{ routes.cart_url }}">Go to Cart</a>
          </div>
          <div class="ml-kpi-row">
            <span class="ml-kpi">Ships from Dubai daily</span>
            <span class="ml-kpi">Same/next-day UAE delivery</span>
            <span class="ml-kpi">Free UAE shipping &ge; 300 AED</span>
          </div>
        </form>
      </div>

      {% if alt_stack != blank %}
        <div class="ml-card ml-alt-card">
          <span class="ml-kicker">Prefer a shortcut?</span>
          <h3 class="ml-heading">{{ s.alt_stack_title | default: "Novice Nootropic Stack" }}</h3>
          <p class="ml-body-muted">{{ s.alt_stack_blurb | default: "A simple, beginner-friendly stack for daily clarity and consistency." }}</p>
          {% if alt_stack.featured_image %}
            <div class="ml-alt-img">
              <img src="{{ alt_stack.featured_image | image_url: width: 800 }}" alt="{{ alt_stack.title }}" loading="lazy" width="800" height="800">
            </div>
          {% endif %}
          <div class="ml-product-footer">
            <div class="ml-product-ctas">
              <a class="btn btn--ghost" href="{{ alt_stack.url }}" aria-label="View {{ alt_stack.title }}">View Stack</a>
              <form method="post" action="{{ routes.cart_add_url }}">
                <input type="hidden" name="id" value="{{ alt_stack.selected_or_first_available_variant.id }}">
                <button type="submit" class="btn btn--primary">Add to Cart</button>
              </form>
            </div>
            <div class="ml-product-meta">From {{ alt_stack.price | money }}</div>
          </div>
        </div>
      {% endif %}
    </div>

    {%- comment -%} ── SUGGESTED ROUTINE (native table) ── {%- endcomment -%}
    <div class="ml-card ml-routine-card">
      <span class="ml-kicker">How to Use</span>
      <h3 class="ml-heading">Suggested Routine</h3>
      <div class="ml-table-wrap">
        <table class="ml-table" aria-label="Daily Memory & Learning Routine">
          <thead>
            <tr>
              <th scope="col">Timing</th>
              <th scope="col">What</th>
              <th scope="col">Purpose</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td data-label="Timing"><strong>Morning / pre-study</strong></td>
              <td data-label="What">1 serving choline donor (per label)</td>
              <td data-label="Purpose">Attention for learning sessions</td>
            </tr>
            <tr>
              <td data-label="Timing"><strong>Study window</strong></td>
              <td data-label="What">1 serving racetam (per label)</td>
              <td data-label="Purpose">Learning support during deep work</td>
            </tr>
            <tr>
              <td data-label="Timing"><strong>Daily</strong></td>
              <td data-label="What">Lion's Mane or Bacopa with food</td>
              <td data-label="Purpose">Long-term brain support</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="ml-routine-note">Tips: keep sessions short (25-50 min), do 2-5 min of active recall, and sleep at a consistent time to aid consolidation. Not medical advice; consult your clinician if you have a condition, are pregnant, or take medication. Check local regulations for racetams.</p>
    </div>

    {%- comment -%} ── SOCIAL PROOF ── {%- endcomment -%}
    <section aria-label="Customer testimonials">
      <span class="ml-kicker">Real routines</span>
      <h2 class="ml-heading">What customers say</h2>
      <div class="ml-testimonial-grid">
        <div class="ml-card ml-testimonial">
          <p>"Citicoline in the morning + study blocks = better recall on quizzes."</p>
          <div class="ml-testimonial-author">&mdash; S., Dubai</div>
        </div>
        <div class="ml-card ml-testimonial">
          <p>"Lion's Mane became part of my daily routine. Feels steady and sustainable."</p>
