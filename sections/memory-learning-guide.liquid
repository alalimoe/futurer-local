  display: grid;
  grid-template-rows: 0fr;
  transition: grid-template-rows 0.35s var(--ease-premium);
}
#memory-guide-{{ sid }} .ml-faq[open] .ml-faq-answer {
  grid-template-rows: 1fr;
}
#memory-guide-{{ sid }} .ml-faq-inner {
  overflow: hidden;
}
#memory-guide-{{ sid }} .ml-faq-inner p {
  padding: 0 18px 16px;
  margin: 0;
  color: var(--ml-muted);
  line-height: 1.6;
  font-size: 14px;
}

/* ═══════════════════════════════════════════════════════
   FINAL CTA
   ═══════════════════════════════════════════════════════ */
#memory-guide-{{ sid }} .ml-final-cta {
  background: var(--ml-bg-alt);
  border-radius: var(--ml-radius);
  padding: 28px 24px;
  box-shadow: var(--ml-shadow-rest);
}
#memory-guide-{{ sid }} .ml-final-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 24px;
}
@media (min-width: 900px) {
  #memory-guide-{{ sid }} .ml-final-grid { grid-template-columns: 1.2fr 0.8fr; align-items: center; }
}
#memory-guide-{{ sid }} .ml-legal {
  font-size: 12px;
  color: var(--ml-muted);
  line-height: 1.6;
  margin: 0;
}

/* ═══════════════════════════════════════════════════════
   ACCESSIBILITY — focus-visible + reduced motion
   ═══════════════════════════════════════════════════════ */
#memory-guide-{{ sid }} :focus-visible {
  outline: 2px solid var(--ml-accent);
  outline-offset: 2px;
}

@media (prefers-reduced-motion: reduce) {
  #memory-guide-{{ sid }} *,
  #memory-guide-{{ sid }} *::before,
  #memory-guide-{{ sid }} *::after {
    animation-duration: 0.01ms !important;
    transition-duration: 0.01ms !important;
  }
}
{%- endstyle -%}

