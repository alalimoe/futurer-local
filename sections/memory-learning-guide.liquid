{%- comment -%} Multi-add script (progressive enhancement) {%- endcomment -%}
<script>
(function(){
  var form = document.getElementById('ml-multi-add-{{ sid }}');
  if (!form) return;
  var cartUrl = form.getAttribute('data-cart-url');

  form.addEventListener('submit', function(e){
    e.preventDefault();
    function pick(name){
      var el = form.querySelector('input[name="'+name+'"]:checked');
      return el ? el.value : null;
    }
    var items = [];
    var choline = pick('choline');
    var racetam = pick('racetam');
    var longterm = pick('longterm');
    if (choline) items.push({id: choline, quantity: 1});
    if (racetam) items.push({id: racetam, quantity: 1});
    if (longterm) items.push({id: longterm, quantity: 1});
    if (items.length === 0) { alert('Select at least one item.'); return; }

    fetch(cartUrl, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify({ items: items })
    })
    .then(function(r){ if(!r.ok) throw new Error('Add failed'); return r.json(); })
    .then(function(){ window.location.href = '/cart'; })
    .catch(function(){ alert('Could not add selected items. Please add individually.'); });
  });
})();
</script>

