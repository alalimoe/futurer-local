{%- style -%}
  .xo-section--{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .xo-section--{{ section.id }} .pg-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .xo-section--{{ section.id }} .pg-header h2 {
    font-family: var(--font-heading-family);
    font-size: clamp(1.4rem, 2.5vw, 1.75rem);
    font-weight: 600;
    margin: 0 0 10px;
    color: rgba(var(--color-foreground));
    letter-spacing: -0.025em;
    line-height: 1.2;
  }

  .xo-section--{{ section.id }} .pg-header p {
    color: color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent);
    font-size: clamp(0.875rem, 1.5vw, 1rem);
  }

  .xo-section--{{ section.id }} .pg-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }

  @media (max-width: 992px) {
    .xo-section--{{ section.id }} .pg-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .xo-section--{{ section.id }} .pg-grid {
      grid-template-columns: 1fr;
    }
  }

  .xo-section--{{ section.id }} .pg-card {
    background: rgba(var(--color-background));
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
    padding: 24px;
    border-radius: var(--general-radius-1, 1rem);
    position: relative;
    transition: border-color 0.3s var(--out-soft, ease);
    opacity: 0;
    transform: translateY(16px);
    animation: pg-reveal-{{ section.id }} 0.5s ease forwards;
    animation-delay: calc(var(--reveal-idx, 0) * 80ms);
  }

  .xo-section--{{ section.id }} .pg-card:hover {
    border-color: rgba(var(--color-accent));
  }

  .xo-section--{{ section.id }} .pg-number {
    width: 32px;
    height: 32px;
    background: rgba(var(--color-accent));
    color: rgba(var(--color-foreground));
    font-weight: 600;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 16px;
    font-size: 13px;
  }

  .xo-section--{{ section.id }} .pg-card h3 {
    font-family: var(--font-heading-family);
    font-weight: 600;
    font-size: clamp(0.95rem, 1.5vw, 1.125rem);
    margin: 0 0 8px;
    color: rgba(var(--color-foreground));
    letter-spacing: -0.01em;
  }

  .xo-section--{{ section.id }} .pg-card p {
    font-size: clamp(0.8rem, 1.2vw, 0.875rem);
    color: color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent);
    line-height: 1.55;
    margin: 0;
  }

  @keyframes pg-reveal-{{ section.id }} {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .xo-section--{{ section.id }} *,
    .xo-section--{{ section.id }} *::before,
    .xo-section--{{ section.id }} *::after {
      animation-duration: 0.01ms !important;
      transition-duration: 0.01ms !important;
    }

    .xo-section--{{ section.id }} .pg-card {
      opacity: 1;
      transform: none;
    }
  }
{%- endstyle -%}

<section {% render 'section-attr' %}>
  <xo-container>
    <div class="pg-header">
      <h2>Reconstitution Protocol</h2>
      <p>Follow these standard laboratory procedures for optimal stability.</p>
    </div>

    <div class="pg-grid">
      {% for block in section.blocks %}
        {% if block.type == 'step' %}
          <div class="pg-card" style="--reveal-idx: {{ forloop.index0 }};" {{ block.shopify_attributes }}>
            <div class="pg-number">{{ forloop.index }}</div>
            <h3>{{ block.settings.title }}</h3>
            <p>{{ block.settings.text }}</p>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </xo-container>
</section>

{% schema %}
{
  "name": "Reconstitution Guide",
  "tag": "section",
  "class": "section-reconstitution-guide",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "default" },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding top", "default": 80 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding bottom", "default": 80 }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Step Title"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description"
        }
      ]
    },
    { "type": "@app" }
  ],
  "presets": [
    {
      "name": "Reconstitution Guide",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "title": "Sterilize",
            "text": "Wipe the rubber stoppers of both the peptide vial and the bacteriostatic water vial with an alcohol swab."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Transfer",
            "text": "Draw the required amount of water (e.g. 2ml) and inject slowly into the peptide vial. Aim for the glass wall."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Dissolve",
            "text": "Gently swirl the vial in a circular motion until clear. Never shake the vial vigorously as this damages the peptide."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Store",
            "text": "Once mixed, the solution must be refrigerated immediately. Use within 4-8 weeks."
          }
        }
      ]
    }
  ]
}
{% endschema %}
