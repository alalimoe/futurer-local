{% schema %}
{
  "name": "Peptide Guide Steps",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#fbbf24"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Step Title"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Peptide Guide Steps",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "title": "Sterilize",
            "text": "Wipe the rubber stoppers of both the peptide vial and the bacteriostatic water vial with an alcohol swab."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Transfer",
            "text": "Draw the required amount of water (e.g. 2ml) and inject slowly into the peptide vial. Aim for the glass wall."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Dissolve",
            "text": "Gently swirl the vial in a circular motion until clear. Never shake the vial vigorously as this damages the peptide."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Store",
            "text": "Once mixed, the solution must be refrigerated immediately. Use within 4-8 weeks."
          }
        }
      ]
    }
  ]
}
{% endschema %}

<div class="pg-section">
  <div class="pg-container">
    <div class="pg-header">
      <h2>Reconstitution Protocol</h2>
      <p>Follow these standard laboratory procedures for optimal stability.</p>
    </div>
    
    <div class="pg-grid">
      {% for block in section.blocks %}
      <div class="pg-card reveal-child" style="--reveal-idx: {{ forloop.index0 }};" {{ block.shopify_attributes }}>
        <div class="pg-number">{{ forloop.index }}</div>
        <h3>{{ block.settings.title }}</h3>
        <p>{{ block.settings.text }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
</div>

<style>
  .pg-section {
    background-color: {{ section.settings.bg_color }};
    padding: clamp(32px, 6vw, 60px) var(--page-gutter);
    font-family: var(--font-body-family, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif);
  }
  .pg-container {
    max-width: var(--container-width-medium);
    margin: 0 auto;
  }
  .pg-header {
    text-align: center;
    margin-bottom: 40px;
  }
  .pg-header h2 {
    font-family: var(--font-heading-family, inherit);
    font-size: clamp(1.4rem, 2.5vw, 1.75rem);
    font-weight: 800;
    margin: 0 0 10px;
    color: var(--nx-text, #0B0B0B);
    letter-spacing: -0.025em;
    line-height: 1.2;
  }
  .pg-header p {
    color: var(--nx-muted, #6b7280);
    font-size: clamp(0.875rem, 1.5vw, 1rem);
  }
  
  .pg-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }
  @media(max-width: 900px) {
    .pg-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media(max-width: 560px) {
    .pg-grid { grid-template-columns: 1fr; }
  }

  .pg-card {
    background: #fff;
    border: none;
    padding: 24px;
    border-radius: 12px;
    position: relative;
    box-shadow: var(--shadow-sm);
    transition: all 0.35s cubic-bezier(0.25, 0.8, 0.25, 1);
    opacity: 0;
    transform: translateY(16px);
    animation: pg-reveal 0.5s ease forwards;
    animation-delay: calc(var(--reveal-idx, 0) * 80ms);
  }
  .pg-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md-hover);
  }
  
  .pg-number {
    width: 32px;
    height: 32px;
    background: {{ section.settings.accent_color }};
    color: var(--color-text-primary);
    font-weight: 700;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 16px;
    font-size: 13px;
  }
  .pg-card h3 {
    font-family: var(--font-heading-family, inherit);
    font-weight: 700;
    font-size: clamp(0.95rem, 1.5vw, 1.125rem);
    margin: 0 0 8px;
    color: var(--nx-text, #0B0B0B);
    letter-spacing: -0.01em;
  }
  .pg-card p {
    font-size: clamp(0.8rem, 1.2vw, 0.875rem);
    color: var(--nx-muted, #6b7280);
    line-height: 1.55;
    margin: 0;
  }

  @keyframes pg-reveal {
    to { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .pg-card {
      opacity: 1;
      transform: none;
      animation: none;
      transition: none;
    }
    .pg-card:hover { transform: none; }
  }
</style>