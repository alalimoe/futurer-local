{{ 'featured-collection-9.css' | asset_url | stylesheet_tag }}
{{ 'collection-image.css' | asset_url | stylesheet_tag }}

{% liquid
  assign sub_heading = section.settings.sub_heading
  assign layout = section.settings.layout
  assign block = section.blocks
%}

<section {% render 'section-attr' %}>
  <div class='featured-collection-style-9'>
    <xo-container class='featured-collection-style-9__container'>
      {% render 'featured-collection-9', layout: layout, sub_heading: sub_heading, block: block %}
    </xo-container>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.featured_collection_style_9.name",
  "disabled_on": {
    "groups": [
      "header",
      "footer",
      "custom.overlay",
      "custom.popups",
      "custom.features"
    ]
  },
  "settings": [
    {
      "type": "text",
      "id": "sub_heading",
      "label": "t:sections.featured_collection_style_9.settings.sub_heading.label",
      "default": "Subheading"
    },
    {
      "type": "header",
      "content": "General settings"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Section color scheme"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color"
    },
    {
      "type": "color_background",
