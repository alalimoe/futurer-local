{%- assign s = section.settings -%}
{%- assign sid = section.id -%}
{%- assign alpha = s.alpha_gpc -%}
{%- assign cdp = s.cdp_choline -%}
{%- assign theo = s.l_theanine -%}
{%- assign cafth = s.caffeine_l_theanine -%}
{%- assign lion = s.lions_mane -%}
{%- assign novice = s.novice_stack -%}
{%- assign enhanced = s.enhanced_stack -%}
{%- assign elite = s.elite_stack -%}

{%- style -%}
#nx-stack-{{ sid }} {
  max-width: var(--container-width-narrow);
  margin: 0 auto;
  padding: 8px var(--page-gutter);
  font-family: var(--font-body-family, sans-serif);
  color: var(--color-text-main, #111827);
  line-height: 1.7;
  content-visibility: auto;
}
#nx-stack-{{ sid }} h2 {
  font-family: var(--font-heading-family, sans-serif);
  font-size: clamp(22px, 3vw, 30px);
  font-weight: 700;
  line-height: 1.2;
  margin: 0 0 12px;
}
#nx-stack-{{ sid }} p {
  color: var(--color-text-muted, #4b5563);
  margin: 0 0 6px;
}
#nx-stack-{{ sid }} p strong { color: var(--color-text-main, #111827); }
#nx-stack-{{ sid }} a:not(.nx-btn) {
  color: var(--color-accent-dark, #92400e);
  text-decoration: none;
  font-weight: 600;
  transition: var(--transition-premium, all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1));
}
#nx-stack-{{ sid }} a:not(.nx-btn):hover { color: var(--color-text-main, #111827); }

#nx-stack-{{ sid }} .nx-btnrow {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
  margin-top: 14px;
}
#nx-stack-{{ sid }} .nx-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10px 16px;
  border-radius: 10px;
  font-size: 14px;
  font-weight: 600;
  text-decoration: none;
  min-height: 44px;
  border: 1.5px solid var(--color-accent-primary, #FBBF24);
  background: transparent;
  color: var(--color-text-main, #111827);
  transition: var(--transition-premium, all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1));
}
#nx-stack-{{ sid }} .nx-btn:hover {
  background: var(--color-accent-primary, #FBBF24);
  color: var(--color-text-primary);
  transform: translateY(-2px);
  box-shadow: var(--shadow-gold-glow, 0 4px 14px rgba(251,191,36,0.25));
}
#nx-stack-{{ sid }} .nx-btn:active { transform: scale(0.98); }

#nx-stack-{{ sid }} a:focus-visible {
  outline: 2px solid var(--color-accent-primary, #FBBF24);
  outline-offset: 2px;
}

@media (prefers-reduced-motion: reduce) {
  #nx-stack-{{ sid }},
  #nx-stack-{{ sid }} * {
    transition: none !important;
    animation: none !important;
    transform: none !important;
  }
}
{%- endstyle -%}

<section id="nx-stack-{{ sid }}" aria-label="Smart stacking guide">
  <h2>Smart Stacking</h2>
  <p><strong>Core pairing:</strong> Racetam + Choline Donor{% if alpha != blank or cdp != blank %} — {% if alpha != blank %}<a href="{{ alpha.url }}">Alpha-GPC</a>{% endif %}{% if alpha != blank and cdp != blank %} or {% endif %}{% if cdp != blank %}<a href="{{ cdp.url }}">CDP-Choline</a>{% endif %}{% endif %}.</p>
  <p><strong>Add-ons:</strong>{% if theo != blank %} <a href="{{ theo.url }}">L-Theanine</a>{% else %} L-Theanine{% endif %}{% if cafth != blank %} or <a href="{{ cafth.url }}">Caffeine + L-Theanine</a>{% endif %};{% if lion != blank %} <a href="{{ lion.url }}">Lion's Mane</a>{% else %} Lion's Mane{% endif %} for plasticity support.</p>

  <div class="nx-btnrow">
    {% if novice != blank %}<a class="nx-btn" href="{{ novice.url }}">Novice Nootropic Stack</a>{% endif %}
    {% if enhanced != blank %}<a class="nx-btn" href="{{ enhanced.url }}">Enhanced Focus Stack</a>{% endif %}
    {% if elite != blank %}<a class="nx-btn" href="{{ elite.url }}">Cognitive Elite Stack</a>{% endif %}
  </div>
</section>

{% schema %}
{
  "name": "NX — Smart Stacking",
  "settings": [
    { "type": "product", "id": "alpha_gpc", "label": "Alpha-GPC" },
    { "type": "product", "id": "cdp_choline", "label": "CDP-Choline" },
    { "type": "product", "id": "l_theanine", "label": "L-Theanine (optional)" },
    { "type": "product", "id": "caffeine_l_theanine", "label": "Caffeine + L-Theanine (optional)" },
    { "type": "product", "id": "lions_mane", "label": "Lion's Mane (optional)" },
    { "type": "product", "id": "novice_stack", "label": "Novice Nootropic Stack (optional)" },
    { "type": "product", "id": "enhanced_stack", "label": "Enhanced Focus Stack (optional)" },
    { "type": "product", "id": "elite_stack", "label": "Cognitive Elite Stack (optional)" }
  ],
  "presets": [{ "name": "NX — Smart Stacking" }]
}
{% endschema %}
