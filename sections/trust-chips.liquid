{% comment %}
Trust Chips — small pill row beneath hero
- Input: freeform string "COA on page | Same-day Dubai | …" OR up to 6 manual chips
- Optional icon toggle
- One-time gentle fade-in on entry
{% endcomment %}

{%- style -%}
  .xo-section--{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .xo-section--{{ section.id }} .t-row {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .xo-section--{{ section.id }} .t-chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 10px;
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
    border-radius: var(--button-radius);
    background: rgba(var(--color-background));
    color: rgba(var(--color-foreground));
    font-weight: 600;
    font-size: 0.85rem;
    line-height: 1;
  }

  .xo-section--{{ section.id }} .t-ico {
    width: 14px;
    height: 14px;
    color: currentColor;
    display: inline-block;
  }

  @media (prefers-reduced-motion: no-preference) {
    .xo-section--{{ section.id }} .t-chip {
      opacity: 0;
      transform: translateY(6px);
    }
    .xo-section--{{ section.id }} .t-chip.in {
      opacity: 1;
      transform: none;
      transition: opacity 0.22s var(--out-soft, ease), transform 0.22s var(--out-soft, ease);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .xo-section--{{ section.id }} .t-chip {
      opacity: 1;
      transform: none;
    }
  }
{%- endstyle -%}

<section {% render 'section-attr' %}>
  <xo-container>
    <div class="t-row" data-trust-row>
      {%- assign chips = section.settings.chips -%}
      {%- if chips -%}
        {%- if chips contains '|' -%}{% assign chips = chips | split:'|' %}{% else %}{% assign chips = chips | split:',' %}{% endif -%}
        {%- for c in chips -%}
          {% assign t = c | strip %}
          {% if t != blank %}
            <span class="t-chip">
              {% if section.settings.show_icons %}
              <span class="t-ico" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
              {% endif %}
              {{ t }}
            </span>
          {% endif %}
        {%- endfor -%}
      {%- endif -%}

      {%- for i in (1..6) -%}
        {%- assign k = 'm' | append:i -%}
        {% assign v = section.settings[k] %}
        {% if v != blank %}
          <span class="t-chip">
            {% if section.settings.show_icons %}
            <span class="t-ico" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
            {% endif %}
            {{ v }}
          </span>
        {% endif %}
      {%- endfor -%}
    </div>
  </xo-container>
</section>

<script>
document.addEventListener('DOMContentLoaded', function(){
  var row = document.querySelector('.xo-section--{{ section.id }} [data-trust-row]'); if(!row) return;
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    row.querySelectorAll('.t-chip').forEach(function(c){ c.classList.add('in'); });
    return;
  }
  var io = new IntersectionObserver(function(es){
    es.forEach(function(e){
      if(e.isIntersecting){
        row.querySelectorAll('.t-chip').forEach(function(c,i){ c.style.transitionDelay = (i*25)+'ms'; c.classList.add('in'); });
        io.disconnect();
      }
    });
  }, { threshold:.35 });
  io.observe(row);
});
</script>

{% schema %}
{
  "name": "Trust chips",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "default" },
    { "type": "text", "id": "chips", "label": "Chips (comma or | separated)", "default": "COA on page | Same-day Dubai delivery | Free intl. shipping $120+ | Research use only" },
    { "type": "checkbox", "id": "show_icons", "label": "Show check icons", "default": true },
    { "type": "text", "id": "m1", "label": "Manual chip 1" },
    { "type": "text", "id": "m2", "label": "Manual chip 2" },
    { "type": "text", "id": "m3", "label": "Manual chip 3" },
    { "type": "text", "id": "m4", "label": "Manual chip 4" },
    { "type": "text", "id": "m5", "label": "Manual chip 5" },
    { "type": "text", "id": "m6", "label": "Manual chip 6" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding top", "default": 16 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding bottom", "default": 16 }
  ],
  "blocks": [
    {
      "type": "@app"
    }
  ],
  "presets": [{ "name": "Trust chips" }]
}
{% endschema %}
