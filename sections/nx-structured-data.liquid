{% comment %} Article + Breadcrumbs (keep FAQ JSON-LD inside the FAQ section) {% endcomment %}
{%- assign page_url = request.origin | append: request.path -%}
<script type="application/ld+json">
{
  "@context":"https://schema.org",
  "@type":"Article",
  "headline":"Racetams 101 — Aniracetam, Phenylpiracetam & More",
  "description":"A complete, shopper-friendly guide focused on in-stock racetams at Nootropix, with stacking tips and FAQs.",
  "mainEntityOfPage": {{ page_url | json }},
  "author": { "@type":"Organization", "name":"Nootropix" },
  "publisher": { "@type":"Organization", "name":"Nootropix" }
}
</script>

<script type="application/ld+json">
{
  "@context":"https://schema.org",
  "@type":"BreadcrumbList",
  "itemListElement":[
    { "@type":"ListItem","position":1,"name":"Home","item": {{ request.origin | json }} },
    { "@type":"ListItem","position":2,"name":"Learn","item": {{ request.origin | append: '/blogs/learn' | json }} },
    { "@type":"ListItem","position":3,"name":"Racetams 101","item": {{ page_url | json }} }
  ]
}
</script>

{% schema %}
{ "name": "Structured Data", "settings": [], "presets": [{ "name": "Structured Data" }] }
{% endschema %}
