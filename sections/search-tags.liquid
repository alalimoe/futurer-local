{% schema %}
{
  "name": "Search & Tags",
  "settings": [
    {
      "type": "text",
      "id": "search_placeholder",
      "label": "Search placeholder",
      "default": "Search this topic…"
    }
  ],
  "presets": [
    {
      "name": "Search & Tags"
    }
  ]
}
{% endschema %}

{%- assign blog_handle = blog.handle -%}
{%- assign query = search.terms | default: '' -%}
{%- assign all_tags = 'nootropics-101,ingredient-spotlights,mood-stress-relief,focus-productivity,energy-motivation,learning-memory,stacks-protocols,lifestyle-optimization,inside-nootropix'
  | split: ','
-%}
{%- assign active_tag = current_tags.first -%}

<div class="search-tags" style="padding: 2rem 1rem; text-align: center;">
  <!-- Minimal search form -->
  <form
    action="{{ routes.blog_url | replace: ':handle', blog_handle }}"
    method="get"
    style="max-width: 360px; margin: 0 auto 1.5rem;"
  >
    <input
      type="search"
      name="q"
      value="{{ query }}"
      placeholder="{{ section.settings.search_placeholder }}"
      style="
        width: 100%;
        padding: 0.75rem 1rem;
        font-size: 1rem;
        border: 1px solid #ccc;
        border-radius: 24px;
        outline: none;
      "
    >
  </form>

  <!-- Topic filters -->
  <div
    class="tag-list"
    style="
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      justify-content: center;
      font-size: 0.875rem;
    "
  >
    {% for tag in all_tags %}
      <a
        href="{{ routes.blog_url | replace: ':handle', blog_handle }}/tagged/{{ tag }}"
        style="
          padding: 0.4rem 0.8rem;
          border-radius: 999px;
          border: 1px solid #ddd;
          text-decoration: none;
          color: {% if tag == active_tag %}#000{% else %}#555{% endif %};
          background-color: {% if tag == active_tag %}#f5f5f5{% else %}transparent{% endif %};
          transition: background-color .2s, color .2s;
        "
      >
        {{ tag | replace: '-', ' ' | capitalize }}
      </a>
    {% endfor %}
  </div>
</div>
