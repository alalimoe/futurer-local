{%- style -%}
  .xo-section--{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .xo-section--{{ section.id }} .uapf-inner {
    max-width: 750px;
    margin: 0 auto;
  }

  .xo-section--{{ section.id }} .uapf-heading {
    font-family: var(--font-heading-family);
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    font-weight: 600;
    color: rgba(var(--color-foreground));
    margin: 0 0 32px;
    text-align: center;
    letter-spacing: -0.02em;
  }

  .xo-section--{{ section.id }} .uapf-promo {
    display: block;
    text-decoration: none;
    color: inherit;
    margin-bottom: 40px;
    border-radius: var(--general-radius-1, 1rem);
    overflow: hidden;
    background: rgba(var(--color-background-2));
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
    text-align: center;
    transition: border-color 0.3s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .uapf-promo:hover {
    border-color: color-mix(in srgb, rgba(var(--color-foreground)) 20%, transparent);
  }

  .xo-section--{{ section.id }} .uapf-promo-img {
    width: 100%;
    display: block;
  }

  .xo-section--{{ section.id }} .uapf-promo-text {
    display: block;
    padding: 16px;
    font-weight: 600;
    font-size: 1.0625rem;
    color: rgba(var(--color-foreground));
  }

  .xo-section--{{ section.id }} .uapf-item {
    border-bottom: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
  }

  .xo-section--{{ section.id }} .uapf-item:first-child {
    border-top: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
  }

  .xo-section--{{ section.id }} .uapf-q {
    padding: 20px 0;
    font-weight: 600;
    font-size: 1rem;
    color: rgba(var(--color-foreground));
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    list-style: none;
    transition: color 0.2s var(--out-soft, ease);
    min-height: 44px;
  }

  .xo-section--{{ section.id }} .uapf-q::-webkit-details-marker {
    display: none;
  }

  .xo-section--{{ section.id }} .uapf-q:hover {
    color: rgba(var(--color-accent));
  }

  .xo-section--{{ section.id }} .uapf-chevron {
    width: 22px;
    height: 22px;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent);
    transition: transform 0.3s var(--out-soft, ease);
    flex-shrink: 0;
  }

  .xo-section--{{ section.id }} .uapf-item[open] .uapf-chevron {
    transform: rotate(180deg);
    color: rgba(var(--color-accent));
  }

  .xo-section--{{ section.id }} .uapf-a {
    padding: 0 0 24px;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent);
    font-size: 0.9375rem;
    line-height: 1.7;
    animation: uapfSlide--{{ section.id }} 0.3s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .uapf-a-inner {
    border-left: 2px solid rgba(var(--color-accent));
    padding-left: 16px;
  }

  @keyframes uapfSlide--{{ section.id }} {
    from { opacity: 0; transform: translateY(-4px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .xo-section--{{ section.id }} :focus-visible {
    outline: 2px solid rgba(var(--color-accent));
    outline-offset: 2px;
  }

  @media (prefers-reduced-motion: reduce) {
    .xo-section--{{ section.id }} *,
    .xo-section--{{ section.id }} *::before,
    .xo-section--{{ section.id }} *::after {
      animation-duration: 0.01ms !important;
      transition-duration: 0.01ms !important;
    }
  }
{%- endstyle -%}

{%- assign uapf_faqs = section.blocks | where: "type", "faq" -%}
{% if uapf_faqs.size > 0 %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {%- for block in uapf_faqs -%}
    {
      "@type": "Question",
      "name": {{ block.settings.question | json }},
      "acceptedAnswer": {
        "@type": "Answer",
        "text": {{ block.settings.answer | strip_html | json }}
      }
    }{%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
  ]
}
</script>
{% endif %}

<section id="uae-pricing" {% render 'section-attr' %}>
  <xo-container>
    <div class="uapf-inner">
      {% if section.settings.heading != blank %}
        <h2 class="uapf-heading">{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.show_promo and section.settings.promo_text != blank %}
        <a href="{{ section.settings.promo_url | default: '/collections/all-nootropics' }}" class="uapf-promo">
          {%- if section.settings.promo_image != blank -%}
            <img src="{{ section.settings.promo_image | image_url: width: 960 }}" alt="{{ section.settings.promo_text | escape }}" width="960" height="{{ 960 | divided_by: section.settings.promo_image.aspect_ratio | round }}" loading="lazy" decoding="async" class="uapf-promo-img">
          {%- endif -%}
          <span class="uapf-promo-text">{{ section.settings.promo_text }}</span>
        </a>
      {% endif %}

      {% if uapf_faqs.size > 0 %}
        <div class="uapf-faq">
          {% for block in uapf_faqs %}
            <details class="uapf-item" {{ block.shopify_attributes }}>
              <summary class="uapf-q">
                {{ block.settings.question }}
                <span class="uapf-chevron"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg></span>
              </summary>
              <div class="uapf-a"><div class="uapf-a-inner">{{ block.settings.answer }}</div></div>
            </details>
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </xo-container>
</section>

{% schema %}
{
  "name": "UAE Pricing FAQ",
  "tag": "section",
  "class": "section-uae-pricing-faq",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "default" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Pricing, Returns and Payments" },
    { "type": "header", "content": "Promo Banner (optional)" },
    { "type": "checkbox", "id": "show_promo", "label": "Show Promo Banner", "default": true },
    { "type": "image_picker", "id": "promo_image", "label": "Promo Image" },
    { "type": "text", "id": "promo_text", "label": "Promo Text", "default": "First order 10% OFF — code WLCM10" },
    { "type": "url", "id": "promo_url", "label": "Promo Link" },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding top", "default": 80 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding bottom", "default": 80 }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "Pricing FAQ",
      "settings": [
        { "type": "text", "id": "question", "label": "Question" },
        { "type": "textarea", "id": "answer", "label": "Answer" }
      ]
    },
    { "type": "@app" }
  ],
  "presets": [
    {
      "name": "UAE Pricing FAQ",
      "blocks": [
        { "type": "faq", "settings": { "question": "Do you have discount codes?", "answer": "Yes — use WLCM10 on your first order. Bundles already include built-in savings." } },
        { "type": "faq", "settings": { "question": "Payment methods?", "answer": "We accept major cards and Apple Pay. Cash on Delivery may be available in select UAE areas." } }
      ]
    }
  ]
}
{% endschema %}
