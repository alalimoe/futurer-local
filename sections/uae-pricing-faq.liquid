{% schema %}
{
  "name": "UAE Pricing FAQ",
  "tag": "section",
  "class": "section-uae-pricing-faq",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Pricing, Returns and Payments" },
    { "type": "header", "content": "Promo Banner (optional)" },
    { "type": "checkbox", "id": "show_promo", "label": "Show Promo Banner", "default": true },
    { "type": "image_picker", "id": "promo_image", "label": "Promo Image" },
    { "type": "text", "id": "promo_text", "label": "Promo Text", "default": "First order 10% OFF — code WLCM10" },
    { "type": "url", "id": "promo_url", "label": "Promo Link" },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#ffffff" },
    { "type": "color", "id": "accent_color", "label": "Accent", "default": "#FBBF24" }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "Pricing FAQ",
      "settings": [
        { "type": "text", "id": "question", "label": "Question" },
        { "type": "textarea", "id": "answer", "label": "Answer" }
      ]
    }
  ],
  "presets": [
    {
      "name": "UAE Pricing FAQ",
      "blocks": [
        { "type": "faq", "settings": { "question": "Do you have discount codes?", "answer": "Yes — use WLCM10 on your first order. Bundles already include built-in savings." } },
        { "type": "faq", "settings": { "question": "Payment methods?", "answer": "We accept major cards and Apple Pay. Cash on Delivery may be available in select UAE areas." } }
      ]
    }
  ]
}
{% endschema %}

{%- assign uapf_faqs = section.blocks | where: "type", "faq" -%}
{% if uapf_faqs.size > 0 %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {%- for block in uapf_faqs -%}
    {
      "@type": "Question",
      "name": {{ block.settings.question | json }},
      "acceptedAnswer": {
        "@type": "Answer",
        "text": {{ block.settings.answer | strip_html | json }}
      }
    }{%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
  ]
}
</script>
{% endif %}

<div class="uapf-wrapper" id="uae-pricing">
  <div class="uapf-inner">
    {% if section.settings.heading != blank %}
      <h2 class="uapf-heading">{{ section.settings.heading }}</h2>
    {% endif %}

    {% if section.settings.show_promo and section.settings.promo_text != blank %}
      <a href="{{ section.settings.promo_url | default: '/collections/all-nootropics' }}" class="uapf-promo">
        {%- if section.settings.promo_image != blank -%}
          <img src="{{ section.settings.promo_image | image_url: width: 960 }}" alt="{{ section.settings.promo_text | escape }}" width="960" height="{{ 960 | divided_by: section.settings.promo_image.aspect_ratio | round }}" loading="lazy" decoding="async" class="uapf-promo-img">
        {%- endif -%}
        <span class="uapf-promo-text">{{ section.settings.promo_text }}</span>
      </a>
    {% endif %}

    {% if uapf_faqs.size > 0 %}
      <div class="uapf-faq">
        {% for block in uapf_faqs %}
          <details class="uapf-item" {{ block.shopify_attributes }}>
            <summary class="uapf-q">
              {{ block.settings.question }}
              <span class="uapf-chevron"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg></span>
            </summary>
            <div class="uapf-a"><div class="uapf-a-inner">{{ block.settings.answer }}</div></div>
          </details>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</div>

<style>
  .uapf-wrapper {
    --uapf-bg: {{ section.settings.bg_color }};
    --uapf-accent: {{ section.settings.accent_color }};
    --uapf-text: var(--color-text-main, #111827);
    --uapf-muted: var(--color-text-muted, #4b5563);
    --uapf-border: var(--nx-pill-border, #E5E7EB);
    --uapf-radius: var(--nx-radius, 14px);
    --uapf-font: var(--font-body-family, sans-serif);
    --uapf-font-heading: var(--font-heading-family, sans-serif);
    --uapf-transition: var(--transition-smooth, all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1));
    background: var(--uapf-bg); padding: 80px var(--page-gutter); font-family: var(--uapf-font);
  }
  .uapf-inner { max-width: 750px; margin: 0 auto; }
  .uapf-heading {
    font-family: var(--uapf-font-heading); font-size: clamp(1.75rem, 3vw, 2.25rem);
    font-weight: 800; color: var(--uapf-text); margin: 0 0 32px; text-align: center; letter-spacing: -0.02em;
  }

  .uapf-promo {
    display: block; text-decoration: none; color: inherit;
    margin-bottom: 40px; border-radius: var(--uapf-radius); overflow: hidden;
    background: var(--color-bg-secondary, #f1f5f9); border: 1px solid var(--uapf-border);
    text-align: center; transition: var(--uapf-transition);
  }
  .uapf-promo:hover { box-shadow: var(--shadow-sm, 0 2px 8px rgba(0,0,0,0.04)); }
  .uapf-promo-img { width: 100%; display: block; }
  .uapf-promo-text {
    display: block; padding: 16px; font-weight: 700; font-size: 1.0625rem; color: var(--uapf-text);
  }

  .uapf-faq { }
  .uapf-item { border-bottom: 1px solid var(--uapf-border); }
  .uapf-item:first-child { border-top: 1px solid var(--uapf-border); }
  .uapf-q {
    padding: 20px 0; font-weight: 700; font-size: 1rem; color: var(--uapf-text);
    display: flex; justify-content: space-between; align-items: center;
    cursor: pointer; list-style: none; transition: color 0.2s; min-height: var(--touch-min, 44px);
  }
  .uapf-q::-webkit-details-marker { display: none; }
  .uapf-q:hover { color: var(--uapf-accent); }
  .uapf-chevron { width: 22px; height: 22px; color: var(--uapf-muted); transition: transform 0.3s ease; flex-shrink: 0; }
  .uapf-item[open] .uapf-chevron { transform: rotate(180deg); color: var(--uapf-accent); }
  .uapf-a { padding: 0 0 24px; color: var(--uapf-muted); font-size: 0.9375rem; line-height: 1.7; animation: uapfSlide 0.3s ease-out; }
  .uapf-a-inner { border-left: 2px solid var(--uapf-accent); padding-left: 16px; }
  @keyframes uapfSlide { from { opacity: 0; transform: translateY(-4px); } to { opacity: 1; transform: translateY(0); } }

  .uapf-wrapper :focus-visible { outline: 2px solid var(--uapf-accent); outline-offset: 2px; }
  @media (prefers-reduced-motion: reduce) { .uapf-wrapper *, .uapf-wrapper *::before, .uapf-wrapper *::after { animation-duration: 0.01ms !important; transition-duration: 0.01ms !important; } }
  @media (max-width: 640px) { .uapf-wrapper { padding: 56px var(--page-gutter); } }
</style>
