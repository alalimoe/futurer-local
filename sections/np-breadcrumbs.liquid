<section class="np-surface">
  <div class="np-wrap np-breadcrumbs" aria-label="Breadcrumb">
    <ol>
      <li><a href="{{ routes.root_url }}">Home</a></li>
      <li><a href="{{ blog.url }}">{{ blog.title }}</a></li>
      {% if current_tags and current_tags.size > 0 %}
        <li aria-current="page">{{ current_tags | join: ', ' }}</li>
      {% else %}
        <li aria-current="page">All</li>
      {% endif %}
    </ol>
  </div>
</section>

{% schema %}
{
  "name": "Breadcrumbs",
  "tag": "section",
  "class": "section",
  "presets": [{ "name": "NP • Breadcrumbs" }]
}
{% endschema %}
