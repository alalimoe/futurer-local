{% comment %}
  Data sheet download link; optional hide when no PDF.
{% endcomment %}

{%- liquid
  assign ds = nil
  if product.metafields.pep.data_sheet_pdf and product.metafields.pep.data_sheet_pdf.value and product.metafields.pep.data_sheet_pdf.value.url
    assign ds = product.metafields.pep.data_sheet_pdf.value.url
  endif
  assign hide_empty = section.settings.hide_when_empty
  if hide_empty == nil
    assign hide_empty = true
  endif
-%}

{% if ds or hide_empty == false %}
{%- style -%}
  .xo-section--{{ section.id }} .ds__card {
    display: flex;
    gap: 1.4rem;
    align-items: center;
    flex-wrap: wrap;
    padding: 1.6rem 1.8rem;
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 8%, transparent);
    border-radius: var(--general-radius-3);
    background: rgba(var(--color-background));
  }

  .xo-section--{{ section.id }} .ds__heading {
    font-family: var(--font-heading-family, sans-serif);
    font-weight: 600;
    font-size: calc(var(--font-body-scale, 1) * 1.6rem);
    letter-spacing: -0.01em;
    color: rgba(var(--color-foreground));
    margin: 0;
  }

  .xo-section--{{ section.id }} .ds__note {
    color: color-mix(in srgb, rgba(var(--color-foreground)) 55%, transparent);
    font-size: calc(var(--font-body-scale, 1) * 1.3rem);
  }
{%- endstyle -%}

<section {% render 'section-attr' %}>
  <xo-container>
    <div class="ds__card">
      <strong class="ds__heading">{{ section.settings.heading | default: 'Technical Data Sheet' }}</strong>
      {% if ds %}
        {% render 'button',
          text: section.settings.label,
          link: ds,
          style: 'link',
          open_in_new_tab: true
        %}
      {% else %}
        <span class="ds__note">No data sheet attached.</span>
      {% endif %}
    </div>
  </xo-container>
</section>
{% endif %}

{% schema %}
{
  "name": "Data Sheet Button",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "background-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Technical Data Sheet"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Button label",
      "default": "Download Data Sheet (PDF)"
    },
    {
      "type": "checkbox",
      "id": "hide_when_empty",
      "label": "Hide section when no data sheet",
      "default": true
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "Desktop top padding",
      "min": 0,
      "max": 60,
      "step": 4,
      "default": 12,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Desktop bottom padding",
      "min": 0,
      "max": 60,
      "step": 4,
      "default": 12,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Mobile top padding",
      "min": 0,
      "max": 40,
      "step": 4,
      "default": 12,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Mobile bottom padding",
      "min": 0,
      "max": 40,
      "step": 4,
      "default": 12,
      "unit": "px"
    }
  ],
  "presets": [{ "name": "Data Sheet Button" }]
}
{% endschema %}
