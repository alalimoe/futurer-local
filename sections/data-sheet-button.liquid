{% comment %}
SECTION: Data Sheet Button
Data: product.metafields.pep.data_sheet_pdf (file)
Renders a primary button when present.
{% endcomment %}

{%- liquid
  assign ds = nil
  if product.metafields.pep.data_sheet_pdf and product.metafields.pep.data_sheet_pdf.value and product.metafields.pep.data_sheet_pdf.value.url
    assign ds = product.metafields.pep.data_sheet_pdf.value.url
  endif
-%}

<section id="data-sheet" class="ds-wrap">
  <style>
    #data-sheet{ --r:14px; --ds-accent:{{ section.settings.btn_bg | default: '#FBBF24' }}; }
    .ds-wrap{padding:12px var(--page-gutter);font-family:var(--font-body-family,sans-serif)}
    .ds-container{max-width:{{ section.settings.max_width | default: 1200 }}px;margin:0 auto}
    .ds-card{border:none;border-radius:var(--r);background:rgba(255,255,255,0.75);-webkit-backdrop-filter:blur(12px);backdrop-filter:blur(12px);padding:16px 18px;box-shadow:var(--shadow-sm);display:flex;gap:14px;align-items:center;flex-wrap:wrap}
    .ds-card strong{font-family:var(--font-heading-family,sans-serif);font-size:clamp(0.9rem,1.3vw,1rem);letter-spacing:-0.01em}
    .ds-btn{
      display:inline-flex;align-items:center;min-height:44px;
      border:2px solid var(--ds-accent);border-radius:10px;
      background:transparent;color:var(--color-text-primary);padding:10px 18px;font-weight:700;font-size:clamp(0.85rem,1.2vw,0.9375rem);text-decoration:none;
      box-shadow:var(--shadow-sm);
      transition:all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
    }
    .ds-btn:hover{background:var(--ds-accent);transform:translateY(-1px);box-shadow:var(--shadow-gold-sm)}
    .ds-btn:active{transform:scale(0.97)}
    .ds-btn:focus-visible{outline:2px solid var(--ds-accent);outline-offset:2px}
    .ds-note{color:var(--nx-muted,#6B7280);font-size:clamp(0.8rem,1.1vw,0.85rem)}
    @media(prefers-reduced-motion:reduce){.ds-btn{transition:none}.ds-btn:hover{transform:none}}
  </style>

  <div class="ds-container">
    <div class="ds-card">
      <strong>{{ section.settings.heading | default: 'Technical Data Sheet' }}</strong>
      {% if ds %}
        <a class="ds-btn" href="{{ ds }}" target="_blank" rel="noopener">{{ section.settings.label | default: 'Download Data Sheet (PDF)' }}</a>
      {% else %}
        <span class="ds-note">No data sheet attached.</span>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name":"Data Sheet Button",
  "settings":[
    { "type":"range","id":"max_width","min":800,"max":1600,"step":10,"unit":"px","label":"Container max width","default":1200 },
    { "type":"text","id":"heading","label":"Heading","default":"Technical Data Sheet" },
    { "type":"text","id":"label","label":"Button label","default":"Download Data Sheet (PDF)" },
    { "type":"color","id":"btn_bg","label":"Button background","default":"#FBBF24" }
  ],
  "presets":[{"name":"Data Sheet Button"}]
}
{% endschema %}
