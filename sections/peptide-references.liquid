{% comment %}
  Peptide references: citation cards from pep.reference metaobject.
{% endcomment %}

{%- liquid
  assign pep_ref = product.metafields.pep.reference
  assign pep = nil
  if pep_ref and pep_ref.value
    assign pep = pep_ref.value
  endif

  assign raw_list = nil
  if pep and pep.scientific_reference_list
    if pep.scientific_reference_list.value
      assign raw_list = pep.scientific_reference_list.value
    else
      assign raw = pep.scientific_reference_list | strip
      assign raw = raw | replace: '["', '' | replace: '"]', ''
      assign raw_list = raw | split: '","'
    endif
  endif

  assign arts = nil
  if product.metafields.pep.featured_articles and product.metafields.pep.featured_articles.value
    assign arts = product.metafields.pep.featured_articles.value
  endif
-%}

{%- style -%}
  .xo-section--{{ section.id }} .prf__head {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin: 0 0 1.2rem;
    flex-wrap: wrap;
  }

  .xo-section--{{ section.id }} .prf__title {
    font-family: var(--font-heading-family, sans-serif);
    font-weight: 600;
    font-size: clamp(1.8rem, 2vw, 2.2rem);
    margin: 0;
    color: rgba(var(--color-foreground));
    letter-spacing: -0.02em;
    line-height: 1.3;
  }

  .xo-section--{{ section.id }} .prf__list {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .xo-section--{{ section.id }} .prf__card {
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 8%, transparent);
    border-radius: var(--general-radius-3);
    background: rgba(var(--color-background));
    padding: 1.4rem 1.6rem;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 0.8rem;
    align-items: start;
    transition: border-color 0.3s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .prf__card:hover {
    border-color: color-mix(in srgb, rgba(var(--color-accent)) 40%, transparent);
  }

  .xo-section--{{ section.id }} .prf__main {
    min-width: 0;
  }

  .xo-section--{{ section.id }} .prf__titleline {
    font-family: var(--font-heading-family, sans-serif);
    font-weight: 600;
    color: rgba(var(--color-foreground));
    margin: 0 0 0.4rem;
    font-size: calc(var(--font-body-scale, 1) * 1.6rem);
    line-height: 1.3;
  }

  .xo-section--{{ section.id }} .prf__link {
    text-decoration: none;
    font-weight: 600;
    color: rgba(var(--color-foreground));
    word-break: break-all;
    border-bottom: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 20%, transparent);
    transition: border-color 0.2s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .prf__link:hover {
    border-color: rgba(var(--color-foreground));
  }

  .xo-section--{{ section.id }} .prf__link:focus-visible {
    outline: 2px solid rgba(var(--color-accent));
    outline-offset: 2px;
    border-radius: 4px;
  }

  .xo-section--{{ section.id }} .prf__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-top: 0.6rem;
  }

  .xo-section--{{ section.id }} .prf__chip {
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 8%, transparent);
    border-radius: var(--button-radius);
    background: rgba(var(--color-background));
    font-size: calc(var(--font-body-scale, 1) * 1.1rem);
    padding: 0.4rem 1rem;
    font-weight: 600;
    color: rgba(var(--color-foreground));
  }

  .xo-section--{{ section.id }} .prf__chip--pubmed {
    background: color-mix(in srgb, rgba(var(--color-accent)) 6%, rgba(var(--color-background)));
  }

  .xo-section--{{ section.id }} .prf__chip--doi {
    background: color-mix(in srgb, rgba(var(--color-foreground)) 4%, rgba(var(--color-background)));
  }

  .xo-section--{{ section.id }} .prf__sub {
    margin: 1.6rem 0 0.8rem;
    font-family: var(--font-heading-family, sans-serif);
    font-weight: 600;
    font-size: clamp(1.6rem, 1.5vw, 1.8rem);
    color: rgba(var(--color-foreground));
    line-height: 1.3;
  }

  .xo-section--{{ section.id }} .prf__arts {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.8rem;
  }

  .xo-section--{{ section.id }} .prf__arts a {
    text-decoration: none;
    font-weight: 600;
    color: rgba(var(--color-foreground));
    border-bottom: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 20%, transparent);
    transition: border-color 0.2s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .prf__arts a:hover {
    border-color: rgba(var(--color-foreground));
  }

  .xo-section--{{ section.id }} .prf__arts a:focus-visible {
    outline: 2px solid rgba(var(--color-accent));
    outline-offset: 2px;
    border-radius: 4px;
  }

  .xo-section--{{ section.id }} .prf__fallback {
    color: color-mix(in srgb, rgba(var(--color-foreground)) 55%, transparent);
    font-size: calc(var(--font-body-scale, 1) * 1.4rem);
  }

  @media (prefers-reduced-motion: reduce) {
    .xo-section--{{ section.id }} .prf__card,
    .xo-section--{{ section.id }} .prf__link,
    .xo-section--{{ section.id }} .prf__arts a {
      transition: none;
    }
    .xo-section--{{ section.id }} .prf__card:hover {
      transform: none;
    }
  }
{%- endstyle -%}

<section id="pep-refs" {% render 'section-attr' %}>
  <xo-container>
    <div class="prf__head">
      <h2 class="prf__title">{{ section.settings.heading | default: 'Referenced Citations' }}</h2>
    </div>

    {% assign has_refs = false %}
    {% if raw_list and raw_list.size > 0 %}{% assign has_refs = true %}{% endif %}

    {% if has_refs %}
      <xo-animate xo-animation="fade-up">
        <ul class="prf__list">
          {%- for item in raw_list -%}
            {%- assign url = nil -%}
            {%- assign title = nil -%}
            {%- assign journal = nil -%}
            {%- if item.url -%}
              {%- assign url = item.url -%}
              {%- if item.title %}{% assign title = item.title %}{% endif -%}
              {%- if item.journal %}{% assign journal = item.journal %}{% endif -%}
            {%- else -%}
              {%- assign url = item -%}
            {%- endif -%}
            {% # theme-check-disable UnknownFilter %}
            {%- assign u = url | to_s | strip -%}
            {% # theme-check-enable UnknownFilter %}
            {%- if u != blank -%}
              {%- assign after_proto = u | split: '//' | last -%}
              {%- assign host = after_proto | split: '/' | first | replace: 'www.', '' -%}
              {%- assign is_pubmed = false -%}
              {%- if host contains 'pubmed' or host contains 'ncbi.nlm.nih.gov' -%}{% assign is_pubmed = true %}{%- endif -%}
              {%- assign doi = nil -%}
              {%- if u contains 'doi.org/' -%}
                {%- assign doi = u | split: 'doi.org/' | last -%}
              {%- endif -%}
              <li class="prf__card">
                <div class="prf__main">
                  {% if title %}
                    <div class="prf__titleline">{{ title }}</div>
                  {% elsif journal %}
                    <div class="prf__titleline">{{ journal }}</div>
                  {% endif %}
                  {%- if title or journal -%}
                    <a class="prf__link" href="{{ u }}" target="_blank" rel="noopener">View source →</a>
                  {%- else -%}
                    <a class="prf__link" href="{{ u }}" target="_blank" rel="noopener">{{ host }} →</a>
                  {%- endif -%}
                  <div class="prf__meta">
                    {% if is_pubmed %}<span class="prf__chip prf__chip--pubmed">PubMed</span>{% endif %}
                    {% if doi %}<span class="prf__chip prf__chip--doi">DOI: {{ doi }}</span>{% endif %}
                    {% if journal %}<span class="prf__chip">{{ journal }}</span>{% endif %}
                    {% if host %}<span class="prf__chip">{{ host }}</span>{% endif %}
                  </div>
                </div>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      </xo-animate>
    {% else %}
      <p class="prf__fallback">{{ section.settings.fallback_text }}</p>
    {% endif %}

    {% if arts and arts.size > 0 %}
      <h3 class="prf__sub">{{ section.settings.featured_heading | default: 'Featured Reading' }}</h3>
      <ul class="prf__arts">
        {% for a in arts %}
          {% if a.url %}
            <li><a href="{{ a.url }}" target="_blank" rel="noopener">{{ a.title | default: a.url }}</a></li>
          {% endif %}
        {% endfor %}
      </ul>
    {% endif %}
  </xo-container>
</section>

{% schema %}
{
  "name": "Peptide references",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "background-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Referenced Citations"
    },
    {
      "type": "text",
      "id": "featured_heading",
      "label": "Featured articles heading",
      "default": "Featured Reading"
    },
    {
      "type": "text",
      "id": "fallback_text",
      "label": "Fallback text",
      "default": "Citations will appear here when added to the metaobject."
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "Desktop top padding",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 24,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Desktop bottom padding",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 24,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Mobile top padding",
      "min": 0,
      "max": 60,
      "step": 4,
      "default": 20,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Mobile bottom padding",
      "min": 0,
      "max": 60,
      "step": 4,
      "default": 20,
      "unit": "px"
    }
  ],
  "presets": [{ "name": "Peptide references" }]
}
{% endschema %}
