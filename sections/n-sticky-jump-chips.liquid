{% comment %}
───────────────────────────────────────────────
NOOTROPIC PDP — Sticky Jump Chips
───────────────────────────────────────────────
{% endcomment %}

<link rel="stylesheet" href="{{ 'sticky-chips.css' | asset_url }}">

<div class="sticky-chips" id="stickyChips">
  <div class="sticky-chips-inner">
    {%- for block in section.blocks -%}
      <a href="#{{ block.settings.id }}" class="sticky-chip">
        {{ block.settings.label }}
      </a>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Sticky Jump Chips",
  "blocks": [
    {
      "type": "chip",
      "name": "Chip",
      "settings": [
        {
          "type": "text",
          "id": "id",
          "label": "Section ID (anchor)",
          "default": "benefits"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Chip Label",
          "default": "Benefits"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Sticky Jump Chips",
      "blocks": [
        { "type": "chip", "settings": { "id": "overview", "label": "Overview" }},
        { "type": "chip", "settings": { "id": "benefits", "label": "Benefits" }},
        { "type": "chip", "settings": { "id": "how-it-works", "label": "How It Works" }},
        { "type": "chip", "settings": { "id": "dosage", "label": "Dosage" }},
        { "type": "chip", "settings": { "id": "research", "label": "Research" }},
        { "type": "chip", "settings": { "id": "faq", "label": "FAQ" }}
      ]
    }
  ]
}
{% endschema %}
