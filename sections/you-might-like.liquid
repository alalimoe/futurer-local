{% comment %}
  You might also like: recommendations API + recent views; SSR collection fallback.
{% endcomment %}

{%- liquid
  assign primary_collection = collection
  if primary_collection == nil
    assign pc_handle = product.metafields.pdp.primary_collection
    if pc_handle and collections[pc_handle]
      assign primary_collection = collections[pc_handle]
    endif
  endif
  if primary_collection == nil and product.collections.size > 0
    assign primary_collection = product.collections.first
  endif

  assign rel_ssr_count = 0
  if primary_collection
    assign count = 0
    for p in primary_collection.products
      if p.id != product.id
        assign count = count | plus: 1
        if count >= section.settings.limit
          break
        endif
      endif
    endfor
    assign rel_ssr_count = count
  endif
-%}

{%- style -%}
  .xo-section--{{ section.id }} .yml__title {
    font-family: var(--font-heading-family, sans-serif);
    font-weight: 600;
    font-size: clamp(1.8rem, 2vw, 2.2rem);
    margin: 0 0 1.4rem;
    color: rgba(var(--color-foreground));
    letter-spacing: -0.02em;
    line-height: 1.3;
  }

  .xo-section--{{ section.id }} .yml__row {
    margin-top: 1.4rem;
  }

  .xo-section--{{ section.id }} .yml__row h3 {
    font-family: var(--font-heading-family, sans-serif);
    margin: 0 0 1rem;
    font-weight: 600;
    color: rgba(var(--color-foreground));
    font-size: clamp(1.6rem, 1.5vw, 1.8rem);
    letter-spacing: -0.015em;
    line-height: 1.3;
  }

  .xo-section--{{ section.id }} .yml__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1.4rem;
  }

  @media (max-width: 992px) {
    .xo-section--{{ section.id }} .yml__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 768px) {
    .xo-section--{{ section.id }} .yml__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .xo-section--{{ section.id }} .yml__card {
    display: flex;
    flex-direction: column;
    min-height: 100%;
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 8%, transparent);
    border-radius: var(--general-radius-3);
    background: rgba(var(--color-background));
    padding: 1.4rem;
    transition: border-color 0.3s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .yml__card:hover {
    border-color: color-mix(in srgb, rgba(var(--color-accent)) 40%, transparent);
  }

  .xo-section--{{ section.id }} .yml__media {
    border: none;
    border-radius: var(--general-radius-1);
    overflow: hidden;
    background: rgba(var(--color-background));
    aspect-ratio: 4/3;
    margin-bottom: 1rem;
    display: block;
  }

  .xo-section--{{ section.id }} .yml__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .xo-section--{{ section.id }} .yml__name {
    font-family: var(--font-heading-family, sans-serif);
    font-weight: 600;
    font-size: calc(var(--font-body-scale, 1) * 1.4rem);
    color: rgba(var(--color-foreground));
    margin: 0 0 0.6rem;
    line-height: 1.3;
  }

  .xo-section--{{ section.id }} .yml__price {
    font-family: var(--font-heading-family, sans-serif);
    font-weight: 600;
    color: rgba(var(--color-foreground));
    margin: 0 0 1rem;
  }

  .xo-section--{{ section.id }} .yml__actions {
    margin-top: auto;
  }

  .xo-section--{{ section.id }} .yml__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: calc(var(--font-body-scale, 1) * 1.2rem);
    font-weight: 600;
    padding: 0.3rem 0.8rem;
    border-radius: var(--button-radius, 10rem);
    border: 1px solid color-mix(in srgb, rgba(var(--color-accent)) 35%, transparent);
    background: color-mix(in srgb, rgba(var(--color-accent)) 7%, rgba(var(--color-background)));
    color: rgba(var(--color-foreground));
    margin: 0 0 0.8rem;
    line-height: 1.1;
  }

  .xo-section--{{ section.id }} .yml__empty {
    color: color-mix(in srgb, rgba(var(--color-foreground)) 55%, transparent);
  }

  .xo-section--{{ section.id }} a {
    color: inherit;
  }

  .xo-section--{{ section.id }} .yml__card a:focus-visible {
    outline: 2px solid rgba(var(--color-accent));
    outline-offset: 2px;
    border-radius: var(--general-radius-3);
  }

  @media (prefers-reduced-motion: reduce) {
    .xo-section--{{ section.id }} .yml__card {
      transition: none;
    }
  }
{%- endstyle -%}

<section {% render 'section-attr' %}>
  <xo-container>
    <h2 class="yml__title">{{ section.settings.title | default: 'You might also like' }}</h2>

    <div class="yml__row" data-row-related {% if rel_ssr_count == 0 %}style="display:none"{% endif %}>
      <h3>{{ section.settings.related_label | default: 'Related peptides' }}</h3>
      <div class="yml__grid" data-rel-grid>
        {% if primary_collection and rel_ssr_count > 0 %}
          {% assign ssr_n = 0 %}
          {% for p in primary_collection.products %}
            {% if p.id != product.id %}
              <div class="yml__card">
                <a class="yml__media" href="{{ p.url }}">
                  {% if p.featured_image %}
                    <img
                      loading="lazy"
                      src="{{ p.featured_image | image_url: width: 640 }}"
                      alt="{{ p.featured_image.alt | default: p.title | escape }}"
                      width="640"
                      height="{{ 640 | divided_by: p.featured_image.aspect_ratio | round }}"
                    >
                  {% endif %}
                </a>
                <a class="yml__name" href="{{ p.url }}">{{ p.title }}</a>
                {% assign card_assay = p.metafields.pdp.assay_percent %}
                {% if card_assay %}
                  <div class="yml__badge">≥{{ card_assay }}% HPLC</div>
                {% endif %}
                <div class="yml__price">{{ p.price | money }}</div>
                <div class="yml__actions"><a class="xo-button xo-button--primary" href="{{ p.url }}">Shop now</a></div>
              </div>
              {% assign ssr_n = ssr_n | plus: 1 %}
              {% if ssr_n >= section.settings.limit %}
                {% break %}
              {% endif %}
            {% endif %}
          {% endfor %}
        {% endif %}
      </div>
    </div>

    <div class="yml__row" data-row-recent style="display:none">
      <h3>{{ section.settings.recent_label | default: 'Recently viewed' }}</h3>
      <div class="yml__grid" data-rv-grid></div>
    </div>
  </xo-container>
</section>

<script>
(function(){
  var root = document.querySelector('.xo-section--{{ section.id }}');
  if (!root) return;
  var relRow = root.querySelector('[data-row-related]');
  var relGrid = root.querySelector('[data-rel-grid]');
  var rvRow = root.querySelector('[data-row-recent]');
  var rvGrid = root.querySelector('[data-rv-grid]');
  var limit = {{ section.settings.limit | default: 8 }};
  var money = {{ shop.money_format | json }};

  function fmt(c) {
    return (window.Shopify && Shopify.formatMoney) ? Shopify.formatMoney(c, money) : (c / 100).toFixed(2);
  }

  function esc(s) {
    return String(s == null ? '' : s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/"/g, '&quot;');
  }

  function productImgSrc(p) {
    if (p.featured_image && p.featured_image.src) return p.featured_image.src;
    if (p.images && p.images[0] && p.images[0].src) return p.images[0].src;
    return '';
  }

  function cardHTML(p) {
    var img = productImgSrc(p);
    var price = p.price || (p.variants && p.variants[0] && p.variants[0].price);
    var url = p.url || ('/products/' + (p.handle || ''));
    var src = img ? (img.indexOf('?') > -1 ? img + '&width=640' : img + '?width=640') : '';
    var imgTag = src
      ? '<img loading="lazy" width="640" height="480" src="' + esc(src) + '" alt="' + esc(p.title) + '">'
      : '';
    var tags = (p.tags || []);
    var hasHplc = tags.some(function(t) { return /hplc/i.test(t); });
    var badgeHTML = hasHplc ? '<div class="yml__badge">HPLC verified</div>' : '';
    return '<div class="yml__card">' +
      '<a class="yml__media" href="' + esc(url) + '">' + imgTag + '</a>' +
      '<a class="yml__name" href="' + esc(url) + '">' + esc(p.title) + '</a>' +
      badgeHTML +
      '<div class="yml__price">' + fmt(parseInt(price, 10) || 0) + '</div>' +
      '<div class="yml__actions"><a class="xo-button xo-button--primary" href="' + esc(url) + '">Shop now</a></div>' +
      '</div>';
  }

  function loadRelated() {
    return fetch('/recommendations/products.json?product_id={{ product.id }}&limit=' + limit, { credentials: 'same-origin' })
      .then(function(res) { if (!res.ok) throw new Error('no recs'); return res.json(); })
      .then(function(data) {
        var items = (data && data.products) ? data.products : [];
        if (items.length) {
          relRow.style.display = '';
          relGrid.innerHTML = '';
          items.forEach(function(p) { relGrid.insertAdjacentHTML('beforeend', cardHTML(p)); });
          return true;
        }
        if (relGrid.children.length > 0) {
          relRow.style.display = '';
          return true;
        }
        return false;
      })
      .catch(function() {
        if (relGrid.children.length > 0) {
          relRow.style.display = '';
          return true;
        }
        return false;
      });
  }

  function loadRecent() {
    var key = 'np_recent';
    var current = {{ product.handle | json }};
    try {
      var existing = JSON.parse(localStorage.getItem(key) || '[]');
      var updated = [current].concat(existing.filter(function(h) { return h !== current; }));
      localStorage.setItem(key, JSON.stringify(updated));
      var arr = updated.filter(function(h) { return h !== current; }).slice(0, limit);
      if (!arr.length) return Promise.resolve(false);

      var chain = Promise.resolve();
      arr.forEach(function(h) {
        chain = chain.then(function() {
          return fetch('/products/' + h + '.js', { credentials: 'same-origin' })
            .then(function(r) { if (!r.ok) return; return r.json(); })
            .then(function(p) { if (p) rvGrid.insertAdjacentHTML('beforeend', cardHTML(p)); });
        });
      });
      return chain.then(function() {
        if (rvGrid.children.length > 0) { rvRow.style.display = ''; return true; }
        return false;
      });
    } catch (e) { return Promise.resolve(false); }
  }

  Promise.all([loadRelated(), loadRecent()]).then(function(results) {
    if (!results[0] && !results[1]) {
      root.style.display = 'none';
    }
  });
})();
</script>

{% schema %}
{
  "name": "You might also like",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "background-1"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Section title",
      "default": "You might also like"
    },
    {
      "type": "text",
      "id": "related_label",
      "label": "Row 1 label (Related)",
      "default": "Related peptides"
    },
    {
      "type": "text",
      "id": "recent_label",
      "label": "Row 2 label (Recently viewed)",
      "default": "Recently viewed"
    },
    {
      "type": "range",
      "id": "limit",
      "min": 2,
      "max": 12,
      "step": 1,
      "label": "Max items per row",
      "default": 8
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "Desktop top padding",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 24,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Desktop bottom padding",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 24,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Mobile top padding",
      "min": 0,
      "max": 60,
      "step": 4,
      "default": 20,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Mobile bottom padding",
      "min": 0,
      "max": 60,
      "step": 4,
      "default": 20,
      "unit": "px"
    }
  ],
  "presets": [{ "name": "You might also like" }]
}
{% endschema %}
