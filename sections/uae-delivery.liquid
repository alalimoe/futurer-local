{% schema %}
{
  "name": "UAE Delivery",
  "tag": "section",
  "class": "section-uae-delivery",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Delivery Speed" },
    { "type": "header", "content": "Delivery Cards" },
    { "type": "image_picker", "id": "card_1_image", "label": "Card 1 Image" },
    { "type": "text", "id": "card_1_title", "label": "Card 1 Title", "default": "Dubai City — 4 Hours" },
    { "type": "text", "id": "card_1_desc", "label": "Card 1 Description", "default": "Same-day within city limits. Orders before 5 PM." },
    { "type": "image_picker", "id": "card_2_image", "label": "Card 2 Image" },
    { "type": "text", "id": "card_2_title", "label": "Card 2 Title", "default": "All Emirates — Next Day" },
    { "type": "text", "id": "card_2_desc", "label": "Card 2 Description", "default": "Next-day to Abu Dhabi, Sharjah, and all UAE." },
    { "type": "image_picker", "id": "card_3_image", "label": "Card 3 Image" },
    { "type": "text", "id": "card_3_title", "label": "Card 3 Title", "default": "International — DHL Express" },
    { "type": "text", "id": "card_3_desc", "label": "Card 3 Description", "default": "Free express on orders 300+ AED. Full tracking." },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#ffffff" },
    { "type": "color", "id": "accent_color", "label": "Accent", "default": "#FBBF24" }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "Shipping FAQ",
      "settings": [
        { "type": "text", "id": "question", "label": "Question" },
        { "type": "textarea", "id": "answer", "label": "Answer" }
      ]
    }
  ],
  "presets": [
    {
      "name": "UAE Delivery",
      "blocks": [
        { "type": "faq", "settings": { "question": "What are Dubai delivery times?", "answer": "Same-day within Dubai city limits (typically ±4 hrs). Outside city limits: same- or next-day depending on address." } },
        { "type": "faq", "settings": { "question": "Do you ship across the UAE?", "answer": "Yes — next-day to all Emirates in most cases. You'll receive live tracking as soon as the courier collects your order." } }
      ]
    }
  ]
}
{% endschema %}

{%- comment -%} ── FAQPage JSON-LD ── {%- endcomment -%}
{%- assign uad_faqs = section.blocks | where: "type", "faq" -%}
{% if uad_faqs.size > 0 %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {%- for block in uad_faqs -%}
    {
      "@type": "Question",
      "name": {{ block.settings.question | json }},
      "acceptedAnswer": {
        "@type": "Answer",
        "text": {{ block.settings.answer | strip_html | json }}
      }
    }{%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
  ]
}
</script>
{% endif %}

<div class="uad-wrapper" id="uae-delivery">
  <div class="uad-inner">
    {% if section.settings.heading != blank %}
      <h2 class="uad-heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="uad-cards">
      {%- for i in (1..3) -%}
        {%- assign img_key = 'card_' | append: i | append: '_image' -%}
        {%- assign title_key = 'card_' | append: i | append: '_title' -%}
        {%- assign desc_key = 'card_' | append: i | append: '_desc' -%}
        {%- if section.settings[title_key] != blank -%}
          <div class="uad-card">
            {%- if section.settings[img_key] != blank -%}
              <img src="{{ section.settings[img_key] | image_url: width: 400 }}" alt="{{ section.settings[title_key] | escape }}" width="400" height="{{ 400 | divided_by: section.settings[img_key].aspect_ratio | round }}" loading="lazy" decoding="async" class="uad-card-img">
            {%- endif -%}
            <h3 class="uad-card-title">{{ section.settings[title_key] }}</h3>
            {%- if section.settings[desc_key] != blank -%}
              <p class="uad-card-desc">{{ section.settings[desc_key] }}</p>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {% if uad_faqs.size > 0 %}
      <div class="uad-faq">
        {% for block in uad_faqs %}
          <details class="uad-item" {{ block.shopify_attributes }}>
            <summary class="uad-q">
              {{ block.settings.question }}
              <span class="uad-chevron"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg></span>
            </summary>
            <div class="uad-a"><div class="uad-a-inner">{{ block.settings.answer }}</div></div>
          </details>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</div>

<style>
  .uad-wrapper {
    --uad-bg: {{ section.settings.bg_color }};
    --uad-accent: {{ section.settings.accent_color }};
    --uad-text: var(--color-text-main, #111827);
    --uad-muted: var(--color-text-muted, #4b5563);
    --uad-border: var(--nx-pill-border, #E5E7EB);
    --uad-radius: var(--nx-radius, 14px);
    --uad-font: var(--font-body-family, sans-serif);
    --uad-font-heading: var(--font-heading-family, sans-serif);
    --uad-transition: var(--transition-smooth, all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1));
    background: var(--uad-bg); padding: 80px var(--page-gutter); font-family: var(--uad-font);
  }
  .uad-inner { max-width: var(--container-width-narrow); margin: 0 auto; }
  .uad-heading {
    font-family: var(--uad-font-heading); font-size: clamp(1.75rem, 3vw, 2.25rem);
    font-weight: 800; color: var(--uad-text); margin: 0 0 40px; text-align: center; letter-spacing: -0.02em;
  }
  .uad-cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-bottom: 48px; }
  .uad-card {
    text-align: center; padding: 24px 16px;
    background: var(--color-bg-secondary, #f9fafb); border: 1px solid var(--uad-border);
    border-radius: var(--uad-radius); transition: var(--uad-transition);
  }
  .uad-card:hover { box-shadow: var(--shadow-sm, 0 2px 8px rgba(0,0,0,0.04)); transform: translateY(-2px); }
  .uad-card-img { width: 100%; max-width: 180px; height: auto; margin: 0 auto 16px; border-radius: 8px; }
  .uad-card-title { font-family: var(--uad-font-heading); font-size: 1.0625rem; font-weight: 700; color: var(--uad-text); margin: 0 0 6px; }
  .uad-card-desc { font-size: 0.875rem; color: var(--uad-muted); line-height: 1.5; margin: 0; }

  .uad-faq { max-width: 750px; margin: 0 auto; }
  .uad-item { border-bottom: 1px solid var(--uad-border); }
  .uad-item:first-child { border-top: 1px solid var(--uad-border); }
  .uad-q {
    padding: 20px 0; font-weight: 700; font-size: 1rem; color: var(--uad-text);
    display: flex; justify-content: space-between; align-items: center;
    cursor: pointer; list-style: none; transition: color 0.2s; min-height: var(--touch-min, 44px);
  }
  .uad-q::-webkit-details-marker { display: none; }
  .uad-q:hover { color: var(--uad-accent); }
  .uad-chevron { width: 22px; height: 22px; color: var(--uad-muted); transition: transform 0.3s ease; flex-shrink: 0; }
  .uad-item[open] .uad-chevron { transform: rotate(180deg); color: var(--uad-accent); }
  .uad-a { padding: 0 0 24px; color: var(--uad-muted); font-size: 0.9375rem; line-height: 1.7; animation: uadSlide 0.3s ease-out; }
  .uad-a-inner { border-left: 2px solid var(--uad-accent); padding-left: 16px; }
  @keyframes uadSlide { from { opacity: 0; transform: translateY(-4px); } to { opacity: 1; transform: translateY(0); } }

  .uad-wrapper :focus-visible { outline: 2px solid var(--uad-accent); outline-offset: 2px; }
  @media (prefers-reduced-motion: reduce) { .uad-wrapper *, .uad-wrapper *::before, .uad-wrapper *::after { animation-duration: 0.01ms !important; transition-duration: 0.01ms !important; } }
  @media (max-width: 640px) {
    .uad-wrapper { padding: 56px var(--page-gutter); }
    .uad-cards { grid-template-columns: 1fr; }
  }
</style>
