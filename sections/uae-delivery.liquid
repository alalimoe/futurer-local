{%- style -%}
  .xo-section--{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .xo-section--{{ section.id }} .uad-heading {
    font-family: var(--font-heading-family);
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    font-weight: 600;
    color: rgba(var(--color-foreground));
    margin: 0 0 40px;
    text-align: center;
    letter-spacing: -0.02em;
  }

  .xo-section--{{ section.id }} .uad-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 48px;
  }

  .xo-section--{{ section.id }} .uad-card {
    text-align: center;
    padding: 24px 16px;
    background: rgba(var(--color-background-2));
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
    border-radius: var(--general-radius-3, 2rem);
    transition: border-color 0.3s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .uad-card:hover {
    border-color: color-mix(in srgb, rgba(var(--color-foreground)) 20%, transparent);
  }

  .xo-section--{{ section.id }} .uad-card-img {
    width: 100%;
    max-width: 180px;
    height: auto;
    margin: 0 auto 16px;
    border-radius: var(--general-radius-small, 1rem);
  }

  .xo-section--{{ section.id }} .uad-card-title {
    font-family: var(--font-heading-family);
    font-size: 1.0625rem;
    font-weight: 600;
    color: rgba(var(--color-foreground));
    margin: 0 0 6px;
  }

  .xo-section--{{ section.id }} .uad-card-desc {
    font-size: 0.875rem;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent);
    line-height: 1.5;
    margin: 0;
  }

  .xo-section--{{ section.id }} .uad-faq {
    max-width: 750px;
    margin: 0 auto;
  }

  .xo-section--{{ section.id }} .uad-item {
    border-bottom: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
  }

  .xo-section--{{ section.id }} .uad-item:first-child {
    border-top: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
  }

  .xo-section--{{ section.id }} .uad-q {
    padding: 20px 0;
    font-weight: 600;
    font-size: 1rem;
    color: rgba(var(--color-foreground));
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    list-style: none;
    transition: color 0.2s var(--out-soft, ease);
    min-height: 44px;
  }

  .xo-section--{{ section.id }} .uad-q::-webkit-details-marker {
    display: none;
  }

  .xo-section--{{ section.id }} .uad-q:hover {
    color: rgba(var(--color-accent));
  }

  .xo-section--{{ section.id }} .uad-chevron {
    width: 22px;
    height: 22px;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent);
    transition: transform 0.3s var(--out-soft, ease);
    flex-shrink: 0;
  }

  .xo-section--{{ section.id }} .uad-item[open] .uad-chevron {
    transform: rotate(180deg);
    color: rgba(var(--color-accent));
  }

  .xo-section--{{ section.id }} .uad-a {
    padding: 0 0 24px;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent);
    font-size: 0.9375rem;
    line-height: 1.7;
    animation: uadSlide--{{ section.id }} 0.3s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .uad-a-inner {
    border-left: 2px solid rgba(var(--color-accent));
    padding-left: 16px;
  }

  @keyframes uadSlide--{{ section.id }} {
    from { opacity: 0; transform: translateY(-4px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .xo-section--{{ section.id }} :focus-visible {
    outline: 2px solid rgba(var(--color-accent));
    outline-offset: 2px;
  }

  @media (max-width: 768px) {
    .xo-section--{{ section.id }} .uad-cards {
      grid-template-columns: 1fr;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .xo-section--{{ section.id }} *,
    .xo-section--{{ section.id }} *::before,
    .xo-section--{{ section.id }} *::after {
      animation-duration: 0.01ms !important;
      transition-duration: 0.01ms !important;
    }
  }
{%- endstyle -%}

{%- comment -%} ── FAQPage JSON-LD ── {%- endcomment -%}
{%- assign uad_faqs = section.blocks | where: "type", "faq" -%}
{% if uad_faqs.size > 0 %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {%- for block in uad_faqs -%}
    {
      "@type": "Question",
      "name": {{ block.settings.question | json }},
      "acceptedAnswer": {
        "@type": "Answer",
        "text": {{ block.settings.answer | strip_html | json }}
      }
    }{%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
  ]
}
</script>
{% endif %}

<section id="uae-delivery" {% render 'section-attr' %}>
  <xo-container>
    {% if section.settings.heading != blank %}
      <h2 class="uad-heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="uad-cards">
      {%- for i in (1..3) -%}
        {%- assign img_key = 'card_' | append: i | append: '_image' -%}
        {%- assign title_key = 'card_' | append: i | append: '_title' -%}
        {%- assign desc_key = 'card_' | append: i | append: '_desc' -%}
        {%- if section.settings[title_key] != blank -%}
          <div class="uad-card">
            {%- if section.settings[img_key] != blank -%}
              <img src="{{ section.settings[img_key] | image_url: width: 400 }}" alt="{{ section.settings[title_key] | escape }}" width="400" height="{{ 400 | divided_by: section.settings[img_key].aspect_ratio | round }}" loading="lazy" decoding="async" class="uad-card-img">
            {%- endif -%}
            <h3 class="uad-card-title">{{ section.settings[title_key] }}</h3>
            {%- if section.settings[desc_key] != blank -%}
              <p class="uad-card-desc">{{ section.settings[desc_key] }}</p>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {% if uad_faqs.size > 0 %}
      <div class="uad-faq">
        {% for block in uad_faqs %}
          <details class="uad-item" {{ block.shopify_attributes }}>
            <summary class="uad-q">
              {{ block.settings.question }}
              <span class="uad-chevron"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg></span>
            </summary>
            <div class="uad-a"><div class="uad-a-inner">{{ block.settings.answer }}</div></div>
          </details>
        {% endfor %}
      </div>
    {% endif %}
  </xo-container>
</section>

{% schema %}
{
  "name": "UAE Delivery",
  "tag": "section",
  "class": "section-uae-delivery",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "default" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Delivery Speed" },
    { "type": "header", "content": "Delivery Cards" },
    { "type": "image_picker", "id": "card_1_image", "label": "Card 1 Image" },
    { "type": "text", "id": "card_1_title", "label": "Card 1 Title", "default": "Dubai City — 4 Hours" },
    { "type": "text", "id": "card_1_desc", "label": "Card 1 Description", "default": "Same-day within city limits. Orders before 5 PM." },
    { "type": "image_picker", "id": "card_2_image", "label": "Card 2 Image" },
    { "type": "text", "id": "card_2_title", "label": "Card 2 Title", "default": "All Emirates — Next Day" },
    { "type": "text", "id": "card_2_desc", "label": "Card 2 Description", "default": "Next-day to Abu Dhabi, Sharjah, and all UAE." },
    { "type": "image_picker", "id": "card_3_image", "label": "Card 3 Image" },
    { "type": "text", "id": "card_3_title", "label": "Card 3 Title", "default": "International — DHL Express" },
    { "type": "text", "id": "card_3_desc", "label": "Card 3 Description", "default": "Free express on orders 300+ AED. Full tracking." },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding top", "default": 80 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding bottom", "default": 80 }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "Shipping FAQ",
      "settings": [
        { "type": "text", "id": "question", "label": "Question" },
        { "type": "textarea", "id": "answer", "label": "Answer" }
      ]
    },
    { "type": "@app" }
  ],
  "presets": [
    {
      "name": "UAE Delivery",
      "blocks": [
        { "type": "faq", "settings": { "question": "What are Dubai delivery times?", "answer": "Same-day within Dubai city limits (typically ±4 hrs). Outside city limits: same- or next-day depending on address." } },
        { "type": "faq", "settings": { "question": "Do you ship across the UAE?", "answer": "Yes — next-day to all Emirates in most cases. You'll receive live tracking as soon as the courier collects your order." } }
      ]
    }
  ]
}
{% endschema %}
