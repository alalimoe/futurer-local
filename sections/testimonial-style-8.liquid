{{ 'testimonial-box.css' | asset_url | stylesheet_tag }}
{{ 'testimonial-box-8.css' | asset_url | stylesheet_tag }}
{{ 'image-button.css' | asset_url | stylesheet_tag }}

<section {% render 'section-attr' %}>
  <div class="testimonial-style-8">
    <xo-container class="testimonial-style-8__container">
      <div class="testimonial-style-8__content">
        {% liquid
          assign layout = section.settings.layout
          assign autoplay_time = section.settings.autoplay_time
          assign autoplay = section.settings.autoplay
          assign blocks = section.blocks
        %}
        {% render 'testimonial-box-8', layout: layout, autoplay: autoplay, autoplay_time: autoplay_time, blocks: blocks %}
      </div>
    </xo-container>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.testimonial_style_8.name",
  "disabled_on": {
    "groups": [
      "header",
      "footer",
      "custom.overlay",
      "custom.popups",
      "custom.features"
    ]
  },
  "settings": [
    {
      "type": "select",
      "id": "layout",
      "label": "t:sections.testimonial_style_8.settings.layout.label",
      "options": [
        {
          "value": "default",
          "label": "t:sections.testimonial_style_8.settings.layout.option__0.label"
        },
        {
          "value": "image",
          "label": "t:sections.testimonial_style_8.settings.layout.option__1.label"
        },
        {
          "value": "product",
          "label": "t:sections.testimonial_style_8.settings.layout.option__2.label"
        }
      ],
      "default": "product"
    },
    {
      "type": "select",
      "id": "autoplay",
      "label": "t:sections.testimonial_style_8.settings.autoplay.label",
      "options": [
        {
          "value": "off",
          "label": "t:sections.testimonial_style_8.settings.autoplay.option__1.label"
        },
        {
          "value": "on",
          "label": "t:sections.testimonial_style_8.settings.autoplay.option__2.label"
        }
      ],
      "default": "off"
    },
    {
      "type": "range",
      "id": "autoplay_time",
      "min": 1000,
      "max": 5000,
      "step": 1000,
      "label": "t:sections.testimonial_style_8.settings.autoplay_time.label",
      "default": 3000
    },
    {
      "type": "header",
      "content": "General settings"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Section color scheme"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color"
    },
    {
      "type": "color_background",
      "id": "background_gradient",
      "label": "Background gradient"
    },
    {
      "type": "number",
      "id": "padding_top_desktop",
      "label": "Padding top desktop",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_bottom_desktop",
      "label": "Padding bottom desktop",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_top_mobile",
      "label": "Padding top mobile",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom mobile",
      "default": 50
    }
  ],
