{% comment %}
  Nootropix — Wholesale / Large-Volume Orders (universal language + improved UX)
  Enhancements:
  • XO theme design system compliant — scoped CSS, theme tokens, flat design
  • SEO/CRO: concise intro with intent keywords, internal links, FAQPage JSON-LD
  • A11y: labels, aria attributes, focus states, reduced-motion
{% endcomment %}

{%- style -%}
  .xo-section--{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .xo-section--{{ section.id }} .npw-wrap {
    color: rgba(var(--color-foreground));
  }

  .xo-section--{{ section.id }} h1 {
    font-size: clamp(26px, 4vw, 40px);
    margin: 0 0 8px;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: rgba(var(--color-foreground));
  }

  .xo-section--{{ section.id }} h2 {
    font-size: clamp(18px, 2.6vw, 22px);
    margin: 0 0 10px;
    font-weight: 600;
    color: rgba(var(--color-foreground));
  }

  .xo-section--{{ section.id }} p {
    margin: 0 0 10px;
  }

  .xo-section--{{ section.id }} .npw-lead {
    font-size: clamp(16px, 2.6vw, 18px);
    color: color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent);
    margin-bottom: 14px;
  }

  .xo-section--{{ section.id }} .npw-lead a {
    color: rgba(var(--color-accent));
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .xo-section--{{ section.id }} .npw-muted {
    color: color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent);
    font-size: 13px;
  }

  .xo-section--{{ section.id }} .npw-btns {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin: 14px 0 0;
  }

  .xo-section--{{ section.id }} .npw-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 10px 16px;
    border-radius: var(--button-radius);
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
    text-decoration: none;
    font-weight: 600;
    transition: opacity 0.2s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .npw-btn--primary {
    background: rgba(var(--color-accent));
    color: rgba(var(--color-foreground));
    border-color: rgba(var(--color-accent));
  }

  .xo-section--{{ section.id }} .npw-btn--ghost {
    background: transparent;
    color: rgba(var(--color-foreground));
  }

  .xo-section--{{ section.id }} .npw-grid {
    display: grid;
    gap: 28px;
    grid-template-columns: 1fr;
    margin-top: 28px;
  }

  @media (min-width: 768px) {
    .xo-section--{{ section.id }} .npw-grid {
      grid-template-columns: 1.1fr 0.9fr;
    }
  }

  .xo-section--{{ section.id }} .npw-card {
    background: rgba(var(--color-background-2));
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
    border-radius: var(--general-radius-3, 2rem);
    padding: 18px;
    margin-bottom: 28px;
  }

  .xo-section--{{ section.id }} .npw-card + .npw-card {
    margin-top: 28px;
  }

  .xo-section--{{ section.id }} .npw-hr {
    height: 1px;
    background: color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
    margin: 18px 0;
  }

  .xo-section--{{ section.id }} table {
    width: 100%;
    border-collapse: collapse;
    margin: 6px 0;
  }

  .xo-section--{{ section.id }} th,
  .xo-section--{{ section.id }} td {
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
    padding: 10px 12px;
    text-align: left;
    font-size: 14px;
    vertical-align: middle;
  }

  .xo-section--{{ section.id }} th {
    background: rgba(var(--color-background));
    font-weight: 600;
  }

  .xo-section--{{ section.id }} .npw-ok {
    color: rgba(var(--color-success, 16, 167, 31));
    font-weight: 600;
  }

  .xo-section--{{ section.id }} .npw-kpis {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
    margin: 12px 0 2px;
  }

  .xo-section--{{ section.id }} .npw-k {
    background: rgba(var(--color-background));
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
    border-radius: var(--general-radius-1, 1rem);
    padding: 10px;
    text-align: center;
  }

  .xo-section--{{ section.id }} .npw-k .t {
    font-size: 12px;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent);
  }

  .xo-section--{{ section.id }} .npw-k .v {
    font-weight: 600;
    color: rgba(var(--color-foreground));
  }

  .xo-section--{{ section.id }} .npw-form label {
    display: block;
    font-size: 13px;
    margin: 8px 0 6px;
    color: rgba(var(--color-foreground));
  }

  .xo-section--{{ section.id }} .npw-form .req::after {
    content: " *";
    color: rgba(var(--color-error, 218, 30, 40));
  }

  .xo-section--{{ section.id }} .npw-form input,
  .xo-section--{{ section.id }} .npw-form select,
  .xo-section--{{ section.id }} .npw-form textarea {
    width: 100%;
    padding: 12px 14px;
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
    border-radius: var(--general-radius-1, 1rem);
    background: rgba(var(--color-background));
    font-size: 15px;
    line-height: 1.3;
    min-height: 44px;
    color: rgba(var(--color-foreground));
    transition: border-color 0.2s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .npw-form input:focus,
  .xo-section--{{ section.id }} .npw-form select:focus,
  .xo-section--{{ section.id }} .npw-form textarea:focus {
    outline: 2px solid rgba(var(--color-accent));
    outline-offset: 2px;
  }

  .xo-section--{{ section.id }} .npw-form .row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
  }

  @media (min-width: 768px) {
    .xo-section--{{ section.id }} .npw-form .row {
      grid-template-columns: 1fr 1fr;
    }
  }

  .xo-section--{{ section.id }} .npw-form .help {
    font-size: 12px;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent);
    margin-top: 4px;
  }

  .xo-section--{{ section.id }} .npw-form .npw-btn {
    width: 100%;
    margin-top: 10px;
  }

  .xo-section--{{ section.id }} .npw-faq dt {
    font-weight: 600;
    margin-top: 14px;
    color: rgba(var(--color-foreground));
  }

  .xo-section--{{ section.id }} .npw-faq dd {
    margin: 6px 0 18px;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent);
    padding-left: 2px;
  }

  .xo-section--{{ section.id }} :focus-visible {
    outline: 2px solid rgba(var(--color-accent));
    outline-offset: 2px;
  }

  @media (prefers-reduced-motion: reduce) {
    .xo-section--{{ section.id }} *,
    .xo-section--{{ section.id }} *::before,
    .xo-section--{{ section.id }} *::after {
      animation-duration: 0.01ms !important;
      transition-duration: 0.01ms !important;
    }
  }
{%- endstyle -%}

<section id="np-wholesale" {% render 'section-attr' %}>
  <xo-container>
    <div class="npw-wrap">
      <header>
        <h1>Wholesale &amp; Large-Volume Orders</h1>
        <p class="npw-lead">
          Better prices for bigger orders. Clear tiers. Fast replies (within 1 business day).
          Bulk examples: <a href="/products/phenibut-500mg-capsules">Phenibut HCL 500&nbsp;mg</a>,
          <a href="/products/phenibut-250mg-capsules">Phenibut HCL 250&nbsp;mg</a>,
          <a href="/products/phenibut-faa-300mg-capsules">Phenibut FAA 300&nbsp;mg</a>.
        </p>
        <div class="npw-btns">
          <a class="npw-btn npw-btn--primary" href="#apply" aria-label="Apply for wholesale">Apply for wholesale</a>
          <a class="npw-btn npw-btn--ghost" href="#tiers" aria-label="See pricing tiers">See pricing tiers</a>
        </div>
      </header>

      <div class="npw-grid">
        <div>
          <div id="tiers" class="npw-card" aria-labelledby="tiers-title">
            <h2 id="tiers-title">Pricing tiers</h2>
            <table aria-label="Wholesale pricing tiers">
              <thead>
                <tr><th>Tier</th><th>Order size</th><th>Discount</th></tr>
              </thead>
              <tbody>
                <tr><td>Tier 1</td><td>12+ items</td><td class="npw-ok">30% off our normal price</td></tr>
                <tr><td>Tier 2</td><td>24+ items</td><td class="npw-ok">35% off our normal price</td></tr>
                <tr><td>Tier 3</td><td>48+ items</td><td class="npw-ok">40% off our normal price</td></tr>
              </tbody>
            </table>
            <p class="npw-muted">We keep prices fair and safe. Very large orders may have limits. Quotes are valid for 7 days.</p>

            <div class="npw-kpis" aria-label="Wholesale benefits">
              <div class="npw-k"><div class="v">Priority</div><div class="t">Stock allocation</div></div>
              <div class="npw-k"><div class="v">COAs</div><div class="t">On file for SKUs</div></div>
              <div class="npw-k"><div class="v">Support</div><div class="t">Dedicated rep</div></div>
            </div>
          </div>

          <div class="npw-card" aria-labelledby="how-title">
            <h2 id="how-title">How it works</h2>
            <ol>
              <li>Send the form with your company, items, and quantity.</li>
              <li>We check stock and email your price list.</li>
              <li>Pay by card or bank transfer. We confirm and ship fast.</li>
              <li>You get tracking for each box.</li>
            </ol>
          </div>

          <div class="npw-card" aria-labelledby="faq-title">
            <h2 id="faq-title">Questions</h2>
            <dl class="npw-faq">
              <dt>Can I pay in instalments (Tabby/Tamara) for bulk?</dt>
              <dd>Instalments may work for smaller orders. Big orders often need card or bank transfer. We'll guide you.</dd>

              <dt>Which products can I order in bulk?</dt>
              <dd>Right now: Phenibut HCL 250&nbsp;mg, Phenibut HCL 500&nbsp;mg, and Phenibut FAA 300&nbsp;mg.</dd>

              <dt>Do you ship internationally?</dt>
              <dd>Yes. Same shipping policy applies. If a package never arrives, we refund. We may split into several boxes to make customs smoother.</dd>

              <dt>How long will it take?</dt>
              <dd>It depends on the quantity, but we prepare orders quickly. We'll confirm timing in our reply.</dd>

              <dt>Do you offer private label?</dt>
              <dd>Not now. We're exploring it. Tell us your idea so we can keep you updated.</dd>
            </dl>
          </div>
        </div>

        <div id="apply" class="npw-card">
          <h2>Apply for wholesale</h2>

          {% form 'contact', id: 'WholesaleForm', class: 'npw-form' %}
            {% if form.posted_successfully? %}
              <p class="npw-ok" role="status">Thank you — we'll reply within 1 business day.</p>
            {% else %}
              {% if form.errors %}<p class="npw-muted" role="alert">Please check the fields marked in red.</p>{% endif %}
              <input type="hidden" name="contact[tags]" value="wholesale, lead">

              <label class="req">Company
                <input type="text" name="contact[Company]" autocomplete="organization" required>
              </label>

              <div class="row">
                <label class="req">Contact name
                  <input type="text" name="contact[Name]" autocomplete="name" required>
                </label>
                <label class="req">Email
                  <input type="email" name="contact[email]" autocomplete="email" required>
                </label>
              </div>

              <label>Quantity (estimate)
                <input type="text" name="contact[Quantity estimate]" placeholder="e.g., 48 bottles / 10 × 500 g">
                <div class="help">Any unit is fine. Rough numbers are OK.</div>
              </label>

              <label>Products of interest
                <textarea name="contact[Products of interest]" rows="3" placeholder="e.g., Phenibut HCL 500 mg; Phenibut FAA 300 mg"></textarea>
              </label>

              <label>Message
                <textarea name="contact[Body]" rows="4" placeholder="Tell us your use case or timeline"></textarea>
              </label>

              <button type="submit" class="npw-btn npw-btn--primary">Send</button>
              <p class="npw-muted">Prefer email? <a href="mailto:wholesale@nootropix.shop">wholesale@nootropix.shop</a> or <a href="mailto:orders@nootropix.shop">orders@nootropix.shop</a>.</p>
            {% endif %}
          {% endform %}
        </div>
      </div>
    </div>
  </xo-container>

  {%- comment -%} SEO: FAQ schema to support Rich Results {%- endcomment -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Can I pay in instalments (Tabby/Tamara) for bulk?",
        "acceptedAnswer": { "@type": "Answer", "text": "Instalments may work for smaller orders. Big orders often need card or bank transfer. We'll guide you." }
      },
      {
        "@type": "Question",
        "name": "Which products can I order in bulk?",
        "acceptedAnswer": { "@type": "Answer", "text": "Right now: Phenibut HCL 250 mg, Phenibut HCL 500 mg, and Phenibut FAA 300 mg." }
      },
      {
        "@type": "Question",
        "name": "Do you ship internationally?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. Same shipping policy applies. If a package never arrives, we refund. We may split into several boxes to make customs smoother." }
      },
      {
        "@type": "Question",
        "name": "How long will it take?",
        "acceptedAnswer": { "@type": "Answer", "text": "It depends on the quantity, but we prepare orders quickly. We'll confirm timing in our reply." }
      },
      {
        "@type": "Question",
        "name": "Do you offer private label?",
        "acceptedAnswer": { "@type": "Answer", "text": "Not now. We're exploring it. Tell us your idea so we can keep you updated." }
      }
    ]
  }
  </script>
</section>

{% schema %}
{
  "name": "Nootropix Wholesale",
  "tag": "section",
  "class": "section-wholesale",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme" },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 48
    }
  ],
  "blocks": [
    { "type": "@app" }
  ],
  "presets": [
    { "name": "Nootropix Wholesale" }
  ]
}
{% endschema %}
