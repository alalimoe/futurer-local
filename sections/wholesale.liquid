{% comment %}
  Nootropix — Wholesale / Large-Volume Orders (universal language + improved UX)
  Enhancements:
  • Spacing tokens + consistent margins for breathing room
  • Clear, simple copy (no jargon), CTA in brand color (#FBBF24)
  • SEO/CRO: concise intro with intent keywords, internal links, FAQPage JSON-LD
  • A11y: labels, aria attributes, focus states
{% endcomment %}

<section id="np-wholesale" class="npw" dir="auto">
  <style>
    /* ---- Tokens / base ---- */
    .npw{
      --fg:var(--color-text-primary); --fg-sub:var(--color-text-secondary); --bg:var(--color-surface-primary); --muted:var(--color-surface-secondary); --ok:var(--color-success); --bdc:rgba(0,0,0,.10);
      --space:28px; --rad:12px; --rad-sm:10px; --accent:var(--color-text-primary); --brand:var(--color-accent-primary);
    }
    .npw *{box-sizing:border-box}
    .npw .wrap{max-width:var(--container-width-large);margin:0 auto;padding:48px var(--page-gutter);color:var(--fg);background:var(--bg);font-family:inherit}

    /* ---- Type ---- */
    .npw h1{font-size:clamp(26px,4vw,40px);margin:0 0 8px;font-weight:700;letter-spacing:-.01em}
    .npw h2{font-size:clamp(18px,2.6vw,22px);margin:0 0 10px}
    .npw p{margin:0 0 10px}
    .npw .lead{font-size:clamp(16px,2.6vw,18px);color:var(--fg-sub);margin-bottom:14px}
    .npw .muted{color:var(--fg-sub);font-size:13px}

    /* ---- Layout ---- */
    .npw .btns{display:flex;gap:10px;flex-wrap:wrap;margin:14px 0 0}
    .npw .btn{
      display:inline-flex;align-items:center;justify-content:center;gap:8px;padding:10px 16px;
      border-radius:var(--nx-radius-md);border:1px solid var(--bdc);text-decoration:none
    }
    .npw .btn--primary{background:var(--brand);color:var(--color-text-primary);border-color:var(--brand)}
    .npw .btn--ghost{background:transparent;color:var(--accent)}
    .npw .grid{display:grid;gap:var(--space);grid-template-columns:1fr;margin-top:var(--space)}
    @media(min-width:900px){.npw .grid{grid-template-columns:1.1fr .9fr}}
    .npw .card{background:var(--muted);border:1px solid var(--bdc);border-radius:var(--rad);padding:18px;margin-bottom:var(--space)}
    .npw .card + .card{margin-top:var(--space)}
    .npw .hr{height:1px;background:var(--bdc);margin:18px 0}

    /* ---- Table / badges ---- */
    .npw table{width:100%;border-collapse:collapse;margin:6px 0}
    .npw th,.npw td{border:1px solid var(--bdc);padding:10px 12px;text-align:left;font-size:14px;vertical-align:middle}
    .npw th{background:var(--color-surface-primary)}
    .npw .ok{color:var(--ok);font-weight:700}
    .npw .kpis{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin:12px 0 2px}
    .npw .k{background:var(--color-surface-primary);border:1px solid var(--bdc);border-radius:var(--nx-radius-md);padding:10px;text-align:center}
    .npw .k .t{font-size:12px;color:var(--fg-sub)}
    .npw .k .v{font-weight:700}

    /* ---- Form UX ---- */
    .npw .form label{display:block;font-size:13px;margin:8px 0 6px}
    .npw .form .req::after{content:" *";color:var(--color-error)}
    .npw .form input,.npw .form select,.npw .form textarea{
      width:100%;padding:12px 14px;border:1px solid var(--bdc);border-radius:var(--rad-sm);
      background:var(--color-surface-primary);font-size:15px;line-height:1.3;min-height:44px
    }
    .npw .form input:focus,.npw .form select:focus,.npw .form textarea:focus{
      outline:2px solid var(--color-success);box-shadow:0 0 0 2px rgba(10,127,66,.1)}
    .npw .form .row{display:grid;grid-template-columns:1fr;gap:12px}
    @media(min-width:700px){.npw .form .row{grid-template-columns:1fr 1fr}}
    .npw .form .help{font-size:12px;color:var(--fg-sub);margin-top:4px}
    .npw .form .btn{width:100%;margin-top:10px}

    /* ---- FAQ emphasis ---- */
    .npw .faq dt{font-weight:700;margin-top:14px}
    .npw .faq dd{margin:6px 0 18px;color:var(--fg-sub);padding-left:2px}
  </style>

  <div class="wrap">
    <!-- Hero -->
    <header>
      <h1>Wholesale &amp; Large-Volume Orders</h1>
      <p class="lead">
        Better prices for bigger orders. Clear tiers. Fast replies (within 1 business day).
        Bulk examples: <a href="/products/phenibut-500mg-capsules">Phenibut HCL 500&nbsp;mg</a>,
        <a href="/products/phenibut-250mg-capsules">Phenibut HCL 250&nbsp;mg</a>,
        <a href="/products/phenibut-faa-300mg-capsules">Phenibut FAA 300&nbsp;mg</a>.
      </p>
      <div class="btns">
        <a class="btn btn--primary" href="#apply" aria-label="Apply for wholesale">Apply for wholesale</a>
        <a class="btn btn--ghost" href="#tiers" aria-label="See pricing tiers">See pricing tiers</a>
      </div>
    </header>

    <div class="grid">
      <!-- Left column -->
      <div>
        <!-- Tiers (simple wording) -->
        <div id="tiers" class="card" aria-labelledby="tiers-title">
          <h2 id="tiers-title">Pricing tiers</h2>
          <table aria-label="Wholesale pricing tiers">
            <thead>
              <tr><th>Tier</th><th>Order size</th><th>Discount</th></tr>
            </thead>
            <tbody>
              <tr><td>Tier 1</td><td>12+ items</td><td class="ok">30% off our normal price</td></tr>
              <tr><td>Tier 2</td><td>24+ items</td><td class="ok">35% off our normal price</td></tr>
              <tr><td>Tier 3</td><td>48+ items</td><td class="ok">40% off our normal price</td></tr>
            </tbody>
          </table>
          <p class="muted">We keep prices fair and safe. Very large orders may have limits. Quotes are valid for 7 days.</p>

          <div class="kpis" aria-label="Wholesale benefits">
            <div class="k"><div class="v">Priority</div><div class="t">Stock allocation</div></div>
            <div class="k"><div class="v">COAs</div><div class="t">On file for SKUs</div></div>
            <div class="k"><div class="v">Support</div><div class="t">Dedicated rep</div></div>
          </div>
        </div>

        <!-- How it works -->
        <div class="card" aria-labelledby="how-title">
          <h2 id="how-title">How it works</h2>
          <ol>
            <li>Send the form with your company, items, and quantity.</li>
            <li>We check stock and email your price list.</li>
            <li>Pay by card or bank transfer. We confirm and ship fast.</li>
            <li>You get tracking for each box.</li>
          </ol>
        </div>

        <!-- FAQ -->
        <div class="card" aria-labelledby="faq-title">
          <h2 id="faq-title">Questions</h2>
          <dl class="faq">
            <dt>Can I pay in instalments (Tabby/Tamara) for bulk?</dt>
            <dd>Instalments may work for smaller orders. Big orders often need card or bank transfer. We’ll guide you.</dd>

            <dt>Which products can I order in bulk?</dt>
            <dd>Right now: Phenibut HCL 250&nbsp;mg, Phenibut HCL 500&nbsp;mg, and Phenibut FAA 300&nbsp;mg.</dd>

            <dt>Do you ship internationally?</dt>
            <dd>Yes. Same shipping policy applies. If a package never arrives, we refund. We may split into several boxes to make customs smoother.</dd>

            <dt>How long will it take?</dt>
            <dd>It depends on the quantity, but we prepare orders quickly. We’ll confirm timing in our reply.</dd>

            <dt>Do you offer private label?</dt>
            <dd>Not now. We’re exploring it. Tell us your idea so we can keep you updated.</dd>
          </dl>
        </div>
      </div>

      <!-- Right column: Form -->
      <div id="apply" class="card">
        <h2>Apply for wholesale</h2>

        {% form 'contact', id: 'WholesaleForm', class: 'form' %}
          {% if form.posted_successfully? %}
            <p class="ok" role="status">Thank you — we’ll reply within 1 business day.</p>
          {% else %}
            {% if form.errors %}<p class="muted" role="alert">Please check the fields marked in red.</p>{% endif %}
            <input type="hidden" name="contact[tags]" value="wholesale, lead">

            <label class="req">Company
              <input type="text" name="contact[Company]" autocomplete="organization" required>
            </label>

            <div class="row">
              <label class="req">Contact name
                <input type="text" name="contact[Name]" autocomplete="name" required>
              </label>
              <label class="req">Email
                <input type="email" name="contact[email]" autocomplete="email" required>
              </label>
            </div>

            <label>Quantity (estimate)
              <input type="text" name="contact[Quantity estimate]" placeholder="e.g., 48 bottles / 10 × 500 g">
              <div class="help">Any unit is fine. Rough numbers are OK.</div>
            </label>

            <label>Products of interest
              <textarea name="contact[Products of interest]" rows="3" placeholder="e.g., Phenibut HCL 500 mg; Phenibut FAA 300 mg"></textarea>
            </label>

            <label>Message
              <textarea name="contact[Body]" rows="4" placeholder="Tell us your use case or timeline"></textarea>
            </label>

            <button type="submit" class="btn btn--primary">Send</button>
            <p class="muted">Prefer email? <a href="mailto:wholesale@nootropix.shop">wholesale@nootropix.shop</a> or <a href="mailto:orders@nootropix.shop">orders@nootropix.shop</a>.</p>
          {% endif %}
        {% endform %}

        
      </div>
    </div>
  </div>

  {%- comment -%} SEO: FAQ schema to support Rich Results {%- endcomment -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Can I pay in instalments (Tabby/Tamara) for bulk?",
        "acceptedAnswer": { "@type": "Answer", "text": "Instalments may work for smaller orders. Big orders often need card or bank transfer. We’ll guide you." }
      },
      {
        "@type": "Question",
        "name": "Which products can I order in bulk?",
        "acceptedAnswer": { "@type": "Answer", "text": "Right now: Phenibut HCL 250 mg, Phenibut HCL 500 mg, and Phenibut FAA 300 mg." }
      },
      {
        "@type": "Question",
        "name": "Do you ship internationally?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. Same shipping policy applies. If a package never arrives, we refund. We may split into several boxes to make customs smoother." }
      },
      {
        "@type": "Question",
        "name": "How long will it take?",
        "acceptedAnswer": { "@type": "Answer", "text": "It depends on the quantity, but we prepare orders quickly. We’ll confirm timing in our reply." }
      },
      {
        "@type": "Question",
        "name": "Do you offer private label?",
        "acceptedAnswer": { "@type": "Answer", "text": "Not now. We’re exploring it. Tell us your idea so we can keep you updated." }
      }
    ]
  }
  </script>
</section>

{% schema %}{ "name": "Nootropix Wholesale", "settings": [] }{% endschema %}
