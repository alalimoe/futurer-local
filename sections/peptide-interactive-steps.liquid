{% schema %}
{
  "name": "Steps (Premium)",
  "tag": "section",
  "class": "section-peptide-steps",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#fafafb" },
    { "type": "color", "id": "card_bg", "label": "Card Background", "default": "rgba(255, 255, 255, 0.6)" },
    { "type": "color", "id": "accent_color", "label": "Brand Accent (Gold)", "default": "#FBBF24" },
    { "type": "color", "id": "text_color", "label": "Main Text", "default": "#0f172a" },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max Width (px)",
      "min": 700,
      "max": 1200,
      "step": 10,
      "default": 900
    },
    {
      "type": "range",
      "id": "padding_y",
      "label": "Vertical Padding (px)",
      "min": 40,
      "max": 160,
      "step": 4,
      "default": 80
    }
  ],
  "presets": [{"name": "Steps (Premium)"}]
}
{% endschema %}

{%- assign s = section.settings -%}
{%- assign sid = section.id -%}

<div class="ps-wrapper" id="ps-{{ sid }}">
  <div class="ps-ambient-glow"></div>
  <div class="ps-container">

    <div class="ps-header">
      <div class="ps-badge"><span class="ps-pulse"></span> Visual Protocol</div>
      <h2 class="ps-title">How to Mix Your Peptides Safely</h2>
    </div>

    <div class="ps-nav-wrap">
      <div class="ps-segmented-control" role="tablist" aria-label="Reconstitution steps">
        <button class="ps-seg-btn active" role="tab" aria-selected="true" aria-controls="ps-step-1-{{ sid }}" id="ps-tab-1-{{ sid }}" tabindex="0">1. Prep</button>
        <button class="ps-seg-btn" role="tab" aria-selected="false" aria-controls="ps-step-2-{{ sid }}" id="ps-tab-2-{{ sid }}" tabindex="-1">2. Draw</button>
        <button class="ps-seg-btn" role="tab" aria-selected="false" aria-controls="ps-step-3-{{ sid }}" id="ps-tab-3-{{ sid }}" tabindex="-1">3. Trickle</button>
        <button class="ps-seg-btn" role="tab" aria-selected="false" aria-controls="ps-step-4-{{ sid }}" id="ps-tab-4-{{ sid }}" tabindex="-1">4. Swirl</button>
      </div>
    </div>

    <div class="ps-content-card">

      <div id="ps-step-1-{{ sid }}" class="ps-pane active" role="tabpanel" aria-labelledby="ps-tab-1-{{ sid }}">
        <div class="ps-text-col">
          <h3>Step 1: Sanitize & Prep</h3>
          <p>Remove the plastic caps from both vials. Vigorously wipe both rubber stoppers with alcohol pads, and let them air dry.</p>
          <div class="ps-warning-box">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            <div><strong>Crucial:</strong> Let them air dry completely—do not blow on them!</div>
          </div>
        </div>
        <div class="ps-visual-col">
          <div class="ps-diagram-box">
            <div class="ps-icon-group">
              <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="9" y1="9" x2="15" y2="15"/><line x1="15" y1="9" x2="9" y2="15"/></svg>
              <span class="ps-plus">+</span>
              <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M10 2v3"/><path d="M14 2v3"/><path d="M8 5h8v3H8z"/><path d="M7 8v12a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V8"/></svg>
            </div>
            <div class="ps-badge-timer"><span class="ps-pulse-dot"></span> Wait 10s to Air Dry</div>
          </div>
        </div>
      </div>

      <div id="ps-step-2-{{ sid }}" class="ps-pane" role="tabpanel" aria-labelledby="ps-tab-2-{{ sid }}" hidden>
        <div class="ps-text-col">
          <h3>Step 2: Equalize Pressure & Draw</h3>
          <p>Draw the amount of bacteriostatic water you need into the mixing syringe.</p>
          <div class="ps-pro-tip"><strong>Pro tip:</strong> Pull air into your large mixing syringe equal to the amount of water you need. Inject that air into the right-side-up BAC water vial. This stops a vacuum from forming.</div>
        </div>
        <div class="ps-visual-col">
           <div class="ps-diagram-box ps-split">
             <div class="ps-split-half">
               <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="12" y1="5" x2="12" y2="19"/><polyline points="19 12 12 19 5 12"/></svg>
               <span class="ps-split-label">Push Air In</span>
             </div>
             <div class="ps-split-divider"></div>
             <div class="ps-split-half ps-split-half--blue">
               <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="12" y1="19" x2="12" y2="5"/><polyline points="5 12 12 5 19 12"/></svg>
               <span class="ps-split-label ps-split-label--blue">Pull Water Out</span>
             </div>
           </div>
        </div>
      </div>

      <div id="ps-step-3-{{ sid }}" class="ps-pane" role="tabpanel" aria-labelledby="ps-tab-3-{{ sid }}" hidden>
        <div class="ps-text-col">
          <h3>Step 3: The Gentle Trickle</h3>
          <p>Push the needle into the peptide vial. <strong>Aim so the water drips on the glass wall</strong>, not directly at the powder.</p>
          <p>Peptides are fragile—never blast water straight down onto the powder!</p>
        </div>
        <div class="ps-visual-col">
           <div class="ps-diagram-box ps-diagram-box--compact">
             <div class="ps-do-box">
               <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg>
               Angle needle 45° - Drip on glass wall
             </div>
             <div class="ps-dont-box">
               <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
               Straight down 90° - Blast the powder
             </div>
           </div>
        </div>
      </div>

      <div id="ps-step-4-{{ sid }}" class="ps-pane" role="tabpanel" aria-labelledby="ps-tab-4-{{ sid }}" hidden>
        <div class="ps-text-col">
          <h3>Step 4: Swirl, Don't Shake</h3>
          <p>Gently swirl the vial, pull the needle out, and gently roll it until the liquid is completely clear.</p>
          <p><strong>Never shake the vial.</strong> Peptides are very delicate, shaking can destroy them.</p>
        </div>
        <div class="ps-visual-col">
           <div class="ps-diagram-box ps-split">
             <div class="ps-split-half ps-split-half--green">
               <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>
               <span class="ps-split-label ps-split-label--green">Swirl Gently</span>
             </div>
             <div class="ps-split-divider"></div>
             <div class="ps-split-half ps-split-half--red">
               <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 13l-6-6-8 8 6 6z"/><path d="M14 17l4-4"/><path d="M8 11l4-4"/><path d="M4 15l4-4"/></svg>
               <span class="ps-split-label ps-split-label--red">DO NOT Shake</span>
             </div>
           </div>
        </div>
      </div>

    </div>
  </div>
</div>

{%- style -%}
  #ps-{{ sid }} {
    --ps-bg: {{ s.bg_color }};
    --ps-card: {{ s.card_bg }};
    --ps-accent: {{ s.accent_color }};
    --ps-text: {{ s.text_color }};
    --ps-max: {{ s.max_width | default: 900 }}px;
    --ps-py: {{ s.padding_y | default: 80 }}px;
    --ps-muted: var(--color-text-muted, #4b5563);
    --ps-font: var(--font-body-family, sans-serif);
    --ps-radius: var(--nx-radius, 14px);
    --ps-shadow-sm: var(--shadow-sm, 0 2px 8px rgba(0,0,0,0.04));
    --ps-shadow-md: var(--shadow-md, 0 12px 30px rgba(0,0,0,0.06));
    --ps-transition: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
    content-visibility: auto;
  }

  .ps-wrapper { background: var(--ps-bg); color: var(--ps-text); padding: var(--ps-py) var(--page-gutter); font-family: var(--ps-font); position: relative; overflow: hidden; }
  .ps-ambient-glow { position: absolute; top: 10%; right: -10%; width: 500px; height: 500px; background: radial-gradient(circle, rgba(251,191,36,0.06), transparent 60%); pointer-events: none; }
  .ps-container { max-width: var(--ps-max); margin: 0 auto; position: relative; z-index: 1; }

  .ps-header { text-align: center; margin-bottom: 40px; }
  .ps-badge { display: inline-flex; align-items: center; gap: 8px; background: var(--color-bg-primary, #fff); padding: 6px 14px; border-radius: var(--nx-radius-pill); font-size: 11px; font-weight: 800; text-transform: uppercase; letter-spacing: 1px; color: var(--ps-muted); margin-bottom: 16px; box-shadow: var(--ps-shadow-sm); }
  .ps-pulse { width: 6px; height: 6px; background: var(--ps-accent); border-radius: 50%; box-shadow: 0 0 8px var(--ps-accent); animation: psPulse 2s infinite; }
  @keyframes psPulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }
  .ps-title { font-size: 32px; font-weight: 800; margin: 0; letter-spacing: -0.5px; }

  .ps-nav-wrap { display: flex; justify-content: center; margin-bottom: 40px; }
  .ps-segmented-control { display: inline-flex; background: rgba(15,23,42,0.04); padding: 6px; border-radius: var(--nx-radius-pill); backdrop-filter: blur(8px); box-shadow: var(--ps-shadow-sm); }
  .ps-seg-btn { background: transparent; border: none; padding: 10px 24px; border-radius: var(--nx-radius-pill); font-size: 14px; font-weight: 600; color: var(--ps-muted); cursor: pointer; transition: var(--ps-transition); font-family: inherit; min-height: var(--touch-min, 44px); }
  .ps-seg-btn:hover { color: var(--ps-text); }
  .ps-seg-btn.active { background: var(--color-bg-primary, #fff); color: var(--ps-text); box-shadow: var(--shadow-sm); }
  .ps-seg-btn:active { transform: scale(0.98); }

  .ps-content-card { background: var(--ps-card); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); border-radius: var(--nx-radius-lg); padding: 48px; box-shadow: 0 20px 40px -10px rgba(0,0,0,0.05), inset 0 1px 0 rgba(255,255,255,1); min-height: 320px; }
  .ps-pane { display: none; gap: 50px; align-items: center; animation: psSlideIn 0.4s cubic-bezier(0.16, 1, 0.3, 1); }
  .ps-pane.active { display: flex; }
  @keyframes psSlideIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

  .ps-text-col { flex: 1 1 350px; }
  .ps-text-col h3 { margin: 0 0 16px; font-size: 24px; font-weight: 800; letter-spacing: -0.5px; }
  .ps-text-col p { margin: 0 0 20px; font-size: 16px; color: var(--ps-muted); line-height: 1.6; }

  .ps-warning-box { display: flex; align-items: flex-start; gap: 12px; background: linear-gradient(90deg, #fffbeb, transparent); padding: 16px; padding-left: 20px; font-size: 14px; color: var(--color-accent-dark, #92400e); margin-top: 24px; border-radius: var(--nx-radius-sm); position: relative; }
  .ps-warning-box::before { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 3px; background: #f59e0b; border-radius: 3px 0 0 3px; }
  .ps-warning-box svg { color: #d97706; flex-shrink: 0; margin-top: 2px; }
  .ps-pro-tip { background: rgba(255,255,255,0.5); padding: 16px; border-radius: var(--nx-radius-md); font-size: 14px; color: var(--color-text-main, #111827); line-height: 1.5; box-shadow: var(--ps-shadow-sm); }

  .ps-visual-col { flex: 1 1 300px; }
  .ps-diagram-box { background: rgba(248, 250, 252, 0.6); border-radius: var(--nx-radius); padding: 40px 30px; display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 200px; box-shadow: inset 0 2px 10px rgba(0,0,0,0.02); }
  .ps-diagram-box--compact { padding: 24px; gap: 12px; }

  .ps-icon-group { display: flex; align-items: center; gap: 16px; color: var(--ps-text); margin-bottom: 24px; }
  .ps-plus { font-size: 24px; color: #94a3b8; font-weight: 300; }

  .ps-badge-timer { background: #ffffff; padding: 8px 16px; border-radius: var(--nx-radius-pill); font-size: 12px; font-weight: 700; color: var(--color-surface-tertiary); display: flex; align-items: center; gap: 8px; box-shadow: var(--ps-shadow-sm); }
  .ps-pulse-dot { width: 8px; height: 8px; background: #ef4444; border-radius: 50%; box-shadow: 0 0 8px #ef4444; animation: psPulseStep 2s infinite; }

  .ps-split { flex-direction: row; padding: 0; overflow: hidden; }
  .ps-split-half { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 40px 10px; color: #475569; }
  .ps-split-half--blue { color: #3b82f6; }
  .ps-split-half--blue svg { stroke: #3b82f6; }
  .ps-split-half--green { color: #059669; }
  .ps-split-half--green svg { stroke: #059669; }
  .ps-split-half--red { color: #dc2626; }
  .ps-split-half--red svg { stroke: #dc2626; }
  .ps-split-divider { width: 1px; background: rgba(15,23,42,0.08); align-self: stretch; }
  .ps-split-label { font-size: 12px; font-weight: 800; margin-top: 16px; text-transform: uppercase; letter-spacing: 0.5px; }
  .ps-split-label--blue { color: #3b82f6; }
  .ps-split-label--green { color: #047857; }
  .ps-split-label--red { color: #b91c1c; }

  .ps-do-box, .ps-dont-box { width: 100%; padding: 16px; border-radius: var(--nx-radius-md); font-size: 14px; font-weight: 700; display: flex; align-items: center; gap: 12px; }
  .ps-do-box { background: #ecfdf5; color: #065f46; box-shadow: inset 0 0 0 1px rgba(16,185,129,0.2); }
  .ps-dont-box { background: #fef2f2; color: #991b1b; box-shadow: inset 0 0 0 1px rgba(239,68,68,0.2); }

  @keyframes psPulseStep { 0% { transform: scale(1); opacity: 1; } 50% { transform: scale(1.5); opacity: 0.5; } 100% { transform: scale(1); opacity: 1; } }

  .ps-wrapper :focus-visible { outline: 2px solid var(--color-accent-primary, #FBBF24); outline-offset: 2px; }

  @media (prefers-reduced-motion: reduce) {
    .ps-wrapper *, .ps-wrapper *::before, .ps-wrapper *::after { animation-duration: 0.01ms !important; transition-duration: 0.01ms !important; }
  }

  @media (max-width: 768px) {
    .ps-content-card { padding: 32px 24px; }
    .ps-pane { flex-direction: column; gap: 40px; }
    .ps-segmented-control { flex-wrap: wrap; justify-content: center; border-radius: var(--nx-radius); padding: 8px; }
    .ps-seg-btn { width: 48%; text-align: center; }
  }
{%- endstyle -%}

<script>
  (function() {
    var root = document.getElementById('ps-{{ sid }}');
    var tabs = root.querySelectorAll('[role="tab"]');
    var panes = root.querySelectorAll('[role="tabpanel"]');

    function activateTab(index) {
      tabs.forEach(function(t, i) {
        var active = i === index;
        t.classList.toggle('active', active);
        t.setAttribute('aria-selected', active ? 'true' : 'false');
        t.setAttribute('tabindex', active ? '0' : '-1');
      });
      panes.forEach(function(p, i) {
        var active = i === index;
        p.classList.toggle('active', active);
        if (active) { p.removeAttribute('hidden'); } else { p.setAttribute('hidden', ''); }
      });
    }

    tabs.forEach(function(tab, i) {
      tab.addEventListener('click', function() { activateTab(i); });
      tab.addEventListener('keydown', function(e) {
        var dir = 0;
        if (e.key === 'ArrowRight' || e.key === 'ArrowDown') dir = 1;
        else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') dir = -1;
        else if (e.key === 'Home') { e.preventDefault(); activateTab(0); tabs[0].focus(); return; }
        else if (e.key === 'End') { e.preventDefault(); activateTab(tabs.length - 1); tabs[tabs.length - 1].focus(); return; }
        if (dir) {
          e.preventDefault();
          var next = (i + dir + tabs.length) % tabs.length;
          activateTab(next);
          tabs[next].focus();
        }
      });
    });
  })();
</script>
