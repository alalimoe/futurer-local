{% schema %}
{
  "name": "COA Finder Steps",
  "tag": "section",
  "class": "section-coa-finder-steps",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Find your COA (fast)" },
    { "type": "header", "content": "Steps" },
    { "type": "textarea", "id": "step_1_text", "label": "Step 1", "default": "Locate the batch/lot on your product label (a quick photo is fine)." },
    { "type": "textarea", "id": "step_2_text", "label": "Step 2", "default": "Match the lot to the COA in the library below (or use the COA link on the product page)." },
    { "type": "textarea", "id": "step_3_text", "label": "Step 3", "default": "Save the PDF for your records — especially in the UAE, where shipping conditions can vary." },
    { "type": "header", "content": "Note" },
    { "type": "checkbox", "id": "show_note", "label": "Show Note", "default": true },
    { "type": "text", "id": "note_title", "label": "Note Title", "default": "Important" },
    { "type": "textarea", "id": "note_text", "label": "Note Text", "default": "If your label is missing a batch/lot number or the COA link doesn't load, don't guess — contact support with your order number + a label photo." },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#ffffff" },
    { "type": "color", "id": "accent_color", "label": "Accent", "default": "#FBBF24" }
  ],
  "presets": [{ "name": "COA Finder Steps" }]
}
{% endschema %}

<div class="clf-wrapper" id="clf-{{ section.id }}">
  <div class="clf-inner">
    {% if section.settings.heading != blank %}
      <h2 class="clf-heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="clf-steps">
      {% if section.settings.step_1_text != blank %}
        <div class="clf-step">
          <div class="clf-step-num">1</div>
          <div class="clf-step-text">{{ section.settings.step_1_text }}</div>
        </div>
      {% endif %}
      {% if section.settings.step_2_text != blank %}
        <div class="clf-step">
          <div class="clf-step-num">2</div>
          <div class="clf-step-text">{{ section.settings.step_2_text }}</div>
        </div>
      {% endif %}
      {% if section.settings.step_3_text != blank %}
        <div class="clf-step">
          <div class="clf-step-num">3</div>
          <div class="clf-step-text">{{ section.settings.step_3_text }}</div>
        </div>
      {% endif %}
    </div>

    {% if section.settings.show_note and section.settings.note_text != blank %}
      <div class="clf-note">
        {% if section.settings.note_title != blank %}
          <div class="clf-note-title">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            {{ section.settings.note_title }}
          </div>
        {% endif %}
        <div class="clf-note-text">{{ section.settings.note_text }}</div>
      </div>
    {% endif %}
  </div>
</div>

<style>
  #clf-{{ section.id }} {
    --clf-bg: {{ section.settings.bg_color }};
    --clf-accent: {{ section.settings.accent_color }};
    --clf-text: var(--color-text-main, #111827);
    --clf-muted: var(--color-text-muted, #4b5563);
    --clf-border: var(--nx-pill-border, #E5E7EB);
    --clf-radius: var(--nx-radius, 14px);
    --clf-font: var(--font-body-family, sans-serif);
    --clf-font-heading: var(--font-heading-family, sans-serif);
    --clf-transition: var(--transition-smooth, all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1));
  }

  .clf-wrapper {
    background: var(--clf-bg);
    padding: 64px var(--page-gutter);
    font-family: var(--clf-font);
  }
  .clf-inner {
    max-width: 800px;
    margin: 0 auto;
  }

  .clf-heading {
    font-family: var(--clf-font-heading);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 800;
    color: var(--clf-text);
    margin: 0 0 32px;
    letter-spacing: -0.02em;
  }

  .clf-steps {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-bottom: 32px;
  }
  .clf-step {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    padding: 20px;
    background: var(--color-bg-secondary, #f9fafb);
    border-radius: var(--clf-radius);
    transition: var(--clf-transition);
  }
  .clf-step:hover {
    box-shadow: var(--shadow-sm, 0 2px 8px rgba(0,0,0,0.04));
  }
  .clf-step-num {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--clf-accent);
    color: var(--color-text-primary);
    font-weight: 800;
    font-size: 0.875rem;
    border-radius: 50%;
  }
  .clf-step-text {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--clf-text);
    padding-top: 4px;
  }

  .clf-note {
    padding: 20px;
    background: rgba(251, 191, 36, 0.06);
    border: 2px solid var(--clf-accent);
    border-radius: var(--clf-radius);
  }
  .clf-note-title {
    display: flex;
    align-items: center;
    gap: 8px;
    font-weight: 700;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--color-accent-dark, #92400e);
    margin-bottom: 8px;
  }
  .clf-note-title svg { color: var(--clf-accent); }
  .clf-note-text {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--clf-muted);
  }

  .clf-wrapper :focus-visible {
    outline: 2px solid var(--clf-accent);
    outline-offset: 2px;
  }

  @media (prefers-reduced-motion: reduce) {
    .clf-wrapper *, .clf-wrapper *::before, .clf-wrapper *::after {
      animation-duration: 0.01ms !important;
      transition-duration: 0.01ms !important;
    }
  }

  @media (max-width: 640px) {
    .clf-wrapper { padding: 48px var(--page-gutter); }
    .clf-step { padding: 16px; }
  }
</style>
