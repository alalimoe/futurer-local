{%- style -%}
  .xo-section--{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .xo-section--{{ section.id }} .clf-inner {
    max-width: 800px;
    margin: 0 auto;
  }

  .xo-section--{{ section.id }} .clf-heading {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 600;
    color: rgba(var(--color-foreground));
    margin: 0 0 32px;
    letter-spacing: -0.02em;
  }

  .xo-section--{{ section.id }} .clf-steps {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-bottom: 32px;
  }

  .xo-section--{{ section.id }} .clf-step {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    padding: 20px;
    background: rgba(var(--color-background-2));
    border-radius: var(--general-radius-1, 1rem);
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
    transition: border-color 0.3s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .clf-step:hover {
    border-color: rgba(var(--color-accent));
  }

  .xo-section--{{ section.id }} .clf-step-num {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(var(--color-accent));
    color: rgba(var(--color-foreground));
    font-weight: 600;
    font-size: 0.875rem;
    border-radius: 50%;
  }

  .xo-section--{{ section.id }} .clf-step-text {
    font-size: 1rem;
    line-height: 1.6;
    color: rgba(var(--color-foreground));
    padding-top: 4px;
  }

  .xo-section--{{ section.id }} .clf-note {
    padding: 20px;
    background: color-mix(in srgb, rgba(var(--color-accent)) 6%, transparent);
    border: 2px solid rgba(var(--color-accent));
    border-radius: var(--general-radius-1, 1rem);
  }

  .xo-section--{{ section.id }} .clf-note-title {
    display: flex;
    align-items: center;
    gap: 8px;
    font-weight: 600;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: rgba(var(--color-foreground));
    margin-bottom: 8px;
  }

  .xo-section--{{ section.id }} .clf-note-title svg {
    color: rgba(var(--color-accent));
  }

  .xo-section--{{ section.id }} .clf-note-text {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent);
  }

  .xo-section--{{ section.id }} :focus-visible {
    outline: 2px solid rgba(var(--color-accent));
    outline-offset: 2px;
  }

  @media (max-width: 768px) {
    .xo-section--{{ section.id }} .clf-step {
      padding: 16px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .xo-section--{{ section.id }} .clf-step {
      transition: none;
    }
  }
{%- endstyle -%}

<section {% render 'section-attr' %}>
  <xo-container>
    <div class="clf-inner">
      {% if section.settings.heading != blank %}
        <h2 class="clf-heading">{{ section.settings.heading }}</h2>
      {% endif %}

      <div class="clf-steps">
        {% if section.settings.step_1_text != blank %}
          <div class="clf-step">
            <div class="clf-step-num">1</div>
            <div class="clf-step-text">{{ section.settings.step_1_text }}</div>
          </div>
        {% endif %}
        {% if section.settings.step_2_text != blank %}
          <div class="clf-step">
            <div class="clf-step-num">2</div>
            <div class="clf-step-text">{{ section.settings.step_2_text }}</div>
          </div>
        {% endif %}
        {% if section.settings.step_3_text != blank %}
          <div class="clf-step">
            <div class="clf-step-num">3</div>
            <div class="clf-step-text">{{ section.settings.step_3_text }}</div>
          </div>
        {% endif %}
      </div>

      {% if section.settings.show_note and section.settings.note_text != blank %}
        <div class="clf-note">
          {% if section.settings.note_title != blank %}
            <div class="clf-note-title">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
              {{ section.settings.note_title }}
            </div>
          {% endif %}
          <div class="clf-note-text">{{ section.settings.note_text }}</div>
        </div>
      {% endif %}
    </div>
  </xo-container>
</section>

{% schema %}
{
  "name": "COA Finder Steps",
  "tag": "section",
  "class": "section-coa-finder-steps",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "default"
    },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Find your COA (fast)" },
    { "type": "header", "content": "Steps" },
    { "type": "textarea", "id": "step_1_text", "label": "Step 1", "default": "Locate the batch/lot on your product label (a quick photo is fine)." },
    { "type": "textarea", "id": "step_2_text", "label": "Step 2", "default": "Match the lot to the COA in the library below (or use the COA link on the product page)." },
    { "type": "textarea", "id": "step_3_text", "label": "Step 3", "default": "Save the PDF for your records — especially in the UAE, where shipping conditions can vary." },
    { "type": "header", "content": "Note" },
    { "type": "checkbox", "id": "show_note", "label": "Show Note", "default": true },
    { "type": "text", "id": "note_title", "label": "Note Title", "default": "Important" },
    { "type": "textarea", "id": "note_text", "label": "Note Text", "default": "If your label is missing a batch/lot number or the COA link doesn't load, don't guess — contact support with your order number + a label photo." },
    { "type": "header", "content": "Spacing" },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 64
    }
  ],
  "blocks": [
    { "type": "@app" }
  ],
  "presets": [{ "name": "COA Finder Steps" }]
}
{% endschema %}
