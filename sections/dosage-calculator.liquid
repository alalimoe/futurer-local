{%- style -%}
  .xo-section--{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .xo-section--{{ section.id }} .nc-header {
    text-align: center;
    max-width: 600px;
    margin: 0 auto 50px;
  }

  .xo-section--{{ section.id }} .nc-brand-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: color-mix(in srgb, rgba(var(--color-accent)) 10%, transparent);
    color: rgba(var(--color-accent));
    padding: 4px 12px;
    border-radius: var(--button-radius);
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 16px;
  }

  .xo-section--{{ section.id }} .nc-title {
    font-family: var(--font-heading-family);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 600;
    color: rgba(var(--color-foreground));
    margin: 0 0 12px;
    letter-spacing: -0.025em;
    line-height: 1.2;
  }

  .xo-section--{{ section.id }} .nc-subtitle {
    color: color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent);
    font-size: clamp(0.875rem, 1.5vw, 1rem);
  }

  .xo-section--{{ section.id }} .nc-main-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 40px;
    align-items: start;
  }

  @media (max-width: 768px) {
    .xo-section--{{ section.id }} .nc-main-grid {
      grid-template-columns: 1fr;
    }
  }

  .xo-section--{{ section.id }} .nc-inputs-col {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .xo-section--{{ section.id }} .nc-step-card {
    background: rgba(var(--color-background));
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
    border-radius: var(--general-radius-1, 1rem);
    padding: 24px;
    transition: border-color 0.3s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .nc-step-card:hover {
    border-color: color-mix(in srgb, rgba(var(--color-foreground)) 20%, transparent);
  }

  .xo-section--{{ section.id }} .nc-step-label {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 4px;
  }

  .xo-section--{{ section.id }} .nc-step-num {
    background: rgba(var(--color-accent));
    color: rgba(var(--color-foreground));
    width: 24px;
    height: 24px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
    font-size: 12px;
  }

  .xo-section--{{ section.id }} .nc-step-text {
    font-family: var(--font-heading-family);
    font-weight: 600;
    font-size: clamp(0.875rem, 1.5vw, 1rem);
    color: rgba(var(--color-foreground));
    letter-spacing: -0.01em;
  }

  .xo-section--{{ section.id }} .nc-explainer {
    margin: 0 0 16px 36px;
    font-size: clamp(0.8rem, 1.2vw, 0.875rem);
    color: color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent);
    line-height: 1.5;
  }

  .xo-section--{{ section.id }} .nc-options-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }

  .xo-section--{{ section.id }} .nc-option-btn {
    background: rgba(var(--color-background));
    border: 1.5px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
    border-radius: var(--general-radius-1, 1rem);
    padding: 16px 8px;
    min-height: 44px;
    cursor: pointer;
    text-align: center;
    transition: border-color 0.3s var(--out-soft, ease);
    color: rgba(var(--color-foreground));
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .xo-section--{{ section.id }} .nc-option-btn:hover {
    border-color: color-mix(in srgb, rgba(var(--color-foreground)) 25%, transparent);
  }

  .xo-section--{{ section.id }} .nc-option-btn.active {
    border-color: rgba(var(--color-accent));
    background: color-mix(in srgb, rgba(var(--color-accent)) 8%, transparent);
    animation: ntx-calc-pulse-{{ section.id }} 0.4s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .nc-option-btn:focus-visible {
    outline: 2px solid rgba(var(--color-accent));
    outline-offset: 2px;
  }

  .xo-section--{{ section.id }} .nc-icon-wrap {
    color: color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent);
    margin-bottom: 8px;
    transition: color 0.3s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .nc-option-btn.active .nc-icon-wrap {
    color: rgba(var(--color-accent));
  }

  .xo-section--{{ section.id }} .nc-icon {
    width: 24px;
    height: 24px;
  }

  .xo-section--{{ section.id }} .nc-option-btn span {
    font-weight: 600;
    font-size: clamp(0.8rem, 1.2vw, 0.875rem);
    display: block;
  }

  .xo-section--{{ section.id }} .nc-option-btn small {
    font-size: 10px;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent);
    text-transform: uppercase;
    font-weight: 600;
    margin-top: 2px;
  }

  .xo-section--{{ section.id }} .nc-options-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .xo-section--{{ section.id }} .nc-pill-btn {
    flex: 1;
    min-width: 60px;
    min-height: 44px;
    background: rgba(var(--color-background));
    border: 1.5px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
    padding: 10px 16px;
    border-radius: var(--button-radius);
    font-size: clamp(0.8rem, 1.2vw, 0.875rem);
    font-weight: 500;
    color: rgba(var(--color-foreground));
    cursor: pointer;
    transition: border-color 0.3s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .nc-pill-btn:hover {
    border-color: color-mix(in srgb, rgba(var(--color-foreground)) 25%, transparent);
  }

  .xo-section--{{ section.id }} .nc-pill-btn:active {
    transform: scale(0.96);
  }

  .xo-section--{{ section.id }} .nc-pill-btn:focus-visible {
    outline: 2px solid rgba(var(--color-accent));
    outline-offset: 2px;
  }

  .xo-section--{{ section.id }} .nc-pill-btn.active {
    background: rgba(var(--color-accent));
    border-color: rgba(var(--color-accent));
    color: rgba(var(--color-foreground));
    font-weight: 600;
    animation: ntx-calc-pulse-{{ section.id }} 0.4s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .nc-input-reveal {
    margin-top: 12px;
  }

  .xo-section--{{ section.id }} .nc-input-reveal.hidden {
    display: none;
  }

  .xo-section--{{ section.id }} .nc-input-reveal input {
    width: 100%;
    padding: 12px 14px;
    border: 1.5px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
    border-radius: var(--button-radius);
    font-size: clamp(0.8rem, 1.2vw, 0.875rem);
    font-family: var(--font-body-family);
    outline: none;
    background: rgba(var(--color-background-2));
    color: rgba(var(--color-foreground));
    min-height: 44px;
    transition: border-color 0.3s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .nc-input-reveal input:focus {
    border-color: rgba(var(--color-accent));
    background: rgba(var(--color-background));
  }

  .xo-section--{{ section.id }} .nc-results-col {
    position: sticky;
    top: 40px;
  }

  .xo-section--{{ section.id }} .nc-result-card {
    background: rgba(var(--color-background));
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
    border-radius: var(--general-radius-1, 1rem);
    padding: 32px;
    text-align: center;
  }

  .xo-section--{{ section.id }} .nc-result-label {
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent);
    display: block;
    margin-bottom: 20px;
  }

  .xo-section--{{ section.id }} .nc-hero-text {
    font-size: 14px;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent);
    margin-bottom: 4px;
  }

  .xo-section--{{ section.id }} .nc-hero-val {
    font-family: var(--font-heading-family);
    font-size: clamp(2.5rem, 5vw, 3rem);
    font-weight: 600;
    color: rgba(var(--color-foreground));
    line-height: 1;
    margin-bottom: 8px;
    letter-spacing: -0.03em;
    transition: color 0.3s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .nc-hero-val small {
    font-size: 14px;
    color: rgba(var(--color-accent));
    vertical-align: middle;
    margin-left: 4px;
  }

  .xo-section--{{ section.id }} .nc-hero-sub {
    font-size: 14px;
    color: rgba(var(--color-foreground));
  }

  .xo-section--{{ section.id }} .nc-syringe-visual {
    margin: 40px auto 10px;
    width: 100%;
    max-width: 320px;
    height: 40px;
    position: relative;
    display: flex;
    align-items: center;
  }

  .xo-section--{{ section.id }} .nc-needle-tip {
    width: 20px;
    height: 1px;
    background: color-mix(in srgb, rgba(var(--color-foreground)) 40%, transparent);
    position: absolute;
    left: -20px;
  }

  .xo-section--{{ section.id }} .nc-syringe-barrel {
    flex-grow: 1;
    height: 100%;
    border: 2px solid color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent);
    border-radius: 4px;
    position: relative;
    background: rgba(var(--color-background));
    overflow: hidden;
    z-index: 2;
  }

  .xo-section--{{ section.id }} .nc-liquid {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    background: rgba(var(--color-accent));
    width: 33%;
    opacity: 0.8;
    transition: width 0.4s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .xo-section--{{ section.id }} .nc-graduations {
    position: absolute;
    inset: 0;
    background-image: repeating-linear-gradient(90deg,
      transparent, transparent calc(10% - 1px),
      color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent) calc(10% - 1px),
      color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent) 10%);
  }

  .xo-section--{{ section.id }} .nc-plunger-stopper {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 4px;
    background: rgba(var(--color-foreground));
    left: 33%;
    transform: translateX(-50%);
    transition: left 0.4s cubic-bezier(0.25, 1, 0.5, 1);
    z-index: 3;
  }

  .xo-section--{{ section.id }} .nc-plunger-rod {
    position: absolute;
    height: 8px;
    background: color-mix(in srgb, rgba(var(--color-foreground)) 20%, transparent);
    top: 50%;
    transform: translateY(-50%);
    left: 100%;
    width: 40px;
    z-index: 1;
  }

  .xo-section--{{ section.id }} .nc-syringe-flange {
    display: none;
  }

  .xo-section--{{ section.id }} .nc-ruler-scale {
    display: flex;
    justify-content: space-between;
    font-size: 10px;
    font-family: monospace;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent);
    max-width: 320px;
    margin: 0 auto 30px;
  }

  .xo-section--{{ section.id }} .nc-summary-action {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    background: rgba(var(--color-background-2));
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
    border-radius: var(--general-radius-1, 1rem);
    padding: 16px;
    margin-bottom: 24px;
  }

  .xo-section--{{ section.id }} .nc-summary-action.hidden {
    display: none;
  }

  .xo-section--{{ section.id }} .nc-summary-text {
    font-size: 14px;
    color: rgba(var(--color-foreground));
    line-height: 1.4;
    text-align: center;
  }

  .xo-section--{{ section.id }} .nc-copy-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(var(--color-background));
    border: 1.5px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
    color: rgba(var(--color-foreground));
    font-size: 13px;
    font-family: var(--font-body-family);
    font-weight: 600;
    padding: 8px 16px;
    min-height: 44px;
    border-radius: var(--button-radius);
    cursor: pointer;
    transition: border-color 0.3s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .nc-copy-btn svg {
    flex-shrink: 0;
    transition: transform 0.3s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .nc-copy-btn:hover {
    border-color: color-mix(in srgb, rgba(var(--color-foreground)) 25%, transparent);
    background: rgba(var(--color-background-2));
  }

  .xo-section--{{ section.id }} .nc-copy-btn:focus-visible {
    outline: 2px solid rgba(var(--color-accent));
    outline-offset: 2px;
  }

  .xo-section--{{ section.id }} .nc-copy-btn.copied {
    border-color: rgba(var(--color-success));
    color: rgba(var(--color-success));
  }

  .xo-section--{{ section.id }} .nc-copy-btn.copied svg {
    transform: scale(1.2);
  }

  .xo-section--{{ section.id }} .nc-error {
    background: color-mix(in srgb, rgba(var(--color-error)) 8%, transparent);
    border: 1px solid color-mix(in srgb, rgba(var(--color-error)) 30%, transparent);
    color: rgba(var(--color-error));
    font-size: 13px;
    padding: 12px;
    border-radius: var(--general-radius-1, 1rem);
    text-align: left;
    display: flex;
    gap: 10px;
    margin-bottom: 20px;
  }

  .xo-section--{{ section.id }} .nc-error.hidden {
    display: none;
  }

  .xo-section--{{ section.id }} .nc-error-icon {
    background: rgba(var(--color-error));
    color: rgba(var(--color-background));
    width: 18px;
    height: 18px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
    flex-shrink: 0;
  }

  .xo-section--{{ section.id }} .nc-stats-row {
    display: flex;
    justify-content: space-between;
    border-top: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
    padding-top: 20px;
  }

  .xo-section--{{ section.id }} .nc-stat label {
    display: block;
    font-size: 10px;
    text-transform: uppercase;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent);
    font-weight: 600;
    letter-spacing: 0.05em;
  }

  .xo-section--{{ section.id }} .nc-stat span {
    font-size: 14px;
    font-weight: 600;
    color: rgba(var(--color-foreground));
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
  }

  .xo-section--{{ section.id }} .nc-disclaimer {
    margin-top: 20px;
    font-size: 11px;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent);
    line-height: 1.5;
    text-align: center;
  }

  .xo-section--{{ section.id }} .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    border: 0;
  }

  @keyframes ntx-calc-pulse-{{ section.id }} {
    0% { border-color: color-mix(in srgb, rgba(var(--color-accent)) 60%, transparent); }
    100% { border-color: rgba(var(--color-accent)); }
  }

  @keyframes ntx-result-flash-{{ section.id }} {
    0% { background-color: color-mix(in srgb, rgba(var(--color-accent)) 12%, transparent); }
    100% { background-color: transparent; }
  }

  .xo-section--{{ section.id }} .nc-hero-val.flash {
    animation: ntx-result-flash-{{ section.id }} 0.4s var(--out-soft, ease);
  }

  @media (prefers-reduced-motion: reduce) {
    .xo-section--{{ section.id }} *,
    .xo-section--{{ section.id }} *::before,
    .xo-section--{{ section.id }} *::after {
      animation-duration: 0.01ms !important;
      transition-duration: 0.01ms !important;
    }
  }
{%- endstyle -%}

<section {% render 'section-attr' %}>
  <xo-container>

    <header class="nc-header">
      <div class="nc-brand-badge">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
        Evidence-Based Tool
      </div>
      <h1 class="nc-title">{{ section.settings.heading }}</h1>
      <p class="nc-subtitle">
        Simplifying research solution preparation. <br>
        <span style="opacity:0.6; font-weight:400;">Select your parameters below to visualize the correct volume.</span>
      </p>
    </header>

    <div class="nc-main-grid">

      <div class="nc-inputs-col">

        <div class="nc-step-card">
          <div class="nc-step-label">
            <span class="nc-step-num">1</span>
            <span class="nc-step-text">Syringe Capacity</span>
          </div>
          <p class="nc-explainer">Match the icon to the syringe you are holding.</p>

          <div class="nc-options-grid" role="group" aria-label="Syringe capacity">
            <button class="nc-option-btn active" aria-pressed="true" aria-label="0.3 mL syringe, 30 units" onclick="setParam('syringe', 0.3, this)">
              <div class="nc-icon-wrap">
                <svg class="nc-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="5" y="10" width="14" height="4" rx="1"/><path d="M19 10v4"/><path d="M22 11v2"/><path d="M2 12h3"/><path d="M9 10v4"/><path d="M13 10v4"/></svg>
              </div>
              <span>0.3 mL</span>
              <small>30 Units</small>
            </button>
            <button class="nc-option-btn" aria-pressed="false" aria-label="0.5 mL syringe, 50 units" onclick="setParam('syringe', 0.5, this)">
              <div class="nc-icon-wrap">
                <svg class="nc-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="4" y="9" width="16" height="6" rx="1"/><path d="M20 9v6"/><path d="M23 11v2"/><path d="M1 12h3"/><path d="M9 9v6"/><path d="M14 9v6"/></svg>
              </div>
              <span>0.5 mL</span>
              <small>50 Units</small>
            </button>
            <button class="nc-option-btn" aria-pressed="false" aria-label="1.0 mL syringe, 100 units" onclick="setParam('syringe', 1.0, this)">
               <div class="nc-icon-wrap">
                 <svg class="nc-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="3" y="8" width="18" height="8" rx="1"/><path d="M21 8v8"/><path d="M24 11v2"/><path d="M0 12h3"/><path d="M9 8v8"/><path d="M15 8v8"/></svg>
               </div>
              <span>1.0 mL</span>
              <small>100 Units</small>
            </button>
          </div>
        </div>

        <div class="nc-step-card">
          <div class="nc-step-label">
             <span class="nc-step-num">2</span>
             <span class="nc-step-text">Vial Quantity (mg)</span>
          </div>
          <p class="nc-explainer">Total powder weight listed on your vial label.</p>

          <div class="nc-options-row" role="group" aria-label="Vial quantity in milligrams">
            <button class="nc-pill-btn" aria-pressed="false" onclick="setParam('peptide', 2, this)">2 mg</button>
            <button class="nc-pill-btn active" aria-pressed="true" onclick="setParam('peptide', 5, this)">5 mg</button>
            <button class="nc-pill-btn" aria-pressed="false" onclick="setParam('peptide', 10, this)">10 mg</button>
            <button class="nc-pill-btn" aria-pressed="false" onclick="setParam('peptide', 15, this)">15 mg</button>
            <button class="nc-pill-btn" aria-pressed="false" onclick="setParam('peptide', 'other', this)">Other</button>
          </div>
          <div id="input-peptide-box" class="nc-input-reveal hidden">
            <label for="input-peptide" class="visually-hidden">Custom vial quantity in mg</label>
            <input type="number" id="input-peptide" inputmode="decimal" aria-label="Custom vial quantity in milligrams" placeholder="Enter custom mg..." oninput="updateCustom('peptide')">
          </div>
        </div>

        <div class="nc-step-card">
          <div class="nc-step-label">
             <span class="nc-step-num">3</span>
             <span class="nc-step-text">Water Added (mL)</span>
          </div>
          <p class="nc-explainer">Amount of bacteriostatic water mixed into the vial.</p>

          <div class="nc-options-row" role="group" aria-label="Water added in milliliters">
            <button class="nc-pill-btn" aria-pressed="false" onclick="setParam('water', 1, this)">1 mL</button>
            <button class="nc-pill-btn active" aria-pressed="true" onclick="setParam('water', 2, this)">2 mL</button>
            <button class="nc-pill-btn" aria-pressed="false" onclick="setParam('water', 3, this)">3 mL</button>
            <button class="nc-pill-btn" aria-pressed="false" onclick="setParam('water', 'other', this)">Other</button>
          </div>
          <div id="input-water-box" class="nc-input-reveal hidden">
            <label for="input-water" class="visually-hidden">Custom water amount in mL</label>
            <input type="number" id="input-water" inputmode="decimal" aria-label="Custom water amount in milliliters" placeholder="Enter custom mL..." oninput="updateCustom('water')">
          </div>
        </div>

        <div class="nc-step-card">
          <div class="nc-step-label">
             <span class="nc-step-num">4</span>
             <span class="nc-step-text">Desired Dose (mcg)</span>
          </div>
          <p class="nc-explainer">The specific amount you want to research per use.</p>

          <div class="nc-options-row" role="group" aria-label="Desired dose in micrograms">
            <button class="nc-pill-btn" aria-pressed="false" onclick="setParam('dose', 100, this)">100</button>
            <button class="nc-pill-btn active" aria-pressed="true" onclick="setParam('dose', 250, this)">250</button>
            <button class="nc-pill-btn" aria-pressed="false" onclick="setParam('dose', 500, this)">500</button>
            <button class="nc-pill-btn" aria-pressed="false" onclick="setParam('dose', 'other', this)">Other</button>
          </div>
          <div id="input-dose-box" class="nc-input-reveal hidden">
            <label for="input-dose" class="visually-hidden">Custom dose in mcg</label>
            <input type="number" id="input-dose" inputmode="decimal" aria-label="Custom dose in micrograms" placeholder="Enter custom mcg..." oninput="updateCustom('dose')">
          </div>
        </div>

      </div>

      <div class="nc-results-col">
        <div class="nc-result-card">

          <div class="nc-result-header">
            <span class="nc-result-label">Visual Guide</span>
          </div>

          <div class="nc-result-hero" role="status" aria-live="polite" aria-atomic="true">
            <div class="nc-hero-text">Draw to:</div>
            <div class="nc-hero-val"><span id="res-units">10</span> <small>UNITS</small></div>
            <div class="nc-hero-sub">To get <strong id="res-dose">250 mcg</strong></div>
          </div>

          <div class="nc-syringe-visual">
            <div class="nc-syringe-barrel">
              <div class="nc-liquid" id="liquid-fill"></div>
              <div class="nc-graduations"></div>
              <div class="nc-plunger-stopper" id="plunger-stopper"></div>
            </div>
            <div class="nc-needle-tip"></div>
            <div class="nc-syringe-flange"></div>
            <div class="nc-plunger-rod"></div>
          </div>

          <div class="nc-ruler-scale">
            <span>0</span>
            <span id="scale-mid">15</span>
            <span id="scale-max">30</span>
          </div>

          <div class="nc-summary-action" id="summary-action">
            <div class="nc-summary-text" id="summary-text">
              To have a dose of <strong>250 mcg</strong>, pull the syringe to <strong>10 units</strong>.
            </div>
            <button class="nc-copy-btn" id="copy-btn" aria-label="Copy calculation result" onclick="copyResult()">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
              <span>Copy Result</span>
            </button>
          </div>

          <div id="error-box" class="nc-error hidden" role="alert">
            <div class="nc-error-icon" aria-hidden="true">!</div>
            <div><strong>Capacity Exceeded:</strong> This dose requires more volume than the selected syringe can hold.</div>
          </div>

          <div class="nc-stats-row">
            <div class="nc-stat">
              <label>Volume</label>
              <span id="res-vol">0.1 mL</span>
            </div>
            <div class="nc-stat">
              <label>Concentration</label>
              <span id="res-conc">2.5 mg/mL</span>
            </div>
          </div>

        </div>

        <p class="nc-disclaimer">
          <strong>Note:</strong> 100 Units = 1 mL. Always verify calculations manually. This tool is for educational laboratory use only.
        </p>
      </div>

    </div>

  </xo-container>
</section>

<script>
  let state = {
    syringe: 0.3,
    peptide: 5,
    water: 2,
    dose: 250
  };

  function setParam(type, value, btn) {
    let container;
    if(type === 'syringe') container = btn.closest('.nc-options-grid');
    else container = btn.closest('.nc-options-row');
    
    const siblings = container.querySelectorAll(type === 'syringe' ? '.nc-option-btn' : '.nc-pill-btn');
    siblings.forEach(function(b) { b.classList.remove('active'); b.setAttribute('aria-pressed', 'false'); });
    btn.classList.add('active');
    btn.setAttribute('aria-pressed', 'true');

    // 2. Input Logic
    const inputContainer = document.getElementById(`input-${type}-box`);
    
    if(inputContainer) {
      if(value === 'other') {
        inputContainer.classList.remove('hidden');
        const customVal = parseFloat(document.getElementById(`input-${type}`).value);
        state[type] = isNaN(customVal) ? 0 : customVal;
      } else {
        inputContainer.classList.add('hidden');
        state[type] = value;
      }
    } else {
      state[type] = value;
    }

    calculate();
  }

  function updateCustom(type) {
    const val = parseFloat(document.getElementById(`input-${type}`).value);
    state[type] = isNaN(val) ? 0 : val;
    calculate();
  }

  function calculate() {
    const { syringe, peptide, water, dose } = state;
    const maxUnits = Math.round(syringe * 100);

    // Scale Label Update
    document.getElementById('scale-max').innerText = maxUnits;
    document.getElementById('scale-mid').innerText = Math.round(maxUnits / 2);

    const summaryAction = document.getElementById('summary-action');
    const errorBox = document.getElementById('error-box');

    // Validations
    if(peptide <= 0 || water <= 0 || dose <= 0) {
      updateVisuals(0, maxUnits);
      document.getElementById('res-units').innerText = '--';
      if(summaryAction) summaryAction.classList.add('hidden');
      return;
    }

    // Math
    const concentration = (peptide * 1000) / water; // mcg/mL
    const vol = dose / concentration; // mL
    let units = vol * 100;

    // Rounding
    units = Math.round(units * 10) / 10;
    const volDisplay = vol.toFixed(3);
    const concDisplay = (peptide / water).toFixed(1); // mg/mL

    var heroEl = document.querySelector('.nc-hero-val');
    if(heroEl) { heroEl.classList.remove('flash'); void heroEl.offsetWidth; heroEl.classList.add('flash'); }
    document.getElementById('res-units').innerText = units;
    document.getElementById('res-dose').innerText = dose + " mcg";
    document.getElementById('res-vol').innerText = volDisplay + " mL";
    document.getElementById('res-conc').innerText = concDisplay + " mg/mL";

    // Dynamic Text Summary Update
    document.getElementById('summary-text').innerHTML = `To have a dose of <strong>${dose} mcg</strong>, pull the syringe to <strong>${units} units</strong>.`;

    // Error & Visuals
    if(units > maxUnits) {
      errorBox.classList.remove('hidden');
      if(summaryAction) summaryAction.classList.add('hidden');
      updateVisuals(maxUnits + 10, maxUnits, true); // Overfill visual
    } else {
      errorBox.classList.add('hidden');
      if(summaryAction) summaryAction.classList.remove('hidden');
      updateVisuals(units, maxUnits, false);
    }
  }

  function updateVisuals(units, max, isError) {
    const liquid = document.getElementById('liquid-fill');
    const stopper = document.getElementById('plunger-stopper');
    
    let pct = (units / max) * 100;
    if(pct > 100) pct = 100;
    if(pct < 0) pct = 0;

    liquid.style.width = pct + '%';
    stopper.style.left = pct + '%';
    
    if(isError) {
      liquid.style.backgroundColor = '#fecaca'; // Light red
      stopper.style.backgroundColor = '#991b1b'; // Dark red
    } else {
      liquid.style.backgroundColor = 'var(--nc-accent)';
      stopper.style.backgroundColor = '#111827';
    }
  }

  function copyResult() {
    const text = document.getElementById('summary-text').innerText;
    
    // Check if secure context for Modern Clipboard API
    if (navigator.clipboard && window.isSecureContext) {
      navigator.clipboard.writeText(text).then(() => {
        showCopiedState();
      }).catch(err => console.error('Failed to copy text: ', err));
    } else {
      // Fallback logic for older browsers
      const textArea = document.createElement("textarea");
      textArea.value = text;
      textArea.style.position = "fixed";
      textArea.style.left = "-999999px";
      textArea.style.top = "-999999px";
      document.body.appendChild(textArea);
      textArea.focus();
      textArea.select();
      try {
        document.execCommand('copy');
        showCopiedState();
      } catch (err) {
        console.error('Fallback copy failed', err);
      }
      textArea.remove();
    }
  }

  function showCopiedState() {
    const btn = document.getElementById('copy-btn');
    const originalHtml = btn.innerHTML;
    
    btn.classList.add('copied');
    btn.innerHTML = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg> <span>Copied!</span>`;
    
    setTimeout(() => {
      btn.classList.remove('copied');
      btn.innerHTML = originalHtml;
    }, 2000);
  }

  // Init
  document.addEventListener('DOMContentLoaded', calculate);
</script>

{% schema %}
{
  "name": "Dosage Calculator",
  "tag": "section",
  "class": "section-dosage-calculator",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "default" },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Beginner Volume Calculator"
    },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding top", "default": 80 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding bottom", "default": 80 }
  ],
  "blocks": [
    { "type": "@app" }
  ],
  "presets": [
    {
      "name": "Dosage Calculator"
    }
  ]
}
{% endschema %}
