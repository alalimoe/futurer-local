{%- assign s = section.settings -%}
{%- assign sid = section.id -%}
{%- assign a_caps = s.aniracetam_caps -%}
{%- assign f_caps = s.fasoracetam_caps -%}
{%- assign ph_caps = s.phenyl_hydrazide_caps -%}
{%- assign pr_caps = s.pramiracetam_caps -%}

{%- style -%}
#nx-sticky-{{ sid }} {
  position: fixed;
  left: 50%;
  bottom: 16px;
  z-index: 50;
  transform: translateX(-50%) translateY(100px);
  opacity: 0;
  pointer-events: none;
  transition: var(--transition-premium, all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1));
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border: 1px solid transparent;
  border-radius: var(--radius-premium, 14px);
  box-shadow: 0 12px 40px rgba(0, 0, 0, 0.1);
  padding: 10px 14px;
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
  justify-content: center;
  align-items: center;
  max-width: 90vw;
}
#nx-sticky-{{ sid }}.is-visible {
  transform: translateX(-50%) translateY(0);
  opacity: 1;
  pointer-events: auto;
}

#nx-sticky-{{ sid }} a {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8px 14px;
  border-radius: 10px;
  font-size: 13px;
  font-weight: 600;
  text-decoration: none;
  min-height: 40px;
  white-space: nowrap;
  border: 1.5px solid var(--color-accent-primary, #FBBF24);
  background: transparent;
  color: var(--color-text-main, #111827);
  transition: var(--transition-premium, all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1));
}
#nx-sticky-{{ sid }} a:hover {
  background: var(--color-accent-primary, #FBBF24);
  color: var(--color-text-primary);
  transform: translateY(-1px);
  box-shadow: var(--shadow-gold-glow, 0 4px 14px rgba(251,191,36,0.25));
}
#nx-sticky-{{ sid }} a:active { transform: scale(0.98); }

#nx-sticky-{{ sid }} a.primary {
  background: var(--color-accent-primary, #FBBF24);
  border-color: var(--color-accent-primary, #FBBF24);
  color: var(--color-text-primary);
  box-shadow: var(--shadow-gold-glow, 0 4px 14px rgba(251,191,36,0.25));
}
#nx-sticky-{{ sid }} a.primary:hover {
  background: var(--color-accent-hover, #D97706);
  border-color: var(--color-accent-hover, #D97706);
  box-shadow: 0 8px 24px rgba(251,191,36,0.35);
}

#nx-sticky-{{ sid }} a:focus-visible {
  outline: 2px solid var(--color-accent-primary, #FBBF24);
  outline-offset: 2px;
}

@media (prefers-reduced-motion: reduce) {
  #nx-sticky-{{ sid }} {
    transition: none !important;
  }
  #nx-sticky-{{ sid }} a {
    transition: none !important;
    transform: none !important;
  }
}
{%- endstyle -%}

<nav id="nx-sticky-{{ sid }}" data-sticky-id="{{ sid }}" aria-label="Quick shop sticky bar">
  {% if a_caps != blank %}<a href="{{ a_caps.url }}">Aniracetam</a>{% endif %}
  {% if f_caps != blank %}<a href="{{ f_caps.url }}">Fasoracetam</a>{% endif %}
  {% if ph_caps != blank %}<a class="primary" href="{{ ph_caps.url }}">Phenylpiracetam Hydrazide</a>{% endif %}
  {% if pr_caps != blank %}<a href="{{ pr_caps.url }}">Pramiracetam</a>{% endif %}
</nav>

<script>
(function () {
  var el = document.querySelector('[data-sticky-id]');
  if (!el) return;
  var showAt = window.innerHeight * 0.4;
  var hideAt = window.innerHeight * 0.2;

  function onScroll() {
    var y = window.scrollY || document.documentElement.scrollTop;
    if (y > showAt) {
      el.classList.add('is-visible');
    } else if (y < hideAt) {
      el.classList.remove('is-visible');
    }
  }

  window.addEventListener('scroll', onScroll, { passive: true });
})();
</script>

{% schema %}
{
  "name": "NX — Sticky CTA",
  "settings": [
    { "type": "product", "id": "aniracetam_caps", "label": "Aniracetam (caps)" },
    { "type": "product", "id": "fasoracetam_caps", "label": "Fasoracetam (caps)" },
    { "type": "product", "id": "phenyl_hydrazide_caps", "label": "Phenylpiracetam Hydrazide (caps)" },
    { "type": "product", "id": "pramiracetam_caps", "label": "Pramiracetam (caps)" }
  ],
  "presets": [{ "name": "NX — Sticky CTA" }]
}
{% endschema %}
