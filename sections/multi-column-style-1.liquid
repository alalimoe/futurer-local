        },
        {
          "type": "richtext",
          "id": "title",
          "label": "t:sections.multi_column_style_1.blocks.settings.title.label",
          "default": "<p>Heading</p>"
        },
        {
          "type": "select",
          "id": "enable_overlay",
          "label": "t:sections.multi_column_style_1.blocks.settings.enable_overlay.label",
          "options": [
            {
              "value": "off",
              "label": "t:sections.multi_column_style_1.blocks.settings.enable_overlay.option__1.label"
            },
            {
              "value": "on",
              "label": "t:sections.multi_column_style_1.blocks.settings.enable_overlay.option__2.label"
            }
