          "label": "t:sections.multi_column_style_1.blocks.settings.image_dark_mode.label",
          "visible_if": "{{ block.settings.hover_type == 'image' }}"
        },
        {
          "type": "video",
          "id": "video",
          "label": "t:sections.multi_column_style_1.blocks.settings.video.label",
          "visible_if": "{{ block.settings.hover_type == 'video' }}"
        },
        {
          "type": "select",
          "id": "aspect_ratio_second",
          "label": "Aspect ratio",
          "default": "auto",
          "options": [
            {
              "value": "auto",
              "label": "Auto"
            },
            {
              "value": "2/3",
              "label": "2:3"
            },
            {
              "value": "3/4",
