        {
          "type": "image_picker",
          "id": "image_first_on_dark_mode",
          "label": "t:sections.multi_column_style_1.blocks.settings.image_dark_mode.label"
        },
        {
          "type": "select",
          "id": "aspect_ratio_first",
          "label": "Aspect ratio",
          "default": "auto",
          "options": [
            {
              "value": "auto",
              "label": "Auto"
            },
            {
              "value": "2/3",
              "label": "2:3"
            },
            {
              "value": "3/4",
              "label": "3:4"
            },
            {
              "value": "3/2",
              "label": "3:2"
            },
            {
