  "name": "t:sections.image_banner_style_3.name",
  "class": "section-hero",
  "settings": [
    {
      "type": "select",
      "id": "font_size",
      "label": "Font size",
      "options": [
        {
          "value": "d1",
          "label": "Display"
        },
        {
          "value": "h1",
          "label": "Extra extra large"
