{{ 'img-banner-4.css' | asset_url | stylesheet_tag }}

{% liquid
  assign heading = section.settings.heading
  assign image_desktop = section.settings.image_desktop | image_url
  assign image_mobile = section.settings.image_mobile | image_url
  assign background_image_desktop = section.settings.background_image_desktop | image_url
  assign background_image_mobile = section.settings.background_image_mobile | image_url
  assign blocks = section.blocks
%}

<section {% render 'section-attr' %}>
  <div class="image-banner-style-4">
    {% render 'img-banner-4',
      heading: heading,
      image_desktop: image_desktop,
      image_mobile: image_mobile,
      background_image_desktop: background_image_desktop,
      background_image_mobile: background_image_mobile,
      blocks: blocks
    %}
  </div>
</section>

{% schema %}
{
