{% liquid
  assign heading = section.settings.text_heading
  assign sub_heading = section.settings.sub_heading
  assign left_image = section.settings.left_image
  assign aspect_ratio_left = section.settings.aspect_ratio_left
  if aspect_ratio_left == 'custom'
    assign aspect_ratio_left = section.settings.aspect_ratio_left_width | append: '/' | append: section.settings.aspect_ratio_left_height
  endif
  assign right_image = section.settings.right_image
  assign aspect_ratio_right = section.settings.aspect_ratio_right
  if aspect_ratio_right == 'custom'
    assign aspect_ratio_right = section.settings.aspect_ratio_right_width | append: '/' | append: section.settings.aspect_ratio_right_height
  endif
  assign show_image_right = section.settings.show_image_right
  assign block = section.blocks
%}

<section {% render 'section-attr' %}>
  <div class="image-with-text-style-2">
    <xo-container class="image-with-text-style-2__container">
      <div class="image-with-text-style-2__content xo-stack" style="--ai: center; --jc: center">
        {% render 'img-with-text-2',
          heading: heading,
          sub_heading: sub_heading,
          left_image: left_image,
          aspect_ratio_left: aspect_ratio_left,
          right_image: right_image,
          aspect_ratio_right: aspect_ratio_right,
          show_image_right: show_image_right,
          block: block
        %}
      </div>
    </xo-container>
  </div>
</section>

