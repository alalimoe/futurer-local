{{ 'multi-column-2.css' | asset_url | stylesheet_tag }}

<section {% render 'section-attr' %}>
  <xo-animate xo-cascade>
    <div class="multi-column-style-2">
      <xo-container class="multi-column-style-2__container">
        {% liquid
          assign class = section.settings.font_size_heading
          assign heading = section.settings.text_heading
          assign duration = section.settings.text_duration
          assign effect = section.settings.text_effect
          assign tag_name = section.settings.text_tag_name
          assign heading_width_desktop = section.settings.text_heading_width_desktop
          assign heading_width_mobile = section.settings.text_heading_width_mobile
          assign column = section.settings.column
          assign block = section.blocks
        %}
        {% render 'multi-column-2', class: class, heading: heading, column: column, block: block %}
      </xo-container>
    </div>
  </xo-animate>
</section>

{% schema %}
{
  "name": "t:sections.multi_column_style_2.name",
  "disabled_on": {
    "groups": [
      "header",
      "footer",
      "custom.overlay",
      "custom.popups",
      "custom.features"
    ]
  },
  "settings": [
    {
      "type": "select",
      "id": "column",
      "label": "t:sections.multi_column_style_2.settings.column.label",
      "options": [
        {
          "value": "3",
          "label": "t:sections.multi_column_style_2.settings.column.option__1.label"
        },
        {
          "value": "4",
          "label": "t:sections.multi_column_style_2.settings.column.option__2.label"
        }
      ],
      "default": "3"
    },
    {
      "type": "header",
      "content": "Text"
    },
    {
      "type": "select",
      "id": "text_tag_name",
      "label": "Tag name",
      "options": [
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        },
        {
          "value": "h4",
          "label": "H4"
        },
        {
          "value": "h5",
          "label": "H5"
        },
        {
          "value": "h6",
          "label": "H6"
        }
      ],
      "default": "h2"
    },
    {
      "type": "textarea",
      "id": "text_heading",
      "label": "Text",
      "default": "Multi column"
    },
    {
      "type": "select",
      "id": "font_size_heading",
      "label": "Font size heading",
      "default": "h3",
      "options": [
        {
          "value": "h1",
          "label": "Extra extra large"
        },
        {
          "value": "h2",
          "label": "Extra large"
        },
        {
          "value": "h3",
          "label": "Large"
        },
        {
          "value": "h4",
          "label": "Medium"
        },
        {
          "value": "h5",
          "label": "Small"
        },
        {
