            }
          ]
        },
        {
          "type": "richtext",
          "id": "title",
          "label": "t:sections.multi_column_style_2.blocks.settings.title.label",
          "default": "<p>Heading</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.multi_column_style_2.presets.name",
      "settings": {
        "font_size_heading": "h5",
        "text_heading": "Multi column",
        "text_duration": 2000,
