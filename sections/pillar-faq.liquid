{% comment %} Pillar-level FAQ with JSON-LD {% endcomment %}

{%- style -%}
  .xo-section--{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .xo-section--{{ section.id }} .f-title {
    margin: 0 0 12px;
    color: rgba(var(--color-foreground));
    font-weight: 600;
  }

  .xo-section--{{ section.id }} details {
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
    border-radius: var(--general-radius-1, 1rem);
    background: rgba(var(--color-background));
    margin-bottom: 10px;
    overflow: hidden;
  }

  .xo-section--{{ section.id }} summary {
    list-style: none;
    cursor: pointer;
    padding: 12px 14px;
    font-weight: 600;
    color: rgba(var(--color-foreground));
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: background 0.2s var(--out-soft, ease);
  }
  .xo-section--{{ section.id }} summary:hover {
    background: color-mix(in srgb, rgba(var(--color-foreground)) 4%, transparent);
  }
  .xo-section--{{ section.id }} summary::-webkit-details-marker {
    display: none;
  }

  .xo-section--{{ section.id }} .ans {
    padding: 0 14px 14px;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent);
  }

  @media (prefers-reduced-motion: reduce) {
    .xo-section--{{ section.id }} summary {
      transition: none;
    }
  }
{%- endstyle -%}

<section {% render 'section-attr' %}>
  <xo-container>
    <h2 class="f-title">{{ section.settings.title | default: 'Frequently Asked Questions' }}</h2>
    <div class="f-acc">
      {% for i in (1..8) %}
        {% assign q_key = 'q' | append: i %}
        {% assign a_key = 'a' | append: i %}
        {% assign q = section.settings[q_key] %}
        {% assign a = section.settings[a_key] %}
        {% if q != blank and a != blank %}
          <details{% if forloop.index == 1 %} open{% endif %}>
            <summary><span>{{ q }}</span></summary>
            <div class="ans">{{ a }}</div>
          </details>
        {% endif %}
      {% endfor %}
    </div>
  </xo-container>
</section>

{%- capture faq_json -%}
[
  {%- assign first = true -%}
  {%- for i in (1..8) -%}
    {%- assign q_key = 'q' | append: i -%}
    {%- assign a_key = 'a' | append: i -%}
    {%- assign q = section.settings[q_key] -%}
    {%- assign a = section.settings[a_key] -%}
    {%- if q != blank and a != blank -%}
      {%- if first == false -%},{%- endif -%}
      {"@type":"Question","name":{{ q | strip | json }},"acceptedAnswer":{"@type":"Answer","text":{{ a | strip | json }}}}
      {%- assign first = false -%}
    {%- endif -%}
  {%- endfor -%}
]
{%- endcapture -%}
<script type="application/ld+json">
{ "@context":"https://schema.org", "@type":"FAQPage", "mainEntity": {{ faq_json | strip }} }
</script>

{% schema %}
{
  "name": "Pillar FAQ",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "default" },
    { "type": "text", "id": "title", "label": "Heading", "default": "Frequently Asked Questions" },
    { "type": "text", "id": "q1", "label": "Q1" }, { "type": "textarea", "id": "a1", "label": "A1" },
    { "type": "text", "id": "q2", "label": "Q2" }, { "type": "textarea", "id": "a2", "label": "A2" },
    { "type": "text", "id": "q3", "label": "Q3" }, { "type": "textarea", "id": "a3", "label": "A3" },
    { "type": "text", "id": "q4", "label": "Q4" }, { "type": "textarea", "id": "a4", "label": "A4" },
    { "type": "text", "id": "q5", "label": "Q5" }, { "type": "textarea", "id": "a5", "label": "A5" },
    { "type": "text", "id": "q6", "label": "Q6" }, { "type": "textarea", "id": "a6", "label": "A6" },
    { "type": "text", "id": "q7", "label": "Q7" }, { "type": "textarea", "id": "a7", "label": "A7" },
    { "type": "text", "id": "q8", "label": "Q8" }, { "type": "textarea", "id": "a8", "label": "A8" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding top", "default": 24 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding bottom", "default": 24 }
  ],
  "blocks": [
    {
      "type": "@app"
    }
  ],
  "presets": [{ "name": "Pillar FAQ" }]
}
{% endschema %}
