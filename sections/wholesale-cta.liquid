{% comment %} Wholesale & Labs CTA {% endcomment %}

{%- style -%}
  .xo-section--{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .xo-section--{{ section.id }} .w-box {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 18px;
    background: rgba(var(--color-background));
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
    border-radius: var(--general-radius-3, 2rem);
    padding: 16px;
  }
  @media (max-width: 768px) {
    .xo-section--{{ section.id }} .w-box {
      flex-direction: column;
      text-align: center;
    }
  }

  .xo-section--{{ section.id }} .w-title {
    margin: 0;
    color: rgba(var(--color-foreground));
    font-weight: 600;
  }

  .xo-section--{{ section.id }} .w-box p {
    color: color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent);
    margin: 4px 0 0;
  }

  .xo-section--{{ section.id }} .w-cta {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .xo-section--{{ section.id }} .w-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 44px;
    padding: 0 14px;
    border-radius: var(--button-radius);
    text-decoration: none;
    font-weight: 600;
    transition: opacity 0.2s var(--out-soft, ease);
  }
  .xo-section--{{ section.id }} .w-btn:hover {
    opacity: 0.85;
  }

  .xo-section--{{ section.id }} .w-btn--p {
    background: rgba(var(--color-accent));
    color: rgba(var(--color-foreground));
    border: 0;
  }

  .xo-section--{{ section.id }} .w-btn--g {
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
    color: rgba(var(--color-foreground));
    background: rgba(var(--color-background));
  }
  .xo-section--{{ section.id }} .w-btn--g:hover {
    background: color-mix(in srgb, rgba(var(--color-accent)) 12%, transparent);
    border-color: rgba(var(--color-accent));
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .xo-section--{{ section.id }} .w-btn {
      transition: none;
    }
  }
{%- endstyle -%}

<section {% render 'section-attr' %}>
  <xo-container>
    <div class="w-box">
      <div>
        <h2 class="w-title">{{ section.settings.title | default: 'Wholesale & Labs' }}</h2>
        {% if section.settings.sub %}<p>{{ section.settings.sub }}</p>{% endif %}
      </div>
      <div class="w-cta">
        {% if section.settings.p_label and section.settings.p_link %}<a class="w-btn w-btn--p" href="{{ section.settings.p_link }}">{{ section.settings.p_label }}</a>{% endif %}
        {% if section.settings.s_label and section.settings.s_link %}<a class="w-btn w-btn--g" href="{{ section.settings.s_link }}">{{ section.settings.s_label }}</a>{% endif %}
      </div>
    </div>
  </xo-container>
</section>

{% schema %}
{
  "name": "Wholesale CTA",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "default" },
    { "type": "text", "id": "title", "label": "Heading", "default": "Wholesale & Labs" },
    { "type": "textarea", "id": "sub", "label": "Subtext", "default": "Volume pricing, standing orders, and batch documentation." },
    { "type": "text", "id": "p_label", "label": "Primary label", "default": "Request access" },
    { "type": "url", "id": "p_link", "label": "Primary link", "default": "/" },
    { "type": "text", "id": "s_label", "label": "Secondary label", "default": "Learn more" },
    { "type": "url", "id": "s_link", "label": "Secondary link", "default": "/" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding top", "default": 24 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding bottom", "default": 24 }
  ],
  "blocks": [
    {
      "type": "@app"
    }
  ],
  "presets": [{ "name": "Wholesale CTA" }]
}
{% endschema %}
