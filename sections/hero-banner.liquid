{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Default heading",
      "default": "Your Topic Title"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline / subtitle",
      "default": "A brief intro to this topic"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}

{%- liquid
  assign hero_is_lcp = false
  if section.location == 'template' and section.index == 1
    assign hero_is_lcp = true
  endif
-%}

{%- if section.settings.bg_image != blank and hero_is_lcp -%}
  <script>
    (function() {
      if (document.querySelector('link[data-hero-preload="{{ section.id }}"]')) return;
      var link = document.createElement('link');
      link.setAttribute('rel', 'preload');
      link.setAttribute('as', 'image');
      link.setAttribute('href', '{{ section.settings.bg_image | image_url: width: 1920 }}');
      link.setAttribute('imagesrcset', '{{ section.settings.bg_image | image_url: width: 768 }} 768w, {{ section.settings.bg_image | image_url: width: 1024 }} 1024w, {{ section.settings.bg_image | image_url: width: 1440 }} 1440w, {{ section.settings.bg_image | image_url: width: 1920 }} 1920w');
      link.setAttribute('imagesizes', '100vw');
      link.setAttribute('fetchpriority', 'high');
      link.setAttribute('data-hero-preload', '{{ section.id }}');
      document.head.appendChild(link);
    })();
  </script>
{%- endif -%}

<div class="hero-banner" style="padding: 6rem 1rem; text-align: center; position: relative;">
  {%- if section.settings.bg_image != blank -%}
    <img
      class="hero-banner__image"
      src="{{ section.settings.bg_image | image_url: width: 1920 }}"
      srcset="
        {{ section.settings.bg_image | image_url: width: 768 }} 768w,
        {{ section.settings.bg_image | image_url: width: 1024 }} 1024w,
        {{ section.settings.bg_image | image_url: width: 1440 }} 1440w,
        {{ section.settings.bg_image | image_url: width: 1920 }} 1920w
      "
      sizes="100vw"
      alt=""
      fetchpriority="{% if hero_is_lcp %}high{% else %}auto{% endif %}"
      loading="{% if hero_is_lcp %}eager{% else %}lazy{% endif %}"
      width="1920"
      height="1080"
      style="position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; z-index: 0;"
    >
  {%- endif -%}
  <div style="position: relative; z-index: 1;">
    {%- comment -%}
      If we're on a tagged blog page, display that tag name;
      otherwise use the default heading from settings.
    {%- endcomment -%}
    <h1 class="hero-heading">
      {% if current_tags and current_tags.size > 0 %}
        {{ current_tags.first | replace: '-', ' ' | capitalize }}
      {% else %}
        {{ section.settings.heading }}
      {% endif %}
    </h1>

    <p class="hero-tagline">
      {{ section.settings.tagline }}
    </p>
  </div>
</div>
