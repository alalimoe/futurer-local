<section class="topics-index wrapper">
  {% for record in shop.metaobjects.topic.values %}
    <a class="topic-tile" href="/pages/{{ record.slug }}">
      <img src="{{ record.hero_image | image_url: width: 600 }}" alt="{{ record.title }}">
      <h2>{{ record.title }}</h2>
      <p>{{ record.promise }}</p>
    </a>
  {% endfor %}
</section>
