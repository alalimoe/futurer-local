{%- assign s = section.settings -%}
{%- assign sid = section.id -%}
{%- assign collection = s.collection -%}
{%- assign alpha = s.alpha_gpc -%}
{%- assign cdp = s.cdp_choline -%}

{%- style -%}
#nx-why-{{ sid }} {
  max-width: var(--container-width-narrow);
  margin: 0 auto;
  padding: 8px var(--page-gutter);
  font-family: var(--font-body-family, sans-serif);
  color: var(--color-text-main, #111827);
  line-height: 1.7;
  content-visibility: auto;
}
#nx-why-{{ sid }} h2 {
  font-family: var(--font-heading-family, sans-serif);
  font-size: clamp(22px, 3vw, 30px);
  font-weight: 700;
  line-height: 1.2;
  margin: 0 0 16px;
}

#nx-why-{{ sid }} ul {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 8px;
}
#nx-why-{{ sid }} li {
  padding: 12px 16px;
  border-radius: var(--radius-premium, 14px);
  border: 1px solid transparent;
  background: rgba(249, 250, 251, 0.5);
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
  transition: var(--transition-premium, all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1));
  color: var(--color-text-muted, #4b5563);
}
#nx-why-{{ sid }} li:hover {
  background: rgba(251, 191, 36, 0.06);
  transform: translateX(4px);
  box-shadow: var(--shadow-sm, 0 2px 8px rgba(0,0,0,0.04));
}
#nx-why-{{ sid }} li strong { color: var(--color-text-main, #111827); }

#nx-why-{{ sid }} .nx-btnrow {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
  margin-top: 16px;
}
#nx-why-{{ sid }} .nx-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10px 16px;
  border-radius: 10px;
  font-size: 14px;
  font-weight: 600;
  text-decoration: none;
  min-height: 44px;
  border: 1.5px solid var(--color-accent-primary, #FBBF24);
  background: transparent;
  color: var(--color-text-main, #111827);
  transition: var(--transition-premium, all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1));
}
#nx-why-{{ sid }} .nx-btn:hover {
  background: var(--color-accent-primary, #FBBF24);
  color: var(--color-text-primary);
  transform: translateY(-2px);
  box-shadow: var(--shadow-gold-glow, 0 4px 14px rgba(251,191,36,0.25));
}
#nx-why-{{ sid }} .nx-btn:active { transform: scale(0.98); }

#nx-why-{{ sid }} .nx-btn.primary {
  background: var(--color-accent-primary, #FBBF24);
  border-color: var(--color-accent-primary, #FBBF24);
  color: var(--color-text-primary);
  box-shadow: var(--shadow-gold-glow, 0 4px 14px rgba(251,191,36,0.25));
}
#nx-why-{{ sid }} .nx-btn.primary:hover {
  background: var(--color-accent-hover, #D97706);
  border-color: var(--color-accent-hover, #D97706);
  box-shadow: 0 8px 24px rgba(251,191,36,0.35);
}

#nx-why-{{ sid }} a:focus-visible {
  outline: 2px solid var(--color-accent-primary, #FBBF24);
  outline-offset: 2px;
}

@media (prefers-reduced-motion: reduce) {
  #nx-why-{{ sid }},
  #nx-why-{{ sid }} * {
    transition: none !important;
    animation: none !important;
    transform: none !important;
  }
}
{%- endstyle -%}

<section id="nx-why-{{ sid }}" aria-label="Why choose Nootropix">
  <h2>Why Nootropix?</h2>
  <ul>
    <li><strong>Same/next-day UAE delivery</strong> (4 hours within Dubai city limits).</li>
    <li><strong>Express international shipping</strong> with <strong>free shipping &ge;300 AED</strong>.</li>
    <li><strong>Quality first:</strong> Industry-leading manufacturers; transparent sourcing.</li>
    <li><strong>Hassle-free returns:</strong> Unopened items; refunds within 3 days.</li>
    <li><strong>Local support from Dubai</strong>, serving the UAE &amp; MENA since 2018.</li>
  </ul>
  <div class="nx-btnrow">
    {% if collection != blank %}<a class="nx-btn primary" href="{{ collection.url }}">Shop Racetams</a>{% endif %}
    {% if alpha != blank %}<a class="nx-btn" href="{{ alpha.url }}">Alpha-GPC</a>{% endif %}
    {% if cdp != blank %}<a class="nx-btn" href="{{ cdp.url }}">CDP-Choline</a>{% endif %}
  </div>
</section>

{% schema %}
{
  "name": "NX — Why Nootropix",
  "settings": [
    { "type": "collection", "id": "collection", "label": "Racetams collection (optional)" },
    { "type": "product", "id": "alpha_gpc", "label": "Alpha-GPC (optional)" },
    { "type": "product", "id": "cdp_choline", "label": "CDP-Choline (optional)" }
  ],
  "presets": [{ "name": "NX — Why Nootropix" }]
}
{% endschema %}
