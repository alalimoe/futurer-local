{%- liquid
  assign npx_id = section.id | replace: '-', '' | replace: '_', '' | downcase

  assign p = product
  if p == blank and section.settings.demo_product != blank
    assign p = section.settings.demo_product
  endif

  assign form_label = section.settings.form_label_override | default: '' | strip
  if form_label == blank
    assign form_label = 'capsules'
    if p and p.title contains 'Powder'
      assign form_label = 'powder'
    endif
  endif

  assign tldr_src = nil
  assign tldr_data = nil
  if p
    assign tldr_src = p.metafields.npx.tl_dr | default: p.metafields.npx.tldr
    if tldr_src != blank
      assign tldr_data = tldr_src.value | default: tldr_src
    endif
  endif

  assign what_it_is_data = p.metafields.npx.what_it_is.value | default: p.metafields.npx.what_it_is
  assign feel_data       = p.metafields.npx.feel_timeline.value | default: p.metafields.npx.feel_timeline
  assign feel_note_data  = p.metafields.npx.feel_note.value | default: p.metafields.npx.feel_note
  assign how_data        = p.metafields.npx.how_to_use.value | default: p.metafields.npx.how_to_use
  assign why_data        = p.metafields.npx.why.value | default: p.metafields.npx.why
  assign faq_data        = p.metafields.npx.faq.value | default: p.metafields.npx.faq

  assign safety_important_data = p.metafields.npx.safety_important.value | default: p.metafields.npx.safety_important
  assign safety_general_data   = p.metafields.npx.safety_general.value | default: p.metafields.npx.safety_general
  assign disclaimer_data       = p.metafields.npx.disclaimer.value | default: p.metafields.npx.disclaimer

  assign how_it_works_field = p.metafields.npx.how_it_works
  assign how_it_works_value = how_it_works_field.value | default: how_it_works_field
-%}
{% # theme-check-disable UnknownFilter %}
{%- liquid
  assign tldr_parsed = nil
  if tldr_data contains '[' or tldr_data contains '{'
    assign tldr_parsed = tldr_data | parse_json
  endif
  if tldr_parsed != blank
    assign tldr_data = tldr_parsed
  endif

  assign what_it_is_parsed = nil
  if what_it_is_data contains '[' or what_it_is_data contains '{'
    assign what_it_is_parsed = what_it_is_data | parse_json
  endif
  if what_it_is_parsed != blank
    assign what_it_is_data = what_it_is_parsed
  endif

  assign feel_parsed = nil
  if feel_data contains '[' or feel_data contains '{'
    assign feel_parsed = feel_data | parse_json
  endif
  if feel_parsed != blank
    assign feel_data = feel_parsed
  endif

  assign how_parsed = nil
  if how_data contains '[' or how_data contains '{'
    assign how_parsed = how_data | parse_json
  endif
  if how_parsed != blank
    assign how_data = how_parsed
  endif

  assign why_parsed = nil
  if why_data contains '[' or why_data contains '{'
    assign why_parsed = why_data | parse_json
  endif
  if why_parsed != blank
    assign why_data = why_parsed
  endif

  assign faq_parsed = nil
  if faq_data contains '[' or faq_data contains '{'
    assign faq_parsed = faq_data | parse_json
  endif
  if faq_parsed != blank
    assign faq_data = faq_parsed
  endif

  assign how_it_works_parsed = nil
  if how_it_works_value contains '[' or how_it_works_value contains '{'
    assign how_it_works_parsed = how_it_works_value | parse_json
  endif

  assign safety_important_parsed = nil
  if safety_important_data contains '[' or safety_important_data contains '{'
    assign safety_important_parsed = safety_important_data | parse_json
  endif
  if safety_important_parsed != blank
    assign safety_important_data = safety_important_parsed
  endif

  assign safety_general_parsed = nil
  if safety_general_data contains '[' or safety_general_data contains '{'
    assign safety_general_parsed = safety_general_data | parse_json
  endif
  if safety_general_parsed != blank
    assign safety_general_data = safety_general_parsed
  endif

  assign disclaimer_parsed = nil
  if disclaimer_data contains '[' or disclaimer_data contains '{'
    assign disclaimer_parsed = disclaimer_data | parse_json
  endif
  if disclaimer_parsed != blank
    assign disclaimer_data = disclaimer_parsed
  endif
-%}
{% # theme-check-enable UnknownFilter %}
{%- liquid
  assign visible_limit = section.settings.max_visible_items | default: 7
-%}

{%- style -%}
  .xo-section--{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .xo-section--{{ section.id }} .vts__inner {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
  }

  .xo-section--{{ section.id }} .vts__header {
    margin-bottom: {{ section.settings.header_spacing }}px;
  }

  .xo-section--{{ section.id }} .vts__title {
    margin: 0 0 10px 0;
    font-size: {{ section.settings.title_font_size }}px;
    font-weight: {{ section.settings.title_font_weight }};
    color: rgba(var(--color-foreground));
    line-height: 1.2;
  }

  .xo-section--{{ section.id }} .vts__subtitle {
    color: color-mix(in srgb, rgba(var(--color-foreground)) 55%, transparent);
    font-size: {{ section.settings.subtitle_font_size }}px;
    line-height: 1.6;
  }

  .xo-section--{{ section.id }} .vts__timeline-wrap {
    position: relative;
  }

  .xo-section--{{ section.id }} .vts__line {
    position: absolute;
    left: {{ section.settings.dot_size | divided_by: 2 }}px;
    top: 0;
    bottom: 0;
    width: {{ section.settings.line_width }}px;
    background-color: color-mix(in srgb, rgba(var(--color-foreground)) 12%, transparent);
    transform: translateX(-50%);
  }

  .xo-section--{{ section.id }} .vts__progress {
    position: absolute;
    left: 0;
    top: 0;
    width: 100%;
    height: 0%;
    background-color: rgba(var(--color-accent));
    transition: height 0.25s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .vts__items {
    position: relative;
    z-index: 1;
  }

  .xo-section--{{ section.id }} .vts__item {
    display: flex;
    gap: {{ section.settings.item_gap }}px;
    margin-bottom: {{ section.settings.item_spacing }}px;
    opacity: 0.45;
    transition: opacity 0.2s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .vts__item.is-active {
    opacity: 1;
  }

  .xo-section--{{ section.id }} .vts__dot-wrap {
    flex-shrink: 0;
    position: relative;
  }

  .xo-section--{{ section.id }} .vts__dot {
    width: {{ section.settings.dot_size }}px;
    height: {{ section.settings.dot_size }}px;
    border-radius: 999px;
    background-color: rgba(var(--color-background));
    border: {{ section.settings.dot_border_width }}px solid color-mix(in srgb, rgba(var(--color-foreground)) 15%, transparent);
    transition: all 0.2s var(--out-soft, ease);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: {{ section.settings.dot_inner_font_size }}px;
    color: rgba(var(--color-foreground));
    line-height: 1;
    user-select: none;
  }

  .xo-section--{{ section.id }} .vts__item.is-active .vts__dot {
    background-color: rgba(var(--color-accent));
    border-color: rgba(var(--color-accent));
    color: rgba(var(--color-background));
    transform: scale(1.12);
  }

  .xo-section--{{ section.id }} .vts__content {
    flex: 1;
    min-width: 0;
    padding-top: {{ section.settings.content_padding_top }}px;
  }

  .xo-section--{{ section.id }} .vts__label {
    font-size: {{ section.settings.label_font_size }}px;
    font-weight: {{ section.settings.label_font_weight }};
    color: color-mix(in srgb, rgba(var(--color-foreground)) 55%, transparent);
    margin: 0 0 8px 0;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .xo-section--{{ section.id }} .vts__item.is-active .vts__label {
    color: rgba(var(--color-foreground));
  }

  .xo-section--{{ section.id }} .vts__label-btn {
    all: unset;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    min-height: var(--touch-min, 44px);
    transition: color 0.3s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .vts__label-btn:focus-visible {
    outline: 2px solid rgba(var(--color-accent));
    outline-offset: 3px;
    border-radius: 4px;
  }

  .xo-section--{{ section.id }} .vts__text {
    color: color-mix(in srgb, rgba(var(--color-foreground)) 55%, transparent);
  }

  .xo-section--{{ section.id }} .vts__item.is-active .vts__text {
    color: rgba(var(--color-foreground));
  }

  .xo-section--{{ section.id }} .vts__text .product-prose {
    font-size: {{ section.settings.text_font_size }}px;
    line-height: 1.7;
  }

  .xo-section--{{ section.id }} .vts__empty {
    color: color-mix(in srgb, rgba(var(--color-foreground)) 40%, transparent);
    font-style: italic;
  }

  .xo-section--{{ section.id }} .vts__faq details {
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
    border-radius: var(--general-radius-1, 1rem);
    padding: 12px 14px;
    margin: 10px 0;
    background: color-mix(in srgb, rgba(var(--color-background)) 90%, transparent);
    transition: border-color 0.3s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .vts__faq details:hover {
    border-color: color-mix(in srgb, rgba(var(--color-foreground)) 20%, transparent);
  }

  .xo-section--{{ section.id }} .vts__faq details[open] {
    border-color: rgba(var(--color-accent));
  }

  .xo-section--{{ section.id }} .vts__faq summary {
    cursor: pointer;
    font-weight: 600;
    list-style: none;
    min-height: var(--touch-min, 44px);
    display: flex;
    align-items: center;
  }

  .xo-section--{{ section.id }} .vts__faq summary::-webkit-details-marker {
    display: none;
  }

  .xo-section--{{ section.id }} .vts__faq summary:focus-visible {
    outline: 2px solid rgba(var(--color-accent));
    outline-offset: 2px;
    border-radius: 4px;
  }

  @media (max-width: 768px) {
    .xo-section--{{ section.id }} .vts__title {
      font-size: {{ section.settings.title_font_size | times: 0.9 }}px;
    }

    .xo-section--{{ section.id }} .vts__label {
      font-size: {{ section.settings.label_font_size | times: 0.92 }}px;
    }

    .xo-section--{{ section.id }} .vts__text .product-prose {
      font-size: {{ section.settings.text_font_size | times: 0.96 }}px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .xo-section--{{ section.id }} .vts__progress,
    .xo-section--{{ section.id }} .vts__dot,
    .xo-section--{{ section.id }} .vts__item,
    .xo-section--{{ section.id }} .vts__label-btn,
    .xo-section--{{ section.id }} .vts__faq details {
      transition: none;
    }
  }
{%- endstyle -%}

<section {% render 'section-attr' %}>
  <xo-container>
    <div class="vts__inner">
      {%- if section.settings.title != blank or section.settings.subtitle != blank -%}
        <div class="vts__header">
          {%- if section.settings.title != blank -%}
            <h2 class="vts__title">{{ section.settings.title }}</h2>
          {%- endif -%}
          {%- if section.settings.subtitle != blank -%}
            <div class="vts__subtitle">{{ section.settings.subtitle }}</div>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- if p == blank -%}
        <div class="vts__empty">
          This section needs a product context. Add it to a product template, or select a "Demo product" in the section settings.
        </div>
      {%- else -%}

        <npx-scroll-timeline-{{ npx_id }}
          class="vts__timeline-wrap"
          data-offset="{{ section.settings.scroll_offset }}"
          data-active-mode="{{ section.settings.active_mode }}"
          data-click-scroll="{{ section.settings.enable_click_scroll }}"
          data-scrollto-offset="{{ section.settings.scroll_to_offset }}"
          style="display:block;"
        >
          <div class="vts__line">
            <div class="vts__progress"></div>
          </div>

          <div class="vts__items">
            {%- liquid
              assign rendered_count = 0
            -%}

            {%- for block in section.blocks -%}
              {%- if block.type != 'item' -%}{%- continue -%}{%- endif -%}
              {%- if rendered_count >= visible_limit -%}{%- break -%}{%- endif -%}

              {%- liquid
                assign label = block.settings.label | default: '' | strip
                assign label = label | replace: '{form}', form_label

                assign source = block.settings.source
              -%}

              {%- capture content_html -%}
                {%- case source -%}

                  {%- when 'tldr' -%}
                    {%- if tldr_data != blank -%}
                      {%- assign tldr_first = tldr_data | json | slice: 0, 1 -%}
                      <div class="product-prose">
                        {%- if tldr_first == '[' -%}
                          <ul>
                            {%- for item in tldr_data -%}
                              {%- assign item_first = item | json | slice: 0, 1 -%}
                              <li>
                                {%- if item_first == '{' -%}
                                  {%- if item.text != blank -%}{{ item.text }}
                                  {%- elsif item.label != blank and item.description != blank -%}<strong>{{ item.label }}:</strong> {{ item.description }}
                                  {%- else -%}{{ item | json }}{%- endif -%}
                                {%- else -%}
                                  {{ item }}
                                {%- endif -%}
                              </li>
                            {%- endfor -%}
                          </ul>
                        {%- else -%}
                          {%- assign lines = tldr_data | newline_to_br | split: '<br />' -%}
                          <ul>
                            {%- for l in lines -%}
                              {%- assign ll = l | strip -%}
                              {%- if ll != blank -%}<li>{{ ll }}</li>{%- endif -%}
                            {%- endfor -%}
                          </ul>
                        {%- endif -%}
                      </div>
                    {%- endif -%}

                  {%- when 'what_it_is' -%}
                    {%- if what_it_is_data != blank -%}
                      {%- assign wi_first = what_it_is_data | json | slice: 0, 1 -%}
                      <div class="product-prose">
                        {%- if wi_first == '[' -%}
                          <ul>
                            {%- for item in what_it_is_data -%}<li>{{ item }}</li>{%- endfor -%}
                          </ul>
                        {%- elsif wi_first == '{' -%}
                          <dl>
                            {%- for kv in what_it_is_data -%}
                              <dt><strong>{{ kv[0] }}</strong></dt>
                              <dd>{{ kv[1] }}</dd>
                            {%- endfor -%}
                          </dl>
                        {%- else -%}
                          <p>{{ what_it_is_data | newline_to_br }}</p>
                        {%- endif -%}
                      </div>
                    {%- endif -%}

                  {%- when 'feel_timeline' -%}
                    {%- if feel_data != blank -%}
                      {%- assign feel_first = feel_data | json | slice: 0, 1 -%}
                      <div class="product-prose">
                        {%- if feel_first == '[' -%}
                          <ul>
                            {%- for f in feel_data -%}
                              {%- assign f_label = f.label | default: f.title | default: f.time -%}
                              {%- assign f_desc  = f.description | default: f.text | default: f.value -%}
                              <li>
                                {%- if f_label != blank and f_desc != blank -%}
                                  <strong>{{ f_label }}:</strong> {{ f_desc }}
                                {%- elsif f_desc != blank -%}
                                  {{ f_desc }}
                                {%- else -%}
                                  {{ f }}
                                {%- endif -%}
                              </li>
                            {%- endfor -%}
                          </ul>
                        {%- else -%}
                          <p>{{ feel_data | newline_to_br }}</p>
                        {%- endif -%}
                      </div>
                    {%- endif -%}

                  {%- when 'feel_note' -%}
                    {%- if feel_note_data != blank -%}
                      <div class="product-prose">
                        <aside class="npx-note">{{ feel_note_data | newline_to_br }}</aside>
                      </div>
                    {%- endif -%}

                  {%- when 'how_it_works' -%}
                    {%- if how_it_works_field != blank -%}
                      <div class="product-prose">
                        {%- if how_it_works_parsed != blank -%}
                          {%- assign hiw_first = how_it_works_parsed | json | slice: 0, 1 -%}
                          {%- if hiw_first == '[' -%}
                            <ul>
                              {%- for item in how_it_works_parsed -%}<li>{{ item }}</li>{%- endfor -%}
                            </ul>
                          {%- elsif hiw_first == '{' -%}
                            <dl>
                              {%- for kv in how_it_works_parsed -%}
                                <dt><strong>{{ kv[0] }}</strong></dt>
                                <dd>{{ kv[1] }}</dd>
                              {%- endfor -%}
                            </dl>
                          {%- else -%}
                            <p>{{ how_it_works_parsed | newline_to_br }}</p>
                          {%- endif -%}
                        {%- else -%}
                          {{ how_it_works_field | metafield_tag }}
                        {%- endif -%}
                      </div>
                    {%- endif -%}

                  {%- when 'how_to_use' -%}
                    {%- if how_data != blank -%}
                      {%- assign how_first = how_data | json | slice: 0, 1 -%}
                      <div class="product-prose">
                        {%- if how_first == '[' -%}
                          <ul>
                            {%- for h in how_data -%}
                              {%- assign h_label = h.label | default: h.title -%}
                              {%- assign h_text  = h.text | default: h.description | default: h.value -%}
                              <li>
                                {%- if h_label != blank and h_text != blank -%}
                                  <strong>{{ h_label }}:</strong> {{ h_text }}
                                {%- elsif h_text != blank -%}
                                  {{ h_text }}
                                {%- else -%}
                                  {{ h }}
                                {%- endif -%}
                              </li>
                            {%- endfor -%}
                          </ul>
                        {%- else -%}
                          <p>{{ how_data | newline_to_br }}</p>
                        {%- endif -%}
                      </div>
                    {%- endif -%}

                  {%- when 'why' -%}
                    {%- if why_data != blank -%}
                      {%- assign why_first = why_data | json | slice: 0, 1 -%}
                      <div class="product-prose">
                        {%- if why_first == '[' -%}
                          <ul>
                            {%- for w in why_data -%}<li>{{ w }}</li>{%- endfor -%}
                          </ul>
                        {%- else -%}
                          {%- assign lines = why_data | newline_to_br | split: '<br />' -%}
                          <ul>
                            {%- for l in lines -%}
                              {%- assign ll = l | strip -%}
                              {%- if ll != blank -%}<li>{{ ll }}</li>{%- endif -%}
                            {%- endfor -%}
                          </ul>
                        {%- endif -%}
                      </div>
                    {%- endif -%}

                  {%- when 'safety' -%}
                    {%- if safety_important_data != blank or safety_general_data != blank or disclaimer_data != blank -%}
                      <div class="product-prose">
                        {%- if safety_important_data != blank -%}
                          {%- assign si_first = safety_important_data | json | slice: 0, 1 -%}
                          {%- if si_first == '[' -%}
                            <aside class="npx-important">
                              <strong>Important:</strong>
                              <ul>
                                {%- for item in safety_important_data -%}<li>{{ item }}</li>{%- endfor -%}
                              </ul>
                            </aside>
                          {%- else -%}
                            <aside class="npx-important"><strong>Important:</strong> {{ safety_important_data | newline_to_br }}</aside>
                          {%- endif -%}
                        {%- endif -%}

                        {%- if safety_general_data != blank -%}
                          {%- assign sg_first = safety_general_data | json | slice: 0, 1 -%}
                          {%- if sg_first == '[' -%}
                            <p><strong>General safety:</strong></p>
                            <ul>
                              {%- for item in safety_general_data -%}<li>{{ item }}</li>{%- endfor -%}
                            </ul>
                          {%- else -%}
                            <p><strong>General safety:</strong> {{ safety_general_data | newline_to_br }}</p>
                          {%- endif -%}
                        {%- endif -%}

                        {%- if disclaimer_data != blank -%}
                          {%- assign d_first = disclaimer_data | json | slice: 0, 1 -%}
                          {%- if d_first == '[' -%}
                            <aside class="npx-disclaimer">
                              <strong>Disclaimer:</strong>
                              <ul>
                                {%- for item in disclaimer_data -%}<li>{{ item }}</li>{%- endfor -%}
                              </ul>
                            </aside>
                          {%- else -%}
                            <aside class="npx-disclaimer"><strong>Disclaimer:</strong> {{ disclaimer_data | newline_to_br }}</aside>
                          {%- endif -%}
                        {%- endif -%}
                      </div>
                    {%- endif -%}

                  {%- when 'faq' -%}
                    {%- if faq_data != blank -%}
                      {%- assign faq_first = faq_data | json | slice: 0, 1 -%}
                      <div class="product-prose vts__faq">
                        {%- if faq_first == '[' -%}
                          {%- if section.settings.faq_style == 'accordion' -%}
                            {%- for q in faq_data -%}
                              <details>
                                <summary>{{ q.q | default: q.question | default: q.title | default: 'Question ' | append: forloop.index }}</summary>
                                <div style="margin-top:10px;">
                                  {{ q.a | default: q.answer | default: q.text | newline_to_br }}
                                </div>
                              </details>
                            {%- endfor -%}
                          {%- else -%}
                            {%- for q in faq_data -%}
                              <p>
                                <strong>{{ forloop.index }}. {{ q.q | default: q.question | default: q.title }}</strong><br>
                                {{ q.a | default: q.answer | default: q.text | newline_to_br }}
                              </p>
                            {%- endfor -%}
                          {%- endif -%}
                        {%- else -%}
                          <p>{{ faq_data | newline_to_br }}</p>
                        {%- endif -%}
                      </div>
                    {%- endif -%}

                  {%- when 'custom' -%}
                    {%- if block.settings.custom_content != blank -%}
                      <div class="product-prose">
                        {{ block.settings.custom_content }}
                      </div>
                    {%- endif -%}

                  {%- else -%}

                {%- endcase -%}
              {%- endcapture -%}

              {%- assign content_stripped = content_html | strip -%}
              {%- liquid
                assign should_render = true
                if content_stripped == blank and block.settings.hide_if_empty
                  assign should_render = false
                endif
              -%}

              {%- if should_render -%}
                {%- liquid
                  assign rendered_count = rendered_count | plus: 1
                  assign rendered_index0 = rendered_count | minus: 1
                -%}

                <div class="vts__item{% if rendered_count == 1 %} is-active{% endif %}"
                     data-index="{{ rendered_index0 }}"
                     style="scroll-margin-top:{{ section.settings.scroll_to_offset }}px;"
                     {{ block.shopify_attributes }}>
                  <div class="vts__dot-wrap">
                    <div class="vts__dot">
                      {%- if section.settings.dot_inner_mode == 'number' -%}
                        {{ rendered_count }}
                      {%- endif -%}
                    </div>
                  </div>

                  <div class="vts__content">
                    {%- if label != blank -%}
                      <div class="vts__label">
                        {%- if section.settings.enable_click_scroll -%}
                          <button class="vts__label-btn" type="button" data-scrollto="{{ rendered_index0 }}">
                            {{ label }}
                          </button>
                        {%- else -%}
                          {{ label }}
                        {%- endif -%}
                      </div>
                    {%- endif -%}

                    {%- if content_stripped != blank -%}
                      <div class="vts__text">
                        {{ content_html }}
                      </div>
                    {%- else -%}
                      {%- if section.settings.show_empty_placeholder -%}
                        <div class="vts__text vts__empty">
                          {{ section.settings.empty_placeholder_text }}
                        </div>
                      {%- endif -%}
                    {%- endif -%}
                  </div>
                </div>
              {%- endif -%}
            {%- endfor -%}

            {%- if rendered_count == 0 -%}
              <div class="vts__empty">
                No configured items have content for this product.
              </div>
            {%- endif -%}
          </div>
        </npx-scroll-timeline-{{ npx_id }}>

      {%- endif -%}
    </div>
  </xo-container>
</section>

<script>
  (function() {
    const tagName = 'npx-scroll-timeline-{{ npx_id }}';
    if (customElements.get(tagName)) return;

    class NpxScrollTimeline extends HTMLElement {
      constructor() {
        super();
        this.items = [];
        this.progressBar = null;
        this.offsetPct = 50;
        this.activeMode = 'cumulative';
        this.clickScroll = false;
        this.scrollToOffset = 0;
        this._ticking = false;

        this.onScroll = this.onScroll.bind(this);
        this.onClick = this.onClick.bind(this);
      }

      connectedCallback() {
        this.items = Array.from(this.querySelectorAll('[data-index]'));
        this.progressBar = this.querySelector('.vts__progress');

        this.offsetPct = parseInt(this.dataset.offset, 10) || 50;
        this.activeMode = (this.dataset.activeMode || 'cumulative').toLowerCase();
        this.clickScroll = (this.dataset.clickScroll === 'true');
        this.scrollToOffset = parseInt(this.dataset.scrolltoOffset, 10) || 0;

        if (this.clickScroll) this.addEventListener('click', this.onClick);

        window.addEventListener('scroll', this.onScroll, { passive: true });
        window.addEventListener('resize', this.onScroll, { passive: true });
        this.onScroll();
      }

      disconnectedCallback() {
        window.removeEventListener('scroll', this.onScroll);
        window.removeEventListener('resize', this.onScroll);
        this.removeEventListener('click', this.onClick);
      }

      onClick(e) {
        const btn = e.target.closest('[data-scrollto]');
        if (!btn) return;

        const index = parseInt(btn.getAttribute('data-scrollto'), 10);
        const el = this.items[index];
        if (!el) return;

        const top = el.getBoundingClientRect().top + window.scrollY - this.scrollToOffset;
        window.scrollTo({ top, behavior: 'smooth' });
      }

      onScroll() {
        if (this._ticking) return;
        this._ticking = true;

        requestAnimationFrame(() => {
          this._ticking = false;

          const vh = window.innerHeight || 0;
          const triggerY = vh * (this.offsetPct / 100);

          let activeIndex = -1;
          for (let i = 0; i < this.items.length; i++) {
            const top = this.items[i].getBoundingClientRect().top;
            if (top <= triggerY) activeIndex = i;
          }

          this.items.forEach((item, idx) => {
            if (this.activeMode === 'single') {
              item.classList.toggle('is-active', idx === activeIndex);
            } else {
              item.classList.toggle('is-active', idx <= activeIndex && activeIndex >= 0);
            }
          });

          let progress = 0;
          if (this.items.length > 1 && activeIndex >= 0) {
            progress = (activeIndex / (this.items.length - 1)) * 100;
          }
          if (this.progressBar) this.progressBar.style.height = `${Math.max(0, Math.min(100, progress))}%`;
        });
      }
    }

    customElements.define(tagName, NpxScrollTimeline);
  })();
</script>

