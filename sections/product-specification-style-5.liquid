{{ 'product-specification-5.css' | asset_url | stylesheet_tag }}
{{ 'feature-special.css' | asset_url | stylesheet_tag }}

{% liquid
  assign layout = section.settings.layout
  assign heading = section.settings.text_heading
  assign image_1 = section.settings.image_1
  assign image_2 = section.settings.image_2
  assign aspect_ratio = section.settings.aspect_ratio
  if aspect_ratio == 'custom'
    assign aspect_ratio = section.settings.aspect_ratio_width | append: '/' | append: section.settings.aspect_ratio_height
  endif
  assign block = section.blocks
%}

<section {% render 'section-attr' %}>
  <div class="product-specification-style-5">
    <xo-container class="product-specification-style-5__container">
      <div class="product-specification-style-5__content">
        {% render 'product-specification-5', heading: heading, image_1: image_1, image_2: image_2, aspect_ratio: aspect_ratio, block: block, layout: layout %}
      </div>
    </xo-container>
  </div>
</section>

