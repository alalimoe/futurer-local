{% schema %}
{
  "name": "Storage Protocol",
  "tag": "section",
  "class": "section-storage-protocol",
  "settings": [
    {
      "type": "header",
      "content": "Theme Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card Background",
      "default": "#f9fafb"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color (Gold)",
      "default": "#fbbf24"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#111827"
    },
    {
      "type": "header",
      "content": "Text Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Storage & Stability"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Follow these guidelines to maintain compound potency."
    }
  ],
  "presets": [
    {
      "name": "Storage Protocol"
    }
  ]
}
{% endschema %}

<div class="sp-wrapper">
  <div class="sp-container">
    
    <div class="sp-header">
      <h2 class="sp-title">{{ section.settings.heading }}</h2>
      <p class="sp-subtitle">{{ section.settings.subheading }}</p>
    </div>

    <div class="sp-grid">
      
      <div class="sp-card">
        <div class="sp-card-header">
          <div class="sp-icon-box">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12h20"/><path d="M12 2v20"/><path d="M20 16l-4-4 4-4"/><path d="M4 8l4 4-4 4"/><path d="M16 4l-4 4-4-4"/><path d="M8 20l4-4 4 4"/></svg>
          </div>
          <h3 class="sp-card-title">Lyophilized (Powder)</h3>
          <span class="sp-badge">Before Mixing</span>
        </div>
        
        <div class="sp-card-body">
          <div class="sp-row">
            <span class="sp-label">Location</span>
            <span class="sp-value">Freezer (-20°C)</span>
          </div>
          <div class="sp-row">
            <span class="sp-label">Shelf Life</span>
            <span class="sp-value">Up to 24 Months</span>
          </div>
          <div class="sp-note">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            <strong>Note:</strong> Keep away from direct light and moisture.
          </div>
        </div>
      </div>

      <div class="sp-card active-card">
        <div class="sp-card-header">
          <div class="sp-icon-box active-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 4v10.54a4 4 0 1 1-4 0V4a2 2 0 0 1 4 0Z"/><path d="M10 20h4"/></svg>
          </div>
          <h3 class="sp-card-title">Reconstituted (Liquid)</h3>
          <span class="sp-badge active-badge">After Mixing</span>
        </div>
        
        <div class="sp-card-body">
          <div class="sp-row">
            <span class="sp-label">Location</span>
            <span class="sp-value">Refrigerator (2°C to 8°C)</span>
          </div>
          <div class="sp-row">
            <span class="sp-label">Shelf Life</span>
            <span class="sp-value">4–8 Weeks</span>
          </div>
          <div class="sp-note warning-note">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            <strong>Warning:</strong> Bacteria grows fast. Discard immediately if cloudy.
          </div>
        </div>
      </div>

    </div>
  </div>
</div>

<style>
  :root {
    --sp-bg: {{ section.settings.bg_color }};
    --sp-card-bg: {{ section.settings.card_bg }};
    --sp-accent: {{ section.settings.accent_color }};
    --sp-text: {{ section.settings.text_color }};
    --sp-border: var(--color-border-default);
    --sp-muted: var(--color-text-secondary);
    --sp-font: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  }

  .sp-wrapper {
    background-color: var(--sp-bg);
    color: var(--sp-text);
    padding: 60px var(--page-gutter);
    font-family: var(--sp-font);
    line-height: 1.5;
  }
  
  .sp-container {
    max-width: var(--container-width-narrow);
    margin: 0 auto;
  }

  /* HEADER */
  .sp-header {
    text-align: center;
    margin-bottom: 40px;
  }
  .sp-title {
    font-size: 28px;
    font-weight: 800;
    margin: 0 0 10px;
    color: var(--sp-text);
  }
  .sp-subtitle {
    color: var(--sp-muted);
    font-size: 16px;
  }

  /* GRID */
  .sp-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 30px;
  }
  @media(max-width: 768px) {
    .sp-grid { grid-template-columns: 1fr; }
  }

  /* CARDS */
  .sp-card {
    background: var(--sp-card-bg);
    border: 1px solid var(--sp-border);
    border-radius: 12px;
    overflow: hidden;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .sp-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.05);
    border-color: var(--color-border-default);
  }

  /* Active Card Styling (Liquid) */
  .sp-card.active-card {
    border-color: var(--sp-accent);
    background: var(--color-surface-primary);
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
  }

  /* HEADER INSIDE CARD */
  .sp-card-header {
    padding: 24px;
    border-bottom: 1px solid var(--sp-border);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    background: rgba(255,255,255,0.5);
  }
  .sp-icon-box {
    width: 48px;
    height: 48px;
    background: var(--color-border-default);
    color: var(--color-ui-charcoal-hover);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 16px;
  }
  .active-icon {
    background: var(--sp-accent);
    color: var(--color-text-primary);
  }

  .sp-card-title {
    font-size: 18px;
    font-weight: 700;
    margin: 0 0 8px;
    color: var(--sp-text);
  }

  .sp-badge {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    background: var(--color-border-default);
    color: var(--color-ui-charcoal-hover);
    padding: 4px 10px;
    border-radius: 99px;
    font-weight: 700;
  }
  .active-badge {
    background: var(--color-warning-bg);
    color: var(--color-warning-text);
    border: 1px solid var(--sp-accent);
  }

  /* BODY */
  .sp-card-body {
    padding: 24px;
  }

  .sp-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--color-surface-secondary);
  }
  .sp-row:last-of-type {
    border-bottom: none;
    padding-bottom: 0;
    margin-bottom: 20px;
  }

  .sp-label {
    font-size: 13px;
    font-weight: 600;
    color: var(--sp-muted);
    text-transform: uppercase;
  }
  .sp-value {
    font-size: 15px;
    font-weight: 700;
    color: var(--sp-text);
  }

  /* NOTES */
  .sp-note {
    background: var(--color-surface-secondary);
    padding: 12px;
    border-radius: 8px;
    font-size: 13px;
    color: var(--color-text-secondary);
    display: flex;
    gap: 8px;
    align-items: start;
    line-height: 1.4;
  }
  .sp-note svg {
    flex-shrink: 0;
    margin-top: 2px;
  }
  .warning-note {
    background: var(--color-error-bg);
    color: var(--color-error-text);
    border: 1px solid var(--color-error);
  }
</style>