{%- style -%}
  .xo-section--{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .xo-section--{{ section.id }} .sp-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .xo-section--{{ section.id }} .sp-title {
    font-family: var(--font-heading-family);
    font-size: clamp(1.4rem, 2.5vw, 1.75rem);
    font-weight: 600;
    margin: 0 0 10px;
    color: rgba(var(--color-foreground));
    letter-spacing: -0.025em;
    line-height: 1.2;
  }

  .xo-section--{{ section.id }} .sp-subtitle {
    color: color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent);
    font-size: clamp(0.875rem, 1.5vw, 1rem);
  }

  .xo-section--{{ section.id }} .sp-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    max-width: 900px;
    margin: 0 auto;
  }

  @media (max-width: 768px) {
    .xo-section--{{ section.id }} .sp-grid {
      grid-template-columns: 1fr;
    }
  }

  .xo-section--{{ section.id }} .sp-card {
    background: rgba(var(--color-background-2));
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
    border-radius: var(--general-radius-3, 2rem);
    overflow: hidden;
    transition: border-color 0.3s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .sp-card:hover {
    border-color: color-mix(in srgb, rgba(var(--color-foreground)) 20%, transparent);
  }

  .xo-section--{{ section.id }} .sp-card.active-card {
    border-color: rgba(var(--color-accent));
    background: rgba(var(--color-background));
  }

  .xo-section--{{ section.id }} .sp-card-header {
    padding: 24px;
    border-bottom: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    background: color-mix(in srgb, rgba(var(--color-background)) 50%, transparent);
  }

  .xo-section--{{ section.id }} .sp-icon-box {
    width: 48px;
    height: 48px;
    background: rgba(var(--color-background-2));
    color: color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 16px;
  }

  .xo-section--{{ section.id }} .active-icon {
    background: rgba(var(--color-accent));
    color: rgba(var(--color-foreground));
  }

  .xo-section--{{ section.id }} .sp-card-title {
    font-family: var(--font-heading-family);
    font-size: 1.125rem;
    font-weight: 600;
    margin: 0 0 8px;
    color: rgba(var(--color-foreground));
  }

  .xo-section--{{ section.id }} .sp-badge {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    background: rgba(var(--color-background-2));
    color: color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent);
    padding: 4px 10px;
    border-radius: var(--button-radius);
    font-weight: 600;
  }

  .xo-section--{{ section.id }} .active-badge {
    background: color-mix(in srgb, rgba(var(--color-accent)) 15%, transparent);
    color: rgba(var(--color-accent));
    border: 1px solid rgba(var(--color-accent));
  }

  .xo-section--{{ section.id }} .sp-card-body {
    padding: 24px;
  }

  .xo-section--{{ section.id }} .sp-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
    padding-bottom: 16px;
    border-bottom: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 8%, transparent);
  }

  .xo-section--{{ section.id }} .sp-row:last-of-type {
    border-bottom: none;
    padding-bottom: 0;
    margin-bottom: 20px;
  }

  .xo-section--{{ section.id }} .sp-label {
    font-size: 13px;
    font-weight: 600;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent);
    text-transform: uppercase;
  }

  .xo-section--{{ section.id }} .sp-value {
    font-size: 15px;
    font-weight: 600;
    color: rgba(var(--color-foreground));
  }

  .xo-section--{{ section.id }} .sp-note {
    background: rgba(var(--color-background-2));
    padding: 12px;
    border-radius: var(--general-radius-1, 1rem);
    font-size: 13px;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent);
    display: flex;
    gap: 8px;
    align-items: start;
    line-height: 1.4;
  }

  .xo-section--{{ section.id }} .sp-note svg {
    flex-shrink: 0;
    margin-top: 2px;
  }

  .xo-section--{{ section.id }} .warning-note {
    background: color-mix(in srgb, rgba(var(--color-error)) 8%, transparent);
    color: rgba(var(--color-error));
    border: 1px solid color-mix(in srgb, rgba(var(--color-error)) 30%, transparent);
  }

  @media (prefers-reduced-motion: reduce) {
    .xo-section--{{ section.id }} *,
    .xo-section--{{ section.id }} *::before,
    .xo-section--{{ section.id }} *::after {
      animation-duration: 0.01ms !important;
      transition-duration: 0.01ms !important;
    }
  }
{%- endstyle -%}

<section {% render 'section-attr' %}>
  <xo-container>

    <div class="sp-header">
      <h2 class="sp-title">{{ section.settings.heading }}</h2>
      <p class="sp-subtitle">{{ section.settings.subheading }}</p>
    </div>

    <div class="sp-grid">

      <div class="sp-card">
        <div class="sp-card-header">
          <div class="sp-icon-box">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12h20"/><path d="M12 2v20"/><path d="M20 16l-4-4 4-4"/><path d="M4 8l4 4-4 4"/><path d="M16 4l-4 4-4-4"/><path d="M8 20l4-4 4 4"/></svg>
          </div>
          <h3 class="sp-card-title">Lyophilized (Powder)</h3>
          <span class="sp-badge">Before Mixing</span>
        </div>

        <div class="sp-card-body">
          <div class="sp-row">
            <span class="sp-label">Location</span>
            <span class="sp-value">Freezer (-20°C)</span>
          </div>
          <div class="sp-row">
            <span class="sp-label">Shelf Life</span>
            <span class="sp-value">Up to 24 Months</span>
          </div>
          <div class="sp-note">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            <strong>Note:</strong> Keep away from direct light and moisture.
          </div>
        </div>
      </div>

      <div class="sp-card active-card">
        <div class="sp-card-header">
          <div class="sp-icon-box active-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 4v10.54a4 4 0 1 1-4 0V4a2 2 0 0 1 4 0Z"/><path d="M10 20h4"/></svg>
          </div>
          <h3 class="sp-card-title">Reconstituted (Liquid)</h3>
          <span class="sp-badge active-badge">After Mixing</span>
        </div>

        <div class="sp-card-body">
          <div class="sp-row">
            <span class="sp-label">Location</span>
            <span class="sp-value">Refrigerator (2°C to 8°C)</span>
          </div>
          <div class="sp-row">
            <span class="sp-label">Shelf Life</span>
            <span class="sp-value">4–8 Weeks</span>
          </div>
          <div class="sp-note warning-note">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            <strong>Warning:</strong> Bacteria grows fast. Discard immediately if cloudy.
          </div>
        </div>
      </div>

    </div>

  </xo-container>
</section>

{% schema %}
{
  "name": "Storage Protocol",
  "tag": "section",
  "class": "section-storage-protocol",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "default" },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Storage & Stability"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Follow these guidelines to maintain compound potency."
    },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding top", "default": 80 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding bottom", "default": 80 }
  ],
  "blocks": [
    { "type": "@app" }
  ],
  "presets": [
    {
      "name": "Storage Protocol"
    }
  ]
}
{% endschema %}
