{%- style -%}
  .xo-section--{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .xo-section--{{ section.id }} .bgb-layout {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 48px;
  }

  .xo-section--{{ section.id }} .bgb-toc {
    position: sticky;
    top: 80px;
    align-self: start;
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 12%, transparent);
    border-radius: var(--general-radius-3, 2rem);
    padding: 20px;
    max-height: calc(100vh - 120px);
    overflow-y: auto;
  }

  .xo-section--{{ section.id }} .bgb-toc__title {
    font-weight: 600;
    font-size: clamp(0.75rem, 1vw, 0.8125rem);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 55%, transparent);
    margin-bottom: 12px;
  }

  .xo-section--{{ section.id }} .bgb-toc__link {
    display: block;
    padding: 8px 12px;
    font-size: calc(var(--font-body-scale, 1) * 1.4rem);
    color: color-mix(in srgb, rgba(var(--color-foreground)) 55%, transparent);
    text-decoration: none;
    border-radius: 8px;
    transition: color 0.3s var(--out-soft, ease), background 0.3s var(--out-soft, ease);
    line-height: 1.4;
  }

  .xo-section--{{ section.id }} .bgb-toc__link:hover {
    color: rgba(var(--color-foreground));
    background: color-mix(in srgb, rgba(var(--color-foreground)) 4%, transparent);
  }

  .xo-section--{{ section.id }} .bgb-toc__link--active {
    color: rgba(var(--color-foreground));
    background: color-mix(in srgb, rgba(var(--color-accent)) 10%, transparent);
    font-weight: 600;
  }

  .xo-section--{{ section.id }} .bgb-main {
    max-width: 70ch;
    min-width: 0;
  }

  .xo-section--{{ section.id }} .bgb-modes {
    display: flex;
    gap: 6px;
    margin-bottom: 24px;
    flex-wrap: wrap;
  }

  .xo-section--{{ section.id }} .bgb-mode-btn {
    min-height: 44px;
    padding: 8px 16px;
    font-size: calc(var(--font-body-scale, 1) * 1.4rem);
    font-weight: 600;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 55%, transparent);
    background: rgba(var(--color-background));
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 12%, transparent);
    border-radius: var(--button-radius);
    cursor: pointer;
    transition: border-color 0.3s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .bgb-mode-btn:hover {
    color: rgba(var(--color-foreground));
  }

  .xo-section--{{ section.id }} .bgb-mode-btn--active {
    color: rgba(var(--color-foreground));
    background: rgba(var(--color-accent));
    border-color: rgba(var(--color-accent));
  }

  .xo-section--{{ section.id }} .bgb-mode-btn:focus-visible {
    outline: 2px solid rgba(var(--color-accent));
    outline-offset: 2px;
  }

  body.bgb-mode-adhd .bgb-prose {
    line-height: 1.95;
  }

  body.bgb-mode-adhd .bgb-prose strong {
    background: color-mix(in srgb, rgba(var(--color-accent)) 15%, transparent);
    padding: 0 2px;
    border-radius: 2px;
  }

  .xo-section--{{ section.id }} .bgb-ai {
    margin-bottom: 28px;
    padding: 20px;
    background: color-mix(in srgb, rgba(var(--color-foreground)) 3%, transparent);
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 12%, transparent);
    border-radius: var(--general-radius-3, 2rem);
  }

  .xo-section--{{ section.id }} .bgb-ai-input-wrap {
    position: relative;
    margin-bottom: 12px;
  }

  .xo-section--{{ section.id }} .bgb-ai-icon {
    position: absolute;
    left: 14px;
    top: 50%;
    transform: translateY(-50%);
    color: color-mix(in srgb, rgba(var(--color-foreground)) 55%, transparent);
    pointer-events: none;
  }

  .xo-section--{{ section.id }} .bgb-ai-input {
    width: 100%;
    padding: 12px 14px 12px 40px;
    font-size: calc(var(--font-body-scale, 1) * 1.5rem);
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 12%, transparent);
    border-radius: var(--general-radius-1, 1rem);
    background: rgba(var(--color-background));
    color: rgba(var(--color-foreground));
    min-height: 44px;
    transition: border-color 0.3s var(--out-soft, ease);
    -webkit-appearance: none;
    appearance: none;
  }

  .xo-section--{{ section.id }} .bgb-ai-input:focus {
    outline: none;
    border-color: rgba(var(--color-accent));
  }

  .xo-section--{{ section.id }} .bgb-ai-input:focus-visible {
    outline: 2px solid rgba(var(--color-accent));
    outline-offset: 2px;
  }

  .xo-section--{{ section.id }} .bgb-ai-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 8px;
  }

  .xo-section--{{ section.id }} .bgb-ai-chip {
    padding: 6px 12px;
    font-size: clamp(0.75rem, 1vw, 0.8125rem);
    font-weight: 500;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 55%, transparent);
    background: rgba(var(--color-background));
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 12%, transparent);
    border-radius: var(--button-radius);
    cursor: pointer;
    transition: border-color 0.3s var(--out-soft, ease);
    min-height: 44px;
  }

  .xo-section--{{ section.id }} .bgb-ai-chip:hover {
    border-color: rgba(var(--color-accent));
    background: color-mix(in srgb, rgba(var(--color-accent)) 8%, transparent);
  }

  .xo-section--{{ section.id }} .bgb-ai-disclaimer {
    font-size: clamp(0.7rem, 1vw, 0.75rem);
    color: color-mix(in srgb, rgba(var(--color-foreground)) 55%, transparent);
    display: block;
  }

  .xo-section--{{ section.id }} .bgb-sens {
    margin-bottom: 32px;
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .xo-section--{{ section.id }} .bgb-sens-label {
    font-size: calc(var(--font-body-scale, 1) * 1.4rem);
    font-weight: 600;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 55%, transparent);
    white-space: nowrap;
  }

  .xo-section--{{ section.id }} .bgb-sens-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .xo-section--{{ section.id }} .bgb-sens-chip {
    padding: 6px 12px;
    font-size: clamp(0.75rem, 1vw, 0.8125rem);
    font-weight: 500;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 55%, transparent);
    background: rgba(var(--color-background));
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 12%, transparent);
    border-radius: var(--button-radius);
    cursor: pointer;
    transition: border-color 0.3s var(--out-soft, ease);
    min-height: 44px;
  }

  .xo-section--{{ section.id }} .bgb-sens-chip:hover {
    border-color: rgba(var(--color-accent));
  }

  .xo-section--{{ section.id }} .bgb-sens-chip--active {
    background: color-mix(in srgb, rgba(var(--color-accent)) 12%, transparent);
    border-color: rgba(var(--color-accent));
    font-weight: 600;
  }

  .xo-section--{{ section.id }} .bgb-content {
    max-width: 70ch;
  }

  .xo-section--{{ section.id }} .bgb-prose {
    font-size: calc(var(--font-body-scale, 1) * 1.6rem);
    line-height: 1.75;
    color: rgba(var(--color-foreground));
    margin-bottom: 1.5rem;
    transition: background 0.3s var(--out-soft, ease);
    padding: 2px 0;
    border-radius: 4px;
  }

  .xo-section--{{ section.id }} .bgb-prose p { margin: 0 0 1em; }
  .xo-section--{{ section.id }} .bgb-prose p:last-child { margin-bottom: 0; }
  .xo-section--{{ section.id }} .bgb-prose strong { color: rgba(var(--color-foreground)); font-weight: 600; }
  .xo-section--{{ section.id }} .bgb-prose a { color: rgba(var(--color-foreground)); text-decoration: underline; text-underline-offset: 3px; }
  .xo-section--{{ section.id }} .bgb-prose ul,
  .xo-section--{{ section.id }} .bgb-prose ol { padding-left: 1.25em; margin: 0.75em 0; }
  .xo-section--{{ section.id }} .bgb-prose li { margin-bottom: 0.4em; }

  .xo-section--{{ section.id }} .bgb-sens-block--highlighted {
    background: color-mix(in srgb, rgba(var(--color-accent)) 8%, transparent);
    border-left: 3px solid rgba(var(--color-accent));
    padding: 8px 12px;
    border-radius: var(--general-radius-1, 1rem);
  }

  .xo-section--{{ section.id }} .bgb-heading {
    color: rgba(var(--color-foreground));
    letter-spacing: -0.02em;
    scroll-margin-top: 80px;
  }

  .xo-section--{{ section.id }} .bgb-heading--h2 {
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    font-weight: 600;
    margin: 2.5rem 0 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid color-mix(in srgb, rgba(var(--color-foreground)) 12%, transparent);
  }

  .xo-section--{{ section.id }} .bgb-heading--h3 {
    font-size: clamp(1.25rem, 2vw, 1.5rem);
    font-weight: 600;
    margin: 2rem 0 0.75rem;
  }

  .xo-section--{{ section.id }} .bgb-heading:first-child { margin-top: 0; }

  .xo-section--{{ section.id }} .bgb-callout {
    display: flex;
    gap: 14px;
    padding: 20px;
    background: color-mix(in srgb, rgba(var(--color-foreground)) 3%, transparent);
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 12%, transparent);
    border-left: 4px solid rgba(var(--color-accent));
    border-radius: var(--general-radius-1, 1rem);
    margin: 1.5rem 0;
  }

  .xo-section--{{ section.id }} .bgb-callout-icon {
    flex-shrink: 0;
    color: rgba(var(--color-accent));
    margin-top: 2px;
  }

  .xo-section--{{ section.id }} .bgb-callout-title {
    display: block;
    font-size: clamp(0.75rem, 1vw, 0.875rem);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: rgba(var(--color-foreground));
    margin-bottom: 6px;
  }

  .xo-section--{{ section.id }} .bgb-callout-text {
    font-size: calc(var(--font-body-scale, 1) * 1.6rem);
    line-height: 1.7;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 70%, transparent);
  }

  .xo-section--{{ section.id }} .bgb-callout-text p { margin: 0 0 0.5em; }
  .xo-section--{{ section.id }} .bgb-callout-text p:last-child { margin-bottom: 0; }

  .xo-section--{{ section.id }} .bgb-quote {
    margin: 2rem 0;
    padding: 0 0 0 20px;
    border-left: 3px solid rgba(var(--color-accent));
  }

  .xo-section--{{ section.id }} .bgb-quote-text {
    font-style: italic;
    font-size: calc(var(--font-body-scale, 1) * 1.6rem);
    line-height: 1.7;
    color: rgba(var(--color-foreground));
    margin: 0;
  }

  .xo-section--{{ section.id }} .bgb-quote-text p { margin: 0 0 0.5em; }
  .xo-section--{{ section.id }} .bgb-quote-text p:last-child { margin-bottom: 0; }

  .xo-section--{{ section.id }} .bgb-quote-cite {
    font-size: calc(var(--font-body-scale, 1) * 1.4rem);
    color: color-mix(in srgb, rgba(var(--color-foreground)) 55%, transparent);
    margin-top: 8px;
    font-style: normal;
  }

  .xo-section--{{ section.id }} .bgb-quote-cite a { color: rgba(var(--color-foreground)); }

  .xo-section--{{ section.id }} :focus-visible {
    outline: 2px solid rgba(var(--color-accent));
    outline-offset: 2px;
  }

  @media (max-width: 768px) {
    .xo-section--{{ section.id }} .bgb-layout {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .xo-section--{{ section.id }} .bgb-toc {
      position: relative;
      top: auto;
      max-height: none;
      margin-bottom: 32px;
    }

    .xo-section--{{ section.id }} .bgb-toc__nav {
      display: flex;
      flex-wrap: wrap;
      gap: 4px;
    }

    .xo-section--{{ section.id }} .bgb-toc__link {
      display: inline-flex;
    }

    .xo-section--{{ section.id }} .bgb-sens {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .xo-section--{{ section.id }} .bgb-toc__link,
    .xo-section--{{ section.id }} .bgb-mode-btn,
    .xo-section--{{ section.id }} .bgb-ai-input,
    .xo-section--{{ section.id }} .bgb-ai-chip,
    .xo-section--{{ section.id }} .bgb-sens-chip,
    .xo-section--{{ section.id }} .bgb-prose {
      transition: none;
    }
  }
{%- endstyle -%}

<section {% render 'section-attr' %}>
  <xo-container>
    <div class="bgb-layout">
      {% if section.settings.show_toc %}
        <aside class="bgb-toc" aria-label="On this page">
          <div class="bgb-toc__title">On this page</div>
          <nav class="bgb-toc__nav" data-bgb-toc-nav></nav>
        </aside>
      {% endif %}

      <div class="bgb-main">
        {% if section.settings.show_reading_modes %}
          <div class="bgb-modes" role="radiogroup" aria-label="Reading mode">
            <button class="bgb-mode-btn bgb-mode-btn--active" role="radio" aria-checked="true" data-bgb-mode="default" type="button">Default</button>
            <button class="bgb-mode-btn" role="radio" aria-checked="false" data-bgb-mode="adhd" type="button">ADHD-friendly</button>
            <button class="bgb-mode-btn" role="radio" aria-checked="false" data-bgb-mode="listen" type="button">Listen</button>
          </div>
        {% endif %}

        {% if section.settings.show_ai_widget %}
          <div class="bgb-ai" aria-label="Ask the Guide">
            <div class="bgb-ai-input-wrap">
              <svg class="bgb-ai-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
              <input type="text" class="bgb-ai-input" placeholder="{{ section.settings.ai_placeholder }}" aria-label="Ask the Guide" autocomplete="off">
            </div>
            {%- assign ai_prompts = section.blocks | where: "type", "ai_prompt" -%}
            {% if ai_prompts.size > 0 %}
              <div class="bgb-ai-chips">
                {%- for block in ai_prompts -%}
                  <button type="button" class="bgb-ai-chip" {{ block.shopify_attributes }}>{{ block.settings.text }}</button>
                {%- endfor -%}
              </div>
            {% endif %}
            <small class="bgb-ai-disclaimer">Educational content only. Not medical advice.</small>
          </div>
        {% endif %}

        {% if section.settings.show_sensitivity_filters %}
          <div class="bgb-sens">
            <span class="bgb-sens-label">Highlight notes for:</span>
            <div class="bgb-sens-chips">
              <button type="button" class="bgb-sens-chip" aria-pressed="false" data-bgb-sens="caffeine">Caffeine</button>
              <button type="button" class="bgb-sens-chip" aria-pressed="false" data-bgb-sens="sleep">Sleep</button>
              <button type="button" class="bgb-sens-chip" aria-pressed="false" data-bgb-sens="gi">GI</button>
              <button type="button" class="bgb-sens-chip" aria-pressed="false" data-bgb-sens="anxiety">Anxiety-prone</button>
            </div>
          </div>
        {% endif %}

        <div class="bgb-content" data-bgb-content>
          {%- for block in section.blocks -%}
            {%- case block.type -%}
              {%- when 'heading' -%}
                {%- assign bgb_tag = block.settings.level | default: 'h2' -%}
                {%- assign bgb_anchor = block.settings.anchor_id | default: block.id -%}
                <{{ bgb_tag }} class="bgb-heading bgb-heading--{{ bgb_tag }}" id="{{ bgb_anchor }}" data-bgb-toc {{ block.shopify_attributes }}>
                  {{ block.settings.text }}
                </{{ bgb_tag }}>

              {%- when 'rich_text' -%}
                {%- assign bgb_sens = block.settings.sensitivity | default: 'none' -%}
                <div class="bgb-prose{% if bgb_sens != 'none' %} bgb-sens-block{% endif %}" {% if bgb_sens != 'none' %}data-bgb-sensitivity="{{ bgb_sens }}"{% endif %} {{ block.shopify_attributes }}>
                  {{ block.settings.content }}
                </div>

              {%- when 'pro_tip' -%}
                <div class="bgb-callout" {{ block.shopify_attributes }}>
                  <div class="bgb-callout-icon">
                    {%- case block.settings.icon -%}
                      {%- when 'lightbulb' -%}
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M12 2a7 7 0 0 0-4 12.7V17h8v-2.3A7 7 0 0 0 12 2z"/></svg>
                      {%- when 'warning' -%}
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                      {%- when 'info' -%}
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
                      {%- when 'star' -%}
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                    {%- endcase -%}
                  </div>
                  <div class="bgb-callout-body">
                    {% if block.settings.title != blank %}<strong class="bgb-callout-title">{{ block.settings.title }}</strong>{% endif %}
                    <div class="bgb-callout-text">{{ block.settings.content }}</div>
                  </div>
                </div>

              {%- when 'blockquote' -%}
                <figure class="bgb-quote" {{ block.shopify_attributes }}>
                  <blockquote class="bgb-quote-text">{{ block.settings.quote }}</blockquote>
                  {% if block.settings.citation != blank %}
                    <figcaption class="bgb-quote-cite">
                      — {% if block.settings.source_url != blank %}<a href="{{ block.settings.source_url }}" target="_blank" rel="noopener">{{ block.settings.citation }}</a>{% else %}{{ block.settings.citation }}{% endif %}
                    </figcaption>
                  {% endif %}
                </figure>
            {%- endcase -%}
          {%- endfor -%}
        </div>
      </div>
    </div>
  </xo-container>
</section>

<script>
(function() {
  var section = document.querySelector('.xo-section--{{ section.id }}');
  if (!section) return;
  var prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  var tocNav = section.querySelector('[data-bgb-toc-nav]');
  var headings = section.querySelectorAll('[data-bgb-toc]');

  if (tocNav && headings.length) {
    headings.forEach(function(h) {
      var a = document.createElement('a');
      a.href = '#' + h.id;
      a.textContent = h.textContent;
      a.className = 'bgb-toc__link';
      tocNav.appendChild(a);
    });

    var tocLinks = tocNav.querySelectorAll('a');
    if ('IntersectionObserver' in window) {
      var tocObserver = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            tocLinks.forEach(function(link) {
              var isMatch = link.getAttribute('href') === '#' + entry.target.id;
              link.classList.toggle('bgb-toc__link--active', isMatch);
              if (isMatch) link.setAttribute('aria-current', 'true');
              else link.removeAttribute('aria-current');
            });
          }
        });
      }, { rootMargin: '-20% 0px -70% 0px' });
      headings.forEach(function(h) { tocObserver.observe(h); });
    }

    tocNav.addEventListener('click', function(e) {
      var link = e.target.closest('a');
      if (!link) return;
      e.preventDefault();
      var target = document.getElementById(link.getAttribute('href').slice(1));
      if (target) target.scrollIntoView({ behavior: prefersReduced ? 'auto' : 'smooth', block: 'start' });
    });
  }

  var modeButtons = section.querySelectorAll('[data-bgb-mode]');
  modeButtons.forEach(function(btn) {
    btn.addEventListener('click', function() {
      var mode = btn.getAttribute('data-bgb-mode');
      document.body.classList.remove('bgb-mode-adhd', 'bgb-mode-listen');
      modeButtons.forEach(function(b) {
        b.setAttribute('aria-checked', 'false');
        b.classList.remove('bgb-mode-btn--active');
      });
      btn.setAttribute('aria-checked', 'true');
      btn.classList.add('bgb-mode-btn--active');
      if (mode === 'adhd') document.body.classList.add('bgb-mode-adhd');
      if (mode === 'listen') {
        document.body.classList.add('bgb-mode-listen');
        if ('speechSynthesis' in window) {
          var text = section.querySelector('[data-bgb-content]').innerText.substring(0, 3000);
          var utter = new SpeechSynthesisUtterance(text);
          utter.rate = 0.95;
          window.speechSynthesis.cancel();
          window.speechSynthesis.speak(utter);
        }
      } else {
        if ('speechSynthesis' in window) window.speechSynthesis.cancel();
      }
    });

    btn.addEventListener('keydown', function(e) {
      var btns = Array.from(modeButtons);
      var idx = btns.indexOf(btn);
      if (e.key === 'ArrowRight' || e.key === 'ArrowDown') { e.preventDefault(); btns[(idx + 1) % btns.length].focus(); btns[(idx + 1) % btns.length].click(); }
      if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') { e.preventDefault(); btns[(idx - 1 + btns.length) % btns.length].focus(); btns[(idx - 1 + btns.length) % btns.length].click(); }
      if (e.key === 'Home') { e.preventDefault(); btns[0].focus(); btns[0].click(); }
      if (e.key === 'End') { e.preventDefault(); btns[btns.length - 1].focus(); btns[btns.length - 1].click(); }
    });
  });

  section.querySelectorAll('[data-bgb-sens]').forEach(function(chip) {
    chip.addEventListener('click', function() {
      var pressed = chip.getAttribute('aria-pressed') === 'true';
      chip.setAttribute('aria-pressed', String(!pressed));
      chip.classList.toggle('bgb-sens-chip--active', !pressed);
      updateSensitivityHighlights();
    });
  });

  function updateSensitivityHighlights() {
    var activeFilters = [];
    section.querySelectorAll('[data-bgb-sens][aria-pressed="true"]').forEach(function(c) {
      activeFilters.push(c.getAttribute('data-bgb-sens'));
    });
    section.querySelectorAll('.bgb-sens-block').forEach(function(block) {
      var tag = block.getAttribute('data-bgb-sensitivity');
      block.classList.toggle('bgb-sens-block--highlighted', activeFilters.indexOf(tag) !== -1);
    });
  }

  section.querySelectorAll('.bgb-ai-chip').forEach(function(chip) {
    chip.addEventListener('click', function() {
      var input = section.querySelector('.bgb-ai-input');
      if (input) { input.value = chip.textContent; input.focus(); }
    });
  });
})();
</script>

