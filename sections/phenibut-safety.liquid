{% comment %}
  Use Safely — Premium refactored section
  - Native <table> for dosing, design tokens, focus-visible, reduced-motion
{% endcomment %}

{%- style -%}
.xo-section--{{ section.id }} {
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
  font-family: var(--font-body-family);
}
.xo-section--{{ section.id }} .phb-safety__container { max-width: {{ section.settings.max_width }}px; margin: 0 auto; padding: 0 16px; display: grid; gap: 16px; }
.xo-section--{{ section.id }} .phb-safety__title {
  font-family: var(--font-heading-family);
  font-size: clamp(22px, 4.2vw, 36px); line-height: 1.2; color: rgba(var(--color-foreground)); margin: 0; font-weight: 600;
}
.xo-section--{{ section.id }} .phb-safety__intro { color: rgba(var(--color-foreground)); line-height: 1.6; }
.xo-section--{{ section.id }} .phb-safety__table-wrap { border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent); border-radius: var(--general-radius-1, 1rem); overflow: hidden; }
.xo-section--{{ section.id }} .phb-safety__table { width: 100%; border-collapse: collapse; }
.xo-section--{{ section.id }} .phb-safety__table thead { background: rgba(var(--color-background-2)); }
.xo-section--{{ section.id }} .phb-safety__table th {
  text-align: left; padding: 10px 12px; font-weight: 600; color: rgba(var(--color-foreground)); font-size: 14px;
}
.xo-section--{{ section.id }} .phb-safety__table td {
  padding: 12px; color: rgba(var(--color-foreground)); font-size: 15px; line-height: 1.6;
  border-top: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
}
.xo-section--{{ section.id }} .phb-safety__lists { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 8px; }
.xo-section--{{ section.id }} .phb-safety__h3 {
  font-family: var(--font-heading-family);
  font-size: 18px; margin: 0 0 8px; color: rgba(var(--color-foreground)); font-weight: 600;
}
.xo-section--{{ section.id }} .phb-safety__list-col ul { padding-left: 18px; margin: 0; }
.xo-section--{{ section.id }} .phb-safety__list-col li { list-style: disc; color: rgba(var(--color-foreground)); line-height: 1.6; }
.xo-section--{{ section.id }} .phb-safety__disc { font-size: 13px; color: color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent); margin-top: 8px; }
.xo-section--{{ section.id }} :focus-visible { outline: 2px solid rgba(var(--color-accent)); outline-offset: 2px; }
@media (max-width: 768px) {
  .xo-section--{{ section.id }} .phb-safety__table thead { display: none; }
  .xo-section--{{ section.id }} .phb-safety__table tr { display: block; padding: 12px; border-top: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent); }
  .xo-section--{{ section.id }} .phb-safety__table tbody tr:first-child { border-top: none; }
  .xo-section--{{ section.id }} .phb-safety__table td { display: block; padding: 4px 0; border-top: none; }
  .xo-section--{{ section.id }} .phb-safety__table td::before { content: attr(data-label) ": "; font-weight: 600; color: rgba(var(--color-foreground)); }
  .xo-section--{{ section.id }} .phb-safety__lists { grid-template-columns: 1fr; }
}
@media (prefers-reduced-motion: reduce) {
  .xo-section--{{ section.id }} *,
  .xo-section--{{ section.id }} *::before,
  .xo-section--{{ section.id }} *::after {
    animation-duration: 0.01ms !important;
    transition-duration: 0.01ms !important;
  }
}
{%- endstyle -%}

<section {% render 'section-attr' %} aria-labelledby="phb-safety-title-{{ section.id }}">
  <xo-container>
    <div class="phb-safety__container">
      <h2 id="phb-safety-title-{{ section.id }}" class="phb-safety__title">{{ section.settings.heading | escape }}</h2>
      {% if section.settings.intro != blank %}
        <div class="phb-safety__intro">{{ section.settings.intro }}</div>
      {% endif %}

      <div class="phb-safety__table-wrap">
        <table class="phb-safety__table" aria-label="Dosing and timing">
          <thead>
            <tr>
              <th scope="col">Form</th>
              <th scope="col">Dose Range</th>
              <th scope="col">Frequency</th>
              <th scope="col">Onset/Duration</th>
            </tr>
          </thead>
          <tbody>
            {% for block in section.blocks %}
              {% if block.type == 'dose_row' %}
                <tr {{ block.shopify_attributes }}>
                  <td data-label="Form"><strong>{{ block.settings.form_name | escape }}</strong></td>
                  <td data-label="Dose Range">{{ block.settings.range | escape }}</td>
                  <td data-label="Frequency">{{ block.settings.freq | escape }}</td>
                  <td data-label="Onset/Duration">{{ block.settings.timing | escape }}</td>
                </tr>
              {% endif %}
            {% endfor %}
          </tbody>
        </table>
      </div>

      <div class="phb-safety__lists">
        {% if section.settings.do_list != blank %}
          <div class="phb-safety__list-col">
            <h3 class="phb-safety__h3">Do</h3>
            {{ section.settings.do_list }}
          </div>
        {% endif %}
        {% if section.settings.dont_list != blank %}
          <div class="phb-safety__list-col">
            <h3 class="phb-safety__h3">Don't</h3>
            {{ section.settings.dont_list }}
          </div>
        {% endif %}
      </div>

      {% if section.settings.disclaimer != blank %}
        <p class="phb-safety__disc">{{ section.settings.disclaimer }}</p>
      {% endif %}
    </div>
  </xo-container>
</section>

{% schema %}
{
  "name": "Use Safely",
  "tag": "section",
  "class": "section-phenibut-safety",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "default" },
    { "type": "text", "id": "anchor_id", "label": "Anchor ID", "default": "safety" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "How to Use Safely" },
    { "type": "richtext", "id": "intro", "label": "Intro", "default": "<p>Use Phenibut <strong>occasionally</strong>. Start low. Never mix with alcohol, benzodiazepines, or other sedatives.</p>" },
    { "type": "range", "id": "max_width", "label": "Max width (px)", "min": 720, "max": 1400, "step": 20, "default": 1200 },
    { "type": "richtext", "id": "do_list", "label": "Do list", "default": "<ul><li>Use 1–2× per week at most.</li><li>Start with the lowest effective dose.</li><li>Wait 24+ hours before redosing.</li></ul>" },
    { "type": "richtext", "id": "dont_list", "label": "Don't list", "default": "<ul><li>Do not drive if drowsy.</li><li>Do not mix with alcohol or sedatives.</li><li>Do not use daily.</li></ul>" },
    { "type": "text", "id": "disclaimer", "label": "Disclaimer", "default": "Educational only. Not medical advice." },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding top", "default": 40 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding bottom", "default": 40 }
  ],
  "blocks": [
    {
      "type": "dose_row",
      "name": "Dose row",
      "settings": [
        { "type": "text", "id": "form_name", "label": "Form", "default": "FAA" },
        { "type": "text", "id": "range", "label": "Dose range", "default": "100–400 mg" },
        { "type": "text", "id": "freq", "label": "Frequency", "default": "No more than 1–2×/week" },
        { "type": "text", "id": "timing", "label": "Onset/Duration", "default": "Onset 1–3 h; effects last several hours" }
      ]
    },
    { "type": "@app" }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Use Safely",
      "blocks": [
        { "type": "dose_row", "settings": { "form_name": "FAA", "range": "100–400 mg", "freq": "≤ 1–2×/week", "timing": "Onset 1–3 h" } },
        { "type": "dose_row", "settings": { "form_name": "HCl", "range": "100–400 mg", "freq": "≤ 1–2×/week", "timing": "Onset 1–2 h" } },
        { "type": "dose_row", "settings": { "form_name": "Capsules", "range": "Follow label", "freq": "≤ 1–2×/week", "timing": "Onset 1–3 h" } }
      ]
    }
  ]
}
{% endschema %}
