{% comment %}
  Use Safely — Premium refactored section
  - Native <table> for dosing, design tokens, focus-visible, reduced-motion
{% endcomment %}

<section id="phb-sf-{{ section.id }}" class="phb-safety" aria-labelledby="phb-safety-title-{{ section.id }}">
  <div class="phb-safety__container">
    <h2 id="phb-safety-title-{{ section.id }}" class="phb-safety__title">{{ section.settings.heading | escape }}</h2>
    {% if section.settings.intro != blank %}
      <div class="phb-safety__intro">{{ section.settings.intro }}</div>
    {% endif %}

    <div class="phb-safety__table-wrap">
      <table class="phb-safety__table" aria-label="Dosing and timing">
        <thead>
          <tr>
            <th scope="col">Form</th>
            <th scope="col">Dose Range</th>
            <th scope="col">Frequency</th>
            <th scope="col">Onset/Duration</th>
          </tr>
        </thead>
        <tbody>
          {% for block in section.blocks %}
            {% if block.type == 'dose_row' %}
              <tr {{ block.shopify_attributes }}>
                <td data-label="Form"><strong>{{ block.settings.form_name | escape }}</strong></td>
                <td data-label="Dose Range">{{ block.settings.range | escape }}</td>
                <td data-label="Frequency">{{ block.settings.freq | escape }}</td>
                <td data-label="Onset/Duration">{{ block.settings.timing | escape }}</td>
              </tr>
            {% endif %}
          {% endfor %}
        </tbody>
      </table>
    </div>

    <div class="phb-safety__lists">
      {% if section.settings.do_list != blank %}
        <div class="phb-safety__list-col">
          <h3 class="phb-safety__h3">Do</h3>
          {{ section.settings.do_list }}
        </div>
      {% endif %}
      {% if section.settings.dont_list != blank %}
        <div class="phb-safety__list-col">
          <h3 class="phb-safety__h3">Don't</h3>
          {{ section.settings.dont_list }}
        </div>
      {% endif %}
    </div>

    {% if section.settings.disclaimer != blank %}
      <p class="phb-safety__disc">{{ section.settings.disclaimer }}</p>
    {% endif %}
  </div>
</section>

{%- style -%}
#phb-sf-{{ section.id }} {
  --phb-bg: {{ section.settings.background_color }};
  --phb-max: {{ section.settings.max_width }}px;
  --phb-py: {{ section.settings.padding_y }}px;
  --phb-accent: var(--color-accent-primary, #FBBF24);
  --phb-heading: var(--color-text-main, #0A2342);
  --phb-text: var(--color-text-main, #0e1726);
  --phb-muted: var(--color-text-muted, #4b5563);
  --phb-card-border: var(--nx-pill-border, rgba(0,0,0,.06));
  --phb-radius: var(--nx-radius, 14px);
  --phb-font: var(--font-body-family, sans-serif);
  --phb-font-heading: var(--font-heading-family, sans-serif);
  --phb-thead-bg: var(--color-bg-secondary, #f7fafb);
  background: var(--phb-bg);
  font-family: var(--phb-font);
}
#phb-sf-{{ section.id }} .phb-safety__container { max-width: var(--phb-max); margin: 0 auto; padding: var(--phb-py) 16px; display: grid; gap: 16px; }
#phb-sf-{{ section.id }} .phb-safety__title {
  font-family: var(--phb-font-heading);
  font-size: clamp(22px, 4.2vw, 36px); line-height: 1.2; color: var(--phb-heading); margin: 0;
}
#phb-sf-{{ section.id }} .phb-safety__intro { color: var(--phb-text); line-height: 1.6; }
#phb-sf-{{ section.id }} .phb-safety__table-wrap { border: 1px solid var(--phb-card-border); border-radius: var(--phb-radius); overflow: hidden; }
#phb-sf-{{ section.id }} .phb-safety__table { width: 100%; border-collapse: collapse; }
#phb-sf-{{ section.id }} .phb-safety__table thead { background: var(--phb-thead-bg); }
#phb-sf-{{ section.id }} .phb-safety__table th {
  text-align: left; padding: 10px 12px; font-weight: 700; color: var(--phb-heading); font-size: 14px;
}
#phb-sf-{{ section.id }} .phb-safety__table td {
  padding: 12px; color: var(--phb-text); font-size: 15px; line-height: 1.6;
  border-top: 1px solid var(--phb-card-border);
}
#phb-sf-{{ section.id }} .phb-safety__lists { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 8px; }
#phb-sf-{{ section.id }} .phb-safety__h3 {
  font-family: var(--phb-font-heading);
  font-size: 18px; margin: 0 0 8px; color: var(--phb-heading);
}
#phb-sf-{{ section.id }} .phb-safety__list-col ul { padding-left: 18px; margin: 0; }
#phb-sf-{{ section.id }} .phb-safety__list-col li { list-style: disc; color: var(--phb-text); line-height: 1.6; }
#phb-sf-{{ section.id }} .phb-safety__disc { font-size: 13px; color: var(--phb-muted); margin-top: 8px; }
#phb-sf-{{ section.id }} :focus-visible { outline: 2px solid var(--phb-accent); outline-offset: 2px; }
@media (max-width: 989px) {
  #phb-sf-{{ section.id }} .phb-safety__table thead { display: none; }
  #phb-sf-{{ section.id }} .phb-safety__table tr { display: block; padding: 12px; border-top: 1px solid var(--phb-card-border); }
  #phb-sf-{{ section.id }} .phb-safety__table tbody tr:first-child { border-top: none; }
  #phb-sf-{{ section.id }} .phb-safety__table td { display: block; padding: 4px 0; border-top: none; }
  #phb-sf-{{ section.id }} .phb-safety__table td::before { content: attr(data-label) ": "; font-weight: 700; color: var(--phb-heading); }
  #phb-sf-{{ section.id }} .phb-safety__lists { grid-template-columns: 1fr; }
}
@media (prefers-reduced-motion: reduce) {
  #phb-sf-{{ section.id }} *,
  #phb-sf-{{ section.id }} *::before,
  #phb-sf-{{ section.id }} *::after {
    animation-duration: 0.01ms !important;
    transition-duration: 0.01ms !important;
  }
}
{%- endstyle -%}

{% schema %}
{
  "name": "Use Safely",
  "tag": "section",
  "class": "section-phenibut-safety",
  "settings": [
    { "type": "text", "id": "anchor_id", "label": "Anchor ID", "default": "safety" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "How to Use Safely" },
    { "type": "richtext", "id": "intro", "label": "Intro", "default": "<p>Use Phenibut <strong>occasionally</strong>. Start low. Never mix with alcohol, benzodiazepines, or other sedatives.</p>" },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#F7FAFB" },
    { "type": "range", "id": "max_width", "label": "Max width (px)", "min": 720, "max": 1400, "step": 20, "default": 1200 },
    { "type": "range", "id": "padding_y", "label": "Vertical padding (px)", "min": 40, "max": 160, "step": 4, "default": 88 },
    { "type": "richtext", "id": "do_list", "label": "Do list", "default": "<ul><li>Use 1–2× per week at most.</li><li>Start with the lowest effective dose.</li><li>Wait 24+ hours before redosing.</li></ul>" },
    { "type": "richtext", "id": "dont_list", "label": "Don't list", "default": "<ul><li>Do not drive if drowsy.</li><li>Do not mix with alcohol or sedatives.</li><li>Do not use daily.</li></ul>" },
    { "type": "text", "id": "disclaimer", "label": "Disclaimer", "default": "Educational only. Not medical advice." }
  ],
  "blocks": [
    {
      "type": "dose_row",
      "name": "Dose row",
      "settings": [
        { "type": "text", "id": "form_name", "label": "Form", "default": "FAA" },
        { "type": "text", "id": "range", "label": "Dose range", "default": "100–400 mg" },
        { "type": "text", "id": "freq", "label": "Frequency", "default": "No more than 1–2×/week" },
        { "type": "text", "id": "timing", "label": "Onset/Duration", "default": "Onset 1–3 h; effects last several hours" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Use Safely",
      "blocks": [
        { "type": "dose_row", "settings": { "form_name": "FAA", "range": "100–400 mg", "freq": "≤ 1–2×/week", "timing": "Onset 1–3 h" } },
        { "type": "dose_row", "settings": { "form_name": "HCl", "range": "100–400 mg", "freq": "≤ 1–2×/week", "timing": "Onset 1–2 h" } },
        { "type": "dose_row", "settings": { "form_name": "Capsules", "range": "Follow label", "freq": "≤ 1–2×/week", "timing": "Onset 1–3 h" } }
      ]
    }
  ]
}
{% endschema %}
