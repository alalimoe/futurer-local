{%- style -%}
  .xo-section--{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .xo-section--{{ section.id }} .clc-inner {
    max-width: 700px;
    margin: 0 auto;
    background: rgba(var(--color-background-2));
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
    border-radius: var(--general-radius-3, 2rem);
    padding: 40px 32px;
  }

  .xo-section--{{ section.id }} .clc-heading {
    font-size: clamp(1.25rem, 2.5vw, 1.5rem);
    font-weight: 600;
    color: rgba(var(--color-foreground));
    margin: 0 0 28px;
    letter-spacing: -0.02em;
  }

  .xo-section--{{ section.id }} .clc-list {
    list-style: none;
    padding: 0;
    margin: 0 0 28px;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .xo-section--{{ section.id }} .clc-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 0;
    border-bottom: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
    font-size: 1rem;
    color: rgba(var(--color-foreground));
    line-height: 1.5;
  }

  .xo-section--{{ section.id }} .clc-item:last-child {
    border-bottom: none;
  }

  .xo-section--{{ section.id }} .clc-icon {
    flex-shrink: 0;
    color: rgba(var(--color-accent));
  }

  .xo-section--{{ section.id }} .clc-text {
    flex: 1;
  }

  .xo-section--{{ section.id }} .clc-cta {
    text-align: center;
  }

  .xo-section--{{ section.id }} .clc-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 0.75rem 2rem;
    font-size: 0.9375rem;
    font-weight: 600;
    background: rgba(var(--color-accent));
    color: rgba(var(--color-foreground));
    border: none;
    border-radius: var(--button-radius, 10rem);
    text-decoration: none;
    transition: opacity 0.3s var(--out-soft, ease);
    cursor: pointer;
  }

  .xo-section--{{ section.id }} .clc-btn:hover {
    opacity: 0.85;
  }

  .xo-section--{{ section.id }} :focus-visible {
    outline: 2px solid rgba(var(--color-accent));
    outline-offset: 2px;
  }

  @media (max-width: 768px) {
    .xo-section--{{ section.id }} .clc-inner {
      padding: 28px 20px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .xo-section--{{ section.id }} .clc-btn {
      transition: none;
    }
  }
{%- endstyle -%}

<section {% render 'section-attr' %}>
  <xo-container>
    <div class="clc-inner">
      {% if section.settings.heading != blank %}
        <h2 class="clc-heading">{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.blocks.size > 0 %}
        <ul class="clc-list">
          {% for block in section.blocks %}
            {% if block.settings.text != blank %}
              <li class="clc-item" {{ block.shopify_attributes }}>
                <svg class="clc-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                <span class="clc-text">{{ block.settings.text }}</span>
              </li>
            {% endif %}
          {% endfor %}
        </ul>
      {% endif %}

      {% if section.settings.button_text != blank %}
        <div class="clc-cta">
          <a href="{{ section.settings.button_link | default: '#' }}" class="clc-btn">{{ section.settings.button_text }}</a>
        </div>
      {% endif %}
    </div>
  </xo-container>
</section>

{% schema %}
{
  "name": "COA Checklist",
  "tag": "section",
  "class": "section-coa-checklist",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "default"
    },
    { "type": "text", "id": "heading", "label": "Heading", "default": "How to verify a COA (quick checklist)" },
    { "type": "header", "content": "CTA Button" },
    { "type": "text", "id": "button_text", "label": "Button Text", "default": "How to Read a COA" },
    { "type": "url", "id": "button_link", "label": "Button Link" },
    { "type": "header", "content": "Spacing" },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 64
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Checklist Item",
      "settings": [
        { "type": "text", "id": "text", "label": "Item Text" }
      ]
    },
    { "type": "@app" }
  ],
  "presets": [
    {
      "name": "COA Checklist",
      "blocks": [
        { "type": "item", "settings": { "text": "Exact product name (not \"close enough\")" } },
        { "type": "item", "settings": { "text": "Batch/lot matches your label" } },
        { "type": "item", "settings": { "text": "Lab name + contact details present" } },
        { "type": "item", "settings": { "text": "Test date is plausible for that batch" } },
        { "type": "item", "settings": { "text": "Methods are stated (HPLC / LC-MS / FTIR, etc.)" } },
        { "type": "item", "settings": { "text": "Results include numbers (not only \"PASS\")" } }
      ]
    }
  ]
}
{% endschema %}
