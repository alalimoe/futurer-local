{% schema %}
{
  "name": "COA Checklist",
  "tag": "section",
  "class": "section-coa-checklist",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "How to verify a COA (quick checklist)" },
    { "type": "header", "content": "CTA Button" },
    { "type": "text", "id": "button_text", "label": "Button Text", "default": "How to Read a COA" },
    { "type": "url", "id": "button_link", "label": "Button Link" },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#ffffff" },
    { "type": "color", "id": "accent_color", "label": "Accent", "default": "#FBBF24" }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Checklist Item",
      "settings": [
        { "type": "text", "id": "text", "label": "Item Text" }
      ]
    }
  ],
  "presets": [
    {
      "name": "COA Checklist",
      "blocks": [
        { "type": "item", "settings": { "text": "Exact product name (not \"close enough\")" } },
        { "type": "item", "settings": { "text": "Batch/lot matches your label" } },
        { "type": "item", "settings": { "text": "Lab name + contact details present" } },
        { "type": "item", "settings": { "text": "Test date is plausible for that batch" } },
        { "type": "item", "settings": { "text": "Methods are stated (HPLC / LC-MS / FTIR, etc.)" } },
        { "type": "item", "settings": { "text": "Results include numbers (not only \"PASS\")" } }
      ]
    }
  ]
}
{% endschema %}

<div class="clc-wrapper" id="clc-{{ section.id }}">
  <div class="clc-inner">
    {% if section.settings.heading != blank %}
      <h2 class="clc-heading">{{ section.settings.heading }}</h2>
    {% endif %}

    {% if section.blocks.size > 0 %}
      <ul class="clc-list">
        {% for block in section.blocks %}
          {% if block.settings.text != blank %}
            <li class="clc-item" {{ block.shopify_attributes }}>
              <svg class="clc-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              <span class="clc-text">{{ block.settings.text }}</span>
            </li>
          {% endif %}
        {% endfor %}
      </ul>
    {% endif %}

    {% if section.settings.button_text != blank %}
      <div class="clc-cta">
        <a href="{{ section.settings.button_link | default: '#' }}" class="clc-btn">{{ section.settings.button_text }}</a>
      </div>
    {% endif %}
  </div>
</div>

<style>
  #clc-{{ section.id }} {
    --clc-bg: {{ section.settings.bg_color }};
    --clc-accent: {{ section.settings.accent_color }};
    --clc-text: var(--color-text-main, #111827);
    --clc-muted: var(--color-text-muted, #4b5563);
    --clc-border: var(--nx-pill-border, #E5E7EB);
    --clc-radius: var(--nx-radius, 14px);
    --clc-font: var(--font-body-family, sans-serif);
    --clc-font-heading: var(--font-heading-family, sans-serif);
    --clc-transition: var(--transition-smooth, all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1));
    --clc-touch: var(--touch-min, 44px);
  }

  .clc-wrapper {
    background: var(--clc-bg);
    padding: 64px var(--page-gutter);
    font-family: var(--clc-font);
  }
  .clc-inner {
    max-width: 700px;
    margin: 0 auto;
    background: var(--color-bg-secondary, #f9fafb);
    border: 1px solid var(--clc-border);
    border-radius: var(--clc-radius);
    padding: 40px 32px;
  }

  .clc-heading {
    font-family: var(--clc-font-heading);
    font-size: clamp(1.25rem, 2.5vw, 1.5rem);
    font-weight: 800;
    color: var(--clc-text);
    margin: 0 0 28px;
    letter-spacing: -0.02em;
  }

  .clc-list {
    list-style: none;
    padding: 0;
    margin: 0 0 28px;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .clc-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 0;
    border-bottom: 1px solid var(--clc-border);
    font-size: 1rem;
    color: var(--clc-text);
    line-height: 1.5;
  }
  .clc-item:last-child { border-bottom: none; }
  .clc-icon {
    flex-shrink: 0;
    color: var(--clc-accent);
  }
  .clc-text { flex: 1; }

  .clc-cta { text-align: center; }
  .clc-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: var(--clc-touch);
    padding: 0.75rem 2rem;
    font-family: var(--clc-font);
    font-size: 0.9375rem;
    font-weight: 700;
    background: var(--clc-accent);
    color: var(--color-text-primary);
    border: none;
    border-radius: var(--clc-radius);
    text-decoration: none;
    transition: var(--clc-transition);
    cursor: pointer;
    box-shadow: var(--shadow-gold-glow, 0 4px 14px rgba(251,191,36,0.25));
  }
  .clc-btn:hover {
    box-shadow: var(--shadow-gold-glow-hover, 0 8px 24px rgba(251,191,36,0.35));
    transform: translateY(-1px);
  }

  .clc-wrapper :focus-visible {
    outline: 2px solid var(--clc-accent);
    outline-offset: 2px;
  }

  @media (prefers-reduced-motion: reduce) {
    .clc-wrapper *, .clc-wrapper *::before, .clc-wrapper *::after {
      animation-duration: 0.01ms !important;
      transition-duration: 0.01ms !important;
    }
  }

  @media (max-width: 640px) {
    .clc-wrapper { padding: 48px var(--page-gutter); }
    .clc-inner { padding: 28px 20px; }
  }
</style>
