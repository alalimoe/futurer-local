{{ 'featured-collection-2.css' | asset_url | stylesheet_tag }}
{{ 'collection-empty.css' | asset_url | stylesheet_tag }}
{{ 'product-information.css' | asset_url | stylesheet_tag }}
{{ 'transform-list.css' | asset_url | stylesheet_tag }}

{% liquid
  assign heading = section.settings.text_heading
  assign image = section.settings.image
  assign title_list = section.settings.list_title
  assign content_list = section.settings.list_content
  assign color_schema_specification = section.settings.color_schema_specification
  assign block = section.blocks
%}

<section {% render 'section-attr' %}>
  <div class="featured-collection-style-2">
    <xo-container class="featured-collection-style-2__container">
      <div class="featured-collection-style-2__content">
        {% render 'featured-collection-2',
          heading: heading,
          image: image,
          title_list: title_list,
          content_list: content_list,
          color_schema_specification: color_schema_specification,
          block: block
        %}
      </div>
    </xo-container>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.featured_collection_style_2.name",
  "disabled_on": {
    "groups": [
      "header",
      "footer",
      "custom.overlay",
      "custom.popups",
      "custom.features"
    ]
  },
  "settings": [
    {
      "type": "header",
      "content": "Text"
    },
    {
      "type": "select",
      "id": "text_tag_name",
      "label": "Tag name",
      "options": [
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        },
        {
          "value": "h4",
          "label": "H4"
        },
        {
          "value": "h5",
          "label": "H5"
        },
        {
          "value": "h6",
          "label": "H6"
        }
      ],
      "default": "h2"
    },
    {
      "type": "textarea",
      "id": "text_heading",
      "label": "Text",
      "default": "Featured collection"
    },
    {
      "type": "select",
      "id": "font_size_heading",
      "label": "Font size heading",
      "default": "h5",
      "options": [
        {
          "value": "h1",
          "label": "Extra extra large"
        },
        {
          "value": "h2",
          "label": "Extra large"
        },
        {
          "value": "h3",
          "label": "Large"
        },
        {
          "value": "h4",
          "label": "Medium"
        },
        {
          "value": "h5",
          "label": "Small"
        },
        {
          "value": "h6",
          "label": "Extra small"
        }
      ]
    },
    {
      "type": "range",
      "id": "text_line_height",
      "label": "Line height",
      "min": 0,
      "max": 3,
      "step": 0.1,
      "default": 1.2
    },
    {
      "type": "select",
      "id": "text_effect",
      "label": "Effect",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "reveal",
          "label": "Blur"
        },
        {
          "value": "split",
          "label": "Split"
        }
      ],
      "default": "split"
    },
    {
      "type": "number",
      "id": "text_duration",
      "label": "Duration (milliseconds)",
      "default": 1000
    },
    {
      "type": "range",
      "id": "text_heading_width_desktop",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "Desktop heading width",
      "default": 100
    },
    {
      "type": "range",
      "id": "text_heading_width_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "Mobile heading width",
      "default": 100
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.featured_collection_style_2.settings.image.label"
    },
    {
      "type": "header",
      "content": "t:sections.featured_collection_style_2.settings.header_specification.content"
    },
    {
      "type": "richtext",
      "id": "list_title",
      "label": "t:sections.featured_collection_style_2.settings.list_title.label"
    },
    {
      "type": "richtext",
      "id": "list_content",
      "label": "t:sections.featured_collection_style_2.settings.list_content.label"
    },
    {
      "type": "color_scheme",
      "id": "color_schema_specification",
      "label": "t:sections.featured_collection_style_2.settings.color_schema_specification.label",
      "default": "scheme_1"
    },
    {
      "type": "header",
      "content": "General settings"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Section color scheme"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color"
    },
    {
      "type": "color_background",
      "id": "background_gradient",
      "label": "Background gradient"
    },
    {
      "type": "number",
      "id": "padding_top_desktop",
      "label": "Padding top desktop",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_bottom_desktop",
      "label": "Padding bottom desktop",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_top_mobile",
      "label": "Padding top mobile",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom mobile",
      "default": 50
    }
  ],
  "blocks": [
    {
      "name": "t:sections.featured_collection_style_2.blocks.name",
      "type": "featured-product",
      "limit": 2,
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "t:sections.featured_collection_style_2.blocks.settings.product.label"
        },
        {
          "type": "header",
          "content": "Product card"
        },
        {
          "type": "select",
          "id": "product_card_aspect_ratio",
          "label": "Aspect ratio",
          "options": [
            {
              "value": "auto",
              "label": "Adapt to image"
            },
            {
              "value": "2/3",
              "label": "2:3"
            },
            {
              "value": "3/4",
              "label": "3:4"
            },
            {
              "value": "3/2",
              "label": "3:2"
            },
            {
              "value": "1",
              "label": "1:1"
            },
            {
              "value": "4/3",
              "label": "4:3"
            },
            {
              "value": "16/9",
              "label": "16:9"
            },
            {
              "value": "21/9",
              "label": "21:9"
            }
          ],
          "default": "1"
        },
        {
          "type": "color_scheme",
          "id": "card_color_scheme",
          "label": "Color scheme"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.featured_collection_style_2.presets.name",
      "settings": {
        "font_size_heading": "h5",
        "text_heading": "Featured collection",
        "text_duration": 1000,
        "text_effect": "split",
        "image": "",
        "list_title": "<ul><li>Title</li><li>Title</li><li>Title</li><li>Title</li><li>Title</li><li>Title</li></ul>",
        "list_content": "<ul><li>Content</li><li>Content</li><li>Content</li><li>Content</li><li>Content</li><li>Content</li></ul>",
        "color_schema_specification": "",
        "color_scheme": "",
        "background_color": "",
        "background_gradient": "",
        "padding_top_desktop": 50,
        "padding_bottom_desktop": 50,
        "padding_top_mobile": 50,
        "padding_bottom_mobile": 50
      },
      "blocks": [
        {
          "type": "featured-product",
          "settings": {
            "product": "",
            "product_card_aspect_ratio": "1",
            "card_color_scheme": "inverse"
          }
        },
        {
          "type": "featured-product",
          "settings": {
            "product": "",
            "product_card_aspect_ratio": "1",
            "card_color_scheme": "inverse"
          }
        }
      ]
    }
  ]
}
{% endschema %}