{{ 'img-with-text-6.css' | asset_url | stylesheet_tag }}

{% liquid
  assign sub_heading = section.settings.sub_heading
  assign class = section.settings.font_size_heading
  assign heading = section.settings.heading
  assign image_1 = section.settings.image_1
  assign image_2 = section.settings.image_2
  assign aspect_ratio = section.settings.aspect_ratio
  if aspect_ratio == 'custom'
    assign aspect_ratio = section.settings.aspect_ratio_width | append: '/' | append: section.settings.aspect_ratio_height
  endif
  assign button = section.settings
%}

<section {% render 'section-attr' %}>
  <div class="image-with-text-style-6">
    <xo-container class="image-with-text-style-6__container">
      <div class="image-with-text-style-6__content">
        {% render 'img-with-text-6', sub_heading: sub_heading, class: class, content: heading, image_1: image_1, image_2: image_2, aspect_ratio: aspect_ratio, button: button %}
      </div>
    </xo-container>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.image_with_text_style_6.name",
  "disabled_on": {
    "groups": [
      "header",
      "footer",
      "custom.overlay",
      "custom.popups",
      "custom.features"
