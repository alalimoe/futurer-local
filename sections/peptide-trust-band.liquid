{% comment %}
  Peptide trust band: two trust notes inside xo-container (replaces legacy app _blocks). Icons + richtext; theme color tokens.
{% endcomment %}

{%- style -%}
  .xo-section--{{ section.id }} .ptb__list {
    display: flex;
    flex-direction: column;
    gap: 1.6rem;
    max-width: 100%;
  }

  .xo-section--{{ section.id }} .ptb__item {
    display: flex;
    gap: 1.2rem;
    align-items: flex-start;
    padding: 1.4rem 1.6rem;
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 8%, transparent);
    border-radius: var(--general-radius-3);
    background: rgba(var(--color-background));
  }

  .xo-section--{{ section.id }} .ptb__icon {
    flex-shrink: 0;
    width: 2.2rem;
    height: 2.2rem;
    color: rgba(var(--color-accent));
    margin-top: 0.2rem;
  }

  .xo-section--{{ section.id }} .ptb__text {
    font-size: calc(var(--font-body-scale, 1) * 1.4rem);
    line-height: 1.6;
    color: rgba(var(--color-foreground));
  }

  .xo-section--{{ section.id }} .ptb__text a {
    color: rgba(var(--color-accent));
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  .xo-section--{{ section.id }} .ptb__text a:focus-visible {
    outline: 2px solid rgba(var(--color-accent));
    outline-offset: 2px;
    border-radius: 4px;
  }
{%- endstyle -%}

<section {% render 'section-attr' %}>
  <xo-container>
    <div class="ptb__list" role="region" aria-label="{{ section.settings.heading | default: 'Trust and shipping' | escape }}">
      {% if section.settings.text_1 != blank %}
        <div class="ptb__item">
          <svg class="ptb__icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M12 3l7 3v6c0 4.418-3.582 7.5-7 9-3.418-1.5-7-4.582-7-9V6l7-3z" stroke="currentColor" stroke-width="1.6"/>
          </svg>
          <div class="ptb__text rte">{{ section.settings.text_1 }}</div>
        </div>
      {% endif %}
      {% if section.settings.text_2 != blank %}
        <div class="ptb__item">
          <svg class="ptb__icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M1 3h12v11H1V3zm13 6h3l4 4v3h-7" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
            <circle cx="6.5" cy="17.5" r="1.8" stroke="currentColor" stroke-width="1.6"/>
            <circle cx="17.5" cy="17.5" r="1.8" stroke="currentColor" stroke-width="1.6"/>
          </svg>
          <div class="ptb__text rte">{{ section.settings.text_2 }}</div>
        </div>
      {% endif %}
    </div>
  </xo-container>
</section>

{% schema %}
{
  "name": "Peptide trust band",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "background-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Region label (accessibility)",
      "default": "Trust and shipping"
    },
    {
      "type": "richtext",
      "id": "text_1",
      "label": "Note 1 (quality / trust)"
    },
    {
      "type": "richtext",
      "id": "text_2",
      "label": "Note 2 (shipping / handling)"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "Desktop top padding",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 24,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Desktop bottom padding",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 24,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Mobile top padding",
      "min": 0,
      "max": 60,
      "step": 4,
      "default": 20,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Mobile bottom padding",
      "min": 0,
      "max": 60,
      "step": 4,
      "default": 20,
      "unit": "px"
    }
  ],
  "presets": [{ "name": "Peptide trust band" }]
}
{% endschema %}
