{% liquid
  assign sub_heading = section.settings.sub_heading
  assign image_dt = section.settings.image_dt
  assign aspect_ratio_dt = section.settings.aspect_ratio_dt
  if aspect_ratio_dt == 'custom'
    assign aspect_ratio_dt = section.settings.aspect_ratio_dt_width | append: '/' | append: section.settings.aspect_ratio_dt_height
  endif
  assign image_mb = section.settings.image_mb
  assign aspect_ratio_mb = section.settings.aspect_ratio_mb
  if aspect_ratio_mb == 'custom'
    assign aspect_ratio_mb = section.settings.aspect_ratio_mb_width | append: '/' | append: section.settings.aspect_ratio_mb_height
  endif
  assign block = section.blocks
%}

<section {% render 'section-attr' %}>
  <div class="image-with-text-style-3">
    <xo-container class="image-with-text-style-3__container">
      {% render 'img-with-text-3',
        sub_heading: sub_heading,
        image_dt: image_dt,
        aspect_ratio_dt: aspect_ratio_dt,
        image_mb: image_mb,
        aspect_ratio_mb: aspect_ratio_mb,
        block: block
      %}
    </xo-container>
  </div>
</section>

