{% comment %}
LABS HERO — B2B Funnel
- Left aligned headline, subheadline, badges, and CTAs
- 16:9 background with responsive srcset
- BreadcrumbList JSON-LD
{% endcomment %}

{%- assign sid = section.id | replace: '_','' | downcase -%}

<style>
#labs-hero-{{ sid }}{
  --b:#E7E9ED; --accent:#FBBF24; --text:#fff;
}
#labs-hero-{{ sid }}{ position:relative; width:100%; aspect-ratio:16/9; overflow:hidden; display:flex; align-items: {{ section.settings.vert_align }}; }
#labs-hero-{{ sid }} .bg{ position:absolute; inset:0; z-index:1; }
#labs-hero-{{ sid }} .bg img{ width:100%; height:100%; object-fit:cover; object-position:center; }
#labs-hero-{{ sid }} .overlay{ position:absolute; inset:0; z-index:2; background: {{ section.settings.overlay_color }}; opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }}; }

#labs-hero-{{ sid }} .inner{
  position:relative; z-index:3; color:var(--text);
  width:100%; max-width: {{ section.settings.max_width }}px; padding: {{ section.settings.pad }}px;
  display:flex; flex-direction:column; align-items:flex-start; text-align:left;
}
@media (max-width:749px){
  #labs-hero-{{ sid }}{ aspect-ratio: {{ section.settings.mobile_aspect_ratio }}; }
  #labs-hero-{{ sid }} .inner{ padding: {{ section.settings.pad_mobile }}px; }
}

#labs-hero-{{ sid }} .bc{ margin-bottom:12px; font-size:14px; color:rgba(255,255,255,.9); }
#labs-hero-{{ sid }} .bc a{ color:var(--color-accent-primary); text-decoration:none; position:relative; }
#labs-hero-{{ sid }} .bc a::after{ content:""; position:absolute; left:50%; right:50%; bottom:-2px; height:1px; background: currentColor; transition:left .18s,right .18s; }
#labs-hero-{{ sid }} .bc a:hover::after{ left:0; right:0; }
#labs-hero-{{ sid }} .bc .sep{ margin:0 8px; }

#labs-hero-{{ sid }} .h1{
  margin:0 0 8px; font-weight:900; color:#fff;
  font-size: clamp(28px, 3.2vw, {{ section.settings.h1_size }}px);
}
#labs-hero-{{ sid }} .sub{
  margin:0 0 14px; color:rgba(255,255,255,.95);
  max-width: var(--container-width-narrow); font-size: {{ section.settings.sub_size }}px; line-height:1.5;
}
@media (max-width:749px){ #labs-hero-{{ sid }} .sub{ font-size: calc({{ section.settings.sub_size }}px * .9); } }

#labs-hero-{{ sid }} .badges{ display:flex; gap:8px; flex-wrap:wrap; margin:0 0 14px; }
#labs-hero-{{ sid }} .chip{
  display:inline-flex; align-items:center; gap:6px; padding:8px 12px;
  border:1px solid rgba(255,255,255,.28); border-radius:999px;
  background:rgba(255,255,255,.12); color:#fff; font-weight:700;
  backdrop-filter: blur(2px);
}
#labs-hero-{{ sid }} .ico{ width:14px; height:14px; color:currentColor; }

#labs-hero-{{ sid }} .ctas{ display:flex; gap:12px; flex-wrap:wrap; }
</style>

<section id="labs-hero-{{ sid }}" aria-label="Labs hero">
  <div class="bg">
    {% if section.settings.bg %}
      {% assign img = section.settings.bg %}
      <img
        src="{{ img | image_url: width: 1600 }}"
        srcset="{{ img | image_url: width: 768 }} 768w, {{ img | image_url: width: 1200 }} 1200w, {{ img | image_url: width: 1600 }} 1600w, {{ img | image_url: width: 2200 }} 2200w"
        sizes="(max-width: 749px) 100vw, 100vw"
        alt="{{ img.alt | default: section.settings.h1 }}"
        loading="eager" fetchpriority="high" decoding="async"
        width="{{ img.width }}" height="{{ img.height }}">
    {% else %}
      <div style="width:100%;height:100%;background:#0F172A;"></div>
    {% endif %}
  </div>
  {% if section.settings.overlay %}<div class="overlay"></div>{% endif %}

  <div class="inner">
    <nav class="bc" aria-label="Breadcrumb">
      <a href="{{ routes.root_url }}">Home</a><span class="sep">/</span><span aria-current="page">Labs</span>
    </nav>

    <h1 class="h1">{{ section.settings.h1 | default: 'For Labs, Clinics & Research Teams' }}</h1>
    <p class="sub">{{ section.settings.sub | default: 'Access verified peptides, wholesale pricing, and batch documentation for professional use.' }}</p>

    <div class="badges">
      {% assign chips = section.settings.badges %}
      {% if chips == blank %}{% assign chips = '≥99% purity|Third-party COA|Same-day dispatch UAE|Worldwide express' %}{% endif %}
      {% assign list = chips | split: '|' %}
      {% for c in list %}
        {% assign t = c | strip %}
        {% if t != blank %}
        <span class="chip">
          <span class="ico" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
          {{ t }}
        </span>
        {% endif %}
      {% endfor %}
    </div>

    <div class="ctas">
      {% if section.settings.p_label and section.settings.p_link %}<a class="btn btn--primary" href="{{ section.settings.p_link }}">{{ section.settings.p_label }}</a>{% endif %}
      {% if section.settings.s_label and section.settings.s_link %}<a class="btn btn--ghost" href="{{ section.settings.s_link }}">{{ section.settings.s_label }}</a>{% endif %}
    </div>
  </div>
</section>

<script type="application/ld+json">
{
  "@context":"https://schema.org",
  "@type":"BreadcrumbList",
  "itemListElement":[
    {"@type":"ListItem","position":1,"name":"Home","item":"{{ routes.root_url }}"},
    {"@type":"ListItem","position":2,"name":"Labs"}
  ]
}
</script>

{% schema %}
{
  "name":"Labs · Hero",
  "settings":[
    { "type":"image_picker","id":"bg","label":"Background image" },
    { "type":"checkbox","id":"overlay","label":"Show overlay","default":true },
    { "type":"color","id":"overlay_color","label":"Overlay color","default":"#000000" },
    { "type":"range","id":"overlay_opacity","label":"Overlay opacity","min":0,"max":100,"step":5,"unit":"%","default":40 },

    { "type":"select","id":"vert_align","label":"Vertical alignment","options":[{"value":"flex-start","label":"Top"},{"value":"center","label":"Center"},{"value":"flex-end","label":"Bottom"}],"default":"center" },
    { "type":"range","id":"max_width","label":"Content max width","min":600,"max":1200,"step":20,"unit":"px","default":920 },
    { "type":"range","id":"pad","label":"Desktop padding","min":20,"max":100,"step":10,"unit":"px","default":40 },
    { "type":"range","id":"pad_mobile","label":"Mobile padding","min":10,"max":50,"step":5,"unit":"px","default":25 },
    { "type":"select","id":"mobile_aspect_ratio","label":"Mobile aspect ratio","options":[{"value":"16 / 9","label":"16:9"},{"value":"4 / 3","label":"4:3"},{"value":"1 / 1","label":"1:1"},{"value":"3 / 4","label":"3:4"}],"default":"4 / 3" },

    { "type":"text","id":"h1","label":"Headline","default":"For Labs, Clinics & Research Teams" },
    { "type":"range","id":"h1_size","label":"H1 size","min":28,"max":88,"step":2,"unit":"px","default":56 },
    { "type":"textarea","id":"sub","label":"Subheadline","default":"Access verified peptides, wholesale pricing, and batch documentation for professional use." },
    { "type":"text","id":"badges","label":"Badges (| separated)","default":"≥99% purity|Third-party COA|Same-day dispatch UAE|Worldwide express" },

    { "type":"text","id":"p_label","label":"Primary CTA label","default":"Request Access" },
{ "type":"url","id":"p_link","label":"Primary CTA link" },
    { "type":"text","id":"s_label","label":"Secondary CTA label","default":"Contact a Specialist" },
{ "type":"url","id":"s_link","label":"Secondary CTA link" }
  ],
  "presets":[{ "name":"Labs · Hero" }]
}
{% endschema %}
