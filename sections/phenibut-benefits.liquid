{% comment %}
  Benefits & Uses — Premium refactored section
  - Benefit cards with emoji/image icons, expandable details
  - Premium design tokens, focus-visible, prefers-reduced-motion
{% endcomment %}

{%- style -%}
.xo-section--{{ section.id }} {
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
  content-visibility: auto;
  contain-intrinsic-size: 1px 800px;
  font-family: var(--font-body-family);
}
.xo-section--{{ section.id }} .phb-benefits__container { max-width: {{ section.settings.max_width }}px; margin: 0 auto; padding: 0 16px; }
.xo-section--{{ section.id }} .phb-benefits__title {
  font-family: var(--font-heading-family);
  font-size: clamp(22px, 4.2vw, 36px); line-height: 1.2;
  margin: 0 0 8px; color: rgba(var(--color-foreground)); text-wrap: balance; font-weight: 600;
}
.xo-section--{{ section.id }} .phb-benefits__intro {
  color: rgba(var(--color-foreground)); font-size: clamp(16px, 2.2vw, 18px);
  line-height: 1.6; max-width: 72ch; margin-bottom: 16px;
}
.xo-section--{{ section.id }} .phb-benefits__grid {
  display: grid; gap: {{ section.settings.gap }}px;
  grid-template-columns: repeat({{ section.settings.columns_desktop }}, minmax(240px, 1fr));
}
.xo-section--{{ section.id }} .phb-benefit {
  background: rgba(var(--color-background)); border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
  border-radius: var(--general-radius-1, 1rem); padding: 16px;
  display: grid; grid-template-rows: auto auto 1fr auto; gap: 10px;
}
.xo-section--{{ section.id }} .phb-benefit__icon {
  width: 48px; height: 48px; border-radius: 10px;
  background: rgba(var(--color-background-2));
  display: inline-flex; align-items: center; justify-content: center;
}
.xo-section--{{ section.id }} .phb-benefit__emoji { font-size: 26px; line-height: 1; }
.xo-section--{{ section.id }} .phb-benefit__icon-img { width: 26px; height: 26px; object-fit: contain; }
.xo-section--{{ section.id }} .phb-benefit__h3 {
  font-family: var(--font-heading-family);
  font-size: 18px; font-weight: 600; margin: 0; color: rgba(var(--color-foreground));
}
.xo-section--{{ section.id }} .phb-benefit__blurb { font-size: 16px; color: rgba(var(--color-foreground)); margin: 0; line-height: 1.5; }
.xo-section--{{ section.id }} .phb-benefit__details { margin-top: 2px; }
.xo-section--{{ section.id }} .phb-benefit__summary {
  display: flex; align-items: center; justify-content: space-between;
  cursor: pointer; user-select: none; padding: 8px 0;
  font-weight: 600; color: rgba(var(--color-foreground)); list-style: none;
}
.xo-section--{{ section.id }} .phb-benefit__summary::-webkit-details-marker { display: none; }
.xo-section--{{ section.id }} .phb-benefit__summary:focus-visible {
  outline: 2px solid rgba(var(--color-accent)); outline-offset: 2px;
}
.xo-section--{{ section.id }} .phb-benefit__chev { transition: transform 0.3s var(--out-soft, ease); }
.xo-section--{{ section.id }} .phb-benefit__details[open] .phb-benefit__chev { transform: rotate(180deg); }
.xo-section--{{ section.id }} .phb-benefit__more { color: rgba(var(--color-foreground)); font-size: 15px; line-height: 1.6; }
.xo-section--{{ section.id }} .phb-benefit__more p { margin: 0 0 10px; }
.xo-section--{{ section.id }} .phb-benefit__more ul { padding-left: 18px; margin: 6px 0 10px; }
.xo-section--{{ section.id }} .phb-benefit__more li { list-style: disc; }
.xo-section--{{ section.id }} .phb-benefits__note {
  margin-top: 12px; font-size: 13px; color: color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent);
}
@media (max-width: 992px) {
  .xo-section--{{ section.id }} .phb-benefits__grid {
    grid-template-columns: repeat({{ section.settings.columns_tablet }}, minmax(240px, 1fr));
  }
}
@media (max-width: 768px) {
  .xo-section--{{ section.id }} .phb-benefits__grid { grid-template-columns: 1fr; }
  .xo-section--{{ section.id }} .phb-benefits__title {
    text-align: {% if section.settings.center_on_mobile %}center{% else %}left{% endif %};
  }
  .xo-section--{{ section.id }} .phb-benefits__intro {
    text-align: {% if section.settings.center_on_mobile %}center{% else %}left{% endif %};
    margin-left: auto; margin-right: auto;
  }
}
@media (prefers-reduced-motion: reduce) {
  .xo-section--{{ section.id }} *,
  .xo-section--{{ section.id }} *::before,
  .xo-section--{{ section.id }} *::after {
    animation-duration: 0.01ms !important;
    transition-duration: 0.01ms !important;
  }
}
{%- endstyle -%}

<section {% render 'section-attr' %} aria-labelledby="phb-benefits-title-{{ section.id }}">
  <xo-container>
    <div class="phb-benefits__container">
      <header class="phb-benefits__header">
        <h2 id="phb-benefits-title-{{ section.id }}" class="phb-benefits__title">
          {{ section.settings.heading | escape }}
        </h2>
        {% if section.settings.intro != blank %}
          <div class="phb-benefits__intro">{{ section.settings.intro }}</div>
        {% endif %}
      </header>

      <div class="phb-benefits__grid">
        {% for block in section.blocks %}
          {% if block.type == 'benefit' %}
            <article id="benefit-{{ block.settings.title | handleize }}" class="phb-benefit" {{ block.shopify_attributes }} aria-labelledby="phb-benefit-title-{{ block.id }}">
              <div class="phb-benefit__icon" aria-hidden="true">
                {% if block.settings.use_image_icon and block.settings.icon_image != blank %}
                  <img class="phb-benefit__icon-img"
                    src="{{ block.settings.icon_image | image_url: width: 120 }}"
                    srcset="{{ block.settings.icon_image | image_url: width: 80 }} 80w, {{ block.settings.icon_image | image_url: width: 120 }} 120w"
                    sizes="48px" width="26" height="26" alt="" role="presentation" loading="lazy" decoding="async">
                {% else %}
                  <span class="phb-benefit__emoji">{{ block.settings.emoji_icon }}</span>
                {% endif %}
              </div>

              <h3 id="phb-benefit-title-{{ block.id }}" class="phb-benefit__h3">{{ block.settings.title | escape }}</h3>
              {% if block.settings.blurb != blank %}
                <p class="phb-benefit__blurb">{{ block.settings.blurb | escape }}</p>
              {% endif %}

              <details class="phb-benefit__details" {% if block.settings.open_by_default %}open{% endif %}>
                <summary class="phb-benefit__summary">
                  <span>{{ block.settings.toggle_label | escape }}</span>
                  <span class="phb-benefit__chev" aria-hidden="true">▾</span>
                </summary>
                <div class="phb-benefit__more">{{ block.settings.details }}</div>
              </details>
            </article>
          {% endif %}
        {% endfor %}
      </div>

      {% if section.settings.show_note and section.settings.note_text != blank %}
        <p class="phb-benefits__note">{{ section.settings.note_text }}</p>
      {% endif %}
    </div>
  </xo-container>
</section>

{% schema %}
{
  "name": "Benefits & Uses",
  "tag": "section",
  "class": "section-phenibut-benefits",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "default" },
    { "type": "text", "id": "anchor_id", "label": "Anchor ID (for TOC/links)", "default": "benefits-uses" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Benefits & Uses" },
    { "type": "richtext", "id": "intro", "label": "Intro sentence", "default": "<p>Where Phenibut can help—when used <strong>occasionally</strong> and responsibly.</p>" },
    { "type": "range", "id": "max_width", "label": "Max content width (px)", "min": 720, "max": 1400, "step": 20, "default": 1200 },
    { "type": "range", "id": "gap", "label": "Card gap (px)", "min": 12, "max": 40, "step": 2, "default": 20 },
    { "type": "range", "id": "columns_desktop", "label": "Columns on desktop", "min": 2, "max": 4, "step": 1, "default": 4 },
    { "type": "range", "id": "columns_tablet", "label": "Columns on tablet", "min": 1, "max": 3, "step": 1, "default": 2 },
    { "type": "checkbox", "id": "center_on_mobile", "label": "Center text on mobile", "default": false },
    { "type": "checkbox", "id": "show_note", "label": "Show disclaimer note", "default": true },
    { "type": "textarea", "id": "note_text", "label": "Disclaimer note text", "default": "This content is educational, not medical advice. Use Phenibut occasionally. Do not combine with alcohol or sedatives." },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding top", "default": 40 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding bottom", "default": 40 }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit card",
      "settings": [
        { "type": "checkbox", "id": "use_image_icon", "label": "Use image icon (else emoji)", "default": false },
        { "type": "image_picker", "id": "icon_image", "label": "Icon image" },
        { "type": "text", "id": "emoji_icon", "label": "Emoji icon", "default": "🧘" },
        { "type": "text", "id": "title", "label": "Title", "default": "Calm & Relaxation" },
        { "type": "text", "id": "blurb", "label": "Short sentence", "default": "Helps dial down mental noise so you feel steady and centered." },
        { "type": "checkbox", "id": "open_by_default", "label": "Start expanded", "default": false },
        { "type": "text", "id": "toggle_label", "label": "Toggle label", "default": "Learn more" },
        { "type": "richtext", "id": "details", "label": "Expanded content", "default": "<p>Acts primarily at GABA‑B receptors to promote a calmer baseline. Best used occasionally. Avoid mixing with alcohol or sedatives. Typical onset: 1–3 hours.</p>" }
      ]
    },
    { "type": "@app" }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Benefits & Uses",
      "blocks": [
        { "type": "benefit", "settings": { "emoji_icon": "🧘", "title": "Calm & Relaxation", "blurb": "Helps dial down mental noise so you feel steady and centered.", "details": "<p>Acts primarily at GABA‑B receptors to promote a calmer baseline. Best used occasionally. Avoid mixing with alcohol or sedatives. Typical onset: 1–3 hours.</p>" } },
        { "type": "benefit", "settings": { "emoji_icon": "😴", "title": "Better Sleep Quality", "blurb": "Can support deeper, more restorative sleep when timed correctly.", "details": "<p>Some users take it in the evening to ease sleep latency. Effects can last several hours—time your dose responsibly and avoid daily use.</p>" } },
        { "type": "benefit", "settings": { "emoji_icon": "🤝", "title": "Social Ease & Confidence", "blurb": "Useful for high‑pressure social settings when you need calm composure.", "details": "<p>May reduce performance jitters in occasionally stressful scenarios. Start low; more is not better. Never combine with other depressants.</p>" } },
        { "type": "benefit", "settings": { "emoji_icon": "🧠", "title": "Cognitive Balance", "blurb": "Takes the edge off overstimulation so focus feels more even.", "details": "<p>A calmer baseline can make focus feel steadier for some users. If grogginess occurs, you likely took too much—use sparingly and adjust timing.</p>" } }
      ]
    }
  ]
}
{% endschema %}
