{%- liquid
  assign enabled = section.settings.enable
  assign only_on_page_handle = section.settings.only_on_page_handle | strip
  assign show_visible_faq = section.settings.show_visible_faq
  assign heading = section.settings.heading | strip

  assign allow_render = true
  if enabled != true
    assign allow_render = false
  endif

  if only_on_page_handle != blank and request.page_type == 'page'
    if page.handle != only_on_page_handle
      assign allow_render = false
    endif
  endif
-%}

{%- if allow_render and section.blocks.size > 0 -%}
  {%- comment -%}
    Visible FAQ (optional). This is useful for users AND helps align content with schema.
  {%- endcomment -%}
  {%- if show_visible_faq -%}
    <section class="nootropix-faq" data-section-id="{{ section.id }}">
      {%- if heading != blank -%}
        <h2 class="nootropix-faq__heading">{{ heading }}</h2>
      {%- endif -%}

      <div class="nootropix-faq__items">
        {%- for block in section.blocks -%}
          {%- assign q = block.settings.question | strip -%}
          {%- assign a = block.settings.answer | strip -%}
          {%- if q != blank and a != blank -%}
            <details class="nootropix-faq__item" {{ block.shopify_attributes }}>
              <summary class="nootropix-faq__question">{{ q }}</summary>
              <div class="nootropix-faq__answer rte">
                {{ a }}
              </div>
            </details>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </section>

    <style>
      .nootropix-faq { margin-top: 2rem; }
      .nootropix-faq__heading { margin: 0 0 1rem 0; }
      .nootropix-faq__item { border-bottom: 1px solid rgba(0,0,0,.08); padding: .75rem 0; }
      .nootropix-faq__question { cursor: pointer; font-weight: 600; }
      .nootropix-faq__answer { margin-top: .5rem; }
    </style>
  {%- endif -%}

  {%- comment -%}
    JSON-LD FAQPage schema. Must be a REAL <script type="application/ld+json">.
  {%- endcomment -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {%- assign first = true -%}
      {%- for block in section.blocks -%}
        {%- assign q = block.settings.question | strip -%}
        {%- assign a = block.settings.answer | strip -%}
        {%- if q != blank and a != blank -%}
          {%- unless first -%},{%- endunless -%}
          {
            "@type": "Question",
            "name": {{ q | json }},
            "acceptedAnswer": {
              "@type": "Answer",
              "text": {{ a | strip_html | json }}
            }
          }
          {%- assign first = false -%}
        {%- endif -%}
      {%- endfor -%}
    ]
  }
  </script>
{%- endif -%}

{% schema %}
{
  "name": "FAQ (JSON-LD)",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable",
      "label": "Enable section",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_visible_faq",
      "label": "Show FAQ on page",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "FAQ heading",
      "default": "FAQs"
    },
    {
      "type": "text",
      "id": "only_on_page_handle",
      "label": "Only render on this page handle (optional)",
      "info": "Example: science-bio-phenibut-alternative"
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ (JSON-LD)",
      "blocks": [
        { "type": "faq_item" },
        { "type": "faq_item" },
        { "type": "faq_item" }
      ]
    }
  ]
}
{% endschema %}
