{%- liquid
  assign enabled = section.settings.enable
  assign only_on_page_handle = section.settings.only_on_page_handle | strip
  assign show_visible_faq = section.settings.show_visible_faq
  assign heading = section.settings.heading | strip

  assign allow_render = true
  if enabled != true
    assign allow_render = false
  endif

  if only_on_page_handle != blank and request.page_type == 'page'
    if page.handle != only_on_page_handle
      assign allow_render = false
    endif
  endif
-%}

{%- if allow_render and section.blocks.size > 0 -%}
  {%- if show_visible_faq -%}
    {%- style -%}
      .xo-section--{{ section.id }} {
        padding-top: {{ section.settings.padding_top }}px;
        padding-bottom: {{ section.settings.padding_bottom }}px;
      }

      .xo-section--{{ section.id }} .faq-ld__heading {
        margin: 0 0 1rem 0;
        font-weight: 600;
        color: rgba(var(--color-foreground));
      }

      .xo-section--{{ section.id }} .faq-ld__item {
        border-bottom: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 8%, transparent);
        padding: 0.75rem 0;
      }

      .xo-section--{{ section.id }} .faq-ld__question {
        cursor: pointer;
        font-weight: 600;
        color: rgba(var(--color-foreground));
        min-height: 44px;
        display: flex;
        align-items: center;
      }

      .xo-section--{{ section.id }} .faq-ld__question:focus-visible {
        outline: 2px solid rgba(var(--color-accent));
        outline-offset: 2px;
        border-radius: 4px;
      }

      .xo-section--{{ section.id }} .faq-ld__question::-webkit-details-marker {
        display: none;
      }

      .xo-section--{{ section.id }} .faq-ld__answer {
        margin-top: 0.5rem;
        color: rgba(var(--color-foreground));
        line-height: 1.6;
      }
    {%- endstyle -%}

    <section {% render 'section-attr' %}>
      <xo-container>
        {%- if heading != blank -%}
          <h2 class="faq-ld__heading">{{ heading }}</h2>
        {%- endif -%}

        <div class="faq-ld__items">
          {%- for block in section.blocks -%}
            {%- assign q = block.settings.question | strip -%}
            {%- assign a = block.settings.answer | strip -%}
            {%- if q != blank and a != blank -%}
              <details class="faq-ld__item" data-faq-item {{ block.shopify_attributes }}>
                <summary class="faq-ld__question">{{ q }}</summary>
                <div class="faq-ld__answer rte">{{ a }}</div>
              </details>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </xo-container>
    </section>
  {%- endif -%}

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {%- assign first = true -%}
      {%- for block in section.blocks -%}
        {%- assign q = block.settings.question | strip -%}
        {%- assign a = block.settings.answer | strip -%}
        {%- if q != blank and a != blank -%}
          {%- unless first -%},{%- endunless -%}
          {
            "@type": "Question",
            "name": {{ q | json }},
            "acceptedAnswer": {
              "@type": "Answer",
              "text": {{ a | strip_html | json }}
            }
          }
          {%- assign first = false -%}
        {%- endif -%}
      {%- endfor -%}
    ]
  }
  </script>
{%- endif -%}

{% schema %}
{
  "name": "FAQ (JSON-LD)",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "default"
    },
    {
      "type": "checkbox",
      "id": "enable",
      "label": "Enable section",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_visible_faq",
      "label": "Show FAQ on page",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "FAQ heading",
      "default": "FAQs"
    },
    {
      "type": "text",
      "id": "only_on_page_handle",
      "label": "Only render on this page handle (optional)",
      "info": "Example: science-bio-phenibut-alternative"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 20
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ item",
      "settings": [
        { "type": "text", "id": "question", "label": "Question" },
        { "type": "richtext", "id": "answer", "label": "Answer" }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ (JSON-LD)",
      "blocks": [
        { "type": "faq_item" },
        { "type": "faq_item" },
        { "type": "faq_item" }
      ]
    }
  ]
}
{% endschema %}
