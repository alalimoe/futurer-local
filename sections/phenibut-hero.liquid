{% comment %}
  Phenibut Hero — Premium refactored section
  - Gradient hero with right packshot
  - Starline + white pull-quote card integrated inside hero
  - WebPage + BreadcrumbList JSON-LD
  - Premium design token system
{% endcomment %}

{%- comment -%} ── JSON-LD: WebPage + BreadcrumbList ── {%- endcomment -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "name": {{ section.settings.heading | json }},
      "description": {{ section.settings.subheading | strip_html | json }},
      "url": "{{ request.origin }}{{ request.path }}",
      "publisher": {
        "@type": "Organization",
        "name": {{ shop.name | json }},
        "url": "{{ shop.url }}"
      },
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": "{{ shop.url }}" },
          { "@type": "ListItem", "position": 2, "name": {{ section.settings.heading | json }}, "item": "{{ request.origin }}{{ request.path }}" }
        ]
      }
    }
  ]
}
</script>

{%- style -%}
.xo-section--{{ section.id }} {
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
}
.xo-section--{{ section.id }} .phb-hero--fullscreen {
  --phb-grad-from: {{ section.settings.gradient_from }};
  --phb-grad-to: {{ section.settings.gradient_to }};
  --phb-max: {{ section.settings.max_width }}px;
  --phb-sticky-offset: 0px;
  min-height: calc(100svh - var(--phb-sticky-offset));
  position: relative;
  overflow: hidden;
}
.xo-section--{{ section.id }} .phb-hero__bg {
  position: absolute; inset: 0; z-index: 0;
  background: linear-gradient(180deg, var(--phb-grad-from) 0%, var(--phb-grad-to) 100%);
}
.xo-section--{{ section.id }} .phb-hero__container {
  position: relative; z-index: 1;
  max-width: var(--phb-max); margin: 0 auto;
  padding: clamp(40px, 7vh, 88px) var(--page-gap);
  display: grid; align-items: center; gap: 28px;
  grid-template-columns: 1fr minmax(360px, 520px);
  color: rgba(var(--color-background));
  font-family: var(--font-body-family);
  min-height: calc(100svh - var(--phb-sticky-offset));
  align-content: center;
}
.xo-section--{{ section.id }} h1 {
  font-family: var(--font-heading-family);
  font-size: clamp(28px, 6vw, 56px);
  line-height: 1.05; font-weight: 600; margin: 0 0 8px 0;
  color: rgba(var(--color-background));
  text-wrap: balance;
}
.xo-section--{{ section.id }} .phb-hero__subhead {
  font-size: clamp(16px, 2.4vw, 20px); line-height: 1.5; max-width: 760px;
  color: color-mix(in srgb, rgba(var(--color-background)) 85%, transparent); margin: 0 0 10px 0;
}
.xo-section--{{ section.id }} .phb-hero__meta {
  font-size: 13px; color: color-mix(in srgb, rgba(var(--color-background)) 85%, transparent); opacity: .85;
  margin: 0 0 6px; font-family: var(--font-body-family);
}
.xo-section--{{ section.id }} .phb-hero__starline {
  display: flex; align-items: center; gap: 8px;
  margin: 2px 0 10px; font-size: 13px;
  color: color-mix(in srgb, rgba(var(--color-background)) 85%, transparent); opacity: .95;
}
.xo-section--{{ section.id }} .phb-hero__stars { color: rgba(var(--color-accent)); letter-spacing: 1px; }
.xo-section--{{ section.id }} .phb-hero__ctas { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 8px; }
.xo-section--{{ section.id }} .phb-hero__quote-card {
  background: rgba(var(--color-background)); color: rgba(var(--color-foreground));
  border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
  border-radius: var(--general-radius-1, 1rem); padding: 12px 14px;
  display: flex; flex-direction: column; gap: 6px; max-width: 640px;
}
.xo-section--{{ section.id }} .phb-hero__quote { margin: 0; font-size: 16px; line-height: 1.6; }
.xo-section--{{ section.id }} .phb-hero__quote-meta {
  margin: 0; font-size: 14px; color: color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent);
  display: flex; gap: 8px; align-items: center; flex-wrap: wrap;
}
.xo-section--{{ section.id }} .phb-hero__quote-link {
  margin-left: auto; font-weight: 600; color: rgba(var(--color-foreground));
  text-decoration: none; border-bottom: 2px solid transparent; padding-bottom: 2px;
  transition: border-color 0.3s var(--out-soft, ease);
}
.xo-section--{{ section.id }} .phb-hero__quote-link:hover { border-color: rgba(var(--color-foreground)); }
.xo-section--{{ section.id }} .phb-badge {
  display: inline-block; padding: 2px 8px; font-size: 12px; line-height: 1.2;
  border-radius: var(--button-radius); background: rgba(var(--color-foreground)); color: rgba(var(--color-background));
  vertical-align: middle;
}
.xo-section--{{ section.id }} .phb-hero__trust {
  margin: 8px 0 6px; font-size: 14px;
  color: color-mix(in srgb, rgba(var(--color-background)) 85%, transparent); opacity: .95;
}
.xo-section--{{ section.id }} .phb-hero__safety {
  margin: 0; font-size: 12px;
  color: color-mix(in srgb, rgba(var(--color-background)) 85%, transparent); opacity: .85;
}
.xo-section--{{ section.id }} .phb-hero__right { display: flex; align-items: center; width: 480px; height: 520px; }
.xo-section--{{ section.id }} .phb-hero__img { width: 100%; height: 100%; object-fit: contain; border-radius: var(--general-radius-1, 1rem); }

@media (max-width: 768px) {
  .xo-section--{{ section.id }} .phb-hero--fullscreen { --phb-sticky-offset: {{ section.settings.sticky_offset }}px; }
  .xo-section--{{ section.id }} .phb-hero__container {
    grid-template-columns: 1fr;
    text-align: {% if section.settings.center_on_mobile %}center{% else %}left{% endif %};
    padding: calc(env(safe-area-inset-top) + {{ section.settings.mobile_padding_top }}px + {{ section.settings.mobile_extra_offset }}px) var(--page-gap) calc(env(safe-area-inset-bottom) + {{ section.settings.mobile_padding_bottom }}px);
    gap: 14px;
  }
  .xo-section--{{ section.id }} h1 { font-size: clamp(24px, 7vw, 40px); margin-bottom: 6px; line-height: 1.1; }
  .xo-section--{{ section.id }} .phb-hero__subhead { margin-bottom: 8px; }
  .xo-section--{{ section.id }} .phb-hero__ctas { flex-direction: column; gap: 10px; margin-bottom: 6px; }
  .xo-section--{{ section.id }} .phb-hero__ctas .btn { width: 100%; text-align: center; }
  .xo-section--{{ section.id }} .phb-hero__quote-card { max-width: 100%; text-align: left; margin-left: auto; margin-right: auto; }
  .xo-section--{{ section.id }} .phb-hero__right {
    display: {% if section.settings.hide_image_mobile %}none{% else %}flex{% endif %};
    width: 100%; height: auto; justify-content: center; margin-top: 8px;
  }
  .xo-section--{{ section.id }} .phb-hero__trust { font-size: 13px; margin: 6px 0 4px; }
  .xo-section--{{ section.id }} .phb-hero__safety { font-size: 12px; }
}
@media (max-width: 390px) {
  .xo-section--{{ section.id }} .phb-hero__quote {
    display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;
  }
}
@media (prefers-reduced-motion: reduce) {
  .xo-section--{{ section.id }} *,
  .xo-section--{{ section.id }} *::before,
  .xo-section--{{ section.id }} *::after {
    animation-duration: 0.01ms !important;
    transition-duration: 0.01ms !important;
  }
}
{%- endstyle -%}

<section {% render 'section-attr' %} aria-labelledby="phb-hero-title-{{ section.id }}">
  <xo-container>
    <div class="phb-hero--fullscreen">
      <div class="phb-hero__bg" aria-hidden="true"></div>

      <div class="phb-hero__container">
        <div class="phb-hero__left">
          <h1 id="phb-hero-title-{{ section.id }}">{{ section.settings.heading | escape }}</h1>

          {% if section.settings.subheading != blank %}
            <div class="phb-hero__subhead">{{ section.settings.subheading }}</div>
          {% endif %}

          {% if section.settings.read_time != blank %}
            <p class="phb-hero__meta">{{ section.settings.read_time | escape }}</p>
          {% endif %}

          {% if section.settings.show_starline %}
            <p class="phb-hero__starline" aria-label="Rated {{ section.settings.pull_quote_rating }} out of 5">
              <span class="phb-hero__stars" aria-hidden="true">
                {% for i in (1..5) %}{% if i <= section.settings.pull_quote_rating %}★{% else %}☆{% endif %}{% endfor %}
              </span>
              <span class="phb-hero__starline-label">{{ section.settings.starline_label | escape }}</span>
            </p>
          {% endif %}

          <div class="phb-hero__ctas">
            {% if section.settings.primary_label != blank and section.settings.primary_href != blank %}
              <a class="btn btn--primary" href="{{ section.settings.primary_href | escape }}">{{ section.settings.primary_label | escape }}</a>
            {% endif %}
            {% if section.settings.show_secondary and section.settings.secondary_label != blank and section.settings.secondary_href != blank %}
              <a class="btn btn--ghost" href="{{ section.settings.secondary_href | escape }}">{{ section.settings.secondary_label | escape }}</a>
            {% endif %}
          </div>

          {% if section.settings.show_pull_quote %}
            <figure class="phb-hero__quote-card">
              <blockquote class="phb-hero__quote" dir="auto">"{{ section.settings.pull_quote_text | escape }}"</blockquote>
              <figcaption class="phb-hero__quote-meta" dir="auto">
                — {{ section.settings.pull_quote_author | escape }}{% if section.settings.pull_quote_location != blank %}, {{ section.settings.pull_quote_location | escape }}{% endif %}
                {% if section.settings.pull_quote_show_verified %}<span class="phb-badge" aria-label="Verified reviewer">Verified</span>{% endif %}
                {% if section.settings.pull_quote_link_label != blank and section.settings.pull_quote_link_href != blank %}
                  <a class="phb-hero__quote-link" href="{{ section.settings.pull_quote_link_href | escape }}">{{ section.settings.pull_quote_link_label | escape }} →</a>
                {% endif %}
              </figcaption>
            </figure>
          {% endif %}

          {% if section.settings.show_trustbar and section.blocks.size > 0 %}
            <p class="phb-hero__trust">
              {% for block in section.blocks %}
                {{ block.settings.text | escape }}{% unless forloop.last %} • {% endunless %}
              {% endfor %}
            </p>
          {% endif %}

          {% if section.settings.show_safety_note and section.settings.safety_note != blank %}
            <p class="phb-hero__safety">{{ section.settings.safety_note }}</p>
          {% endif %}
        </div>

        {% if section.settings.right_image != blank or section.settings.use_fallback_image %}
          <div class="phb-hero__right{% if section.settings.hide_image_mobile %} phb-hero__right--hide-m{% endif %}">
            {% assign fallback_img = 'phenibut-hero-packshot.png' | file_url %}
            {%- if section.settings.right_image != blank -%}
              {%- assign hero_img_height = 960 | divided_by: section.settings.right_image.aspect_ratio | round -%}
            {%- else -%}
              {%- assign hero_img_height = 960 -%}
            {%- endif -%}
            <picture>
              {% if section.settings.right_image_mobile != blank %}
                <source media="(max-width: 768px)" srcset="
                  {{ section.settings.right_image_mobile | image_url: width: 480 }} 480w,
                  {{ section.settings.right_image_mobile | image_url: width: 700 }} 700w
                " sizes="100vw">
              {% endif %}
              <img
                {% if section.settings.right_image != blank %}
                  src="{{ section.settings.right_image | image_url: width: 960 }}"
                  srcset="
                    {{ section.settings.right_image | image_url: width: 480 }} 480w,
                    {{ section.settings.right_image | image_url: width: 700 }} 700w,
                    {{ section.settings.right_image | image_url: width: 960 }} 960w
                  "
                  sizes="(max-width: 768px) 0px, 480px"
                  alt="{% unless section.settings.right_image_decorative %}{{ section.settings.right_image_alt | escape }}{% endunless %}"
                {% else %}
                  src="{{ fallback_img }}"
                  alt="Phenibut FAA 300mg, Phenibut 500mg, and Phenibut 250mg capsules—product lineup."
                {% endif %}
                width="960"
                height="{{ hero_img_height }}"
                loading="eager" fetchpriority="high" decoding="async" class="phb-hero__img"
              >
            </picture>
          </div>
        {% endif %}
      </div>
    </div>
  </xo-container>
</section>

{% schema %}
{
  "name": "Phenibut Hero",
  "tag": "section",
  "class": "section-phenibut-hero",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "default" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Phenibut: Calm, Rest, Reset" },
    { "type": "richtext", "id": "subheading", "label": "Sub-headline", "default": "<p>Fast-acting calm for demanding days—clearly dosed Phenibut (FAA &amp; HCl), delivered fast from Dubai.</p>" },
    { "type": "text", "id": "read_time", "label": "Estimated read time", "default": "8 min read" },

    { "type": "text", "id": "primary_label", "label": "Primary CTA label", "default": "Shop Phenibut" },
    { "type": "text", "id": "primary_href", "label": "Primary CTA link (URL or anchor)", "default": "#shop-phenibut" },

    { "type": "checkbox", "id": "show_secondary", "label": "Show secondary CTA", "default": true },
    { "type": "text", "id": "secondary_label", "label": "Secondary CTA label", "default": "How to Use Safely" },
    { "type": "text", "id": "secondary_href", "label": "Secondary CTA link (URL or anchor)", "default": "#safety" },

    { "type": "image_picker", "id": "right_image", "label": "Right image (desktop)" },
    { "type": "image_picker", "id": "right_image_mobile", "label": "Right image (mobile override)" },
    { "type": "text", "id": "right_image_alt", "label": "Right image alt text" },
    { "type": "checkbox", "id": "right_image_decorative", "label": "Mark right image decorative (hides from screen readers)", "default": true },
    { "type": "checkbox", "id": "hide_image_mobile", "label": "Hide right image on mobile", "default": true },
    { "type": "checkbox", "id": "use_fallback_image", "label": "Use fallback file 'phenibut-hero-packshot.png' if no image set", "default": false },

    { "type": "color", "id": "gradient_from", "label": "Gradient from", "default": "#0A2342" },
    { "type": "color", "id": "gradient_to", "label": "Gradient to", "default": "#CFE7E7" },

    { "type": "range", "id": "max_width", "label": "Max content width (px)", "min": 720, "max": 1400, "step": 20, "default": 1200 },
    { "type": "checkbox", "id": "center_on_mobile", "label": "Center text on mobile", "default": true },

    { "type": "range", "id": "mobile_padding_top", "label": "Mobile top padding (px)", "min": 40, "max": 120, "step": 4, "default": 64 },
    { "type": "range", "id": "mobile_padding_bottom", "label": "Mobile bottom padding (px)", "min": 24, "max": 120, "step": 4, "default": 52 },
    { "type": "range", "id": "mobile_extra_offset", "label": "Mobile extra offset (px)", "min": 0, "max": 64, "step": 2, "default": 8 },

    { "type": "checkbox", "id": "show_starline", "label": "Show starline under subhead", "default": true },
    { "type": "text", "id": "starline_label", "label": "Starline label", "default": "4.9/5 from verified buyers" },

    { "type": "checkbox", "id": "show_pull_quote", "label": "Show review pull-quote card", "default": true },
    { "type": "textarea", "id": "pull_quote_text", "label": "Pull-quote text", "default": "You can get this in a lot of places, but Nootropix's quality is so much better and their customer service is exceptional." },
    { "type": "text", "id": "pull_quote_author", "label": "Pull-quote author", "default": "Anonymous" },
    { "type": "text", "id": "pull_quote_location", "label": "Pull-quote location", "default": "UAE" },
    { "type": "checkbox", "id": "pull_quote_show_verified", "label": "Show Verified badge", "default": true },
    { "type": "text", "id": "pull_quote_link_label", "label": "Link label", "default": "Read reviews" },
    { "type": "text", "id": "pull_quote_link_href", "label": "Link href (URL or #anchor)", "default": "#reviews" },

    { "type": "range", "id": "pull_quote_rating", "label": "Star rating (for starline)", "min": 1, "max": 5, "step": 1, "default": 5 },

    { "type": "range", "id": "sticky_offset", "label": "Mobile sticky bar offset (px)", "min": 0, "max": 120, "step": 4, "default": 64 },

    { "type": "checkbox", "id": "show_trustbar", "label": "Show trust bar", "default": true },
    { "type": "textarea", "id": "safety_note", "label": "Safety note", "default": "Use responsibly. Not for daily use. Do not combine with alcohol or sedatives. See our safety guide." },
    { "type": "checkbox", "id": "show_safety_note", "label": "Show safety note", "default": true },

    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding top", "default": 0 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding bottom", "default": 0 }
  ],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust item",
      "settings": [
        { "type": "text", "id": "text", "label": "Item text", "default": "4-hour delivery in Dubai" }
      ]
    },
    { "type": "@app" }
  ],
  "max_blocks": 6,
  "presets": [
    { "name": "Phenibut Hero" }
  ]
}
{% endschema %}
