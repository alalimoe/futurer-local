<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {%- for block in section.blocks -%}
    {
      "@type": "Question",
      "name": {{ block.settings.question | json }},
      "acceptedAnswer": {
        "@type": "Answer",
        "text": {{ block.settings.answer | strip_html | json }}
      }
    }{%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
  ]
}
</script>

{%- style -%}
  .xo-section--{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .xo-section--{{ section.id }} .bfaq__title {
    text-align: center;
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    font-weight: 600;
    color: rgba(var(--color-foreground));
    margin: 0 0 48px;
    letter-spacing: -0.02em;
  }

  .xo-section--{{ section.id }} .bfaq__list {
    display: flex;
    flex-direction: column;
    max-width: 750px;
    margin: 0 auto;
  }

  .xo-section--{{ section.id }} .bfaq__item {
    border-bottom: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 12%, transparent);
  }

  .xo-section--{{ section.id }} .bfaq__item:first-child {
    border-top: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 12%, transparent);
  }

  .xo-section--{{ section.id }} .bfaq__q {
    padding: 24px 0;
    font-weight: 600;
    font-size: calc(var(--font-body-scale, 1) * 1.7rem);
    color: rgba(var(--color-foreground));
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    list-style: none;
    transition: color 0.2s var(--out-soft, ease);
    min-height: 44px;
  }

  .xo-section--{{ section.id }} .bfaq__q::-webkit-details-marker {
    display: none;
  }

  .xo-section--{{ section.id }} .bfaq__q:hover {
    color: rgba(var(--color-accent));
  }

  .xo-section--{{ section.id }} .bfaq__q:focus-visible {
    outline: 2px solid rgba(var(--color-accent));
    outline-offset: 2px;
  }

  .xo-section--{{ section.id }} .bfaq__icon {
    width: 24px;
    height: 24px;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 55%, transparent);
    transition: transform 0.3s var(--out-soft, ease);
    flex-shrink: 0;
  }

  .xo-section--{{ section.id }} .bfaq__item[open] .bfaq__icon {
    transform: rotate(180deg);
    color: rgba(var(--color-accent));
  }

  .xo-section--{{ section.id }} .bfaq__a {
    padding: 0 0 28px 0;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 70%, transparent);
    font-size: calc(var(--font-body-scale, 1) * 1.6rem);
    line-height: 1.75;
  }

  .xo-section--{{ section.id }} .bfaq__a-inner {
    border-left: 2px solid rgba(var(--color-accent));
    padding-left: 16px;
  }

  @media (prefers-reduced-motion: reduce) {
    .xo-section--{{ section.id }} .bfaq__q,
    .xo-section--{{ section.id }} .bfaq__icon {
      transition: none;
    }
  }
{%- endstyle -%}

<section {% render 'section-attr' %}>
  <xo-container>
    <h2 class="bfaq__title">{{ section.settings.title }}</h2>
    <div class="bfaq__list">
      {% for block in section.blocks %}
        <details class="bfaq__item" {{ block.shopify_attributes }}>
          <summary class="bfaq__q">
            {{ block.settings.question }}
            <span class="bfaq__icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
            </span>
          </summary>
          <div class="bfaq__a"><div class="bfaq__a-inner">{{ block.settings.answer }}</div></div>
        </details>
      {% endfor %}
    </div>
  </xo-container>
</section>

{% schema %}
{
  "name": "Beginners FAQ",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "default" },
    { "type": "text", "id": "title", "label": "Heading", "default": "Frequently Asked Questions" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding top", "default": 80 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding bottom", "default": 80 }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ",
      "settings": [
        { "type": "text", "id": "question", "label": "Question" },
        { "type": "textarea", "id": "answer", "label": "Answer" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Beginners FAQ",
      "blocks": [
        { "type": "faq", "settings": { "question": "How fast will I feel it?", "answer": "Some items (Caffeine + Theanine) are felt same-day; others (Lion's Mane, Bacopa) build with consistent use over 2–4 weeks." } },
        { "type": "faq", "settings": { "question": "Capsules vs. powder — what's better for beginners?", "answer": "Capsules are simpler and consistent; powders allow fine-tuning. Most beginners start with capsules." } }
      ]
    }
  ]
}
{% endschema %}
