{%- assign bgp_prod = section.settings.product -%}

{%- style -%}
  .xo-section--{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .xo-section--{{ section.id }} .bgp-inner {
    max-width: 800px;
    margin: 0 auto;
  }

  .xo-section--{{ section.id }} .bgp-card {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 40px;
    align-items: center;
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 8%, transparent);
    border-radius: var(--general-radius-3, 2rem);
    padding: 32px;
  }

  .xo-section--{{ section.id }} .bgp-img {
    width: 100%;
    height: auto;
    border-radius: var(--general-radius-1, 1rem);
    object-fit: contain;
  }

  .xo-section--{{ section.id }} .bgp-label {
    display: inline-block;
    font-size: clamp(0.7rem, 1vw, 0.75rem);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.8px;
    color: rgba(var(--color-foreground));
    background: color-mix(in srgb, rgba(var(--color-accent)) 12%, transparent);
    padding: 4px 12px;
    border-radius: var(--button-radius);
    margin-bottom: 12px;
  }

  .xo-section--{{ section.id }} .bgp-title {
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    font-weight: 600;
    color: rgba(var(--color-foreground));
    margin: 0 0 10px;
    letter-spacing: -0.02em;
  }

  .xo-section--{{ section.id }} .bgp-desc {
    font-size: clamp(0.9375rem, 1.2vw, 1.0625rem);
    line-height: 1.7;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 55%, transparent);
    margin: 0 0 16px;
  }

  .xo-section--{{ section.id }} .bgp-price {
    font-size: 1.25rem;
    font-weight: 600;
    color: rgba(var(--color-foreground));
    margin-bottom: 16px;
  }

  .xo-section--{{ section.id }} .bgp-price-compare {
    color: color-mix(in srgb, rgba(var(--color-foreground)) 55%, transparent);
    font-weight: 400;
    margin-right: 8px;
  }

  .xo-section--{{ section.id }} .bgp-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 0.75rem 2rem;
    font-size: calc(var(--font-body-scale, 1) * 1.5rem);
    font-weight: 600;
    color: rgba(var(--color-foreground));
    background: rgba(var(--color-accent));
    border: none;
    border-radius: var(--button-radius);
    cursor: pointer;
    transition: opacity 0.3s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .bgp-btn:hover:not(:disabled) {
    opacity: 0.85;
  }

  .xo-section--{{ section.id }} .bgp-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .xo-section--{{ section.id }} .bgp-btn:focus-visible {
    outline: 2px solid rgba(var(--color-accent));
    outline-offset: 2px;
  }

  .xo-section--{{ section.id }} .bgp-link {
    display: inline-block;
    margin-top: 10px;
    font-size: calc(var(--font-body-scale, 1) * 1.4rem);
    font-weight: 600;
    color: rgba(var(--color-foreground));
    text-decoration: none;
    transition: opacity 0.3s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .bgp-link:hover {
    text-decoration: underline;
  }

  @media (max-width: 768px) {
    .xo-section--{{ section.id }} .bgp-card {
      grid-template-columns: 1fr;
      gap: 24px;
      padding: 24px;
      text-align: center;
    }

    .xo-section--{{ section.id }} .bgp-img {
      max-width: 240px;
      margin: 0 auto;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .xo-section--{{ section.id }} .bgp-btn,
    .xo-section--{{ section.id }} .bgp-link {
      transition: none;
    }
  }
{%- endstyle -%}

{% if bgp_prod != blank %}
  <section {% render 'section-attr' %}>
    <xo-container>
      <div class="bgp-inner">
        <div class="bgp-card">
          {% if bgp_prod.featured_image %}
            <div class="bgp-img-col">
              <img
                src="{{ bgp_prod.featured_image | image_url: width: 500 }}"
                srcset="{{ bgp_prod.featured_image | image_url: width: 250 }} 250w, {{ bgp_prod.featured_image | image_url: width: 500 }} 500w, {{ bgp_prod.featured_image | image_url: width: 750 }} 750w"
                sizes="(max-width: 768px) 80vw, 280px"
                alt="{{ bgp_prod.featured_image.alt | default: bgp_prod.title | escape }}"
                width="500"
                height="{{ 500 | divided_by: bgp_prod.featured_image.aspect_ratio | round }}"
                loading="lazy"
                decoding="async"
                class="bgp-img"
              >
            </div>
          {% endif %}
          <div class="bgp-body">
            {% if section.settings.label != blank %}
              <span class="bgp-label">{{ section.settings.label }}</span>
            {% endif %}
            <h2 class="bgp-title">{{ bgp_prod.title }}</h2>
            {% if section.settings.description != blank %}
              <p class="bgp-desc">{{ section.settings.description }}</p>
            {% endif %}
            <div class="bgp-price">
              {%- if bgp_prod.compare_at_price > bgp_prod.price -%}
                <s class="bgp-price-compare">{{ bgp_prod.compare_at_price | money }}</s>
              {%- endif -%}
              {{ bgp_prod.price | money }}
            </div>
            <xo-cart-add {% unless bgp_prod.available %}xo-disabled{% endunless %}>
              <button type="button" class="bgp-btn" {% unless bgp_prod.available %}disabled{% endunless %} aria-label="Add {{ bgp_prod.title | escape }} to cart">
                {%- if bgp_prod.available -%}Add to Cart{%- else -%}Sold Out{%- endif -%}
              </button>
              <input type="hidden" name="id" value="{{ bgp_prod.selected_or_first_available_variant.id }}">
            </xo-cart-add>
            <a href="{{ bgp_prod.url }}" class="bgp-link">View full details &rarr;</a>
          </div>
        </div>
      </div>
    </xo-container>
  </section>
{% endif %}

{% schema %}
{
  "name": "Editor's Pick",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "default" },
    { "type": "text", "id": "label", "label": "Label", "default": "Editor's Pick" },
    { "type": "textarea", "id": "description", "label": "Description", "default": "Our most popular starter bundle — everything a first-timer needs in one click." },
    { "type": "product", "id": "product", "label": "Product" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding top", "default": 64 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding bottom", "default": 64 }
  ],
  "presets": [{ "name": "Editor's Pick" }]
}
{% endschema %}
