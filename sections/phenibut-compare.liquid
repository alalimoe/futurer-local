{% comment %}
  Compare — XO theme design system
  - Native <table>, ItemList JSON-LD, reduced-motion
{% endcomment %}

{%- comment -%} ── JSON-LD: ItemList (alternatives) ── {%- endcomment -%}
{% if section.blocks.size > 0 %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": {{ section.settings.heading | json }},
  "numberOfItems": {{ section.blocks.size }},
  "itemListElement": [
    {%- for block in section.blocks -%}
      {%- if block.type == 'alt_row' -%}
        {
          "@type": "ListItem",
          "position": {{ forloop.index }},
          "name": {{ block.settings.name | json }},
          "description": {{ block.settings.mechanism | json }}
        }{%- unless forloop.last -%},{%- endunless -%}
      {%- endif -%}
    {%- endfor -%}
  ]
}
</script>
{% endif %}

{%- style -%}
  .xo-section--{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .xo-section--{{ section.id }} .phb-compare__title {
    font-size: clamp(22px, 4.2vw, 36px);
    line-height: 1.2;
    color: rgba(var(--color-foreground));
    margin: 0;
    font-weight: 600;
  }

  .xo-section--{{ section.id }} .phb-compare__intro {
    color: color-mix(in srgb, rgba(var(--color-foreground)) 75%, transparent);
    line-height: 1.6;
  }

  .xo-section--{{ section.id }} .phb-compare__table-wrap {
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
    border-radius: var(--general-radius-1, 1rem);
    overflow: hidden;
    margin-top: 16px;
  }

  .xo-section--{{ section.id }} .phb-compare__table {
    width: 100%;
    border-collapse: collapse;
  }

  .xo-section--{{ section.id }} .phb-compare__table thead {
    background: rgba(var(--color-background-2));
  }

  .xo-section--{{ section.id }} .phb-compare__table th {
    text-align: left;
    padding: 10px 12px;
    font-weight: 600;
    color: rgba(var(--color-foreground));
    font-size: 14px;
  }

  .xo-section--{{ section.id }} .phb-compare__table td {
    padding: 12px;
    color: rgba(var(--color-foreground));
    font-size: 15px;
    line-height: 1.6;
    border-top: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
  }

  .xo-section--{{ section.id }} .phb-compare__table td p {
    margin: 0;
  }

  .xo-section--{{ section.id }} :focus-visible {
    outline: 2px solid rgba(var(--color-accent));
    outline-offset: 2px;
  }

  @media (max-width: 768px) {
    .xo-section--{{ section.id }} .phb-compare__table thead {
      display: none;
    }

    .xo-section--{{ section.id }} .phb-compare__table tr {
      display: block;
      padding: 12px;
      border-top: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
    }

    .xo-section--{{ section.id }} .phb-compare__table tbody tr:first-child {
      border-top: none;
    }

    .xo-section--{{ section.id }} .phb-compare__table td {
      display: block;
      padding: 4px 0;
      border-top: none;
    }

    .xo-section--{{ section.id }} .phb-compare__table td::before {
      content: attr(data-label) ": ";
      font-weight: 600;
      color: rgba(var(--color-foreground));
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .xo-section--{{ section.id }} *,
    .xo-section--{{ section.id }} *::before,
    .xo-section--{{ section.id }} *::after {
      animation-duration: 0.01ms !important;
      transition-duration: 0.01ms !important;
    }
  }
{%- endstyle -%}

<section {% render 'section-attr' %} aria-labelledby="phb-compare-title-{{ section.id }}">
  <xo-container>
    <h2 id="phb-compare-title-{{ section.id }}" class="phb-compare__title">{{ section.settings.heading | escape }}</h2>
    {% if section.settings.intro != blank %}
      <div class="phb-compare__intro">{{ section.settings.intro }}</div>
    {% endif %}

    <div class="phb-compare__table-wrap">
      <table class="phb-compare__table" aria-label="Phenibut vs alternatives">
        <thead>
          <tr>
            <th scope="col">Option</th>
            <th scope="col">Mechanism</th>
            <th scope="col">Best For</th>
            <th scope="col">Onset</th>
            <th scope="col">Notes</th>
          </tr>
        </thead>
        <tbody>
          {% for block in section.blocks %}
            {% if block.type == 'alt_row' %}
              <tr {{ block.shopify_attributes }}>
                <td data-label="Option"><strong>{{ block.settings.name | escape }}</strong></td>
                <td data-label="Mechanism">{{ block.settings.mechanism | escape }}</td>
                <td data-label="Best For">{{ block.settings.best_for | escape }}</td>
                <td data-label="Onset">{{ block.settings.onset | escape }}</td>
                <td data-label="Notes">{{ block.settings.notes }}</td>
              </tr>
            {% endif %}
          {% endfor %}
        </tbody>
      </table>
    </div>
  </xo-container>
</section>

{% schema %}
{
  "name": "Compare",
  "tag": "section",
  "class": "section-phenibut-compare",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "default" },
    { "type": "text", "id": "anchor_id", "label": "Anchor ID", "default": "alternatives" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Phenibut vs Alternatives" },
    { "type": "richtext", "id": "intro", "label": "Intro", "default": "<p>How Phenibut compares to gentler options you might try first.</p>" },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding top", "default": 40 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding bottom", "default": 40 }
  ],
  "blocks": [
    { "type": "alt_row", "name": "Alternative row", "settings": [
      { "type": "text", "id": "name", "label": "Name", "default": "L‑Theanine" },
      { "type": "text", "id": "mechanism", "label": "Mechanism", "default": "Glutamate modulation; alpha waves" },
      { "type": "text", "id": "best_for", "label": "Best for", "default": "Smooth focus; daytime calm" },
      { "type": "text", "id": "onset", "label": "Onset", "default": "30–60 min" },
      { "type": "richtext", "id": "notes", "label": "Notes", "default": "<p>Well‑tolerated; pairs with caffeine.</p>" }
    ] },
    { "type": "@app" }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Compare",
      "blocks": [
        { "type": "alt_row", "settings": { "name": "GABA", "mechanism": "Peripheral GABA; limited BBB crossing", "best_for": "Very mild relaxation", "onset": "30–60 min", "notes": "<p>Gentle; effects can be subtle.</p>" } },
        { "type": "alt_row", "settings": { "name": "L‑Theanine", "mechanism": "Glutamate modulation; alpha waves", "best_for": "Calm focus", "onset": "30–60 min", "notes": "<p>Pairs with caffeine for balance.</p>" } },
        { "type": "alt_row", "settings": { "name": "Ashwagandha", "mechanism": "Adaptogen; cortisol modulation", "best_for": "Stress resilience", "onset": "Days–weeks", "notes": "<p>Daily adaptogen; cumulative effect.</p>" } }
      ]
    }
  ]
}
{% endschema %}
