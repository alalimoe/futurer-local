{% liquid
  assign blog = section.settings.blog
  assign heading = section.settings.heading
  assign button = section.settings
  assign column_dt = section.settings.column_dt
  assign blog_to_show = section.settings.blog_to_show
  assign image_default = 'blog-apparel-1'
  assign title_default = 'blogs.article_placeholder.title' | t
  assign author_default = 'blogs.article_placeholder.author' | t
  assign date_default = 'blogs.article_placeholder.date' | t
  assign description_default = 'blogs.article_placeholder.description' | t
%}

<div class="nc-wrapper section-{{ section.id }}">
  <div class="nc-container">
    
    <header class="nc-header">
      <div class="nc-brand-badge">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M4 22h14a2 2 0 0 0 2-2V7.5L14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
        Journals & Guides
      </div>
      <h2 class="nc-title">{{ heading }}</h2>
      
      {% if button.button_text != blank %}
        <div class="nc-header-action">
          <a href="{{ button.button_link }}" class="btn btn--secondary">
            {{ button.button_text }}
          </a>
        </div>
      {% endif %}
    </header>

    {% if blog != blank and blog.articles.size > 0 %}
      <div class="nc-blog-grid" style="--dt-cols: {{ column_dt }};">
        {% for article in blog.articles limit: blog_to_show %}
          <a href="{{ article.url }}" class="nc-step-card nc-blog-card">
            
            {% if section.settings.show_image %}
              <div class="nc-blog-image-wrap" style="aspect-ratio: {% if section.settings.aspect_ratio == 'auto' %}16/9{% else %}{{ section.settings.aspect_ratio }}{% endif %};">
                {% if article.image %}
                  <img src="{{ article.image | image_url: width: 600 }}" alt="{{ article.image.alt | escape }}" loading="lazy" width="600" height="{{ 600 | divided_by: article.image.aspect_ratio | round }}">
                {% else %}
                  {{ image_default | placeholder_svg_tag: 'placeholder-svg' }}
                {% endif %}
              </div>
            {% endif %}
            
            <div class="nc-blog-content">
              <div class="nc-blog-meta">
                {% if section.settings.show_tag and article.tags.size > 0 %}
                  <span class="nc-meta-pill">{{ article.tags.first }}</span>
                {% elsif section.settings.show_author %}
                  <span class="nc-meta-pill">{{ article.author }}</span>
                {% endif %}
                
                {% if section.settings.show_date %}
                  <span class="nc-meta-text">{{ article.published_at | date: "%b %d, %Y" }}</span>
                {% endif %}
              </div>
              
              <h3 class="nc-blog-title">{{ article.title }}</h3>
              
              {% if section.settings.show_description %}
                <p class="nc-blog-excerpt">
                  {% if article.excerpt.size > 0 %}
                    {{ article.excerpt | strip_html | truncatewords: 20 }}
                  {% else %}
                    {{ article.content | strip_html | truncatewords: 20 }}
                  {% endif %}
                </p>
              {% endif %}
            </div>
            
          </a>
        {% endfor %}
      </div>
    {% else %}
      <div class="nc-blog-grid" style="--dt-cols: {{ column_dt }};">
        {% for i in (1..3) %}
          <div class="nc-step-card nc-blog-card">
            <div class="nc-blog-image-wrap" style="aspect-ratio: 16/9;">
              {{ image_default | placeholder_svg_tag: 'placeholder-svg' }}
            </div>
            <div class="nc-blog-content">
              <div class="nc-blog-meta">
                <span class="nc-meta-pill">{{ author_default }}</span>
                <span class="nc-meta-text">{{ date_default }}</span>
              </div>
              <h3 class="nc-blog-title">{{ title_default }}</h3>
              <p class="nc-blog-excerpt">{{ description_default }}</p>
            </div>
          </div>
        {% endfor %}
      </div>
    {% endif %}

  </div>
</div>

<style>
  .section-{{ section.id }} {
    --nc-bg: {{ section.settings.bg_color | default: 'var(--color-surface-primary)' }};
    --nc-card: {{ section.settings.card_bg | default: 'var(--color-surface-secondary)' }};
    --nc-accent: {{ section.settings.accent_color | default: '#fbbf24' }};
    --nc-text: {{ section.settings.text_color | default: 'var(--color-text-primary)' }};
    --nc-border: var(--color-border-default);
    --nc-border-hover: var(--color-border-default);
    --nc-muted: var(--color-text-secondary);
    --nc-font: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    --nc-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
    --nc-radius: 12px;
  }

  .nc-wrapper {
    background-color: var(--nc-bg);
    color: var(--nc-text);
    padding: {{ section.settings.padding_top_mobile }}px var(--page-gutter) {{ section.settings.padding_bottom_mobile }}px;
    font-family: var(--nc-font);
    line-height: 1.5;
  }
  
  @media (min-width: 768px) {
    .nc-wrapper {
      padding: {{ section.settings.padding_top_desktop }}px var(--page-gutter) {{ section.settings.padding_bottom_desktop }}px;
    }
  }

  .nc-container {
    max-width: var(--container-width-max);
    margin: 0 auto;
  }

  /* HEADER */
  .nc-header {
    text-align: center;
    max-width: 600px;
    margin: 0 auto 50px;
  }
  .nc-brand-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--color-warning-bg); 
    color: var(--color-warning-text); 
    padding: 4px 12px;
    border-radius: 99px;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 16px;
  }
  .nc-title {
    font-size: 32px;
    font-weight: 800;
    color: var(--nc-text);
    margin: 0 0 20px;
    letter-spacing: -0.5px;
  }
  /* GRID */
  .nc-blog-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }
  @media (min-width: 768px) {
    .nc-blog-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1024px) {
    .nc-blog-grid {
      grid-template-columns: repeat(var(--dt-cols), 1fr);
    }
  }

  /* CARDS */
  .nc-blog-card {
    background: var(--color-surface-primary);
    border: 1px solid var(--nc-border);
    border-radius: var(--nc-radius);
    overflow: hidden;
    transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    padding: 0; /* Override step-card padding */
  }
  .nc-blog-card:hover {
    border-color: var(--nc-border-hover);
    transform: translateY(-2px);
    box-shadow: var(--nc-shadow);
  }

  .nc-blog-image-wrap {
    width: 100%;
    background: var(--color-surface-secondary);
    overflow: hidden;
    border-bottom: 1px solid var(--nc-border);
  }
  .nc-blog-image-wrap img, 
  .nc-blog-image-wrap svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }
  .nc-blog-card:hover .nc-blog-image-wrap img {
    transform: scale(1.03);
  }

  .nc-blog-content {
    padding: 24px;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .nc-blog-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 12px;
  }
  .nc-meta-pill {
    background: var(--color-surface-secondary);
    color: var(--nc-text);
    font-size: 10px;
    font-weight: 700;
    padding: 4px 10px;
    border-radius: 99px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .nc-meta-text {
    font-size: 12px;
    color: var(--nc-muted);
    font-weight: 500;
  }

  .nc-blog-title {
    font-size: 18px;
    font-weight: 700;
    color: var(--nc-text);
    margin: 0 0 8px 0;
    line-height: 1.3;
  }
  
  .nc-blog-excerpt {
    font-size: 14px;
    color: var(--nc-muted);
    margin: 0;
    line-height: 1.5;
    flex-grow: 1;
  }
</style>

{% schema %}
{
  "name": "t:sections.blog_list.name",
  "disabled_on": {
    "groups": [
      "header",
      "footer",
      "custom.overlay",
      "custom.popups"
    ]
  },
  "settings": [
    {
      "type": "header",
      "content": "Theme Colors (Calculator Sync)"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card Background",
      "default": "#f9f9f9"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Brand Accent (Gold)",
      "default": "#fbbf24"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Main Text",
      "default": "#111827"
    },
    {
      "type": "header",
      "content": "t:sections.blog_list.settings.header_text"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.blog_list.settings.heading",
      "default": "Our journals"
    },
    {
      "type": "header",
      "content": "t:sections.blog_list.settings.header_button"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "View All Articles"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link",
      "default": "/"
    },
    {
      "type": "header",
      "content": "t:sections.blog_list.settings.header_blog"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "t:sections.blog_list.settings.blog"
    },
    {
      "type": "checkbox",
      "id": "show_image",
      "label": "t:sections.blog_list.settings.show_image",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_date",
      "label": "t:sections.blog_list.settings.show_date",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_author",
      "label": "t:sections.blog_list.settings.show_author",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "t:sections.blog_list.settings.show_description",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_tag",
      "label": "t:sections.blog_list.settings.show_tag",
      "default": true
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "Image Aspect ratio",
      "default": "16/9",
      "options": [
        { "value": "auto", "label": "Auto" },
        { "value": "2/3", "label": "2:3" },
        { "value": "3/4", "label": "3:4" },
        { "value": "3/2", "label": "3:2" },
        { "value": "1", "label": "1:1" },
        { "value": "4/3", "label": "4:3" },
        { "value": "16/9", "label": "16:9" },
        { "value": "21/9", "label": "21:9" }
      ]
    },
    {
      "type": "header",
      "content": "t:sections.blog_list.settings.header_layout"
    },
    {
      "type": "range",
      "id": "column_dt",
      "min": 2,
      "max": 4,
      "step": 1,
      "label": "t:sections.blog_list.settings.column_dt",
      "default": 3
    },
    {
      "type": "range",
      "id": "blog_to_show",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 3,
      "label": "t:sections.blog_list.settings.blog_to_show"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "number",
      "id": "padding_top_desktop",
      "label": "Padding top desktop",
      "default": 60
    },
    {
      "type": "number",
      "id": "padding_bottom_desktop",
      "label": "Padding bottom desktop",
      "default": 60
    },
    {
      "type": "number",
      "id": "padding_top_mobile",
      "label": "Padding top mobile",
      "default": 40
    },
    {
      "type": "number",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom mobile",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Nootropix Blog List",
      "settings": {}
    }
  ]
}
{% endschema %}