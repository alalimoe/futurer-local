            </div>
          {% endif %}
          <div class="fg-product-footer">
            {% if product_lion != blank %}
              <div class="fg-product-ctas">
                <a class="fg-btn fg-btn--ghost" href="{{ product_lion.url }}" aria-label="View {{ product_lion.title }}">View Product</a>
                <form method="post" action="{{ routes.cart_add_url }}">
                  <input type="hidden" name="id" value="{{ product_lion.selected_or_first_available_variant.id }}">
                  <button type="submit" class="fg-btn fg-btn--primary">Add to Cart</button>
                </form>
              </div>
              <div class="fg-product-meta">From {{ product_lion.price | money }}</div>
            {% else %}
