  list-style: none;
  min-height: var(--touch-min, 44px);
}
#focus-guide-{{ sid }} .fg-faq-q::-webkit-details-marker { display: none; }
#focus-guide-{{ sid }} .fg-faq-q::marker { content: ""; }

#focus-guide-{{ sid }} .fg-faq-chevron {
  flex-shrink: 0;
  width: 20px;
  height: 20px;
  position: relative;
  transition: transform 0.35s cubic-bezier(0.25, 0.8, 0.25, 1);
}
#focus-guide-{{ sid }} .fg-faq-chevron::before,
#focus-guide-{{ sid }} .fg-faq-chevron::after {
  content: "";
  position: absolute;
  top: 50%;
  width: 10px;
  height: 2px;
  background: var(--fg-muted);
  border-radius: 1px;
  transition: transform 0.35s cubic-bezier(0.25, 0.8, 0.25, 1);
}
#focus-guide-{{ sid }} .fg-faq-chevron::before {
  left: 1px;
  transform: translateY(-50%) rotate(45deg);
}
#focus-guide-{{ sid }} .fg-faq-chevron::after {
  right: 1px;
  transform: translateY(-50%) rotate(-45deg);
}
#focus-guide-{{ sid }} .fg-faq[open] .fg-faq-chevron::before {
  transform: translateY(-50%) rotate(-45deg);
}
#focus-guide-{{ sid }} .fg-faq[open] .fg-faq-chevron::after {
  transform: translateY(-50%) rotate(45deg);
}
