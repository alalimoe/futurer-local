                <a class="fg-btn fg-btn--ghost" href="/products/lion-mane-mushroom-capsules">View Product</a>
              </div>
            {% endif %}
          </div>
        </article>
      </div>
    </section>

    {%- comment -%} ── BUNDLE CTA + DOSING TABLE ── {%- endcomment -%}
