          {% endif %}
          <div class="fg-product-footer">
            {% if product_choline != blank %}
              <div class="fg-product-ctas">
                <a class="fg-btn fg-btn--ghost" href="{{ product_choline.url }}" aria-label="View {{ product_choline.title }}">View Product</a>
                <form method="post" action="{{ routes.cart_add_url }}">
                  <input type="hidden" name="id" value="{{ product_choline.selected_or_first_available_variant.id }}">
                  <button type="submit" class="fg-btn fg-btn--primary">Add to Cart</button>
                </form>
              </div>
              <div class="fg-product-meta">From {{ product_choline.price | money }}</div>
            {% else %}
              <div class="fg-product-ctas">
                <a class="fg-btn fg-btn--ghost" href="/products/alpha-gpc">View Product</a>
              </div>
            {% endif %}
          </div>
        </article>

        {%- comment -%} Card 3: Lion's Mane {%- endcomment -%}
