{% comment %}
  =============================================
  Section: Focus & Attention Guide
  File: sections/focus-attention-guide.liquid
  Purpose: Education-first LP — CRO / SEO / UX / A11y
  Theme: Futurer 2.x (OS 2.0) — cascades from global tokens
  =============================================
{% endcomment %}

{%- assign s = section.settings -%}
{%- assign sid = section.id -%}

{%- comment -%} ── Product resolution (picker → handle → known fallback) ── {%- endcomment -%}
{%- assign product_theanine = s.theanine_product -%}
{%- if product_theanine == blank and s.theanine_handle != blank -%}
  {%- assign product_theanine = all_products[s.theanine_handle] -%}
{%- endif -%}
{%- if product_theanine == blank -%}
  {%- assign product_theanine = all_products['caffeine-l-theanine-capsules'] -%}
{%- endif -%}

{%- assign product_choline = s.choline_product -%}
{%- if product_choline == blank and s.choline_handle != blank -%}
  {%- assign product_choline = all_products[s.choline_handle] -%}
{%- endif -%}
{%- if product_choline == blank -%}
  {%- assign product_choline = all_products['alpha-gpc'] -%}
{%- endif -%}

{%- assign product_lion = s.lion_product -%}
{%- if product_lion == blank and s.lion_handle != blank -%}
  {%- assign product_lion = all_products[s.lion_handle] -%}
{%- endif -%}
{%- if product_lion == blank -%}
  {%- assign product_lion = all_products['lion-mane-mushroom-capsules'] -%}
{%- endif -%}

{%- assign bundle = s.stack_product -%}
{%- if bundle == blank and s.stack_product_handle != blank -%}
  {%- assign bundle = all_products[s.stack_product_handle] -%}
{%- endif -%}
{%- if bundle == blank -%}
  {%- assign bundle = all_products['enhanced-focus-stack'] -%}
{%- endif -%}

{%- comment -%} ── JSON-LD: Article ── {%- endcomment -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": {{ s.hero_title | default: "Sharper Focus, Naturally." | json }},
  "description": {{ s.hero_subtitle | strip_html | truncate: 160 | json }},
  "author": { "@type": "Organization", "name": "Nootropix" },
  "publisher": {
    "@type": "Organization",
    "name": "Nootropix",
    "url": {{ shop.url | json }},
    "logo": {
      "@type": "ImageObject",
      "url": {{ shop.url | append: '/cdn/shop/files/nootropix-logo.png' | json }}
    }
  },
  "datePublished": {{ s.date_published | default: "2025-06-01" | json }},
  "dateModified": {{ page.updated_at | date: "%Y-%m-%d" | default: "2025-06-01" | json }},
  "mainEntityOfPage": {{ canonical_url | json }},
  "about": ["Focus", "Attention", "Nootropics", "L-Theanine", "Alpha-GPC", "Lion's Mane"]
}
</script>

{%- comment -%} ── JSON-LD: ItemList (3 stack products) ── {%- endcomment -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Focus & Attention Stack",
  "numberOfItems": 3,
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Caffeine + L-Theanine", "description": "Calm, clean energy — pairing L-Theanine with caffeine for focused alertness." },
    { "@type": "ListItem", "position": 2, "name": "Alpha-GPC", "description": "A choline donor that supports acetylcholine for attention, learning, and memory." },
    { "@type": "ListItem", "position": 3, "name": "Lion's Mane Mushroom", "description": "Daily staple for long-term brain support; researched for NGF and memory." }
  ]
}
</script>

{%- comment -%} ── JSON-LD: FAQPage (dynamic from blocks) ── {%- endcomment -%}
{%- assign faq_blocks = section.blocks | where: 'type', 'faq' -%}
{% if faq_blocks.size > 0 %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {%- for block in faq_blocks -%}
        {
          "@type": "Question",
          "name": {{ block.settings.q | json }},
          "acceptedAnswer": { "@type": "Answer", "text": {{ block.settings.a | json }} }
        }{%- unless forloop.last -%},{%- endunless -%}
      {%- endfor -%}
    ]
  }
  </script>
{% endif %}

<section id="focus-guide-{{ sid }}" class="fg-section" aria-labelledby="fg-title-{{ sid }}">
  <div class="fg-inner">

    {%- comment -%} ── HERO ── {%- endcomment -%}
    <header class="fg-hero">
      <div class="fg-hero-grid">
        <div class="fg-hero-content">
          <h1 id="fg-title-{{ sid }}" class="fg-hero-title">{{ s.hero_title | default: "Sharper Focus, Naturally." }}</h1>
          <p class="fg-hero-sub">{{ s.hero_subtitle | default: "Understand the science behind distraction and build a simple, effective Focus Stack that helps you feel calm, clear, and in control." }}</p>
          <div class="fg-hero-actions">
            <a href="#focus-stack" class="fg-btn fg-btn--primary" aria-label="Jump to Focus Stack">Start Your Focus Stack</a>
            <span class="fg-hero-note">No hype. Just what works for your brain.</span>
          </div>
        </div>
        <div class="fg-hero-aside">
          {% if s.hero_image != blank %}
            <div class="fg-hero-img-wrap">
              <img src="{{ s.hero_image | image_url: width: 900 }}" alt="{{ s.hero_image.alt | default: 'Nootropix Focus Stack illustration' }}" loading="eager" fetchpriority="high" width="900" height="{{ 900 | divided_by: s.hero_image.aspect_ratio | round }}">
            </div>
          {% else %}
            <div class="fg-science-card">
              <span class="fg-chip">Science Snapshot</span>
              <p class="fg-science-text">Focus isn't "willpower." It's chemistry. Stress ramps cortisol; adenosine builds up and you feel heavy; low acetylcholine makes thoughts slippery. The right routine supports calmer, more consistent attention.</p>
              <ul class="fg-check-list">
                <li>L-Theanine may promote relaxed, alert alpha waves.</li>
                <li>Caffeine blocks adenosine to lift alertness.</li>
                <li>Choline donors (Alpha-GPC) support acetylcholine for focus & memory.</li>
                <li>Lion's Mane is researched for long-term brain support.</li>
              </ul>
            </div>
          {% endif %}
        </div>
      </div>
    </header>

    {%- comment -%} ── EDUCATION ── {%- endcomment -%}
    <div class="fg-edu-grid" aria-label="Education">
      <div class="fg-card">
        <span class="fg-kicker">Why focus feels hard</span>
        <h2 class="fg-heading">It's not laziness — it's load.</h2>
        <p class="fg-body-muted">When stress, sleep debt, and constant pings pile up, your brain leans toward distraction. That's normal. Instead of fighting your biology, support it: calm the noise, smooth your energy, and give your attention systems the raw materials they use every day.</p>
        <div class="fg-banner">
          <strong>Respect the basics:</strong> hydration, daylight, and consistent sleep timing. Nootropics work best in a solid routine.
        </div>
      </div>
      <div class="fg-card">
        <span class="fg-kicker">How this guide helps</span>
        <h3 class="fg-heading">A simple 3-part Focus Stack</h3>
        <p class="fg-body-muted">Short-term calm + clean energy, mid-term focus chemistry, long-term brain support.</p>
        <ul class="fg-check-list">
          <li><strong>Calm Energy:</strong> L-Theanine + Caffeine for smooth alertness without the jitters.</li>
          <li><strong>Focus Chemistry:</strong> Alpha-GPC to support acetylcholine — the "pay attention" neurotransmitter.</li>
          <li><strong>Long-Term Support:</strong> Lion's Mane, featured in research on nerve growth factor (NGF) and memory.</li>
        </ul>
      </div>
    </div>

    {%- comment -%} ── 3-PRODUCT STACK GRID ── {%- endcomment -%}
