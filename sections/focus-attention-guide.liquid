          <span class="fg-chip">Calm Energy</span>
          <h3 class="fg-product-title">L-Theanine + Caffeine</h3>
          <p class="fg-product-desc">Pairing L-Theanine with Caffeine can promote focused alertness and smoother energy.</p>
          {% if product_theanine != blank and product_theanine.featured_image %}
            <div class="fg-product-img">
              <img src="{{ product_theanine.featured_image | image_url: width: 600 }}" alt="{{ product_theanine.title }}" loading="lazy" width="600" height="600">
            </div>
          {% endif %}
          <div class="fg-product-footer">
            {% if product_theanine != blank %}
              <div class="fg-product-ctas">
                <a class="fg-btn fg-btn--ghost" href="{{ product_theanine.url }}" aria-label="View {{ product_theanine.title }}">View Product</a>
                <form method="post" action="{{ routes.cart_add_url }}">
                  <input type="hidden" name="id" value="{{ product_theanine.selected_or_first_available_variant.id }}">
                  <button type="submit" class="fg-btn fg-btn--primary">Add to Cart</button>
                </form>
              </div>
              <div class="fg-product-meta">From {{ product_theanine.price | money }}</div>
            {% else %}
              <div class="fg-product-ctas">
                <a class="fg-btn fg-btn--ghost" href="/products/caffeine-l-theanine-capsules">View Product</a>
              </div>
            {% endif %}
          </div>
        </article>

        {%- comment -%} Card 2: Alpha-GPC {%- endcomment -%}
        <article class="fg-product-card">
          <span class="fg-chip">Focus Chemistry</span>
          <h3 class="fg-product-title">Alpha-GPC</h3>
          <p class="fg-product-desc">A choline donor that supports acetylcholine — key for attention, learning, and memory.</p>
