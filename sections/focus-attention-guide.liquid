{%- style -%}
/* ═══════════════════════════════════════════════════════
   FOCUS & ATTENTION GUIDE — Premium Design Tokens
   ═══════════════════════════════════════════════════════ */

#focus-guide-{{ sid }} {
  --section-max-width: {{ s.max_width | default: 1100 }}px;
  --fg-py: {{ s.padding_y | default: 56 }}px;
  --fg-accent: var(--color-accent-primary, #FBBF24);
  --fg-accent-hover: var(--color-accent-hover, #D97706);
  --fg-accent-dark: var(--color-accent-dark, #92400e);
  --fg-accent-glass: rgba(251, 191, 36, 0.08);
  --fg-accent-glass-strong: rgba(251, 191, 36, 0.14);
  --fg-text: var(--color-text-main, #111827);
  --fg-muted: var(--color-text-muted, #4b5563);
  --fg-bg: {{ s.background_color | default: '#ffffff' }};
  --fg-bg-alt: var(--color-bg-secondary, #f9fafb);
  --fg-radius: var(--radius-premium, 14px);
  --fg-transition: var(--transition-premium, all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1));
  --fg-shadow-rest: var(--shadow-sm, 0 2px 8px rgba(0, 0, 0, 0.04));
  --fg-shadow-hover: var(--shadow-md, 0 12px 30px rgba(0, 0, 0, 0.06));
  --fg-gold-glow: var(--shadow-gold-glow, 0 4px 14px rgba(251, 191, 36, 0.25));
  --fg-gold-glow-hover: var(--shadow-gold-glow-hover, 0 8px 24px rgba(251, 191, 36, 0.35));
  --fg-font: var(--font-body-family, sans-serif);
  --fg-font-heading: var(--font-heading-family, sans-serif);

  background: var(--fg-bg);
  color: var(--fg-text);
  font-family: var(--fg-font);
  line-height: 1.6;
  content-visibility: auto;
  contain-intrinsic-size: 1px 5000px;
}

/* ── Inner container ── */
#focus-guide-{{ sid }} .fg-inner {
  max-width: var(--section-max-width);
  margin: 0 auto;
  padding: var(--fg-py) var(--page-gutter);
  display: flex;
  flex-direction: column;
  gap: 40px;
}
@media (min-width: 990px) {
  #focus-guide-{{ sid }} .fg-inner { gap: 56px; }
}

/* ── Shared typography ── */
#focus-guide-{{ sid }} .fg-kicker {
  display: block;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  font-weight: 700;
  font-size: 12px;
  color: var(--fg-accent-dark);
  margin-bottom: 6px;
}
#focus-guide-{{ sid }} .fg-heading {
  font-family: var(--fg-font-heading);
  font-size: clamp(22px, 3vw, 34px);
  font-weight: 700;
  line-height: 1.2;
  color: var(--fg-text);
  margin: 0 0 10px;
}
#focus-guide-{{ sid }} .fg-body-muted {
  color: var(--fg-muted);
  line-height: 1.6;
  margin: 0 0 8px;
}

/* ── Cards (borderless elevation) ── */
#focus-guide-{{ sid }} .fg-card {
  background: var(--fg-bg);
  border: none;
  border-radius: var(--fg-radius);
  padding: 24px;
  box-shadow: var(--fg-shadow-rest);
  transition: var(--fg-transition);
}
#focus-guide-{{ sid }} .fg-card:hover {
