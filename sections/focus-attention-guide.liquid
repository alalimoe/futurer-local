#focus-guide-{{ sid }} .fg-final-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 24px;
}
@media (min-width: 900px) {
  #focus-guide-{{ sid }} .fg-final-grid { grid-template-columns: 1.2fr 0.8fr; align-items: center; }
}
#focus-guide-{{ sid }} .fg-legal {
