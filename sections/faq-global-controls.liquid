{%- style -%}
  .xo-section--{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .xo-section--{{ section.id }} .fgc__input {
    width: 100%;
    padding: 12px 16px;
    min-height: 44px;
    box-sizing: border-box;
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 12%, transparent);
    border-radius: var(--general-radius-1, 1rem);
    font-size: clamp(0.85rem, 1.3vw, 0.9375rem);
    background: rgba(var(--color-background));
    color: rgba(var(--color-foreground));
    transition: border-color 0.3s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .fgc__input:focus {
    outline: none;
    border-color: rgba(var(--color-accent));
  }

  .xo-section--{{ section.id }} .fgc__input:focus-visible {
    outline: 2px solid rgba(var(--color-accent));
    outline-offset: 2px;
  }

  .xo-section--{{ section.id }} .fgc__input::placeholder {
    opacity: 0.5;
  }

  .xo-section--{{ section.id }} .fgc__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 12px;
  }

  .xo-section--{{ section.id }} .fgc__chip {
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 12%, transparent);
    border-radius: var(--button-radius);
    padding: 8px 14px;
    min-height: 44px;
    box-sizing: border-box;
    background: rgba(var(--color-background));
    cursor: pointer;
    font-size: clamp(0.8rem, 1.2vw, 0.875rem);
    display: inline-flex;
    align-items: center;
    color: rgba(var(--color-foreground));
    transition: border-color 0.3s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .fgc__chip:hover {
    border-color: rgba(var(--color-accent));
  }

  .xo-section--{{ section.id }} .fgc__chip:focus-visible {
    outline: 2px solid rgba(var(--color-accent));
    outline-offset: 2px;
  }

  .xo-section--{{ section.id }} .fgc__chip--active {
    border-color: rgba(var(--color-accent));
    font-weight: 600;
    background: color-mix(in srgb, rgba(var(--color-accent)) 8%, transparent);
  }

  @media (prefers-reduced-motion: reduce) {
    .xo-section--{{ section.id }} .fgc__input,
    .xo-section--{{ section.id }} .fgc__chip {
      transition: none;
    }
  }
{%- endstyle -%}

<section {% render 'section-attr' %}>
  <xo-container>
    <h2 class="visually-hidden">Search FAQs</h2>
    <input type="search" class="fgc__input" data-faq-global-search placeholder="{{ section.settings.placeholder }}" aria-label="Search all FAQs">

    <div class="fgc__chips">
      <button class="fgc__chip fgc__chip--active" data-faq-chip="*">All</button>
      <button class="fgc__chip" data-faq-chip="Dubai Delivery">Dubai Delivery</button>
      <button class="fgc__chip" data-faq-chip="UAE-wide Delivery">UAE Delivery</button>
      <button class="fgc__chip" data-faq-chip="DHL Delivery">International Delivery</button>
      <button class="fgc__chip" data-faq-chip="tag:4-hour">Dubai 4-Hour</button>
      <button class="fgc__chip" data-faq-chip="tag:next day">Dubai Next-Day</button>
    </div>
  </xo-container>
</section>

<script>
(function(){
  var section = document.querySelector('.xo-section--{{ section.id }}');
  if (!section) return;

  var search = section.querySelector('[data-faq-global-search]');
  var chips = section.querySelectorAll('[data-faq-chip]');
  var items = document.querySelectorAll('[data-faq-item]');

  function activeChipKey(){
    var a = section.querySelector('.fgc__chip--active');
    return a ? a.getAttribute('data-faq-chip') : '*';
  }

  function matchesChip(el, key){
    if (key === '*') return true;
    if (!key.startsWith('tag:')) {
      var cat = (el.getAttribute('data-category') || '').toLowerCase();
      return cat.indexOf(key.toLowerCase()) !== -1;
    }
    var tag = key.replace('tag:','').toLowerCase();
    var tags = (el.getAttribute('data-tags') || '').toLowerCase();
    return tags.indexOf(tag) !== -1;
  }

  function matchesTerm(el, term){
    if (!term) return true;
    term = term.toLowerCase();
    var q = (el.querySelector('summary')?.textContent || '').toLowerCase();
    var a = (el.querySelector('.rte, [class*="answer"]')?.textContent || '').toLowerCase();
    var t = (el.getAttribute('data-tags') || '').toLowerCase();
    return q.indexOf(term) !== -1 || a.indexOf(term) !== -1 || t.indexOf(term) !== -1;
  }

  function applyFilters(){
    var term = search ? search.value.trim() : '';
    var key = activeChipKey();
    items.forEach(function(el){
      el.style.display = (matchesChip(el, key) && matchesTerm(el, term)) ? '' : 'none';
    });
  }

  if (search) search.addEventListener('input', applyFilters);
  chips.forEach(function(c){
    c.addEventListener('click', function(){
      chips.forEach(function(x){ x.classList.remove('fgc__chip--active'); });
      c.classList.add('fgc__chip--active');
      applyFilters();
    });
  });

  applyFilters();
})();
</script>

{% schema %}
{
  "name": "FAQ – Global Controls",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "default" },
    { "type": "text", "id": "placeholder", "label": "Search placeholder", "default": "Search all FAQs… e.g., 4-hour, next-day, DHL, COD" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding top", "default": 8 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding bottom", "default": 16 }
  ],
  "presets": [{ "name": "FAQ – Global Controls" }]
}
{% endschema %}
