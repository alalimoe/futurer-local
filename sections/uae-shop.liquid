{%- style -%}
  .xo-section--{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .xo-section--{{ section.id }} .uas-heading {
    font-family: var(--font-heading-family);
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    font-weight: 600;
    color: rgba(var(--color-foreground));
    margin: 0 0 12px;
    text-align: center;
    letter-spacing: -0.02em;
  }

  .xo-section--{{ section.id }} .uas-intro {
    font-size: 1rem;
    line-height: 1.7;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent);
    margin: 0 0 40px;
    text-align: center;
    max-width: 640px;
    margin-inline: auto;
  }

  .xo-section--{{ section.id }} .uas-cats {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
    margin-bottom: 48px;
  }

  .xo-section--{{ section.id }} .uas-cat {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 20px;
    background: rgba(var(--color-background-2));
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
    border-radius: var(--general-radius-3, 2rem);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.3s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .uas-cat:hover {
    border-color: rgba(var(--color-accent));
  }

  .xo-section--{{ section.id }} .uas-cat-img {
    width: 56px;
    height: 56px;
    border-radius: var(--general-radius-1, 1rem);
    object-fit: cover;
    flex-shrink: 0;
  }

  .xo-section--{{ section.id }} .uas-cat-body {
    flex: 1;
    min-width: 0;
  }

  .xo-section--{{ section.id }} .uas-cat-title {
    font-family: var(--font-heading-family);
    font-size: 1rem;
    font-weight: 600;
    color: rgba(var(--color-foreground));
    margin: 0 0 2px;
  }

  .xo-section--{{ section.id }} .uas-cat-tag {
    font-size: 0.8125rem;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent);
    margin: 0;
    line-height: 1.4;
  }

  .xo-section--{{ section.id }} .uas-cat-arrow {
    flex-shrink: 0;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent);
    transition: color 0.2s var(--out-soft, ease), transform 0.2s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .uas-cat:hover .uas-cat-arrow {
    color: rgba(var(--color-accent));
    transform: translateX(2px);
  }

  .xo-section--{{ section.id }} .uas-picks-heading {
    font-family: var(--font-heading-family);
    font-size: clamp(1.125rem, 2vw, 1.375rem);
    font-weight: 600;
    color: rgba(var(--color-foreground));
    margin: 0 0 20px;
    text-align: center;
  }

  .xo-section--{{ section.id }} .uas-picks {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }

  .xo-section--{{ section.id }} .uas-pick {
    text-align: center;
  }

  .xo-section--{{ section.id }} .uas-pick-link {
    display: block;
  }

  .xo-section--{{ section.id }} .uas-pick-img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: contain;
    border-radius: var(--general-radius-1, 1rem);
    background: rgba(var(--color-background-2));
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
    transition: border-color 0.3s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .uas-pick-img:hover {
    border-color: color-mix(in srgb, rgba(var(--color-foreground)) 20%, transparent);
  }

  .xo-section--{{ section.id }} .uas-pick-label {
    display: inline-block;
    margin-top: 8px;
    font-size: 0.75rem;
    font-weight: 600;
    background: rgba(var(--color-accent));
    color: rgba(var(--color-foreground));
    padding: 2px 8px;
    border-radius: var(--general-radius-xs, 0.6rem);
  }

  .xo-section--{{ section.id }} :focus-visible {
    outline: 2px solid rgba(var(--color-accent));
    outline-offset: 2px;
  }

  @media (max-width: 768px) {
    .xo-section--{{ section.id }} .uas-cats {
      grid-template-columns: 1fr;
    }

    .xo-section--{{ section.id }} .uas-picks {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .xo-section--{{ section.id }} *,
    .xo-section--{{ section.id }} *::before,
    .xo-section--{{ section.id }} *::after {
      animation-duration: 0.01ms !important;
      transition-duration: 0.01ms !important;
    }
  }
{%- endstyle -%}

{%- assign uas_categories = section.blocks | where: "type", "category" -%}
{%- assign uas_picks = section.blocks | where: "type", "pick" -%}

<section id="uae-shop" {% render 'section-attr' %}>
  <xo-container>
    {% if section.settings.heading != blank %}
      <h2 class="uas-heading">{{ section.settings.heading }}</h2>
    {% endif %}

    {% if section.settings.intro != blank %}
      <p class="uas-intro">{{ section.settings.intro }}</p>
    {% endif %}

    {% if uas_categories.size > 0 %}
      <div class="uas-cats">
        {% for block in uas_categories %}
          <a href="{{ block.settings.url | default: block.settings.collection.url | default: '#' }}" class="uas-cat" {{ block.shopify_attributes }}>
            {%- if block.settings.collection != blank and block.settings.collection.image != blank -%}
              <img src="{{ block.settings.collection.image | image_url: width: 400 }}" alt="{{ block.settings.title | escape }}" width="400" height="{{ 400 | divided_by: block.settings.collection.image.aspect_ratio | round }}" loading="lazy" decoding="async" class="uas-cat-img">
            {%- endif -%}
            <div class="uas-cat-body">
              <h3 class="uas-cat-title">{{ block.settings.title | default: block.settings.collection.title }}</h3>
              {% if block.settings.tagline != blank %}<p class="uas-cat-tag">{{ block.settings.tagline }}</p>{% endif %}
            </div>
            <span class="uas-cat-arrow"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg></span>
          </a>
        {% endfor %}
      </div>
    {% endif %}

    {% if uas_picks.size > 0 %}
      {% if section.settings.picks_heading != blank %}
        <h3 class="uas-picks-heading">{{ section.settings.picks_heading }}</h3>
      {% endif %}
      <div class="uas-picks">
        {% for block in uas_picks %}
          {%- assign pick_prod = block.settings.product -%}
          <div class="uas-pick" {{ block.shopify_attributes }}>
            {%- if pick_prod != blank and pick_prod.featured_image != blank -%}
              <a href="{{ pick_prod.url }}" class="uas-pick-link">
                <img src="{{ pick_prod.featured_image | image_url: width: 300 }}" alt="{{ pick_prod.title | escape }}" width="300" height="{{ 300 | divided_by: pick_prod.featured_image.aspect_ratio | round }}" loading="lazy" decoding="async" class="uas-pick-img">
              </a>
            {%- endif -%}
            {% if block.settings.label != blank %}
              <span class="uas-pick-label">{{ block.settings.label }}</span>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </xo-container>
</section>

{% schema %}
{
  "name": "UAE Shop",
  "tag": "section",
  "class": "section-uae-shop",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "default" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Buy Nootropics Online in the UAE" },
    { "type": "textarea", "id": "intro", "label": "Intro Text", "default": "Order from Nootropix with same-/next-day UAE delivery and express international shipping. Track every order from checkout to doorstep." },
    { "type": "header", "content": "Editor's Picks" },
    { "type": "text", "id": "picks_heading", "label": "Picks Heading", "default": "Editor's Picks" },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding top", "default": 80 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding bottom", "default": 80 }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category Card",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection" },
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "text", "id": "tagline", "label": "Tagline" },
        { "type": "url", "id": "url", "label": "Link" }
      ]
    },
    {
      "type": "pick",
      "name": "Editor's Pick",
      "settings": [
        { "type": "product", "id": "product", "label": "Product" },
        { "type": "text", "id": "label", "label": "Label (e.g. Smooth Alertness)" }
      ]
    },
    { "type": "@app" }
  ],
  "presets": [
    {
      "name": "UAE Shop",
      "blocks": [
        { "type": "category", "settings": { "title": "Focus & Energy", "tagline": "Clean energy and task focus." } },
        { "type": "category", "settings": { "title": "Memory & Learning", "tagline": "Learning, recall, clarity." } },
        { "type": "category", "settings": { "title": "Mood & Stress", "tagline": "Calm balance for busy days." } },
        { "type": "category", "settings": { "title": "Sleep & Recovery", "tagline": "Rest & digest essentials." } }
      ]
    }
  ]
}
{% endschema %}
