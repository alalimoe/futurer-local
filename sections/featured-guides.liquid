{% schema %}
{
  "name": "Featured Guides",
  "tag": "section",
  "class": "section-featured-guides",
  "settings": [
    {
      "type": "header",
      "content": "Theme Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#f9fafb"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#111827"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#fbbf24"
    },
    {
      "type": "header",
      "content": "Section Header"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Compound Research Guides"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Deep dive into protocols, benefits, and safety data."
    }
  ],
  "blocks": [
    {
      "type": "guide_card",
      "name": "Guide Card",
      "settings": [
        {
          "type": "header",
          "content": "Source Selection",
          "info": "Select an Article or Page. Title and Image will pull automatically unless overridden below."
        },
        {
          "type": "article",
          "id": "article_ref",
          "label": "Select Blog Post"
        },
        {
          "type": "page",
          "id": "page_ref",
          "label": "Select Page (if not a blog post)"
        },
        {
          "type": "url",
          "id": "custom_url",
          "label": "Custom Link (Fallback)",
          "info": "Use this only if not selecting an Article or Page above."
        },
        {
          "type": "header",
          "content": "Card Content Overrides"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Custom Cover Image",
          "info": "Overrides the article's featured image."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Custom Title",
          "info": "Overrides the article's title."
        },
        {
          "type": "textarea",
          "id": "excerpt",
          "label": "Custom Excerpt",
          "info": "Overrides the article's excerpt. Keep it short."
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge Text",
          "default": "Guide",
          "info": "E.g. 'Popular', 'New'. Leave blank to hide."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured Guides",
      "blocks": [
        {
          "type": "guide_card",
          "settings": {
            "title": "BPC-157 Protocol",
            "excerpt": "The ultimate guide to healing protocols and systemic recovery.",
            "badge": "Popular"
          }
        },
        {
          "type": "guide_card",
          "settings": {
            "title": "TB-500 Research",
            "excerpt": "Understanding Thymosin Beta-4 and tissue regeneration.",
            "badge": "Advanced"
          }
        },
        {
          "type": "guide_card",
          "settings": {
            "title": "Stacking 101",
            "excerpt": "How to safely combine compounds for synergistic effects.",
            "badge": "Beginner"
          }
        }
      ]
    }
  ]
}
{% endschema %}

<div class="fg-wrapper">
  <div class="fg-container">
    
    <div class="fg-header">
      <h2 class="fg-title">{{ section.settings.heading }}</h2>
      <p class="fg-subtitle">{{ section.settings.subheading }}</p>
    </div>

    <div class="fg-grid">
      {% for block in section.blocks %}
        {% comment %} 
          LOGIC: Determine Content Source 
          Priority: Article -> Page -> Custom Link
        {% endcomment %}
        
        {% assign link_url = '#' %}
        {% assign card_image = blank %}
        {% assign card_title = 'Guide Title' %}
        {% assign card_excerpt = 'Guide description goes here.' %}

        {% if block.settings.article_ref != blank %}
          {% assign link_url = block.settings.article_ref.url %}
          {% assign card_image = block.settings.article_ref.image %}
          {% assign card_title = block.settings.article_ref.title %}
          {% assign card_excerpt = block.settings.article_ref.excerpt_or_content | strip_html | truncate: 120 %}
        {% elsif block.settings.page_ref != blank %}
          {% assign link_url = block.settings.page_ref.url %}
          {% assign card_title = block.settings.page_ref.title %}
          {% assign card_excerpt = block.settings.page_ref.content | strip_html | truncate: 120 %}
        {% elsif block.settings.custom_url != blank %}
          {% assign link_url = block.settings.custom_url %}
        {% endif %}

        {% comment %} Apply Overrides {% endcomment %}
        {% if block.settings.image != blank %}
          {% assign card_image = block.settings.image %}
        {% endif %}
        
        {% if block.settings.title != blank %}
          {% assign card_title = block.settings.title %}
        {% endif %}

        {% if block.settings.excerpt != blank %}
          {% assign card_excerpt = block.settings.excerpt %}
        {% endif %}


        <a href="{{ link_url }}" class="fg-card">
          
          <div class="fg-image-wrap">
            {% if card_image != blank %}
              <img src="{{ card_image | image_url: width: 600 }}" alt="{{ card_title }}" width="600" height="{{ 600 | divided_by: card_image.aspect_ratio | round }}" loading="lazy">
            {% else %}
              <div class="fg-placeholder">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
              </div>
            {% endif %}
            
            {% if block.settings.badge != blank %}
              <span class="fg-badge">{{ block.settings.badge }}</span>
            {% endif %}
          </div>

          <div class="fg-content">
            <h3 class="fg-card-title">{{ card_title }}</h3>
            <p class="fg-excerpt">{{ card_excerpt }}</p>
            <div class="fg-link">
              Read Guide 
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
            </div>
          </div>

        </a>
      {% endfor %}
    </div>

  </div>
</div>

<style>
  :root {
    --fg-bg: {{ section.settings.bg_color }};
    --fg-text: {{ section.settings.text_color }};
    --fg-accent: {{ section.settings.accent_color }};
    --fg-border: #e5e7eb;
    --fg-muted: #6b7280;
    --fg-font: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  }

  .fg-wrapper {
    background-color: var(--fg-bg);
    color: var(--fg-text);
    padding: 80px var(--page-gutter);
    font-family: var(--fg-font);
  }
  
  .fg-container {
    max-width: var(--container-width-large);
    margin: 0 auto;
  }

  /* Header */
  .fg-header {
    text-align: center;
    margin-bottom: 50px;
  }
  .fg-title {
    font-size: 32px;
    font-weight: 800;
    margin: 0 0 12px;
    color: var(--fg-text);
    letter-spacing: -0.5px;
  }
  .fg-subtitle {
    color: var(--fg-muted);
    font-size: 16px;
    max-width: 500px;
    margin: 0 auto;
  }

  /* Grid */
  .fg-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
  }
  @media(max-width: 900px) {
    .fg-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media(max-width: 600px) {
    .fg-grid { grid-template-columns: 1fr; }
  }

  /* Card */
  .fg-card {
    background: #ffffff;
    border: 1px solid var(--fg-border);
    border-radius: 16px;
    overflow: hidden;
    text-decoration: none;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    display: flex;
    flex-direction: column;
    height: 100%;
  }
  
  .fg-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
    border-color: #d1d5db;
  }

  /* Image Area */
  .fg-image-wrap {
    width: 100%;
    height: 200px;
    position: relative;
    background: #f3f4f6;
    overflow: hidden;
  }
  .fg-image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .fg-card:hover .fg-image-wrap img {
    transform: scale(1.05);
  }
  
  .fg-placeholder {
    width: 100%; height: 100%;
    display: flex; align-items: center; justify-content: center;
    color: #9ca3af;
  }

  /* Badge */
  .fg-badge {
    position: absolute;
    top: 12px;
    left: 12px;
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(4px);
    color: var(--color-text-primary);
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    padding: 6px 10px;
    border-radius: 99px;
    letter-spacing: 0.5px;
    box-shadow: var(--shadow-xs);
  }

  /* Content */
  .fg-content {
    padding: 24px;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }
  .fg-card-title {
    font-size: 18px;
    font-weight: 700;
    margin: 0 0 8px;
    color: var(--fg-text);
  }
  .fg-excerpt {
    font-size: 14px;
    color: var(--fg-muted);
    line-height: 1.5;
    margin: 0 0 20px;
    flex-grow: 1;
  }
  
  .fg-link {
    font-size: 13px;
    font-weight: 700;
    color: #b45309; /* Darker gold for readability */
    text-transform: uppercase;
    letter-spacing: 0.5px;
    display: flex;
    align-items: center;
    gap: 6px;
    margin-top: auto;
  }
  .fg-card:hover .fg-link {
    text-decoration: underline;
    text-underline-offset: 4px;
  }
</style>