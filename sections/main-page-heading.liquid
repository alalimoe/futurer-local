{% liquid
  assign class = section.settings.font_size_heading
  assign heading = section.settings.heading
  assign sub_heading = section.settings.sub_heading
  assign align = section.settings.align
%}

<section {% render 'section-attr' %}>
  <xo-container class='main-page__heading'>
    {% render 'page-heading', class: class, heading: heading, description: sub_heading, align: align %}
  </xo-container>
</section>

{% schema %}
{
  "name": "t:sections.main_page_heading.name",
  "disabled_on": {
    "groups": [
      "header",
      "footer",
      "custom.overlay",
      "custom.popups",
      "custom.features"
    ]
  },
  "settings": [
    {
      "type": "select",
      "id": "font_size_heading",
      "label": "Font size heading",
      "default": "h4",
      "options": [
        {
          "value": "h1",
          "label": "Extra extra large"
        },
        {
          "value": "h2",
          "label": "Extra large"
        },
        {
          "value": "h3",
          "label": "Large"
        },
        {
          "value": "h4",
          "label": "Medium"
        },
        {
          "value": "h5",
          "label": "Small"
        },
        {
          "value": "h6",
          "label": "Extra small"
        }
      ]
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "t:sections.main_page_heading.settings.heading.label",
      "default": "<p>Page heading</p>"
    },
    {
      "type": "richtext",
      "id": "sub_heading",
      "label": "t:sections.main_page_heading.settings.sub_heading.label",
      "default": "<p>Subheading</p>"
    },
    {
      "type": "select",
      "id": "align",
      "label": "t:sections.main_page_heading.settings.align.label",
      "options": [
        {
          "value": "left",
          "label": "t:sections.main_page_heading.settings.align.option__1.label"
        },
        {
          "value": "center",
          "label": "t:sections.main_page_heading.settings.align.option__2.label"
        },
        {
          "value": "right",
          "label": "t:sections.main_page_heading.settings.align.option__3.label"
        }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "General settings"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Section color scheme"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color"
    },
    {
      "type": "color_background",
      "id": "background_gradient",
      "label": "Background gradient"
    },
    {
      "type": "number",
      "id": "padding_top_desktop",
      "label": "Padding top desktop",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_bottom_desktop",
      "label": "Padding bottom desktop",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_top_mobile",
      "label": "Padding top mobile",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom mobile",
      "default": 50
    }
  ]
}
{% endschema %}