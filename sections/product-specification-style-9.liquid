{{ 'section-product-specification-style-9.css' | asset_url | stylesheet_tag }}
{{ 'product-specification-9.css' | asset_url | stylesheet_tag }}
{{ 'perfomance.css' | asset_url | stylesheet_tag }}
{{ 'chart.css' | asset_url | stylesheet_tag }}

{% liquid
  assign block = section.blocks
  assign button = section.settings
  assign heading = section.settings.heading
  assign heading = section.settings.text_heading
%}

<section {% render 'section-attr' %}>
  <div class="product-specification-style-9">
    {% render 'section-bg-image' %}
    <xo-container class="product-specification-style-9__container">
      <div class="product-specification-style-9__content">
        {% render 'product-specification-9', heading: heading, effect: effect, button: button, block: block %}
      </div>
    </xo-container>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.product_specification_style_9.name",
  "disabled_on": {
    "groups": [
      "header",
      "footer",
      "custom.overlay",
      "custom.popups",
      "custom.features"
    ]
  },
  "settings": [
    {
      "type": "header",
      "content": "Text"
    },
    {
      "type": "select",
      "id": "text_tag_name",
      "label": "Tag name",
      "options": [
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        },
        {
          "value": "h4",
          "label": "H4"
        },
        {
          "value": "h5",
          "label": "H5"
        },
        {
          "value": "h6",
          "label": "H6"
        }
      ],
      "default": "h2"
    },
    {
      "type": "textarea",
      "id": "text_heading",
      "label": "Text",
      "default": "Product specification"
    },
    {
      "type": "select",
      "id": "font_size_heading",
      "label": "Font size heading",
      "default": "h5",
      "options": [
        {
          "value": "h1",
          "label": "Extra extra large"
        },
        {
          "value": "h2",
          "label": "Extra large"
        },
        {
          "value": "h3",
          "label": "Large"
        },
        {
          "value": "h4",
          "label": "Medium"
        },
        {
          "value": "h5",
          "label": "Small"
        },
        {
          "value": "h6",
          "label": "Extra small"
        }
      ]
    },
    {
      "type": "range",
      "id": "text_line_height",
      "label": "Line height",
      "min": 0,
      "max": 3,
      "step": 0.1,
      "default": 1.2
    },
    {
      "type": "select",
      "id": "text_effect",
      "label": "Effect",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "reveal",
          "label": "Blur"
        },
        {
          "value": "split",
          "label": "Split"
        }
      ],
      "default": "split"
    },
    {
      "type": "number",
      "id": "text_duration",
      "label": "Duration (milliseconds)",
      "default": 1000
    },
    {
      "type": "range",
      "id": "text_heading_width_desktop",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "Desktop heading width",
      "default": 100
    },
    {
      "type": "range",
      "id": "text_heading_width_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "Mobile heading width",
      "default": 100
    },
    {
      "type": "header",
      "content": "t:sections.product_specification_style_9.settings.header_button.content"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Button"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link",
      "default": "/collections/all"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "Button style",
      "options": [
        {
          "value": "primary",
          "label": "Primary"
        },
        {
          "value": "secondary",
          "label": "Secondary"
        },
        {
          "value": "link",
          "label": "Link"
        }
      ],
      "default": "primary"
    },
    {
      "type": "select",
      "id": "button_size",
      "label": "Button size",
      "options": [
        {
          "value": "xs",
          "label": "Extra small"
        },
        {
          "value": "sm",
          "label": "Small"
        },
        {
          "value": "md",
          "label": "Medium"
        },
        {
          "value": "lg",
          "label": "Large"
        }
      ],
      "default": "md"
    },
    {
      "type": "header",
      "content": "General settings"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Section color scheme"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color"
    },
    {
      "type": "color_background",
      "id": "background_gradient",
      "label": "Background gradient"
    },
    {
      "type": "select",
      "id": "background_type",
      "label": "Background type",
      "options": [
        {
          "value": "image",
          "label": "Image"
        },
        {
          "value": "video",
          "label": "Video"
        }
      ],
      "default": "image"
    },
    {
      "type": "video",
      "id": "background_video_desktop",
      "label": "Background video desktop",
      "visible_if": "{{ section.settings.background_type == 'video' }}"
    },
    {
      "type": "video",
      "id": "background_video_mobile",
      "label": "Background video mobile",
      "visible_if": "{{ section.settings.background_type == 'video' }}"
    },
    {
      "type": "image_picker",
      "id": "background_image_desktop",
      "label": "Background image desktop",
      "visible_if": "{{ section.settings.background_type == 'image' }}"
    },
    {
      "type": "image_picker",
      "id": "background_image_mobile",
      "label": "Background image mobile",
      "visible_if": "{{ section.settings.background_type == 'image' }}"
    },
    {
      "type": "checkbox",
      "id": "use_parallax",
      "label": "Use parallax",
      "default": true
    },
    {
      "type": "number",
      "id": "padding_top_desktop",
      "label": "Padding top desktop",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_bottom_desktop",
      "label": "Padding bottom desktop",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_top_mobile",
      "label": "Padding top mobile",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom mobile",
      "default": 50
    }
  ],
  "blocks": [
    {
      "name": "t:sections.product_specification_style_9.blocks.name_1",
      "type": "perfomance",
      "limit": 2,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "t:sections.product_specification_style_9.blocks.settings.title.label",
          "default": "Heading"
        },
        {
          "type": "number",
          "id": "number",
          "label": "t:sections.product_specification_style_9.blocks.settings.number.label",
          "default": 50
        },
        {
          "type": "text",
          "id": "sub_title",
          "label": "t:sections.product_specification_style_9.blocks.settings.sub_title.label",
          "default": "Subheading"
        }
      ]
    },
    {
      "name": "t:sections.product_specification_style_9.blocks.name_2",
      "type": "chart",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "sub_heading",
          "label": "t:sections.product_specification_style_9.blocks.settings.sub_title.label",
          "default": "Heading"
        },
        {
          "type": "header",
          "content": "t:sections.product_specification_style_9.blocks.settings.specifications.content"
        },
        {
          "type": "number",
          "id": "value_max",
          "label": "t:sections.product_specification_style_9.blocks.settings.value_max.label",
          "default": 60
        },
        {
          "type": "textarea",
          "id": "x_label",
          "label": "t:sections.product_specification_style_9.blocks.settings.x_label.label",
          "default": "0\n1h\n6h\n14h\n20h\n24h"
        },
        {
          "type": "textarea",
          "id": "y_label",
          "label": "t:sections.product_specification_style_9.blocks.settings.y_label.label",
          "default": "60\n40\n20\n0"
        },
        {
          "type": "textarea",
          "id": "dataset",
          "label": "t:sections.product_specification_style_9.blocks.settings.dataset.label",
          "default": "0,20,39,40,30,42\n0,30,40,5,10,32"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.product_specification_style_9.presets.name",
      "settings": {
        "font_size_heading": "h5",
        "text_heading": "Product specification",
        "text_duration": 2000,
        "text_effect": "split",
        "button_text": "Shop now",
        "button_link": "shopify://collections/all",
        "button_style": "primary",
        "button_size": "md",
        "color_scheme": "",
        "background_color": "",
        "background_gradient": "",
        "use_parallax": true,
        "padding_top_desktop": 50,
        "padding_bottom_desktop": 50,
        "padding_top_mobile": 50,
        "padding_bottom_mobile": 50
      },
      "blocks": [
        {
          "type": "perfomance",
          "settings": {
            "title": "Subheading",
            "number": 50,
            "sub_title": "Heading"
          }
        },
        {
          "type": "perfomance",
          "settings": {
            "title": "Subheading",
            "number": 50,
            "sub_title": "Heading"
          }
        },
        {
          "type": "chart",
          "settings": {
            "sub_heading": "Heading",
            "value_max": 60,
            "x_label": "0\n1h\n6h\n14h\n20h\n24h",
            "y_label": "60\n40\n20\n0",
            "dataset": "0,20,39,40,30,42\n0,30,40,5,10,32"
          }
        }
      ]
    }
  ]
}
{% endschema %}