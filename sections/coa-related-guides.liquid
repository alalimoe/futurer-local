{%- style -%}
  .xo-section--{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .xo-section--{{ section.id }} .clr-inner {
    max-width: var(--page-width);
    margin: 0 auto;
  }

  .xo-section--{{ section.id }} .clr-heading {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 600;
    color: rgba(var(--color-foreground));
    margin: 0 0 28px;
    letter-spacing: -0.02em;
  }

  .xo-section--{{ section.id }} .clr-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 16px;
    margin-bottom: 32px;
  }

  .xo-section--{{ section.id }} .clr-card {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 24px;
    background: rgba(var(--color-background-2));
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
    border-radius: var(--general-radius-1, 1rem);
    text-decoration: none;
    transition: border-color 0.3s var(--out-soft, ease);
    position: relative;
  }

  .xo-section--{{ section.id }} .clr-card:hover {
    border-color: rgba(var(--color-accent));
  }

  .xo-section--{{ section.id }} .clr-card-arrow {
    position: absolute;
    top: 20px;
    right: 20px;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent);
    transition: color 0.3s var(--out-soft, ease), transform 0.3s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .clr-card:hover .clr-card-arrow {
    color: rgba(var(--color-accent));
    transform: translateX(3px);
  }

  .xo-section--{{ section.id }} .clr-card-title {
    font-size: 1.0625rem;
    font-weight: 600;
    color: rgba(var(--color-foreground));
    margin: 0;
    padding-right: 28px;
    transition: color 0.2s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .clr-card:hover .clr-card-title {
    color: rgba(var(--color-accent));
  }

  .xo-section--{{ section.id }} .clr-card-desc {
    font-size: 0.875rem;
    line-height: 1.6;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent);
    margin: 0;
  }

  .xo-section--{{ section.id }} .clr-disclaimer {
    padding: 16px 20px;
    background: rgba(var(--color-background-2));
    border-radius: var(--general-radius-1, 1rem);
    font-size: 0.8125rem;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent);
    text-align: center;
  }

  .xo-section--{{ section.id }} :focus-visible {
    outline: 2px solid rgba(var(--color-accent));
    outline-offset: 2px;
  }

  @media (max-width: 768px) {
    .xo-section--{{ section.id }} .clr-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .xo-section--{{ section.id }} .clr-card,
    .xo-section--{{ section.id }} .clr-card-arrow,
    .xo-section--{{ section.id }} .clr-card-title {
      transition: none;
    }
  }
{%- endstyle -%}

<section {% render 'section-attr' %}>
  <xo-container>
    <div class="clr-inner">
      {% if section.settings.heading != blank %}
        <h2 class="clr-heading">{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.blocks.size > 0 %}
        <div class="clr-grid">
          {% for block in section.blocks %}
            {% if block.type == 'guide' %}
              <a href="{{ block.settings.url | default: '#' }}" class="clr-card" {{ block.shopify_attributes }}>
                <div class="clr-card-arrow" aria-hidden="true">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </div>
                <h3 class="clr-card-title">{{ block.settings.title }}</h3>
                {% if block.settings.desc != blank %}
                  <p class="clr-card-desc">{{ block.settings.desc }}</p>
                {% endif %}
              </a>
            {% endif %}
          {% endfor %}
        </div>
      {% endif %}

      {% if section.settings.disclaimer != blank %}
        <div class="clr-disclaimer">{{ section.settings.disclaimer }}</div>
      {% endif %}
    </div>
  </xo-container>
</section>

{% schema %}
{
  "name": "COA Related Guides",
  "tag": "section",
  "class": "section-coa-related-guides",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "default"
    },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Related Guides" },
    { "type": "textarea", "id": "disclaimer", "label": "Disclaimer", "default": "Educational information only. Not medical advice." },
    { "type": "header", "content": "Spacing" },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 64
    }
  ],
  "blocks": [
    {
      "type": "guide",
      "name": "Guide Card",
      "settings": [
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "url", "id": "url", "label": "URL" },
        { "type": "textarea", "id": "desc", "label": "Short Description" }
      ]
    },
    { "type": "@app" }
  ],
  "presets": [
    {
      "name": "COA Related Guides",
      "blocks": [
        { "type": "guide", "settings": { "title": "How to Read a COA", "desc": "Learn what each section of a Certificate of Analysis means and how to interpret results." } },
        { "type": "guide", "settings": { "title": "UAE Quality & Trust Guide", "desc": "Understand quality assurance, regulatory context, and what to expect when buying in the UAE." } },
        { "type": "guide", "settings": { "title": "Shipping in UAE Heat", "desc": "Temperature-sensitive products need care. Learn how we handle last-mile delivery in hot climates." } },
        { "type": "guide", "settings": { "title": "Storage & Handling", "desc": "Best practices for storing peptides, nootropics, and supplements after delivery." } }
      ]
    }
  ]
}
{% endschema %}
