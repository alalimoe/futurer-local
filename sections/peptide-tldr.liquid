{% schema %}
{
  "name": "Peptide TL;DR",
  "tag": "section",
  "class": "section-peptide-tldr",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Key Takeaways (TL;DR)"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme"
    },
    { "type": "header", "content": "Spacing" },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "takeaway",
      "name": "Takeaway",
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Takeaway text"
        }
      ]
    },
    { "type": "@app" }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Peptide TL;DR",
      "blocks": [
        { "type": "takeaway", "settings": { "text": "<p>Enter your vial details into our <strong>free calculator</strong> for instant, exact dosing.</p>" } },
        { "type": "takeaway", "settings": { "text": "<p>Always use <strong>bacteriostatic water</strong> — never tap or distilled.</p>" } },
        { "type": "takeaway", "settings": { "text": "<p>Reconstituted peptides must be <strong>refrigerated (2–8 °C)</strong> and used within 30 days.</p>" } }
      ]
    }
  ]
}
{% endschema %}

{%- assign s = section.settings -%}

{%- style -%}
  .xo-section--{{ section.id }} {
    padding-top: {{ s.padding_top }}px;
    padding-bottom: {{ s.padding_bottom }}px;
  }

  .xo-section--{{ section.id }} .ptldr-container {
    max-width: 800px;
    margin: 0 auto;
  }

  .xo-section--{{ section.id }} .ptldr-card {
    background: rgba(var(--color-background));
    border-radius: var(--general-radius-3, 2rem);
    padding: 32px 32px 28px 36px;
    position: relative;
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
  }

  .xo-section--{{ section.id }} .ptldr-card::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 4px;
    background: rgba(var(--color-accent));
    border-radius: var(--general-radius-3, 2rem) 0 0 var(--general-radius-3, 2rem);
  }

  .xo-section--{{ section.id }} .ptldr-heading {
    font-family: var(--font-heading-family);
    font-size: clamp(20px, 2.5vw, 24px);
    font-weight: 600;
    color: rgba(var(--color-foreground));
    margin: 0 0 20px;
    letter-spacing: -0.3px;
  }

  .xo-section--{{ section.id }} .ptldr-list {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .xo-section--{{ section.id }} .ptldr-item {
    position: relative;
    padding: 10px 0 10px 24px;
    font-size: 15px;
    line-height: 1.7;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent);
  }

  .xo-section--{{ section.id }} .ptldr-item + .ptldr-item {
    border-top: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
  }

  .xo-section--{{ section.id }} .ptldr-item::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 8px;
    height: 8px;
    background: rgba(var(--color-accent));
    border-radius: 50%;
  }

  .xo-section--{{ section.id }} .ptldr-item strong {
    color: rgba(var(--color-foreground));
    font-weight: 600;
  }

  .xo-section--{{ section.id }} .ptldr-item p {
    margin: 0;
  }

  .xo-section--{{ section.id }} :focus-visible {
    outline: 2px solid rgba(var(--color-accent));
    outline-offset: 2px;
  }

  @media (prefers-reduced-motion: reduce) {
    .xo-section--{{ section.id }} *,
    .xo-section--{{ section.id }} *::before,
    .xo-section--{{ section.id }} *::after {
      animation-duration: 0.01ms !important;
      transition-duration: 0.01ms !important;
    }
  }

  @media (max-width: 768px) {
    .xo-section--{{ section.id }} .ptldr-card {
      padding: 24px 20px 20px 28px;
    }
  }
{%- endstyle -%}

<section {% render 'section-attr' %}>
  <xo-container>
    <div class="ptldr-container">
      <div class="ptldr-card">
        <h2 class="ptldr-heading">{{ s.heading }}</h2>
        {% if section.blocks.size > 0 %}
          <ul class="ptldr-list" role="list">
            {% for block in section.blocks %}
              <li class="ptldr-item" {{ block.shopify_attributes }}>{{ block.settings.text }}</li>
            {% endfor %}
          </ul>
        {% endif %}
      </div>
    </div>
  </xo-container>
</section>
