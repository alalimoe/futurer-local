{%- style -%}
  .xo-section--{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .xo-section--{{ section.id }} .fc__title {
    font-size: clamp(1.2rem, 2.2vw, 1.5rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.2;
    color: rgba(var(--color-foreground));
    margin: 0 0 4px;
  }

  .xo-section--{{ section.id }} .fc__lead {
    color: color-mix(in srgb, rgba(var(--color-foreground)) 55%, transparent);
    margin-top: 6px;
    font-size: clamp(0.85rem, 1.2vw, 0.9375rem);
  }

  .xo-section--{{ section.id }} .fc__row {
    display: grid;
    gap: 6px;
    margin-bottom: 14px;
  }

  .xo-section--{{ section.id }} .fc__row label {
    font-size: clamp(0.8rem, 1.1vw, 0.875rem);
    font-weight: 600;
    color: rgba(var(--color-foreground));
  }

  .xo-section--{{ section.id }} .fc__row input,
  .xo-section--{{ section.id }} .fc__row textarea {
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 12%, transparent);
    border-radius: var(--general-radius-1, 1rem);
    padding: 10px 14px;
    min-height: 44px;
    box-sizing: border-box;
    font-size: clamp(0.85rem, 1.3vw, 0.9375rem);
    background: rgba(var(--color-background));
    color: rgba(var(--color-foreground));
    transition: border-color 0.3s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .fc__row input:focus,
  .xo-section--{{ section.id }} .fc__row textarea:focus {
    outline: none;
    border-color: rgba(var(--color-accent));
  }

  .xo-section--{{ section.id }} .fc__row input:focus-visible,
  .xo-section--{{ section.id }} .fc__row textarea:focus-visible {
    outline: 2px solid rgba(var(--color-accent));
    outline-offset: 2px;
  }

  .xo-section--{{ section.id }} .fc__row input::placeholder,
  .xo-section--{{ section.id }} .fc__row textarea::placeholder {
    opacity: 0.5;
  }

  .xo-section--{{ section.id }} .fc__btn {
    border: none;
    border-radius: var(--button-radius);
    padding: 12px 20px;
    min-height: 44px;
    background: rgba(var(--color-foreground));
    color: rgba(var(--color-background));
    font-size: clamp(0.85rem, 1.2vw, 0.9375rem);
    font-weight: 600;
    cursor: pointer;
    transition: opacity 0.3s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .fc__btn:hover {
    opacity: 0.85;
  }

  .xo-section--{{ section.id }} .fc__btn:focus-visible {
    outline: 2px solid rgba(var(--color-accent));
    outline-offset: 2px;
  }

  .xo-section--{{ section.id }} .fc__success {
    color: rgba(var(--color-success, 16, 167, 31));
    margin-top: 12px;
    font-weight: 500;
    font-size: clamp(0.85rem, 1.2vw, 0.9375rem);
  }

  .xo-section--{{ section.id }} .fc__error {
    color: rgba(var(--color-error, 218, 30, 40));
    margin-top: 12px;
    font-weight: 500;
    font-size: clamp(0.85rem, 1.2vw, 0.9375rem);
  }

  .xo-section--{{ section.id }} .fc__embed iframe {
    width: 100%;
    min-height: 560px;
    height: 660px;
    border: 0;
    border-radius: var(--general-radius-3, 2rem);
  }

  @media (prefers-reduced-motion: reduce) {
    .xo-section--{{ section.id }} .fc__row input,
    .xo-section--{{ section.id }} .fc__row textarea,
    .xo-section--{{ section.id }} .fc__btn {
      transition: none;
    }
  }
{%- endstyle -%}

<section {% render 'section-attr' %}>
  <xo-container>
    <h2 class="fc__title">{{ section.settings.heading }}</h2>
    <p class="fc__lead">{{ section.settings.subheading }}</p>

    {% if section.settings.use_embed and section.settings.helpdesk_embed != blank %}
      <div class="fc__embed">
        {{ section.settings.helpdesk_embed }}
      </div>
    {% else %}
      <div class="fc__form">
        {% form 'contact' %}
          <div class="fc__row">
            <label for="ContactFormName-{{ section.id }}">Name</label>
            <input id="ContactFormName-{{ section.id }}" type="text" name="contact[name]" required autocomplete="name">
          </div>
          <div class="fc__row">
            <label for="ContactFormEmail-{{ section.id }}">Email</label>
            <input id="ContactFormEmail-{{ section.id }}" type="email" name="contact[email]" required autocomplete="email">
          </div>
          <div class="fc__row">
            <label for="ContactFormOrder-{{ section.id }}">Order # (optional)</label>
            <input id="ContactFormOrder-{{ section.id }}" type="text" name="contact[Order Number]">
          </div>
          <div class="fc__row">
            <label for="ContactFormBody-{{ section.id }}">How can we help?</label>
            <textarea id="ContactFormBody-{{ section.id }}" name="contact[body]" rows="6" required></textarea>
          </div>
          <button class="fc__btn" type="submit">Send message</button>
          {% if form.posted_successfully? %}
            <p class="fc__success" role="status" aria-live="polite">Thanks! We'll get back to you shortly.</p>
          {% endif %}
          {% if form.errors %}
            <p class="fc__error" role="alert">Please check the form and try again.</p>
          {% endif %}
        {% endform %}
      </div>
    {% endif %}
  </xo-container>
</section>

{% schema %}
{
  "name": "FAQ – Help & Support",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "default" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Still need help?" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Message us and we'll jump on it." },
    { "type": "checkbox", "id": "use_embed", "label": "Use embed form", "default": false },
    { "type": "html", "id": "helpdesk_embed", "label": "Embed code (iframe/script)", "default": "<!-- paste HelpDesk iframe here, then toggle 'Use embed form' on -->" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding top", "default": 24 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding bottom", "default": 24 }
  ],
  "presets": [{ "name": "FAQ – Help & Support" }]
}
{% endschema %}
