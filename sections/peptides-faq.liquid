{%- style -%}
  .xo-section--{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .xo-section--{{ section.id }} .faq-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .xo-section--{{ section.id }} .faq-title {
    font-family: var(--font-heading-family);
    font-size: clamp(1.4rem, 2.5vw, 1.75rem);
    font-weight: 600;
    margin: 0 0 10px;
    color: rgba(var(--color-foreground));
    letter-spacing: -0.025em;
    line-height: 1.2;
  }

  .xo-section--{{ section.id }} .faq-subtitle {
    color: color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent);
    font-size: clamp(0.875rem, 1.5vw, 1rem);
  }

  .xo-section--{{ section.id }} .faq-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
    max-width: 800px;
    margin: 0 auto;
  }

  .xo-section--{{ section.id }} .faq-item {
    background: rgba(var(--color-background));
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
    border-radius: var(--general-radius-1, 1rem);
    overflow: hidden;
    transition: border-color 0.3s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .faq-item[open] {
    border-color: rgba(var(--color-accent));
  }

  .xo-section--{{ section.id }} .faq-question {
    padding: 20px 24px;
    font-weight: 600;
    font-size: 1rem;
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: rgba(var(--color-foreground));
  }

  .xo-section--{{ section.id }} .faq-question::-webkit-details-marker {
    display: none;
  }

  .xo-section--{{ section.id }} .faq-icon {
    color: color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent);
    transition: transform 0.3s var(--out-soft, ease);
    display: flex;
    align-items: center;
    flex-shrink: 0;
    margin-left: 16px;
  }

  .xo-section--{{ section.id }} .faq-item[open] .faq-icon {
    transform: rotate(180deg);
    color: rgba(var(--color-accent));
  }

  .xo-section--{{ section.id }} .faq-answer {
    padding: 0 24px 24px 24px;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent);
    line-height: 1.6;
    font-size: 0.9375rem;
    animation: faqFadeIn-{{ section.id }} 0.3s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .faq-answer strong {
    color: rgba(var(--color-foreground));
  }

  @keyframes faqFadeIn-{{ section.id }} {
    from {
      opacity: 0;
      transform: translateY(-5px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .xo-section--{{ section.id }} *,
    .xo-section--{{ section.id }} *::before,
    .xo-section--{{ section.id }} *::after {
      animation-duration: 0.01ms !important;
      transition-duration: 0.01ms !important;
    }
  }
{%- endstyle -%}

<section {% render 'section-attr' %}>
  <xo-container>

    <div class="faq-header">
      <h2 class="faq-title">{{ section.settings.heading }}</h2>
      <p class="faq-subtitle">{{ section.settings.subheading }}</p>
    </div>

    <div class="faq-list">
      {% for block in section.blocks %}
        {% if block.type == 'faq' %}
          <details class="faq-item" {{ block.shopify_attributes }}>
            <summary class="faq-question">
              <span>{{ block.settings.question }}</span>
              <div class="faq-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>
              </div>
            </summary>
            <div class="faq-answer">
              {{ block.settings.answer }}
            </div>
          </details>
        {% endif %}
      {% endfor %}
    </div>

  </xo-container>
</section>

{% if section.blocks.size > 0 %}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {%- for block in section.blocks -%}
          {%- if block.type == 'faq' and block.settings.question != blank -%}
            {
              "@type": "Question",
              "name": {{ block.settings.question | json }},
              "acceptedAnswer": {
                "@type": "Answer",
                "text": {{ block.settings.answer | strip_html | json }}
              }
            }{% unless forloop.last %},{% endunless %}
          {%- endif -%}
        {%- endfor -%}
      ]
    }
  </script>
{% endif %}

{% schema %}
{
  "name": "Peptide FAQ Accordion",
  "tag": "section",
  "class": "section-peptide-faq",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "default" },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Common Questions"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Troubleshooting your research process."
    },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding top", "default": 80 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding bottom", "default": 80 }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "Question",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer"
        }
      ]
    },
    { "type": "@app" }
  ],
  "presets": [
    {
      "name": "Peptide FAQ Accordion",
      "blocks": [
        {
          "type": "faq",
          "settings": {
            "question": "My solution is cloudy or has floaters. Is it ruined?",
            "answer": "<p><strong>Stop.</strong> Do not use cloudy solutions immediately. Most lyophilized peptides should dissolve into a crystal-clear solution. <br><br>1. Allow the vial to sit in the refrigerator for 20 minutes.<br>2. If it remains cloudy or has visible particles (floaters) after this time, the peptide may have degraded or the bacteriostatic water quality is compromised. For safety, discard the vial.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "The vial has a vacuum (sucks the plunger in). Is that normal?",
            "answer": "<p><strong>Yes, this is a sign of a good seal.</strong> Manufacturers often seal vials under negative pressure (vacuum) to ensure sterility. <br><br>If the vacuum makes it difficult to draw liquid, simply inject an amount of air equal to the amount of liquid you intend to withdraw. This equalizes the pressure.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "Can I mix two peptides in one syringe?",
            "answer": "<p><strong>Generally, yes.</strong> This is common in research to reduce the number of injections. <br><br><strong>Protocol:</strong><br>1. Calculate the units for Peptide A and Peptide B separately.<br>2. Draw Peptide A first.<br>3. Carefully draw Peptide B into the same syringe.<br><em>Note: Be extremely careful not to push liquid from the syringe back into the second vial, as this cross-contaminates your supply.</em></p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "I added too much water. What do I do?",
            "answer": "<p><strong>Don't panic.</strong> Your product is safe, but the concentration is now lower (more dilute). <br><br><strong>The Fix:</strong> Scroll up to the calculator and change the <strong>'Water Added'</strong> input to the <em>actual</em> amount you used. The calculator will automatically adjust and give you the new, larger volume you need to draw to achieve your target dose.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
