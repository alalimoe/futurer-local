{% doc %}
  @name Collection Chips Only
  @desc Horizontal filter chip rows for collection pages. Supports up to 2 configurable filter rows, pinned "In stock" chip, active filter summary, scroll chevrons, sticky positioning, and scroll-to-grid on filter click. JS retained for scroll/chevron/sticky behaviors (no theme web component equivalent).
{% enddoc %}

{% if request.page_type == 'collection' %}

{%- style -%}
  .xo-section--{{ section.id }} {
    border-bottom: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 8%, transparent);
    {% if section.settings.compact %}margin-bottom: 0.4rem;{% else %}margin-bottom: 0.8rem;{% endif %}
    background: rgba(var(--color-background));
  }

  {% if section.settings.sticky %}
    .xo-section--{{ section.id }} {
      position: sticky;
      top: 0;
      z-index: 6;
    }

    .xo-section--{{ section.id }}.is-stuck {
      background: color-mix(in srgb, rgba(var(--color-background)) 92%, transparent);
      -webkit-backdrop-filter: blur(12px);
      backdrop-filter: blur(12px);
      border-bottom-color: transparent;
    }
  {% endif %}

  .xo-section--{{ section.id }} .chips__inner {
    padding-top: 1.2rem;
    padding-bottom: 1.2rem;
  }

  .xo-section--{{ section.id }} .chips__summary {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    align-items: center;
    margin: 0.2rem 0 0.6rem;
  }

  .xo-section--{{ section.id }} .chips__summary-item {
    font-size: calc(var(--font-body-scale, 1) * 1.3rem);
    color: color-mix(in srgb, rgba(var(--color-foreground)) 55%, transparent);
  }

  .xo-section--{{ section.id }} .chips__summary-item strong {
    color: rgba(var(--color-foreground));
  }

  .xo-section--{{ section.id }} .chips__wrap {
    position: relative;
  }

  .xo-section--{{ section.id }} .chips__scroll-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 3.4rem;
    height: 3.4rem;
    border-radius: var(--button-radius);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.6rem;
    cursor: pointer;
    user-select: none;
    z-index: 2;
    background: rgba(var(--color-background));
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 12%, transparent);
    transition: border-color 0.3s var(--out-soft, ease);
    color: color-mix(in srgb, rgba(var(--color-foreground)) 55%, transparent);
  }

  .xo-section--{{ section.id }} .chips__scroll-btn:hover {
    border-color: rgba(var(--color-accent));
    color: rgba(var(--color-foreground));
  }

  .xo-section--{{ section.id }} .chips__scroll-btn:focus-visible {
    outline: 2px solid rgba(var(--color-accent));
    outline-offset: 2px;
  }

  .xo-section--{{ section.id }} .chips__scroll-btn[hidden] {
    display: none;
  }

  .xo-section--{{ section.id }} .chips__scroll-btn--left {
    left: -0.2rem;
  }

  .xo-section--{{ section.id }} .chips__scroll-btn--right {
    right: -0.2rem;
  }

  .xo-section--{{ section.id }} .chips__row {
    display: flex;
    gap: 0.8rem;
    flex-wrap: nowrap;
    overflow-x: auto;
    padding: 0.4rem 0.2rem 0.8rem;
    margin: 0;
    -webkit-overflow-scrolling: touch;
    scroll-snap-type: x proximity;
    mask-image: linear-gradient(to right, transparent, black 12px, black calc(100% - 12px), transparent);
  }

  .xo-section--{{ section.id }} .chips__row--active {
    padding-top: 0.4rem;
  }

  .xo-section--{{ section.id }} .chips__row--pinned {
    padding-top: 0.2rem;
  }

  .xo-section--{{ section.id }} .chips__chip {
    scroll-snap-align: start;
    white-space: nowrap;
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
    border-radius: var(--button-radius);
    padding: 0.8rem 1.6rem;
    font-size: calc(var(--font-body-scale, 1) * 1.4rem);
    font-weight: 500;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 65%, transparent);
    text-decoration: none;
    line-height: 1;
    min-height: 44px;
    box-sizing: border-box;
    background: rgba(var(--color-background));
    transition: border-color 0.3s var(--out-soft, ease), color 0.3s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .chips__chip:hover {
    border-color: rgba(var(--color-accent));
    color: rgba(var(--color-foreground));
  }

  .xo-section--{{ section.id }} .chips__chip:active {
    transform: scale(0.97);
  }

  .xo-section--{{ section.id }} .chips__chip.is-active {
    border-color: color-mix(in srgb, rgba(var(--color-accent)) 60%, transparent);
    font-weight: 600;
    color: rgba(var(--color-foreground));
    background: color-mix(in srgb, rgba(var(--color-accent)) 6%, rgba(var(--color-background)));
  }

  .xo-section--{{ section.id }} .chips__chip.is-active:hover {
    background: color-mix(in srgb, rgba(var(--color-accent)) 10%, rgba(var(--color-background)));
  }

  .xo-section--{{ section.id }} .chips__row--active .chips__chip.is-active {
    background: color-mix(in srgb, rgba(var(--color-accent)) 5%, rgba(var(--color-background)));
  }

  .xo-section--{{ section.id }} .chips__chip--muted {
    background: transparent;
    border-color: transparent;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 55%, transparent);
    font-weight: 500;
    text-decoration: underline;
    text-decoration-color: transparent;
    text-underline-offset: 3px;
  }

  .xo-section--{{ section.id }} .chips__chip--muted:hover {
    text-decoration-color: color-mix(in srgb, rgba(var(--color-foreground)) 55%, transparent);
    background: transparent;
    border-color: transparent;
    transform: none;
  }

  .xo-section--{{ section.id }} .chips__chip:focus-visible {
    outline: 2px solid rgba(var(--color-accent));
    outline-offset: 2px;
  }

  .xo-section--{{ section.id }} .chips__count {
    font-variant-numeric: tabular-nums;
    font-size: 0.8em;
    opacity: 0.55;
  }

  .xo-section--{{ section.id }} .chips__row::-webkit-scrollbar {
    height: 4px;
  }

  .xo-section--{{ section.id }} .chips__row::-webkit-scrollbar-thumb {
    background: color-mix(in srgb, rgba(var(--color-foreground)) 8%, transparent);
    border-radius: var(--button-radius);
  }

  .xo-section--{{ section.id }} .chips__row::-webkit-scrollbar-track {
    background: transparent;
  }

  @media (max-width: 768px) {
    .xo-section--{{ section.id }} .chips__chip {
      padding: 0.7rem 1.2rem;
      font-size: calc(var(--font-body-scale, 1) * 1.3rem);
    }
    .xo-section--{{ section.id }} .chips__inner {
      padding-top: 1rem;
      padding-bottom: 1rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .xo-section--{{ section.id }} .chips__chip,
    .xo-section--{{ section.id }} .chips__scroll-btn {
      transition: none;
    }
  }

  .xo-section--{{ section.id }} .chips__debug {
    margin-top: 0.4rem;
    opacity: 0.65;
  }

  .xo-section--{{ section.id }} .chips__debug code {
    background: color-mix(in srgb, rgba(var(--color-foreground)) 4%, transparent);
    padding: 0.2rem 0.4rem;
    border-radius: 4px;
  }
{%- endstyle -%}

<a id="np-chipbar-anchor"></a>
<section {% render 'section-attr' %}>
  <xo-container>
    <div class="chips__inner">

      {% assign has_active = false %}
      {% for f in collection.filters %}
        {% if f.active_values.size > 0 %}{% assign has_active = true %}{% break %}{% endif %}
      {% endfor %}

      {%- if section.settings.show_active and has_active -%}
        <div class="chips__row chips__row--active" role="region" aria-label="Active filters">
          {% for f in collection.filters %}
            {% for v in f.active_values %}
              <a class="chips__chip is-active" href="{{ v.url_to_remove }}" data-np-chip aria-label="Remove {{ v.label | escape }}">
                {{ v.label }} <span aria-hidden="true">✕</span>
              </a>
            {% endfor %}
          {% endfor %}
          <a class="chips__chip chips__chip--muted" href="{{ collection.url }}" data-np-chip>Clear all</a>
        </div>

        {% if section.settings.show_summary %}
          <div class="chips__summary" aria-live="polite">
            {% for f in collection.filters %}
              {% if f.active_values.size > 0 %}
                <span class="chips__summary-item">
                  <strong>{{ f.label }}:</strong>
                  {% for v in f.active_values %}{{ v.label }}{% unless forloop.last %}, {% endunless %}{% endfor %}
                </span>
              {% endif %}
            {% endfor %}
          </div>
        {% endif %}
      {%- endif -%}

      {%- liquid
        assign show_counts = section.settings.show_counts
        assign max_chips = section.settings.limit | default: 16 | plus: 0
        assign filter1_label = section.settings.filter_1_label | strip
        assign filter2_label = section.settings.filter_2_label | strip
        assign filter1_label_norm = filter1_label | downcase
        assign filter2_label_norm = filter2_label | downcase
      -%}

      {% if section.settings.pin_in_stock %}
        {% assign availability_label_norm = 'availability' %}
        {% assign avail_filter = blank %}
        {% for f in collection.filters %}
          {% assign flabel_norm = f.label | strip | downcase %}
          {% if flabel_norm == availability_label_norm %}
            {% assign avail_filter = f %}
            {% break %}
          {% endif %}
        {% endfor %}

        {% if avail_filter %}
          {% assign in_stock_option = blank %}
          {% for v in avail_filter.values %}
            {% assign vlabel_norm = v.label | strip | downcase %}
            {% if vlabel_norm contains 'in stock' %}
              {% assign in_stock_option = v %}
              {% break %}
            {% endif %}
          {% endfor %}
          {% if in_stock_option %}
            <div class="chips__wrap" data-scroll-wrap>
              {% if section.settings.enable_chevrons %}
                <button class="chips__scroll-btn chips__scroll-btn--left" data-scroll-left aria-label="Scroll filters left" hidden>‹</button>
              {% endif %}
              <div class="chips__row chips__row--pinned" role="navigation" aria-label="Quick availability" data-chiprow>
                <a class="chips__chip {% if in_stock_option.active %}is-active{% endif %}"
                   href="{% if in_stock_option.active %}{{ in_stock_option.url_to_remove }}{% else %}{{ in_stock_option.url_to_add }}{% endif %}"
                   data-np-chip>
                  In stock
                  {% if show_counts and in_stock_option.count %}<span class="chips__count">{{ in_stock_option.count }}</span>{% endif %}
                </a>
              </div>
              {% if section.settings.enable_chevrons %}
                <button class="chips__scroll-btn chips__scroll-btn--right" data-scroll-right aria-label="Scroll filters right" hidden>›</button>
              {% endif %}
            </div>
          {% endif %}
        {% endif %}
      {% endif %}

      {% if filter1_label_norm != blank %}
        {% assign chip_filter = blank %}
        {% for f in collection.filters %}
          {% assign flabel_norm = f.label | strip | downcase %}
          {% if flabel_norm == filter1_label_norm %}
            {% assign chip_filter = f %}
            {% break %}
          {% endif %}
        {% endfor %}

        {% if chip_filter %}
          <div class="chips__wrap" data-scroll-wrap>
            {% if section.settings.enable_chevrons %}
              <button class="chips__scroll-btn chips__scroll-btn--left" data-scroll-left aria-label="Scroll filters left" hidden>‹</button>
            {% endif %}
            <div class="chips__row" role="navigation" aria-label="{{ chip_filter.label | escape }}" data-chiprow>
              {% assign idx = 0 %}
              {%- assign values_source = chip_filter.values -%}
              {%- if section.settings.sort_by_count and show_counts -%}
                {%- assign values_source = chip_filter.values | sort: 'count' | reverse -%}
              {%- endif -%}
              {% for v in values_source %}
                {% if idx < max_chips %}
                  <a class="chips__chip {% if v.active %}is-active{% endif %}" data-np-chip
                     {% if v.active %}aria-current="true"{% endif %}
                     href="{% if v.active %}{{ v.url_to_remove }}{% else %}{{ v.url_to_add }}{% endif %}">
                    {{ v.label }}{% if show_counts and v.count %} <span class="chips__count">{{ v.count }}</span>{% endif %}
                  </a>
                  {% assign idx = idx | plus: 1 %}
                {% endif %}
              {% endfor %}
            </div>
            {% if section.settings.enable_chevrons %}
              <button class="chips__scroll-btn chips__scroll-btn--right" data-scroll-right aria-label="Scroll filters right" hidden>›</button>
            {% endif %}
          </div>
        {% endif %}
      {% endif %}

      {% if section.settings.enable_filter_2 and filter2_label_norm != blank %}
        {% assign chip_filter2 = blank %}
        {% for f in collection.filters %}
          {% assign flabel_norm = f.label | strip | downcase %}
          {% if flabel_norm == filter2_label_norm %}
            {% assign chip_filter2 = f %}
            {% break %}
          {% endif %}
        {% endfor %}

        {% if chip_filter2 %}
          <div class="chips__wrap" data-scroll-wrap>
            {% if section.settings.enable_chevrons %}
              <button class="chips__scroll-btn chips__scroll-btn--left" data-scroll-left aria-label="Scroll filters left" hidden>‹</button>
            {% endif %}
            <div class="chips__row" role="navigation" aria-label="{{ chip_filter2.label | escape }}" data-chiprow>
              {% assign idx2 = 0 %}
              {%- assign values_source2 = chip_filter2.values -%}
              {%- if section.settings.sort_by_count and show_counts -%}
                {%- assign values_source2 = chip_filter2.values | sort: 'count' | reverse -%}
              {%- endif -%}
              {% for v in values_source2 %}
                {% if idx2 < max_chips %}
                  <a class="chips__chip {% if v.active %}is-active{% endif %}" data-np-chip
                     {% if v.active %}aria-current="true"{% endif %}
                     href="{% if v.active %}{{ v.url_to_remove }}{% else %}{{ v.url_to_add }}{% endif %}">
                    {{ v.label }}{% if show_counts and v.count %} <span class="chips__count">{{ v.count }}</span>{% endif %}
                  </a>
                  {% assign idx2 = idx2 | plus: 1 %}
                {% endif %}
              {% endfor %}
            </div>
            {% if section.settings.enable_chevrons %}
              <button class="chips__scroll-btn chips__scroll-btn--right" data-scroll-right aria-label="Scroll filters right" hidden>›</button>
            {% endif %}
          </div>
        {% endif %}
      {% endif %}

      {%- if section.settings.debug -%}
        <div class="chips__debug"><small>Filter labels detected:
          {% for f in collection.filters %}<code>{{ f.label }}</code>{% unless forloop.last %}, {% endunless %}{% endfor %}
        </small></div>
      {%- endif -%}

    </div>
  </xo-container>
</section>
{% endif %}

<script>
(function(){
  var root = document.querySelector('.xo-section--{{ section.id }}');
  if (!root) return;

  root.querySelectorAll('.chips__row').forEach(function(row) {
    row.addEventListener('wheel', function(e) {
      if (Math.abs(e.deltaY) > Math.abs(e.deltaX)) {
        row.scrollLeft += e.deltaY;
        e.preventDefault();
      }
    }, { passive: false });
  });

  function setupWrap(wrap) {
    var row = wrap.querySelector('[data-chiprow]');
    if (!row) return;
    var left = wrap.querySelector('[data-scroll-left]');
    var right = wrap.querySelector('[data-scroll-right]');
    if (!left || !right) return;

    function update() {
      var overflow = row.scrollWidth > row.clientWidth + 2;
      var max = row.scrollWidth - row.clientWidth - 1;
      left.hidden = !overflow || row.scrollLeft <= 0;
      right.hidden = !overflow || row.scrollLeft >= max;
    }
    left.addEventListener('click', function() { row.scrollBy({ left: -Math.max(160, row.clientWidth * 0.66), behavior: 'smooth' }); });
    right.addEventListener('click', function() { row.scrollBy({ left: Math.max(160, row.clientWidth * 0.66), behavior: 'smooth' }); });
    row.addEventListener('scroll', update, { passive: true });
    new ResizeObserver(update).observe(row);
    update();
  }
  root.querySelectorAll('[data-scroll-wrap]').forEach(setupWrap);

  {% if section.settings.sticky %}
    var onScroll = function() { root.classList.toggle('is-stuck', window.scrollY > 8); };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  {% endif %}

  var chipLinks = root.querySelectorAll('a[data-np-chip]');
  chipLinks.forEach(function(a) {
    a.addEventListener('click', function() {
      try { sessionStorage.setItem('np-scroll-grid', '1'); } catch (e) {}
    });
  });

  try {
    if (sessionStorage.getItem('np-scroll-grid') === '1') {
      sessionStorage.removeItem('np-scroll-grid');
      var grid = document.getElementById('product-grid') ||
                 document.querySelector('[data-products]') ||
                 document.querySelector('.collection, main');
      if (grid) { grid.scrollIntoView({ behavior: 'smooth', block: 'start' }); }
    }
  } catch (e) {}
})();
</script>

{% schema %}
{
  "name": "Collection chips",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "background-1"
    },
    {
      "type": "checkbox",
      "id": "show_active",
      "label": "Show active filter chips",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "pin_in_stock",
      "label": "Pin \"In stock\" chip (if available)",
      "default": true
    },
    {
      "type": "header",
      "content": "Chip rows (choose filter labels)"
    },
    {
      "type": "text",
      "id": "filter_1_label",
      "label": "Filter 1 label",
      "default": "Goal / Need",
      "info": "Type the label exactly as it appears in your store (case-insensitive). Examples: Goal / Need, Form, Availability, Stack Level"
    },
    {
      "type": "checkbox",
      "id": "enable_filter_2",
      "label": "Enable Filter 2 row",
      "default": false
    },
    {
      "type": "text",
      "id": "filter_2_label",
      "label": "Filter 2 label",
      "default": "Form"
    },
    {
      "type": "range",
      "id": "limit",
      "label": "Max chips per row",
      "min": 6,
      "max": 32,
      "step": 1,
      "default": 16
    },
    {
      "type": "checkbox",
      "id": "show_counts",
      "label": "Show counts on chips",
      "default": true
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "checkbox",
      "id": "compact",
      "label": "Compact spacing",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "sticky",
      "label": "Stick to top when scrolling",
      "default": true
    },
    {
      "type": "header",
      "content": "UX Upgrades"
    },
    {
      "type": "checkbox",
      "id": "enable_chevrons",
      "label": "Show scroll chevrons when overflowing",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_summary",
      "label": "Show active filter summary line",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "sort_by_count",
      "label": "Sort chip rows by count (desc) when counts visible",
      "default": false
    },
    {
      "type": "header",
      "content": "Debug"
    },
    {
      "type": "checkbox",
      "id": "debug",
      "label": "Show detected filter labels (for setup)",
      "default": false
    }
  ],
  "presets": [
    { "name": "Collection chips" }
  ]
}
{% endschema %}
