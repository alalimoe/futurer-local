{% comment %}
  Collection • Chips only — Nootropix (Oomph Pack v2.1)
  Adds: chevrons, sticky shadow, active summary, scroll-to-grid, a11y polish
  Pipe-safe comparisons (labels are normalized first)
{% endcomment %}

{% if request.page_type == 'collection' %}
<a id="np-chipbar-anchor"></a>
<section class="np-chipbar {% if section.settings.compact %}np-chipbar--compact{% endif %}{% if section.settings.sticky %} np-chipbar--sticky{% endif %}">
  <div class="page-container np-chipbar__inner">

    {%- comment -%} Any active filters? {%- endcomment -%}
    {% assign has_active = false %}
    {% for f in collection.filters %}
      {% if f.active_values.size > 0 %}{% assign has_active = true %}{% break %}{% endif %}
    {% endfor %}

    {%- if section.settings.show_active and has_active -%}
      <div class="np-chiprow np-chiprow--active" role="region" aria-label="Active filters">
        {% for f in collection.filters %}
          {% for v in f.active_values %}
            <a class="np-chip is-active" href="{{ v.url_to_remove }}" data-np-chip aria-label="Remove {{ v.label | escape }}">
              {{ v.label }} <span aria-hidden="true">✕</span>
            </a>
          {% endfor %}
        {% endfor %}
        <a class="np-chip np-chip--muted" href="{{ collection.url }}" data-np-chip>Clear all</a>
      </div>

      {% if section.settings.show_summary %}
        <div class="np-summary" aria-live="polite">
          {% for f in collection.filters %}
            {% if f.active_values.size > 0 %}
              <span class="np-summary__item">
                <strong>{{ f.label }}:</strong>
                {% for v in f.active_values %}{{ v.label }}{% unless forloop.last %}, {% endunless %}{% endfor %}
              </span>
            {% endif %}
          {% endfor %}
        </div>
      {% endif %}
    {%- endif -%}

    {%- liquid
      assign show_counts = section.settings.show_counts
      assign max_chips = section.settings.limit | default: 16 | plus: 0

      assign filter1_label = section.settings.filter_1_label | strip
      assign filter2_label = section.settings.filter_2_label | strip

      assign filter1_label_norm = filter1_label | downcase
      assign filter2_label_norm = filter2_label | downcase
    -%}

    {%- comment -%} Optional pinned "In stock" from Availability {%- endcomment -%}
    {% if section.settings.pin_in_stock %}
      {% assign availability_label_norm = 'availability' %}
      {% assign avail_filter = blank %}
      {% for f in collection.filters %}
        {% assign flabel_norm = f.label | strip | downcase %}
        {% if flabel_norm == availability_label_norm %}
          {% assign avail_filter = f %}
          {% break %}
        {% endif %}
      {% endfor %}

      {% if avail_filter %}
        {% assign in_stock_option = blank %}
        {% for v in avail_filter.values %}
          {% assign vlabel_norm = v.label | strip | downcase %}
          {% if vlabel_norm contains 'in stock' %}
            {% assign in_stock_option = v %}
            {% break %}
          {% endif %}
        {% endfor %}
        {% if in_stock_option %}
          <div class="np-chipwrap" data-scroll-wrap>
            {% if section.settings.enable_chevrons %}
              <button class="np-scroll np-scroll--left" data-scroll-left aria-label="Scroll filters left" hidden>‹</button>
            {% endif %}
            <div class="np-chiprow np-chiprow--pinned" role="navigation" aria-label="Quick availability" data-chiprow>
              <a class="np-chip {% if in_stock_option.active %}is-active{% endif %}"
                 href="{% if in_stock_option.active %}{{ in_stock_option.url_to_remove }}{% else %}{{ in_stock_option.url_to_add }}{% endif %}"
                 data-np-chip>
                In stock
                {% if show_counts and in_stock_option.count %}<span class="np-count">{{ in_stock_option.count }}</span>{% endif %}
              </a>
            </div>
            {% if section.settings.enable_chevrons %}
              <button class="np-scroll np-scroll--right" data-scroll-right aria-label="Scroll filters right" hidden>›</button>
            {% endif %}
          </div>
        {% endif %}
      {% endif %}
    {% endif %}

    {%- comment -%} Chip row 1 (e.g., Goal / Need) {%- endcomment -%}
    {% if filter1_label_norm != blank %}
      {% assign chip_filter = blank %}
      {% for f in collection.filters %}
        {% assign flabel_norm = f.label | strip | downcase %}
        {% if flabel_norm == filter1_label_norm %}
          {% assign chip_filter = f %}
          {% break %}
        {% endif %}
      {% endfor %}

      {% if chip_filter %}
        <div class="np-chipwrap" data-scroll-wrap>
          {% if section.settings.enable_chevrons %}
            <button class="np-scroll np-scroll--left" data-scroll-left aria-label="Scroll filters left" hidden>‹</button>
          {% endif %}
          <div class="np-chiprow" role="navigation" aria-label="{{ chip_filter.label | escape }}" data-chiprow>
            {% assign idx = 0 %}

            {%- assign values_source = chip_filter.values -%}
            {%- if section.settings.sort_by_count and show_counts -%}
              {%- assign values_source = chip_filter.values | sort: 'count' | reverse -%}
            {%- endif -%}

            {% for v in values_source %}
              {% if idx < max_chips %}
                <a class="np-chip {% if v.active %}is-active{% endif %}" data-np-chip
                   {% if v.active %}aria-current="true"{% endif %}
                   href="{% if v.active %}{{ v.url_to_remove }}{% else %}{{ v.url_to_add }}{% endif %}">
                  {{ v.label }}{% if show_counts and v.count %} <span class="np-count">{{ v.count }}</span>{% endif %}
                </a>
                {% assign idx = idx | plus: 1 %}
              {% endif %}
            {% endfor %}
          </div>
          {% if section.settings.enable_chevrons %}
            <button class="np-scroll np-scroll--right" data-scroll-right aria-label="Scroll filters right" hidden>›</button>
          {% endif %}
        </div>
      {% endif %}
    {% endif %}

    {%- comment -%} Chip row 2 (optional, e.g., Form) {%- endcomment -%}
    {% if section.settings.enable_filter_2 and filter2_label_norm != blank %}
      {% assign chip_filter2 = blank %}
      {% for f in collection.filters %}
        {% assign flabel_norm = f.label | strip | downcase %}
        {% if flabel_norm == filter2_label_norm %}
          {% assign chip_filter2 = f %}
          {% break %}
        {% endif %}
      {% endfor %}

      {% if chip_filter2 %}
        <div class="np-chipwrap" data-scroll-wrap>
          {% if section.settings.enable_chevrons %}
            <button class="np-scroll np-scroll--left" data-scroll-left aria-label="Scroll filters left" hidden>‹</button>
          {% endif %}
          <div class="np-chiprow" role="navigation" aria-label="{{ chip_filter2.label | escape }}" data-chiprow>
            {% assign idx2 = 0 %}

            {%- assign values_source2 = chip_filter2.values -%}
            {%- if section.settings.sort_by_count and show_counts -%}
              {%- assign values_source2 = chip_filter2.values | sort: 'count' | reverse -%}
            {%- endif -%}

            {% for v in values_source2 %}
              {% if idx2 < max_chips %}
                <a class="np-chip {% if v.active %}is-active{% endif %}" data-np-chip
                   {% if v.active %}aria-current="true"{% endif %}
                   href="{% if v.active %}{{ v.url_to_remove }}{% else %}{{ v.url_to_add }}{% endif %}">
                  {{ v.label }}{% if show_counts and v.count %} <span class="np-count">{{ v.count }}</span>{% endif %}
                </a>
                {% assign idx2 = idx2 | plus: 1 %}
              {% endif %}
            {% endfor %}
          </div>
          {% if section.settings.enable_chevrons %}
            <button class="np-scroll np-scroll--right" data-scroll-right aria-label="Scroll filters right" hidden>›</button>
          {% endif %}
        </div>
      {% endif %}
    {% endif %}

    {%- if section.settings.debug -%}
      <div class="np-debug"><small>Filter labels detected:
        {% for f in collection.filters %}<code>{{ f.label }}</code>{% unless forloop.last %}, {% endunless %}{% endfor %}
      </small></div>
    {%- endif -%}

  </div>
</section>
{% endif %}

<style>
:root{ --np-accent: var(--color-accent-primary, #FBBF24); }

/* ── Container ── */
.np-chipbar{
  border-bottom:1px solid var(--color-border-subtle, #F3F4F6);
  margin-bottom:8px;
  background:var(--color-surface-primary, #fff);
}
.np-chipbar--compact{ margin-bottom:4px }
.np-chipbar--sticky{ position:sticky; top:0; z-index:6; }
.np-chipbar__inner{ padding-top:12px; padding-bottom:12px; }

/* Frosted glass when stuck */
.np-chipbar--sticky.is-stuck{
  background:rgba(255,255,255,0.92);
  -webkit-backdrop-filter:blur(12px); backdrop-filter:blur(12px);
  box-shadow:var(--shadow-xs);
  border-bottom-color:transparent;
}

/* ── Active-filter summary ── */
.np-summary{ display:flex; gap:10px; flex-wrap:wrap; align-items:center; margin:2px 0 6px; }
.np-summary__item{ font-size:var(--font-size-body-sm, .875rem); color:var(--color-text-secondary); }
.np-summary__item strong{ color:var(--color-text-primary); }

/* ── Chevron scroll buttons ── */
.np-chipwrap{ position:relative; }
.np-scroll{
  position:absolute; top:50%; transform:translateY(-50%);
  width:34px; height:34px; border-radius:var(--nx-radius-pill);
  display:flex; align-items:center; justify-content:center;
  font-size:16px; cursor:pointer; user-select:none; z-index:2;
  background:var(--color-surface-primary, #fff);
  border:1px solid var(--color-border-default, #E5E7EB);
  box-shadow:var(--shadow-xs);
  -webkit-backdrop-filter:blur(8px); backdrop-filter:blur(8px);
  transition:var(--transition-smooth, all .3s ease);
  color:var(--color-text-secondary);
}
.np-scroll:hover{
  border-color:var(--np-accent);
  box-shadow:var(--shadow-sm), 0 0 0 2px rgba(251,191,36,0.08);
  transform:translateY(-50%) scale(1.06);
  color:var(--color-text-primary);
}
.np-scroll:focus-visible{ outline:2px solid var(--color-accent-dark, #92400e); outline-offset:2px; }
.np-scroll[hidden]{ display:none; }
.np-scroll--left{ left:-2px; }
.np-scroll--right{ right:-2px; }

/* ── Chip rows ── */
.np-chiprow{
  display:flex; gap:8px; flex-wrap:nowrap; overflow-x:auto;
  padding:4px 2px 8px; margin:0;
  -webkit-overflow-scrolling:touch; scroll-snap-type:x proximity;
  mask-image:linear-gradient(to right, transparent, black 12px, black calc(100% - 12px), transparent);
}
.np-chiprow--active{ padding-top:4px; }
.np-chiprow--pinned{ padding-top:2px; }

/* ── Chips ── */
.np-chip{
  scroll-snap-align:start; white-space:nowrap;
  display:inline-flex; align-items:center; gap:6px;
  border:1px solid rgba(229,231,235,0.7);
  border-radius:var(--nx-radius-pill);
  padding:8px 16px;
  font-size:var(--font-size-body-sm, .875rem);
  font-weight:500;
  color:var(--color-text-secondary);
  text-decoration:none; line-height:1;
  min-height:44px; box-sizing:border-box;
  background:var(--color-surface-primary, #fff);
  box-shadow:none;
  transition:var(--transition-premium, all .4s cubic-bezier(.25,.8,.25,1));
}
.np-chip:hover{
  border-color:var(--np-accent);
  color:var(--color-text-primary);
  background:var(--color-surface-primary);
  box-shadow:var(--shadow-xs);
  transform:translateY(-1px);
}
.np-chip:active{ transform:translateY(0) scale(0.97); }

/* Active gold signature */
.np-chip.is-active{
  border-color:rgba(251,191,36,0.6);
  font-weight:600;
  color:var(--color-accent-dark, #92400e);
  background:rgba(251,191,36,0.06);
  box-shadow:0 0 0 1px rgba(251,191,36,0.15), 0 2px 8px rgba(251,191,36,0.10);
}
.np-chip.is-active:hover{
  background:rgba(251,191,36,0.10);
  box-shadow:0 0 0 1px rgba(251,191,36,0.25), 0 4px 12px rgba(251,191,36,0.14);
}

/* Dismiss / clear-all */
.np-chiprow--active .np-chip.is-active{
  background:rgba(251,191,36,0.05);
  color:var(--color-accent-dark);
}
.np-chip--muted{
  background:transparent;
  border-color:transparent;
  color:var(--color-text-secondary);
  font-weight:500;
  text-decoration:underline;
  text-decoration-color:transparent;
  text-underline-offset:3px;
  box-shadow:none;
}
.np-chip--muted:hover{
  text-decoration-color:var(--color-text-secondary);
  background:transparent;
  border-color:transparent;
  box-shadow:none;
  transform:none;
}

.np-chip:focus-visible{ outline:2px solid var(--color-accent-dark, #92400e); outline-offset:2px; }

/* ── Count badge ── */
@keyframes ntx-count-flash{
  0%  { color:inherit; }
  30% { color:var(--np-accent, #FBBF24); transform:scale(1.15); }
  100%{ color:inherit; transform:scale(1); }
}
.np-count{ font-variant-numeric:tabular-nums; font-size:.8em; opacity:.55; transition:color .3s ease; }
.np-count.is-changed{ animation:ntx-count-flash .4s ease-out; }

/* ── Scrollbar ── */
.np-chiprow::-webkit-scrollbar{ height:4px; }
.np-chiprow::-webkit-scrollbar-thumb{ background:rgba(0,0,0,0.08); border-radius:var(--nx-radius-pill); }
.np-chiprow::-webkit-scrollbar-track{ background:transparent; }

/* ── Dark mode ── */
@media (prefers-color-scheme: dark){
  .np-chipbar{ background:var(--color-surface-tertiary, #111827); border-bottom-color:rgba(255,255,255,.08); }
  .np-chipbar--sticky.is-stuck{ background:rgba(17,24,39,0.92); }
  .np-chip{ border-color:rgba(255,255,255,.10); background:rgba(255,255,255,.04); color:rgba(255,255,255,.7); }
  .np-chip:hover{ border-color:var(--np-accent); color:#fff; background:rgba(255,255,255,.06); }
  .np-chip.is-active{ background:rgba(251,191,36,.08); color:var(--np-accent); border-color:rgba(251,191,36,.4); }
  .np-scroll{ background:var(--color-surface-tertiary); border-color:rgba(255,255,255,.1); color:rgba(255,255,255,.6); }
  .np-scroll:hover{ border-color:var(--np-accent); color:#fff; }
  .np-chiprow::-webkit-scrollbar-thumb{ background:rgba(255,255,255,0.08); }
}

/* ── Mobile density ── */
@media (max-width: 767px){
  .np-chip{ padding:7px 12px; font-size:0.8125rem; }
  .np-chipbar__inner{ padding-top:10px; padding-bottom:10px; }
}

/* ── Reduced motion ── */
@media (prefers-reduced-motion: reduce){
  .np-chip, .np-scroll{ transition:none; }
}

.np-debug{ margin-top:4px; opacity:.65; }
.np-debug code{ background:rgba(0,0,0,.04); padding:2px 4px; border-radius:4px; }
</style>

<script>
document.addEventListener('DOMContentLoaded', function(){
  // 1) Wheel-to-scroll
  document.querySelectorAll('.np-chiprow').forEach(function(row){
    row.addEventListener('wheel', function(e){
      if(Math.abs(e.deltaY) > Math.abs(e.deltaX)){
        row.scrollLeft += e.deltaY; e.preventDefault();
      }
    }, {passive:false});
  });

  // 2) Smart chevrons
  function setupWrap(wrap){
    var row = wrap.querySelector('[data-chiprow]');
    if(!row) return;
    var left = wrap.querySelector('[data-scroll-left]');
    var right = wrap.querySelector('[data-scroll-right]');
    if(!left || !right) return;

    function update(){
      var overflow = row.scrollWidth > row.clientWidth + 2;
      var max = row.scrollWidth - row.clientWidth - 1;
      left.hidden = !overflow || row.scrollLeft <= 0;
      right.hidden = !overflow || row.scrollLeft >= max;
      wrap.classList.toggle('is-overflowing', overflow);
    }
    left.addEventListener('click', function(){ row.scrollBy({left: -Math.max(160, row.clientWidth * 0.66), behavior:'smooth'}); });
    right.addEventListener('click', function(){ row.scrollBy({left:  Math.max(160, row.clientWidth * 0.66), behavior:'smooth'}); });
    row.addEventListener('scroll', update, {passive:true});
    new ResizeObserver(update).observe(row);
    update();
  }
  document.querySelectorAll('[data-scroll-wrap]').forEach(setupWrap);

  // 3) Sticky shadow toggle
  var sticky = document.querySelector('.np-chipbar--sticky');
  if(sticky){
    var onScroll = function(){ sticky.classList.toggle('is-stuck', window.scrollY > 8); };
    onScroll(); window.addEventListener('scroll', onScroll, {passive:true});
  }

  // 4) Scroll to grid after click (keeps user near products)
  var chipLinks = document.querySelectorAll('.np-chipbar a[data-np-chip]');
  chipLinks.forEach(function(a){
    a.addEventListener('click', function(){
      try{ sessionStorage.setItem('np-scroll-grid','1'); }catch(e){}
    });
  });

  // 5) On load, if a filter was clicked, scroll to product grid
  try{
    if(sessionStorage.getItem('np-scroll-grid') === '1'){
      sessionStorage.removeItem('np-scroll-grid');
      var grid = document.getElementById('product-grid') ||
                 document.querySelector('[data-products]') ||
                 document.querySelector('.collection, main');
      if(grid){ grid.scrollIntoView({behavior:'smooth', block:'start'}); }
    }
  }catch(e){}
});
</script>

{% schema %}
{
  "name": "Collection • Chips only",
  "settings": [
    { "type": "checkbox", "id": "show_active", "label": "Show active filter chips", "default": true },
    { "type": "checkbox", "id": "pin_in_stock", "label": "Pin \"In stock\" chip (if available)", "default": true },

    { "type": "header", "content": "Chip rows (choose filter labels)" },
    { "type": "text", "id": "filter_1_label", "label": "Filter 1 label", "default": "Goal / Need", "info": "Type the label exactly as it appears in your store (case-insensitive). Examples: Goal / Need, Form, Availability, Stack Level" },
    { "type": "checkbox", "id": "enable_filter_2", "label": "Enable Filter 2 row", "default": false },
    { "type": "text", "id": "filter_2_label", "label": "Filter 2 label", "default": "Form" },
    { "type": "range", "id": "limit", "label": "Max chips per row", "min": 6, "max": 32, "step": 1, "default": 16 },
    { "type": "checkbox", "id": "show_counts", "label": "Show counts on chips", "default": true },

    { "type": "header", "content": "Layout" },
    { "type": "checkbox", "id": "compact", "label": "Compact spacing", "default": true },
    { "type": "checkbox", "id": "sticky", "label": "Stick to top when scrolling", "default": true },

    { "type": "header", "content": "UX Upgrades" },
    { "type": "checkbox", "id": "enable_chevrons", "label": "Show scroll chevrons when overflowing", "default": true },
    { "type": "checkbox", "id": "show_summary", "label": "Show active filter summary line", "default": true },
    { "type": "checkbox", "id": "sort_by_count", "label": "Sort chip rows by count (desc) when counts visible", "default": false },

    { "type": "header", "content": "Debug" },
    { "type": "checkbox", "id": "debug", "label": "Show detected filter labels (for setup)", "default": false }
  ],
  "presets": [
    { "name": "Collection • Chips only" }
  ]
}
{% endschema %}
