{%- style -%}
  .xo-section--{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .xo-section--{{ section.id }} .ual-heading {
    font-family: var(--font-heading-family);
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    font-weight: 600;
    color: rgba(var(--color-foreground));
    margin: 0 0 16px;
    text-align: center;
    letter-spacing: -0.02em;
  }

  .xo-section--{{ section.id }} .ual-intro {
    font-size: 1rem;
    line-height: 1.7;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent);
    margin: 0 0 40px;
    text-align: center;
    max-width: 640px;
    margin-inline: auto;
  }

  .xo-section--{{ section.id }} .ual-faq {
    margin-bottom: 40px;
  }

  .xo-section--{{ section.id }} .ual-item {
    border-bottom: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
  }

  .xo-section--{{ section.id }} .ual-item:first-child {
    border-top: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
  }

  .xo-section--{{ section.id }} .ual-q {
    padding: 20px 0;
    font-weight: 600;
    font-size: 1rem;
    color: rgba(var(--color-foreground));
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    list-style: none;
    transition: color 0.2s var(--out-soft, ease);
    min-height: 44px;
  }

  .xo-section--{{ section.id }} .ual-q::-webkit-details-marker {
    display: none;
  }

  .xo-section--{{ section.id }} .ual-q:hover {
    color: rgba(var(--color-accent));
  }

  .xo-section--{{ section.id }} .ual-chevron {
    width: 22px;
    height: 22px;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent);
    transition: transform 0.3s var(--out-soft, ease);
    flex-shrink: 0;
  }

  .xo-section--{{ section.id }} .ual-item[open] .ual-chevron {
    transform: rotate(180deg);
    color: rgba(var(--color-accent));
  }

  .xo-section--{{ section.id }} .ual-a {
    padding: 0 0 24px;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent);
    font-size: 0.9375rem;
    line-height: 1.7;
    animation: ualSlide--{{ section.id }} 0.3s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .ual-a-inner {
    border-left: 2px solid rgba(var(--color-accent));
    padding-left: 16px;
  }

  @keyframes ualSlide--{{ section.id }} {
    from { opacity: 0; transform: translateY(-4px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .xo-section--{{ section.id }} .ual-disclaimer {
    display: flex;
    gap: 14px;
    padding: 20px;
    background: color-mix(in srgb, rgba(var(--color-error)) 5%, transparent);
    border: 1px solid color-mix(in srgb, rgba(var(--color-error)) 25%, transparent);
    border-radius: var(--general-radius-1, 1rem);
  }

  .xo-section--{{ section.id }} .ual-disclaimer-icon {
    flex-shrink: 0;
    color: rgba(var(--color-error));
    margin-top: 2px;
  }

  .xo-section--{{ section.id }} .ual-disclaimer-text {
    font-size: 0.875rem;
    line-height: 1.6;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent);
    margin: 0 0 10px;
  }

  .xo-section--{{ section.id }} .ual-refs {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 8px 16px;
  }

  .xo-section--{{ section.id }} .ual-refs a {
    font-size: 0.8125rem;
    font-weight: 600;
    color: rgba(var(--color-accent));
    text-decoration: none;
  }

  .xo-section--{{ section.id }} .ual-refs a:hover {
    text-decoration: underline;
  }

  .xo-section--{{ section.id }} .ual-inner {
    max-width: 750px;
    margin: 0 auto;
  }

  .xo-section--{{ section.id }} :focus-visible {
    outline: 2px solid rgba(var(--color-accent));
    outline-offset: 2px;
  }

  @media (prefers-reduced-motion: reduce) {
    .xo-section--{{ section.id }} *,
    .xo-section--{{ section.id }} *::before,
    .xo-section--{{ section.id }} *::after {
      animation-duration: 0.01ms !important;
      transition-duration: 0.01ms !important;
    }
  }
{%- endstyle -%}

{%- assign ual_faqs = section.blocks | where: "type", "faq" -%}
{% if ual_faqs.size > 0 %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {%- for block in ual_faqs -%}
    {
      "@type": "Question",
      "name": {{ block.settings.question | json }},
      "acceptedAnswer": {
        "@type": "Answer",
        "text": {{ block.settings.answer | strip_html | json }}
      }
    }{%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
  ]
}
</script>
{% endif %}

<section id="uae-legality" {% render 'section-attr' %}>
  <xo-container>
    <div class="ual-inner">
      {% if section.settings.heading != blank %}
        <h2 class="ual-heading">{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.intro != blank %}
        <p class="ual-intro">{{ section.settings.intro }}</p>
      {% endif %}

      {% if ual_faqs.size > 0 %}
        <div class="ual-faq">
          {% for block in ual_faqs %}
            <details class="ual-item" {{ block.shopify_attributes }}>
              <summary class="ual-q">
                {{ block.settings.question }}
                <span class="ual-chevron"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg></span>
              </summary>
              <div class="ual-a"><div class="ual-a-inner">{{ block.settings.answer }}</div></div>
            </details>
          {% endfor %}
        </div>
      {% endif %}

      {% if section.settings.disclaimer != blank %}
        <div class="ual-disclaimer">
          <svg class="ual-disclaimer-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
          <div>
            <p class="ual-disclaimer-text">{{ section.settings.disclaimer }}</p>
            <ul class="ual-refs">
              {%- for i in (1..3) -%}
                {%- assign rt = 'ref_' | append: i | append: '_text' -%}
                {%- assign ru = 'ref_' | append: i | append: '_url' -%}
                {%- if section.settings[rt] != blank and section.settings[ru] != blank -%}
                  <li><a href="{{ section.settings[ru] }}" rel="nofollow noopener" target="_blank">{{ section.settings[rt] }}</a></li>
                {%- endif -%}
              {%- endfor -%}
            </ul>
          </div>
        </div>
      {% endif %}
    </div>
  </xo-container>
</section>

{% schema %}
{
  "name": "UAE Legality",
  "tag": "section",
  "class": "section-uae-legality",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "default" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Legality and Customs" },
    { "type": "textarea", "id": "intro", "label": "Intro Text", "default": "Supplement regulations in the UAE are managed by MOHAP. Most nootropics we carry are sold as dietary supplements — but some substances may require approval." },
    { "type": "header", "content": "Disclaimer" },
    { "type": "textarea", "id": "disclaimer", "label": "Disclaimer Text", "default": "This page is informational only and not legal or medical advice. Regulations can change without notice. For personal-use import approvals or controlled items, consult official sources." },
    { "type": "text", "id": "ref_1_text", "label": "Reference 1 Text", "default": "Nootropix Legality Guide" },
    { "type": "url", "id": "ref_1_url", "label": "Reference 1 URL" },
    { "type": "text", "id": "ref_2_text", "label": "Reference 2 Text", "default": "UAE Gov: Drugs & Controlled Medicines" },
    { "type": "text", "id": "ref_2_url", "label": "Reference 2 URL (external)", "default": "https://u.ae/en/information-and-services/health-and-fitness/handling-medicines/drugs-and-controlled-medicines" },
    { "type": "text", "id": "ref_3_text", "label": "Reference 3 Text", "default": "Dubai Customs" },
    { "type": "text", "id": "ref_3_url", "label": "Reference 3 URL (external)", "default": "https://www.dubaicustoms.gov.ae" },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding top", "default": 80 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding bottom", "default": 80 }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "Legality FAQ",
      "settings": [
        { "type": "text", "id": "question", "label": "Question" },
        { "type": "textarea", "id": "answer", "label": "Answer" }
      ]
    },
    { "type": "@app" }
  ],
  "presets": [
    {
      "name": "UAE Legality",
      "blocks": [
        { "type": "faq", "settings": { "question": "Are nootropics legal in the UAE?", "answer": "Many are sold as dietary supplements. Certain substances may be restricted or require approval. Always check the latest MOHAP guidance." } },
        { "type": "faq", "settings": { "question": "Do I need approval to import personal meds?", "answer": "Some medicines require prior MOHAP approval. Supplements with restricted ingredients may be stopped by customs." } }
      ]
    }
  ]
}
{% endschema %}
