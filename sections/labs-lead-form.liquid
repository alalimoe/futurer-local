{% comment %} Labs — Lead Capture Form (short) {% endcomment %}
{%- assign sid = section.id | replace:'_','' | downcase -%}
<style>
#labs-form-{{ sid }}{ --b:var(--color-border-default); }
#labs-form-{{ sid }} .f-wrap{ padding:24px var(--page-gutter); border-top:1px solid var(--b); background:var(--color-surface-secondary); }
#labs-form-{{ sid }} .f-container{ max-width:{{ section.settings.maxw | default:1200 }}px; margin:0 auto; }
#labs-form-{{ sid }} .box{ border:1px solid var(--b); border-radius:14px; background:var(--color-surface-primary); padding:16px; }
#labs-form-{{ sid }} .title{ margin:0 0 8px; font-weight:800; }
#labs-form-{{ sid }} .grid{ display:grid; gap:10px; grid-template-columns:1fr 1fr; }
@media(max-width:780px){ #labs-form-{{ sid }} .grid{ grid-template-columns:1fr; } }
#labs-form-{{ sid }} .input, #labs-form-{{ sid }} textarea{
  height:44px; border:1px solid var(--b); border-radius:12px; padding:0 12px; width:100%;
}
#labs-form-{{ sid }} textarea{ height:96px; padding:10px 12px; }
#labs-form-{{ sid }} .btn{ display:inline-flex; align-items:center; justify-content:center; height:46px; padding:0 16px; border-radius:12px; background:var(--color-accent-primary); color:var(--color-text-primary); font-weight:800; border:0; }
#labs-form-{{ sid }} .row{ display:flex; gap:10px; flex-wrap:wrap; align-items:center; margin-top:10px; }
#labs-form-{{ sid }} .ok{ color:var(--color-success); }
#labs-form-{{ sid }} .err{ color:var(--color-error); }
</style>

<section id="labs-form-{{ sid }}" class="pdp-section" aria-label="Request wholesale access">
  <div class="f-wrap">
    <div class="f-container">
      <div class="box">
        <h2 class="title">{{ section.settings.title | default: 'Request Wholesale Access' }}</h2>
        <p>{{ section.settings.sub | default: 'Tell us a little about your lab and volume needs. We’ll get back to you fast.' }}</p>

        {% form 'contact', id: 'labs-wholesale' %}
          <input type="hidden" name="contact[tags]" value="wholesale,labs,b2b">
          <div class="grid">
            <input class="input" type="text" name="contact[lab_name]" placeholder="Lab name" required autocomplete="organization">
            <input class="input" type="email" name="contact[email]" placeholder="Work email" required autocomplete="email">
          </div>
          <div class="grid" style="grid-template-columns:1fr;">
            <textarea name="contact[volume_requirement]" placeholder="Volume requirement (e.g., 10+ vials/month, specific peptides)"></textarea>
          </div>
          <div class="row">
            <button class="btn btn--primary" type="submit">Request Wholesale Access</button>
            {% if form.posted_successfully? %}<span class="ok">Thanks — we’ll be in touch shortly.</span>{% endif %}
            {% if form.errors %}<span class="err">{{ form.errors | default_errors }}</span>{% endif %}
          </div>
        {% endform %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name":"Labs · Lead form",
  "settings":[
    { "type":"range","id":"maxw","min":800,"max":1600,"step":10,"unit":"px","label":"Max width","default":1200 },
    { "type":"text","id":"title","label":"Heading","default":"Request Wholesale Access" },
    { "type":"textarea","id":"sub","label":"Subtext","default":"Tell us a little about your lab and volume needs. We’ll get back to you fast." }
  ],
  "presets":[{ "name":"Labs · Lead form" }]
}
{% endschema %}
