<section class="np-surface">
  {{ 'blog-home.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'blog-home.js' | asset_url }}" defer></script>

  <div class="np-wrap np-hero">
    <h1>{{ section.settings.title | default: blog.title }}</h1>
    {% if section.settings.subheading != blank %}
      <p>{{ section.settings.subheading }}</p>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Blog Hero Title",
  "settings": [
    { "type":"text", "id":"title", "label":"Title", "default": "Nootropix Blog" },
    { "type":"textarea", "id":"subheading", "label":"Subheading", "default":"Science‑backed guides on focus, memory, energy, and brain health." }
  ],
  "presets":[{ "name":"NP • Blog Hero Title" }]
}
{% endschema %}
