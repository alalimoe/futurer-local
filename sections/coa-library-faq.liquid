{%- style -%}
  .xo-section--{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .xo-section--{{ section.id }} .clq-container {
    max-width: 750px;
    margin: 0 auto;
  }

  .xo-section--{{ section.id }} .clq-title {
    text-align: center;
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    font-weight: 600;
    color: rgba(var(--color-foreground));
    margin: 0 0 48px;
    letter-spacing: -0.02em;
  }

  .xo-section--{{ section.id }} .clq-list {
    display: flex;
    flex-direction: column;
  }

  .xo-section--{{ section.id }} .clq-item {
    border-bottom: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
    transition: border-color 0.3s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .clq-item:first-child {
    border-top: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
  }

  .xo-section--{{ section.id }} .clq-item[open] {
    border-bottom-color: rgba(var(--color-accent));
  }

  .xo-section--{{ section.id }} .clq-q {
    padding: 24px 0;
    font-weight: 600;
    font-size: 1.0625rem;
    color: rgba(var(--color-foreground));
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    list-style: none;
    transition: color 0.2s var(--out-soft, ease);
    min-height: 44px;
  }

  .xo-section--{{ section.id }} .clq-q::-webkit-details-marker {
    display: none;
  }

  .xo-section--{{ section.id }} .clq-q:hover {
    color: rgba(var(--color-accent));
  }

  .xo-section--{{ section.id }} .clq-icon {
    width: 24px;
    height: 24px;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent);
    transition: transform 0.3s var(--out-soft, ease);
    flex-shrink: 0;
  }

  .xo-section--{{ section.id }} .clq-item[open] .clq-icon {
    transform: rotate(180deg);
    color: rgba(var(--color-accent));
  }

  .xo-section--{{ section.id }} .clq-a {
    padding: 0 0 28px 0;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent);
    font-size: 1rem;
    line-height: 1.75;
  }

  .xo-section--{{ section.id }} .clq-a-inner {
    border-left: 2px solid rgba(var(--color-accent));
    padding-left: 16px;
  }

  .xo-section--{{ section.id }} :focus-visible {
    outline: 2px solid rgba(var(--color-accent));
    outline-offset: 2px;
  }

  @media (prefers-reduced-motion: reduce) {
    .xo-section--{{ section.id }} .clq-item,
    .xo-section--{{ section.id }} .clq-q,
    .xo-section--{{ section.id }} .clq-icon {
      transition: none;
    }
  }
{%- endstyle -%}

{%- comment -%} ── FAQPage JSON-LD ── {%- endcomment -%}
{%- assign has_faq_ld = false -%}
{%- for block in section.blocks -%}
  {%- if block.type == 'faq' and block.settings.question != blank and block.settings.answer != blank -%}
    {%- assign has_faq_ld = true -%}
    {%- break -%}
  {%- endif -%}
{%- endfor -%}

{%- if has_faq_ld -%}
  {%- capture faq_json -%}
  [
    {%- assign first = true -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'faq' and block.settings.question != blank and block.settings.answer != blank -%}
        {%- if first == false -%},{%- endif -%}
        {"@type":"Question","name":{{ block.settings.question | strip | json }},"acceptedAnswer":{"@type":"Answer","text":{{ block.settings.answer | strip_html | strip | json }}}}
        {%- assign first = false -%}
      {%- endif -%}
    {%- endfor -%}
  ]
  {%- endcapture -%}
  <script type="application/ld+json">
  {"@context":"https://schema.org","@type":"FAQPage","mainEntity":{{ faq_json | strip }}}
  </script>
{%- endif -%}

<section {% render 'section-attr' %}>
  <xo-container>
    <div class="clq-container">
      {% if section.settings.title != blank %}
        <h2 class="clq-title">{{ section.settings.title }}</h2>
      {% endif %}
      <div class="clq-list">
        {% for block in section.blocks %}
          {% if block.type == 'faq' %}
            <details class="clq-item" {{ block.shopify_attributes }}>
              <summary class="clq-q">
                {{ block.settings.question }}
                <span class="clq-icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
                </span>
              </summary>
              <div class="clq-a"><div class="clq-a-inner">{{ block.settings.answer }}</div></div>
            </details>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </xo-container>
</section>

{% schema %}
{
  "name": "COA Library FAQ",
  "tag": "section",
  "class": "section-coa-library-faq",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "default"
    },
    { "type": "text", "id": "title", "label": "Heading", "default": "Frequently Asked Questions" },
    { "type": "header", "content": "Spacing" },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ",
      "settings": [
        { "type": "text", "id": "question", "label": "Question" },
        { "type": "textarea", "id": "answer", "label": "Answer" }
      ]
    },
    { "type": "@app" }
  ],
  "presets": [
    {
      "name": "COA Library FAQ",
      "blocks": [
        { "type": "faq", "settings": { "question": "Are COAs batch-specific?", "answer": "COAs only matter when they match a real batch/lot. Always match the lot on your unit to the lot shown on the COA." } },
        { "type": "faq", "settings": { "question": "Do COAs guarantee legality or regulatory status?", "answer": "No. A COA is a lab document about analysis results. Legality depends on ingredient classification, labeling, and import context." } }
      ]
    }
  ]
}
{% endschema %}
