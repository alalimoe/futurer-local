{% comment %} About our peptides — intro copy {% endcomment %}

{%- style -%}
  .xo-section--{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .xo-section--{{ section.id }} .i-grid {
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: 18px;
  }
  @media (max-width: 768px) {
    .xo-section--{{ section.id }} .i-grid {
      grid-template-columns: 1fr;
    }
  }

  .xo-section--{{ section.id }} .i-title {
    margin: 0;
    color: rgba(var(--color-foreground));
    font-weight: 600;
  }

  .xo-section--{{ section.id }} .i-body {
    background: rgba(var(--color-background));
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
    border-radius: var(--general-radius-1, 1rem);
    padding: 14px;
  }

  .xo-section--{{ section.id }} .i-body p {
    color: color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent);
    margin: 0;
  }
{%- endstyle -%}

<section {% render 'section-attr' %}>
  <xo-container>
    <div class="i-grid">
      <div><h2 class="i-title">{{ section.settings.title | default: 'About our peptides' }}</h2></div>
      <div class="i-body">
        {{ section.settings.rich | default: "<p>Every batch is independently tested for identity (FTIR), purity & potency (HPLC). We publish downloadable COAs and ship fast, worldwide. Research use only.</p>" }}
      </div>
    </div>
  </xo-container>
</section>

{% schema %}
{
  "name": "Pillar intro",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "default" },
    { "type": "text", "id": "title", "label": "Heading", "default": "About our peptides" },
    { "type": "richtext", "id": "rich", "label": "Body" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding top", "default": 24 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding bottom", "default": 24 }
  ],
  "blocks": [
    {
      "type": "@app"
    }
  ],
  "presets": [{ "name": "Pillar intro" }]
}
{% endschema %}
