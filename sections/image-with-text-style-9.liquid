{{ 'img-with-text-9.css' | asset_url | stylesheet_tag }}
{{ 'section-image-with-text-style-9.css' | asset_url | stylesheet_tag }}

{% liquid
  assign heading = section.settings.text_heading
  assign sub_heading = section.settings.sub_heading
  assign description = section.settings.description
  assign alignment_desktop = section.settings.alignment_desktop
  assign alignment_mobile = section.settings.alignment_mobile
  assign expand_grid = section.settings.expand_grid
%}

<section {% render 'section-attr' %}>
  <div class="xo-image-with-text-style-9">
    {% render 'section-bg-image' %}
    <xo-container class="xo-image-with-text-style-9__container">
      <div class="xo-image-with-text-style-9__content">
        {% render 'img-with-text-9',
          heading: heading,
          sub_heading: sub_heading,
          description: description,
          alignment_desktop: alignment_desktop,
          alignment_mobile: alignment_mobile,
          expand_grid: expand_grid
        %}
      </div>
    </xo-container>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.image_with_text_style_9.name",
  "class": "section-image-with-text-style-9",
  "disabled_on": {
    "groups": [
      "header",
      "footer",
      "custom.overlay",
      "custom.popups",
      "custom.features"
    ]
  },
  "settings": [
    {
      "type": "header",
      "content": "Text"
    },
    {
      "type": "select",
      "id": "text_tag_name",
      "label": "Tag name",
      "options": [
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        },
        {
          "value": "h4",
          "label": "H4"
        },
        {
          "value": "h5",
          "label": "H5"
        },
        {
          "value": "h6",
          "label": "H6"
        }
      ],
      "default": "h2"
    },
    {
      "type": "textarea",
      "id": "text_heading",
      "label": "Text",
      "default": "Image with text style 9"
    },
    {
      "type": "select",
      "id": "font_size_heading",
      "label": "Font size heading",
      "default": "h3",
      "options": [
        {
          "value": "h1",
          "label": "Extra extra large"
        },
        {
          "value": "h2",
          "label": "Extra large"
        },
        {
          "value": "h3",
          "label": "Large"
        },
        {
          "value": "h4",
          "label": "Medium"
        },
        {
          "value": "h5",
          "label": "Small"
        },
        {
          "value": "h6",
          "label": "Extra small"
        }
      ]
    },
    {
      "type": "range",
      "id": "text_line_height",
      "label": "Line height",
      "min": 0,
      "max": 3,
      "step": 0.1,
      "default": 1.2
    },
    {
      "type": "select",
      "id": "text_effect",
      "label": "Effect",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "reveal",
          "label": "Blur"
        },
        {
          "value": "split",
          "label": "Split"
        }
      ],
      "default": "split"
    },
    {
      "type": "number",
      "id": "text_duration",
      "label": "Duration (milliseconds)",
      "default": 1000
    },
    {
      "type": "range",
      "id": "text_heading_width_desktop",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "Desktop heading width",
      "default": 100
    },
    {
      "type": "range",
      "id": "text_heading_width_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "Mobile heading width",
      "default": 100
    },
    {
      "type": "text",
      "id": "sub_heading",
      "label": "t:sections.image_with_text_style_9.settings.sub_heading.label",
      "default": "Subheading"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "t:sections.image_with_text_style_9.settings.description.label",
      "default": "Use this text to share information about your brand with your customers. Describe a product, share announcements, or welcome customers to your store."
    },
    {
      "type": "select",
      "id": "alignment_desktop",
      "label": "t:sections.image_with_text_style_9.settings.alignment_desktop.label",
      "default": "left",
      "options": [
        {
          "value": "left",
          "label": "t:sections.image_with_text_style_9.settings.alignment_desktop.option_1.label"
        },
        {
          "value": "center",
          "label": "t:sections.image_with_text_style_9.settings.alignment_desktop.option_2.label"
        },
        {
          "value": "right",
          "label": "t:sections.image_with_text_style_9.settings.alignment_desktop.option_3.label"
        }
      ]
    },
    {
      "type": "select",
      "id": "alignment_mobile",
      "label": "t:sections.image_with_text_style_9.settings.alignment_mobile.label",
      "default": "top",
      "options": [
        {
          "value": "top",
          "label": "t:sections.image_with_text_style_9.settings.alignment_mobile.option_1.label"
        },
        {
          "value": "middle",
          "label": "t:sections.image_with_text_style_9.settings.alignment_mobile.option_2.label"
        },
        {
          "value": "bottom",
          "label": "t:sections.image_with_text_style_9.settings.alignment_mobile.option_3.label"
        }
      ]
    },
    {
      "type": "header",
      "content": "t:sections.image_with_text_style_9.settings.header_advanced.content"
    },
    {
      "type": "checkbox",
      "id": "expand_grid",
      "label": "t:sections.image_with_text_style_9.settings.expand_grid.label",
      "default": false
    },
    {
      "type": "header",
      "content": "General settings"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Section color scheme"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color"
    },
    {
      "type": "color_background",
      "id": "background_gradient",
      "label": "Background gradient"
    },
    {
      "type": "select",
      "id": "background_type",
      "label": "Background type",
      "options": [
        {
          "value": "image",
          "label": "Image"
        },
        {
          "value": "video",
          "label": "Video"
        }
      ],
      "default": "image"
    },
    {
      "type": "video",
      "id": "background_video_desktop",
      "label": "Background video desktop",
      "visible_if": "{{ section.settings.background_type == 'video' }}"
    },
    {
      "type": "video",
      "id": "background_video_mobile",
      "label": "Background video mobile",
      "visible_if": "{{ section.settings.background_type == 'video' }}"
    },
    {
      "type": "image_picker",
      "id": "background_image_desktop",
      "label": "Background image desktop",
      "visible_if": "{{ section.settings.background_type == 'image' }}"
    },
    {
      "type": "image_picker",
      "id": "background_image_mobile",
      "label": "Background image mobile",
      "visible_if": "{{ section.settings.background_type == 'image' }}"
    },
    {
      "type": "checkbox",
      "id": "use_parallax",
      "label": "Use parallax",
      "default": true
    },
    {
      "type": "number",
      "id": "padding_top_desktop",
      "label": "Padding top desktop",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_bottom_desktop",
      "label": "Padding bottom desktop",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_top_mobile",
      "label": "Padding top mobile",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom mobile",
      "default": 50
    }
  ],
  "blocks": [],
  "presets": [
    {
      "name": "t:sections.image_with_text_style_9.presets.name",
      "settings": {},
      "blocks": []
    }
  ]
}
{% endschema %}