{%- style -%}
  .xo-section--{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .xo-section--{{ section.id }} .usg-inner {
    max-width: 960px;
    margin: 0 auto;
  }

  .xo-section--{{ section.id }} .usg-heading {
    font-family: var(--font-heading-family);
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    font-weight: 600;
    color: rgba(var(--color-foreground));
    margin: 0 0 32px;
    text-align: center;
    letter-spacing: -0.02em;
  }

  .xo-section--{{ section.id }} .usg-sub {
    font-family: var(--font-heading-family);
    font-size: 1.125rem;
    font-weight: 600;
    color: rgba(var(--color-foreground));
    margin: 0 0 16px;
  }

  .xo-section--{{ section.id }} .usg-scroll {
    overflow-x: auto;
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
    border-radius: var(--general-radius-1, 1rem);
    margin-bottom: 32px;
    background: rgba(var(--color-background));
  }

  .xo-section--{{ section.id }} .usg-table {
    width: 100%;
    border-collapse: collapse;
    min-width: 560px;
  }

  .xo-section--{{ section.id }} .usg-table thead {
    background: rgba(var(--color-background-2));
  }

  .xo-section--{{ section.id }} .usg-table th {
    padding: 12px 16px;
    text-align: left;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent);
  }

  .xo-section--{{ section.id }} .usg-table td {
    padding: 14px 16px;
    font-size: 0.9375rem;
    color: rgba(var(--color-foreground));
    border-top: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
  }

  .xo-section--{{ section.id }} .usg-name {
    font-weight: 600;
  }

  .xo-section--{{ section.id }} .usg-table tbody tr:hover {
    background: rgba(var(--color-background-2));
  }

  .xo-section--{{ section.id }} .usg-link {
    font-weight: 600;
    font-size: 0.875rem;
    color: rgba(var(--color-accent));
    text-decoration: none;
    transition: color 0.2s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .usg-link:hover {
    text-decoration: underline;
  }

  .xo-section--{{ section.id }} :focus-visible {
    outline: 2px solid rgba(var(--color-accent));
    outline-offset: 2px;
  }

  @media (prefers-reduced-motion: reduce) {
    .xo-section--{{ section.id }} *,
    .xo-section--{{ section.id }} *::before,
    .xo-section--{{ section.id }} *::after {
      animation-duration: 0.01ms !important;
      transition-duration: 0.01ms !important;
    }
  }
{%- endstyle -%}

{%- assign usg_compounds = section.blocks | where: "type", "compound" -%}
{%- assign usg_compares = section.blocks | where: "type", "compare" -%}

{%- comment -%} ── JSON-LD: ItemList ── {%- endcomment -%}
{% if usg_compounds.size > 0 %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": {{ section.settings.heading | json }},
  "numberOfItems": {{ usg_compounds.size }},
  "itemListElement": [
    {%- for block in usg_compounds -%}
    {
      "@type": "ListItem",
      "position": {{ forloop.index }},
      "name": {{ block.settings.name | json }},
      "description": {{ block.settings.use | json }}
      {%- if block.settings.url != blank -%}
      ,"url": "{{ block.settings.url }}"
      {%- endif -%}
    }{%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
  ]
}
</script>
{% endif %}

<section id="uae-stacks" {% render 'section-attr' %}>
  <xo-container>
    <div class="usg-inner">
      {% if section.settings.heading != blank %}
        <h2 class="usg-heading">{{ section.settings.heading }}</h2>
      {% endif %}

      {% if usg_compounds.size > 0 %}
        {% if section.settings.table_1_heading != blank %}
          <h3 class="usg-sub">{{ section.settings.table_1_heading }}</h3>
        {% endif %}
        <div class="usg-scroll">
          <table class="usg-table">
            <thead>
              <tr><th>Compound</th><th>Primary Use</th><th>Onset</th><th>Pairs With</th><th>Shop</th></tr>
            </thead>
            <tbody>
              {%- for block in usg_compounds -%}
                <tr {{ block.shopify_attributes }}>
                  <td class="usg-name">{{ block.settings.name }}</td>
                  <td>{{ block.settings.use }}</td>
                  <td>{{ block.settings.onset }}</td>
                  <td>{{ block.settings.pairs }}</td>
                  <td>{% if block.settings.url != blank %}<a href="{{ block.settings.url }}" class="usg-link">View</a>{% endif %}</td>
                </tr>
              {%- endfor -%}
            </tbody>
          </table>
        </div>
      {% endif %}

      {% if usg_compares.size > 0 %}
        {% if section.settings.table_2_heading != blank %}
          <h3 class="usg-sub">{{ section.settings.table_2_heading }}</h3>
        {% endif %}
        <div class="usg-scroll">
          <table class="usg-table">
            <thead>
              <tr><th>VS</th><th>Use Case</th><th>Feels Like</th><th>Notes</th></tr>
            </thead>
            <tbody>
              {%- for block in usg_compares -%}
                <tr {{ block.shopify_attributes }}>
                  <td class="usg-name">{{ block.settings.vs }}</td>
                  <td>{{ block.settings.use_case }}</td>
                  <td>{{ block.settings.feels }}</td>
                  <td>{{ block.settings.notes }}</td>
                </tr>
              {%- endfor -%}
            </tbody>
          </table>
        </div>
      {% endif %}
    </div>
  </xo-container>
</section>

{% schema %}
{
  "name": "UAE Stack Guide",
  "tag": "section",
  "class": "section-uae-stack-guide",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "default" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Quick Stack Guide" },
    { "type": "text", "id": "table_1_heading", "label": "Table 1 Heading", "default": "Popular Compounds" },
    { "type": "text", "id": "table_2_heading", "label": "Table 2 Heading", "default": "Head-to-Head Comparisons" },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding top", "default": 80 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding bottom", "default": 80 }
  ],
  "blocks": [
    {
      "type": "compound",
      "name": "Compound Row",
      "settings": [
        { "type": "text", "id": "name", "label": "Compound" },
        { "type": "text", "id": "use", "label": "Primary Use" },
        { "type": "text", "id": "onset", "label": "Onset" },
        { "type": "text", "id": "pairs", "label": "Pairs With" },
        { "type": "url", "id": "url", "label": "Product Link" }
      ]
    },
    {
      "type": "compare",
      "name": "Comparison Row",
      "settings": [
        { "type": "text", "id": "vs", "label": "VS" },
        { "type": "text", "id": "use_case", "label": "Use Case" },
        { "type": "text", "id": "feels", "label": "Feels Like" },
        { "type": "text", "id": "notes", "label": "Notes" }
      ]
    },
    { "type": "@app" }
  ],
  "presets": [
    {
      "name": "UAE Stack Guide",
      "blocks": [
        { "type": "compound", "settings": { "name": "Caffeine + L-Theanine", "use": "Calm focus", "onset": "15-30 m", "pairs": "CDP-Choline" } },
        { "type": "compound", "settings": { "name": "Alpha-GPC", "use": "Choline source", "onset": "30-60 m", "pairs": "Noopept" } },
        { "type": "compound", "settings": { "name": "CDP-Choline", "use": "Memory support", "onset": "30-60 m", "pairs": "Phenylpiracetam" } },
        { "type": "compare", "settings": { "vs": "CDP-Choline vs Alpha-GPC", "use_case": "Memory vs power output", "feels": "Clean vs robust", "notes": "Try one; avoid doubling high doses" } }
      ]
    }
  ]
}
{% endschema %}
