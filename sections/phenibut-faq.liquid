{% comment %}
  FAQ — XO theme design system
  - FAQPage JSON-LD dynamically generated from blocks, reduced-motion
{% endcomment %}

{%- style -%}
  .xo-section--{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .xo-section--{{ section.id }} .phb-faq__title {
    font-size: clamp(22px, 4.2vw, 36px);
    line-height: 1.2;
    color: rgba(var(--color-foreground));
    margin: 0 0 8px;
    font-weight: 600;
  }

  .xo-section--{{ section.id }} .phb-faq__list {
    display: grid;
    gap: 10px;
  }

  .xo-section--{{ section.id }} .phb-faq__item {
    background: rgba(var(--color-background));
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
    border-radius: var(--general-radius-1, 1rem);
    padding: 12px 14px;
    transition: border-color 0.3s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .phb-faq__item[open] {
    border-color: rgba(var(--color-accent));
  }

  .xo-section--{{ section.id }} .phb-faq__q {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-weight: 600;
    cursor: pointer;
    list-style: none;
    color: rgba(var(--color-foreground));
  }

  .xo-section--{{ section.id }} .phb-faq__q::-webkit-details-marker {
    display: none;
  }

  .xo-section--{{ section.id }} .phb-faq__q:focus-visible {
    outline: 2px solid rgba(var(--color-accent));
    outline-offset: 2px;
  }

  .xo-section--{{ section.id }} .phb-faq__a {
    color: color-mix(in srgb, rgba(var(--color-foreground)) 75%, transparent);
    line-height: 1.6;
    margin-top: 8px;
  }

  .xo-section--{{ section.id }} .phb-faq__chev {
    transition: transform 0.3s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .phb-faq__item[open] .phb-faq__chev {
    transform: rotate(180deg);
  }

  @media (prefers-reduced-motion: reduce) {
    .xo-section--{{ section.id }} *,
    .xo-section--{{ section.id }} *::before,
    .xo-section--{{ section.id }} *::after {
      animation-duration: 0.01ms !important;
      transition-duration: 0.01ms !important;
    }
  }
{%- endstyle -%}

<section {% render 'section-attr' %} aria-labelledby="phb-faq-title-{{ section.id }}">
  <xo-container>
    <h2 id="phb-faq-title-{{ section.id }}" class="phb-faq__title">{{ section.settings.heading | escape }}</h2>

    <div class="phb-faq__list">
      {% for block in section.blocks %}
        {% if block.type == 'qa' %}
          <details class="phb-faq__item" {{ block.shopify_attributes }}{% if block.settings.open_by_default %} open{% endif %}>
            <summary class="phb-faq__q">
              <span>{{ block.settings.question | escape }}</span>
              <span class="phb-faq__chev" aria-hidden="true">▾</span>
            </summary>
            <div class="phb-faq__a" dir="auto">{{ block.settings.answer }}</div>
          </details>
        {% endif %}
      {% endfor %}
    </div>
  </xo-container>
</section>

{%- assign qa_blocks = section.blocks | where: 'type', 'qa' -%}
{% if qa_blocks.size > 0 %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {%- for b in qa_blocks -%}
      {
        "@type": "Question",
        "name": {{ b.settings.question | json }},
        "acceptedAnswer": {
          "@type": "Answer",
          "text": {{ b.settings.answer | strip_html | json }}
        }
      }{%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
  ]
}
</script>
{% endif %}

{% schema %}
{
  "name": "FAQ",
  "tag": "section",
  "class": "section-phenibut-faq",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "default" },
    { "type": "text", "id": "anchor_id", "label": "Anchor ID", "default": "faq" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Frequently Asked Questions" },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding top", "default": 40 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding bottom", "default": 40 }
  ],
  "blocks": [
    { "type": "qa", "name": "FAQ item", "settings": [
      { "type": "text", "id": "question", "label": "Question", "default": "What's the difference between HCl and FAA?" },
      { "type": "richtext", "id": "answer", "label": "Answer", "default": "<p>HCl dissolves readily in water; FAA is the free amino acid form. Potency per mg can feel similar when dosed equivalently; solubility and handling differ.</p>" },
      { "type": "checkbox", "id": "open_by_default", "label": "Open by default", "default": false }
    ] },
    { "type": "@app" }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "FAQ",
      "blocks": [
        { "type": "qa", "settings": { "question": "Is Phenibut addictive?", "answer": "<p>Regular/frequent use can lead to tolerance and dependence. Use occasionally, follow conservative dosing, and never mix with other depressants.</p>" } },
        { "type": "qa", "settings": { "question": "How long does it last?", "answer": "<p>Onset is usually 1–3 hours, with effects lasting several hours depending on dose, form, and individual response.</p>" } }
      ]
    }
  ]
}
{% endschema %}
