{% comment %}
  FAQ — Premium refactored section
  - Preserves FAQPage JSON-LD, adds design tokens, focus-visible, reduced-motion
{% endcomment %}

<section id="phb-fq-{{ section.id }}" class="phb-faq" aria-labelledby="phb-faq-title-{{ section.id }}">
  <div class="phb-faq__container">
    <h2 id="phb-faq-title-{{ section.id }}" class="phb-faq__title">{{ section.settings.heading | escape }}</h2>

    <div class="phb-faq__list">
      {% for block in section.blocks %}
        {% if block.type == 'qa' %}
          <details class="phb-faq__item" {{ block.shopify_attributes }}{% if block.settings.open_by_default %} open{% endif %}>
            <summary class="phb-faq__q">
              <span>{{ block.settings.question | escape }}</span>
              <span class="phb-faq__chev" aria-hidden="true">▾</span>
            </summary>
            <div class="phb-faq__a" dir="auto">{{ block.settings.answer }}</div>
          </details>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{%- assign qa_blocks = section.blocks | where: 'type', 'qa' -%}
{% if qa_blocks.size > 0 %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {%- for b in qa_blocks -%}
      {
        "@type": "Question",
        "name": {{ b.settings.question | json }},
        "acceptedAnswer": {
          "@type": "Answer",
          "text": {{ b.settings.answer | strip_html | json }}
        }
      }{%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
  ]
}
</script>
{% endif %}

{%- style -%}
#phb-fq-{{ section.id }} {
  --phb-bg: {{ section.settings.background_color }};
  --phb-max: {{ section.settings.max_width }}px;
  --phb-py: {{ section.settings.padding_y }}px;
  --phb-accent: var(--color-accent-primary, #FBBF24);
  --phb-heading: var(--color-text-main, #0A2342);
  --phb-text: var(--color-text-main, #0e1726);
  --phb-card-bg: var(--color-bg-primary, #fff);
  --phb-card-border: var(--nx-pill-border, rgba(0,0,0,.06));
  --phb-radius: var(--nx-radius, 14px);
  --phb-font: var(--font-body-family, sans-serif);
  --phb-font-heading: var(--font-heading-family, sans-serif);
  --phb-transition: var(--transition-smooth, all 0.3s cubic-bezier(0.25,0.8,0.25,1));
  background: var(--phb-bg);
  font-family: var(--phb-font);
}
#phb-fq-{{ section.id }} .phb-faq__container { max-width: var(--phb-max); margin: 0 auto; padding: var(--phb-py) 16px; }
#phb-fq-{{ section.id }} .phb-faq__title {
  font-family: var(--phb-font-heading);
  font-size: clamp(22px, 4.2vw, 36px); line-height: 1.2; color: var(--phb-heading); margin: 0 0 8px;
}
#phb-fq-{{ section.id }} .phb-faq__list { display: grid; gap: 10px; }
#phb-fq-{{ section.id }} .phb-faq__item {
  background: var(--phb-card-bg); border: 1px solid var(--phb-card-border);
  border-radius: var(--phb-radius); padding: 12px 14px;
}
#phb-fq-{{ section.id }} .phb-faq__q {
  display: flex; align-items: center; justify-content: space-between;
  font-weight: 700; cursor: pointer; list-style: none;
  color: var(--phb-heading); font-family: var(--phb-font-heading);
}
#phb-fq-{{ section.id }} .phb-faq__q::-webkit-details-marker { display: none; }
#phb-fq-{{ section.id }} .phb-faq__q:focus-visible {
  outline: 2px solid var(--phb-accent); outline-offset: 2px;
}
#phb-fq-{{ section.id }} .phb-faq__a { color: var(--phb-text); line-height: 1.6; margin-top: 8px; }
#phb-fq-{{ section.id }} .phb-faq__chev { transition: var(--phb-transition); }
#phb-fq-{{ section.id }} .phb-faq__item[open] .phb-faq__chev { transform: rotate(180deg); }
@media (prefers-reduced-motion: reduce) {
  #phb-fq-{{ section.id }} *,
  #phb-fq-{{ section.id }} *::before,
  #phb-fq-{{ section.id }} *::after {
    animation-duration: 0.01ms !important;
    transition-duration: 0.01ms !important;
  }
}
{%- endstyle -%}

{% schema %}
{
  "name": "FAQ",
  "tag": "section",
  "class": "section-phenibut-faq",
  "settings": [
    { "type": "text", "id": "anchor_id", "label": "Anchor ID", "default": "faq" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Frequently Asked Questions" },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#F7FAFB" },
    { "type": "range", "id": "max_width", "label": "Max width (px)", "min": 720, "max": 1400, "step": 20, "default": 900 },
    { "type": "range", "id": "padding_y", "label": "Vertical padding (px)", "min": 40, "max": 160, "step": 4, "default": 64 }
  ],
  "blocks": [
    { "type": "qa", "name": "FAQ item", "settings": [
      { "type": "text", "id": "question", "label": "Question", "default": "What's the difference between HCl and FAA?" },
      { "type": "richtext", "id": "answer", "label": "Answer", "default": "<p>HCl dissolves readily in water; FAA is the free amino acid form. Potency per mg can feel similar when dosed equivalently; solubility and handling differ.</p>" },
      { "type": "checkbox", "id": "open_by_default", "label": "Open by default", "default": false }
    ] }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "FAQ",
      "blocks": [
        { "type": "qa", "settings": { "question": "Is Phenibut addictive?", "answer": "<p>Regular/frequent use can lead to tolerance and dependence. Use occasionally, follow conservative dosing, and never mix with other depressants.</p>" } },
        { "type": "qa", "settings": { "question": "How long does it last?", "answer": "<p>Onset is usually 1–3 hours, with effects lasting several hours depending on dose, form, and individual response.</p>" } }
      ]
    }
  ]
}
{% endschema %}
