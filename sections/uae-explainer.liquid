{% schema %}
{
  "name": "UAE Explainer",
  "tag": "section",
  "class": "section-uae-explainer",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "What Are Nootropics?" },
    { "type": "textarea", "id": "body", "label": "Body Text", "default": "Nootropics are substances used to support focus, memory, mood, and mental performance. Always follow label directions. If you have a medical condition or take prescription meds, consult a professional." },
    { "type": "textarea", "id": "disclaimer", "label": "Disclaimer", "default": "This content is educational only — not medical advice." },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#ffffff" },
    { "type": "color", "id": "accent_color", "label": "Accent", "default": "#FBBF24" }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category Card",
      "settings": [
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "textarea", "id": "desc", "label": "Description" },
        { "type": "url", "id": "url", "label": "Link (optional)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "UAE Explainer",
      "blocks": [
        { "type": "category", "settings": { "title": "Cholinergics", "desc": "Alpha-GPC, CDP-Choline — support acetylcholine for memory and focus." } },
        { "type": "category", "settings": { "title": "Racetams", "desc": "Phenylpiracetam, Aniracetam, Noopept — cognitive enhancers with varied profiles." } },
        { "type": "category", "settings": { "title": "Amino Acids", "desc": "L-Theanine, N-Acetyl-L-Tyrosine — building blocks for calm focus and stress resilience." } },
        { "type": "category", "settings": { "title": "Natural Extracts", "desc": "Lion's Mane, Rhodiola — time-tested botanicals for neuroprotection and adaptation." } }
      ]
    }
  ]
}
{% endschema %}

<div class="uaex-wrapper" id="uae-explainer">
  <div class="uaex-inner">
    {% if section.settings.heading != blank %}
      <h2 class="uaex-heading">{{ section.settings.heading }}</h2>
    {% endif %}

    {% if section.settings.body != blank %}
      <p class="uaex-body">{{ section.settings.body }}</p>
    {% endif %}

    {% if section.blocks.size > 0 %}
      <div class="uaex-grid">
        {% for block in section.blocks %}
          <div class="uaex-card" {{ block.shopify_attributes }}>
            <h3 class="uaex-card-title">{{ block.settings.title }}</h3>
            {% if block.settings.desc != blank %}
              <p class="uaex-card-desc">{{ block.settings.desc }}</p>
            {% endif %}
            {% if block.settings.url != blank %}
              <a href="{{ block.settings.url }}" class="uaex-card-link">Browse &rarr;</a>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    {% endif %}

    {% if section.settings.disclaimer != blank %}
      <p class="uaex-disclaimer">{{ section.settings.disclaimer }}</p>
    {% endif %}
  </div>
</div>

<style>
  .uaex-wrapper {
    --uaex-bg: {{ section.settings.bg_color }};
    --uaex-accent: {{ section.settings.accent_color }};
    --uaex-text: var(--color-text-main, #111827);
    --uaex-muted: var(--color-text-muted, #4b5563);
    --uaex-border: var(--nx-pill-border, #E5E7EB);
    --uaex-radius: var(--nx-radius, 14px);
    --uaex-font: var(--font-body-family, sans-serif);
    --uaex-font-heading: var(--font-heading-family, sans-serif);
    --uaex-transition: var(--transition-smooth, all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1));
    background: var(--uaex-bg); padding: 80px var(--page-gutter); font-family: var(--uaex-font);
  }
  .uaex-inner { max-width: var(--container-width-narrow); margin: 0 auto; }
  .uaex-heading {
    font-family: var(--uaex-font-heading); font-size: clamp(1.75rem, 3vw, 2.25rem);
    font-weight: 800; color: var(--uaex-text); margin: 0 0 16px; text-align: center; letter-spacing: -0.02em;
  }
  .uaex-body { font-size: 1rem; line-height: 1.7; color: var(--uaex-muted); text-align: center; max-width: 640px; margin: 0 auto 40px; }

  .uaex-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; margin-bottom: 32px; }
  .uaex-card {
    padding: 24px; background: var(--color-bg-secondary, #f9fafb); border: 1px solid var(--uaex-border);
    border-radius: var(--uaex-radius); transition: var(--uaex-transition);
  }
  .uaex-card:hover { border-color: var(--uaex-accent); box-shadow: var(--shadow-sm, 0 2px 8px rgba(0,0,0,0.04)); }
  .uaex-card-title { font-family: var(--uaex-font-heading); font-size: 1.0625rem; font-weight: 700; color: var(--uaex-text); margin: 0 0 8px; }
  .uaex-card-desc { font-size: 0.875rem; line-height: 1.6; color: var(--uaex-muted); margin: 0 0 12px; }
  .uaex-card-link { font-size: 0.875rem; font-weight: 700; color: var(--uaex-accent); text-decoration: none; }
  .uaex-card-link:hover { text-decoration: underline; }

  .uaex-disclaimer {
    text-align: center; font-size: 0.8125rem; color: var(--uaex-muted);
    background: var(--color-bg-secondary, #f1f5f9); padding: 12px 16px;
    border-radius: var(--uaex-radius); margin: 0;
  }

  .uaex-wrapper :focus-visible { outline: 2px solid var(--uaex-accent); outline-offset: 2px; }
  @media (prefers-reduced-motion: reduce) { .uaex-wrapper *, .uaex-wrapper *::before, .uaex-wrapper *::after { animation-duration: 0.01ms !important; transition-duration: 0.01ms !important; } }
  @media (max-width: 640px) {
    .uaex-wrapper { padding: 56px var(--page-gutter); }
    .uaex-grid { grid-template-columns: 1fr; }
  }
</style>
