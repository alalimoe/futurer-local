{%- style -%}
  .xo-section--{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .xo-section--{{ section.id }} .cle-inner {
    max-width: 800px;
    margin: 0 auto;
  }

  .xo-section--{{ section.id }} .cle-heading {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 600;
    color: rgba(var(--color-foreground));
    margin: 0 0 16px;
    letter-spacing: -0.02em;
  }

  .xo-section--{{ section.id }} .cle-intro {
    font-size: 1rem;
    line-height: 1.7;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent);
    margin: 0 0 32px;
  }

  .xo-section--{{ section.id }} .cle-items {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-bottom: 32px;
  }

  .xo-section--{{ section.id }} .cle-item {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    padding: 20px;
    background: rgba(var(--color-background));
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
    border-left: 4px solid rgba(var(--color-accent));
    border-radius: var(--general-radius-1, 1rem);
    transition: border-color 0.3s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .cle-item:hover {
    border-color: rgba(var(--color-accent));
  }

  .xo-section--{{ section.id }} .cle-item-num {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(var(--color-accent));
    color: rgba(var(--color-foreground));
    font-weight: 600;
    font-size: 0.8125rem;
    border-radius: 50%;
  }

  .xo-section--{{ section.id }} .cle-item-body {
    flex: 1;
  }

  .xo-section--{{ section.id }} .cle-item-title {
    display: block;
    font-weight: 600;
    color: rgba(var(--color-foreground));
    font-size: 1rem;
    margin-bottom: 4px;
  }

  .xo-section--{{ section.id }} .cle-item-text {
    font-size: 0.875rem;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent);
    line-height: 1.5;
  }

  .xo-section--{{ section.id }} .cle-callout {
    display: flex;
    gap: 14px;
    padding: 20px;
    background: color-mix(in srgb, rgba(var(--color-accent)) 6%, transparent);
    border: 1px solid rgba(var(--color-accent));
    border-radius: var(--general-radius-1, 1rem);
  }

  .xo-section--{{ section.id }} .cle-callout-icon {
    flex-shrink: 0;
    color: rgba(var(--color-accent));
    margin-top: 2px;
  }

  .xo-section--{{ section.id }} .cle-callout-text {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent);
    margin: 0;
  }

  .xo-section--{{ section.id }} :focus-visible {
    outline: 2px solid rgba(var(--color-accent));
    outline-offset: 2px;
  }

  @media (max-width: 768px) {
    .xo-section--{{ section.id }} .cle-item {
      padding: 16px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .xo-section--{{ section.id }} .cle-item {
      transition: none;
    }
  }
{%- endstyle -%}

<section {% render 'section-attr' %}>
  <xo-container>
    <div class="cle-inner">

      {% if section.settings.heading != blank %}
        <h2 class="cle-heading">{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.intro_text != blank %}
        <p class="cle-intro">{{ section.settings.intro_text }}</p>
      {% endif %}

      <div class="cle-items">
        {% for i in (1..4) %}
          {%- assign title_key = 'item_' | append: i | append: '_title' -%}
          {%- assign text_key = 'item_' | append: i | append: '_text' -%}
          {%- assign item_title = section.settings[title_key] -%}
          {%- assign item_text = section.settings[text_key] -%}
          {% if item_title != blank %}
            <div class="cle-item">
              <div class="cle-item-num">{{ i }}</div>
              <div class="cle-item-body">
                <strong class="cle-item-title">{{ item_title }}</strong>
                {% if item_text != blank %}
                  <span class="cle-item-text">{{ item_text }}</span>
                {% endif %}
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>

      {% if section.settings.callout_text != blank %}
        <div class="cle-callout">
          <svg class="cle-callout-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
          <p class="cle-callout-text">{{ section.settings.callout_text }}</p>
        </div>
      {% endif %}

    </div>
  </xo-container>
</section>

{% schema %}
{
  "name": "COA Explainer",
  "tag": "section",
  "class": "section-coa-explainer-what",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "default"
    },
    { "type": "text", "id": "heading", "label": "Heading", "default": "What a COA should prove (and what it shouldn't)" },
    { "type": "textarea", "id": "intro_text", "label": "Intro Text", "default": "A COA is documentation that connects a specific batch to lab analysis. At a minimum, a useful COA should help answer:" },
    { "type": "header", "content": "Items" },
    { "type": "text", "id": "item_1_title", "label": "Item 1 Title", "default": "Identity: Is it the right compound?" },
    { "type": "text", "id": "item_1_text", "label": "Item 1 Detail", "default": "Common methods: FTIR, LC-MS/MS, MS, etc." },
    { "type": "text", "id": "item_2_title", "label": "Item 2 Title", "default": "Purity / assay: How much of it is the target compound?" },
    { "type": "text", "id": "item_2_text", "label": "Item 2 Detail", "default": "Common method: HPLC" },
    { "type": "text", "id": "item_3_title", "label": "Item 3 Title", "default": "Traceability: Does the document match your batch/lot?" },
    { "type": "text", "id": "item_3_text", "label": "Item 3 Detail" },
    { "type": "text", "id": "item_4_title", "label": "Item 4 Title", "default": "Scope clarity: What was tested — and what wasn't" },
    { "type": "text", "id": "item_4_text", "label": "Item 4 Detail" },
    { "type": "header", "content": "Callout" },
    { "type": "textarea", "id": "callout_text", "label": "Callout Text", "default": "Not every COA includes every possible contaminant panel. Some reports focus on identity/purity only. If you need a specific panel (metals/solvents/micro, etc.), ask support and we'll tell you what documentation exists for your batch." },
    { "type": "header", "content": "Spacing" },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 64
    }
  ],
  "blocks": [
    { "type": "@app" }
  ],
  "presets": [{ "name": "COA Explainer" }]
}
{% endschema %}
