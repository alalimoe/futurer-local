{% schema %}
{
  "name": "COA Explainer",
  "tag": "section",
  "class": "section-coa-explainer-what",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "What a COA should prove (and what it shouldn't)" },
    { "type": "textarea", "id": "intro_text", "label": "Intro Text", "default": "A COA is documentation that connects a specific batch to lab analysis. At a minimum, a useful COA should help answer:" },
    { "type": "header", "content": "Items" },
    { "type": "text", "id": "item_1_title", "label": "Item 1 Title", "default": "Identity: Is it the right compound?" },
    { "type": "text", "id": "item_1_text", "label": "Item 1 Detail", "default": "Common methods: FTIR, LC-MS/MS, MS, etc." },
    { "type": "text", "id": "item_2_title", "label": "Item 2 Title", "default": "Purity / assay: How much of it is the target compound?" },
    { "type": "text", "id": "item_2_text", "label": "Item 2 Detail", "default": "Common method: HPLC" },
    { "type": "text", "id": "item_3_title", "label": "Item 3 Title", "default": "Traceability: Does the document match your batch/lot?" },
    { "type": "text", "id": "item_3_text", "label": "Item 3 Detail" },
    { "type": "text", "id": "item_4_title", "label": "Item 4 Title", "default": "Scope clarity: What was tested — and what wasn't" },
    { "type": "text", "id": "item_4_text", "label": "Item 4 Detail" },
    { "type": "header", "content": "Callout" },
    { "type": "textarea", "id": "callout_text", "label": "Callout Text", "default": "Not every COA includes every possible contaminant panel. Some reports focus on identity/purity only. If you need a specific panel (metals/solvents/micro, etc.), ask support and we'll tell you what documentation exists for your batch." },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#f9fafb" },
    { "type": "color", "id": "accent_color", "label": "Accent", "default": "#FBBF24" }
  ],
  "presets": [{ "name": "COA Explainer" }]
}
{% endschema %}

<div class="cle-wrapper" id="cle-{{ section.id }}">
  <div class="cle-inner">

    {% if section.settings.heading != blank %}
      <h2 class="cle-heading">{{ section.settings.heading }}</h2>
    {% endif %}

    {% if section.settings.intro_text != blank %}
      <p class="cle-intro">{{ section.settings.intro_text }}</p>
    {% endif %}

    <div class="cle-items">
      {% for i in (1..4) %}
        {%- assign title_key = 'item_' | append: i | append: '_title' -%}
        {%- assign text_key = 'item_' | append: i | append: '_text' -%}
        {%- assign item_title = section.settings[title_key] -%}
        {%- assign item_text = section.settings[text_key] -%}
        {% if item_title != blank %}
          <div class="cle-item">
            <div class="cle-item-num">{{ i }}</div>
            <div class="cle-item-body">
              <strong class="cle-item-title">{{ item_title }}</strong>
              {% if item_text != blank %}
                <span class="cle-item-text">{{ item_text }}</span>
              {% endif %}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    {% if section.settings.callout_text != blank %}
      <div class="cle-callout">
        <svg class="cle-callout-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
        <p class="cle-callout-text">{{ section.settings.callout_text }}</p>
      </div>
    {% endif %}

  </div>
</div>

<style>
  #cle-{{ section.id }} {
    --cle-bg: {{ section.settings.bg_color }};
    --cle-accent: {{ section.settings.accent_color }};
    --cle-text: var(--color-text-main, #111827);
    --cle-muted: var(--color-text-muted, #4b5563);
    --cle-border: var(--nx-pill-border, #E5E7EB);
    --cle-radius: var(--nx-radius, 14px);
    --cle-font: var(--font-body-family, sans-serif);
    --cle-font-heading: var(--font-heading-family, sans-serif);
    --cle-transition: var(--transition-smooth, all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1));
  }

  .cle-wrapper {
    background: var(--cle-bg);
    padding: 64px var(--page-gutter);
    font-family: var(--cle-font);
  }
  .cle-inner {
    max-width: 800px;
    margin: 0 auto;
  }

  .cle-heading {
    font-family: var(--cle-font-heading);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 800;
    color: var(--cle-text);
    margin: 0 0 16px;
    letter-spacing: -0.02em;
  }
  .cle-intro {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--cle-muted);
    margin: 0 0 32px;
  }

  .cle-items {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-bottom: 32px;
  }
  .cle-item {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    padding: 20px;
    background: var(--color-bg-primary, #fff);
    border: 1px solid var(--cle-border);
    border-left: 4px solid var(--cle-accent);
    border-radius: var(--cle-radius);
    transition: var(--cle-transition);
  }
  .cle-item:hover {
    box-shadow: var(--shadow-sm, 0 2px 8px rgba(0,0,0,0.04));
    transform: translateY(-1px);
  }
  .cle-item-num {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--cle-accent);
    color: var(--color-text-primary);
    font-weight: 800;
    font-size: 0.8125rem;
    border-radius: 50%;
  }
  .cle-item-body { flex: 1; }
  .cle-item-title {
    display: block;
    font-weight: 700;
    color: var(--cle-text);
    font-size: 1rem;
    margin-bottom: 4px;
  }
  .cle-item-text {
    font-size: 0.875rem;
    color: var(--cle-muted);
    line-height: 1.5;
  }

  .cle-callout {
    display: flex;
    gap: 14px;
    padding: 20px;
    background: rgba(251, 191, 36, 0.06);
    border: 1px solid var(--cle-accent);
    border-radius: var(--cle-radius);
  }
  .cle-callout-icon {
    flex-shrink: 0;
    color: var(--cle-accent);
    margin-top: 2px;
  }
  .cle-callout-text {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--cle-muted);
    margin: 0;
  }

  .cle-wrapper :focus-visible {
    outline: 2px solid var(--cle-accent);
    outline-offset: 2px;
  }

  @media (prefers-reduced-motion: reduce) {
    .cle-wrapper *, .cle-wrapper *::before, .cle-wrapper *::after {
      animation-duration: 0.01ms !important;
      transition-duration: 0.01ms !important;
    }
  }

  @media (max-width: 640px) {
    .cle-wrapper { padding: 48px var(--page-gutter); }
    .cle-item { padding: 16px; }
  }
</style>
