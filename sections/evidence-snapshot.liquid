{%- assign snapshot_ref = product.metafields.evidence.snapshot -%}
{%- assign snapshot = snapshot_ref.value | default: snapshot_ref -%}
{%- assign claims = snapshot.claims_list.value | default: snapshot.claims_list -%}

{%- if snapshot and claims -%}

{%- style -%}
  .xo-section--{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .xo-section--{{ section.id }} .es__wrap {
    padding: 18px;
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
    border-radius: var(--general-radius-3, 2rem);
  }

  .xo-section--{{ section.id }} .es__eyebrow {
    font-size: calc(var(--font-body-scale, 1) * 1.2rem);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: rgba(var(--color-accent));
    font-weight: 600;
  }

  .xo-section--{{ section.id }} .es__title {
    margin: 4px 0;
    font-size: calc(var(--font-body-scale, 1) * 1.8rem);
    line-height: 1.3;
    color: rgba(var(--color-foreground));
    font-weight: 600;
  }

  .xo-section--{{ section.id }} .es__hint {
    font-size: calc(var(--font-body-scale, 1) * 1.3rem);
    color: color-mix(in srgb, rgba(var(--color-foreground)) 55%, transparent);
  }

  .xo-section--{{ section.id }} .es__grid {
    list-style: none;
    margin: 14px 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 18px;
  }

  .xo-section--{{ section.id }} .es-claim {
    display: grid;
    grid-template-columns: 32px 1fr;
    gap: 12px;
    padding: 14px;
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 8%, transparent);
    border-radius: var(--general-radius-1, 1rem);
    transition: border-color 0.3s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .es-claim:hover {
    border-color: color-mix(in srgb, rgba(var(--color-foreground)) 20%, transparent);
  }

  .xo-section--{{ section.id }} .es-claim__icon {
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    background: color-mix(in srgb, rgba(var(--color-accent)) 15%, transparent);
    font-size: 16px;
  }

  .xo-section--{{ section.id }} .es-claim__headline {
    font-weight: 600;
    margin: 0 0 6px;
    color: rgba(var(--color-foreground));
  }

  .xo-section--{{ section.id }} .es-claim__notes {
    font-size: calc(var(--font-body-scale, 1) * 1.4rem);
    color: rgba(var(--color-foreground));
    line-height: 1.5;
  }

  .xo-section--{{ section.id }} .es-claim__notes p:last-child {
    display: inline;
  }

  .xo-section--{{ section.id }} .es-claim__notes .es-ref {
    margin-left: 6px;
  }

  .xo-section--{{ section.id }} .es-ref {
    display: inline-flex;
    align-items: center;
    font-weight: 600;
    font-size: calc(var(--font-body-scale, 1) * 1.2rem);
    line-height: 1;
    padding: 2px 6px;
    border-radius: 6px;
    background: color-mix(in srgb, rgba(var(--color-foreground)) 5%, transparent);
    color: rgba(var(--color-accent));
    text-decoration: none;
    transition: background 0.3s var(--out-soft, ease), color 0.3s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .es-ref:hover {
    background: rgba(var(--color-accent));
    color: rgba(var(--color-background));
  }

  .xo-section--{{ section.id }} .es-ref:focus-visible {
    outline: 2px solid rgba(var(--color-accent));
    outline-offset: 2px;
    border-radius: 6px;
  }

  @media (min-width: 768px) {
    .xo-section--{{ section.id }} .es__wrap {
      padding: 24px 28px;
    }

    .xo-section--{{ section.id }} .es__grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 768px) {
    .xo-section--{{ section.id }} .es__grid {
      gap: 12px;
    }

    .xo-section--{{ section.id }} .es-claim {
      padding: 10px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .xo-section--{{ section.id }} .es-claim,
    .xo-section--{{ section.id }} .es-ref {
      transition: none;
    }
  }
{%- endstyle -%}

<section {% render 'section-attr' %}>
  <xo-container>
    <xo-animate xo-animation="fade-up">
      <div class="es__wrap" id="evidence-snapshot" aria-label="Clinical evidence snapshot">
        <header class="es__header">
          <div class="es__eyebrow">{{ section.settings.eyebrow_text }}</div>
          <h3 class="es__title">
            {{ snapshot.title.value | default: snapshot.title | default: section.settings.heading_text }}
          </h3>
          <div class="es__hint">
            {{ section.settings.hint_text }}
          </div>
        </header>

        <ul class="es__grid" role="list">
          {%- for claim in claims -%}
            {%- assign headline = claim.headline.value | default: claim.headline -%}
            {%- assign source   = claim.sources.value  | default: claim.sources  -%}
            {%- assign lbl      = source.label.value   | default: source.label   -%}
            {%- assign url      = source.pubmed_url.value | default: source.pubmed_url -%}

            <li class="es-claim">
              <div class="es-claim__icon" aria-hidden="true">⚡</div>
              <div class="es-claim__body">
                <div class="es-claim__headline">{{ headline }}</div>

                <div class="es-claim__notes">
                  {%- assign notes_html = claim.notes | metafield_tag -%}
                  {{ notes_html }}
                  {%- if url != blank and lbl != blank -%}
                    {%- unless notes_html contains lbl -%}
                      <a class="es-ref" href="{{ url }}" target="_blank" rel="nofollow noopener">[{{ lbl }}]</a>
                    {%- endunless -%}
                  {%- endif -%}
                </div>
              </div>
            </li>
          {%- endfor -%}
        </ul>
      </div>
    </xo-animate>
  </xo-container>
</section>

{%- endif -%}

{% schema %}
{
  "name": "Evidence snapshot",
  "class": "evidence-snapshot-section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "default"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow_text",
      "label": "Eyebrow text",
      "default": "EVIDENCE SNAPSHOT"
    },
    {
      "type": "text",
      "id": "heading_text",
      "label": "Heading (fallback if metafield title is empty)",
      "default": "Evidence Snapshot"
    },
    {
      "type": "text",
      "id": "hint_text",
      "label": "Hint text",
      "default": "Hover or tap the numbered chips to see the study details."
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 24
    }
  ],
  "presets": [
    { "name": "Evidence snapshot" }
  ]
}
{% endschema %}
