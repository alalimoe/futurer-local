{{ 'section-featured-collection-style-10.css' | asset_url | stylesheet_tag }}
{{ 'featured-collection-10.css' | asset_url | stylesheet_tag }}

{% liquid
  assign sub_heading = section.settings.sub_heading
  assign heading = section.settings.text_heading
  assign autoplay = section.settings.autoplay
  assign autoplay_time = section.settings.autoplay_time
  assign background_style = section.settings.background_style
  assign video_url = section.settings.video_url
  assign block = section.blocks
%}

<section {% render 'section-attr' %}>
  <div class="featured-collection-style-10">
    {% if background_style == 'video' %}
      <div class="featured-collection-style-10__background">
        <xo-video-cover class="featured-collection-style-10__video" xo-src="{{ video_url }}"></xo-video-cover>
      </div>
    {%- else -%}
      {% render 'section-bg-image' %}
    {% endif %}
    <xo-container class="featured-collection-style-10__container">
      <div class="featured-collection-style-10__content">
        {% render 'featured-collection-10', sub_heading: sub_heading, heading: heading, effect: effect, autoplay: autoplay, autoplay_time: autoplay_time, block: block %}
      </div>
    </xo-container>
  </div>
</section>

{% schema %}
{
