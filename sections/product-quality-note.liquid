{% comment %}
  Quality & testing accordion: metafields + optional COA links.
{% endcomment %}

{%- liquid
  assign form_mf = product.metafields.peptide.form
  assign storage_mf = product.metafields.peptide.storage
  assign recon_mf = product.metafields.peptide.reconstitution
  assign research_disc = product.metafields.peptide.research_disclaimer

  assign safety_imp = product.metafields.npx.safety_important
  assign safety_gen = product.metafields.npx.safety_general
  assign disclaimer_mf = product.metafields.npx.disclaimer

  assign has_any = false
  if form_mf or storage_mf or recon_mf or research_disc or safety_imp or safety_gen or disclaimer_mf
    assign has_any = true
  endif

  assign pdp_coa_override = product.metafields.pdp.coa_url
  assign coa_pdf_mf = product.metafields.pep.coa_pdf
  assign coa_files_mf = product.metafields.peptide.coa_file

  assign coa_url = nil
  if pdp_coa_override and pdp_coa_override != blank
    assign coa_url = pdp_coa_override
  elsif coa_pdf_mf and coa_pdf_mf.value and coa_pdf_mf.value.url
    assign coa_url = coa_pdf_mf.value.url
  elsif coa_files_mf and coa_files_mf.value and coa_files_mf.value.size > 0
    assign first_file = coa_files_mf.value.first
    if first_file and first_file.url
      assign coa_url = first_file.url
    endif
  endif
-%}

{% if has_any or section.settings.fallback_note != blank %}

{%- style -%}
  .xo-section--{{ section.id }} details {
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 8%, transparent);
    border-radius: var(--general-radius-3);
    background: rgba(var(--color-background));
    overflow: hidden;
  }

  .xo-section--{{ section.id }} summary {
    list-style: none;
    cursor: pointer;
    padding: 1.4rem 1.6rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    min-height: 44px;
    gap: 1.2rem;
    transition: background 0.2s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} summary::-webkit-details-marker {
    display: none;
  }

  .xo-section--{{ section.id }} summary:hover {
    background: color-mix(in srgb, rgba(var(--color-foreground)) 2%, transparent);
  }

  .xo-section--{{ section.id }} summary:focus-visible {
    outline: 2px solid rgba(var(--color-accent));
    outline-offset: 2px;
  }

  .xo-section--{{ section.id }} .qt__left {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .xo-section--{{ section.id }} .qt__ico {
    width: 2.2rem;
    height: 2.2rem;
    flex: 0 0 2.2rem;
    color: rgba(var(--color-foreground));
  }

  .xo-section--{{ section.id }} .qt__title {
    font-family: var(--font-heading-family, sans-serif);
    font-weight: 600;
    font-size: calc(var(--font-body-scale, 1) * 1.6rem);
    color: rgba(var(--color-foreground));
    letter-spacing: -0.01em;
    line-height: 1.3;
  }

  .xo-section--{{ section.id }} .qt__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-left: 1.6rem;
  }

  .xo-section--{{ section.id }} .qt__chip {
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 8%, transparent);
    border-radius: var(--button-radius);
    padding: 0.5rem 1.2rem;
    background: rgba(var(--color-background));
    font-size: calc(var(--font-body-scale, 1) * 1.2rem);
    font-weight: 600;
    color: rgba(var(--color-foreground));
  }

  .xo-section--{{ section.id }} .qt__caret {
    transition: transform 0.2s var(--out-soft, ease);
    color: rgba(var(--color-foreground));
    flex-shrink: 0;
  }

  .xo-section--{{ section.id }} details[open] .qt__caret {
    transform: rotate(180deg);
  }

  .xo-section--{{ section.id }} .qt__panel {
    padding: 0 1.6rem 1.6rem;
  }

  .xo-section--{{ section.id }} .qt__bullets {
    margin: 0 0 1.2rem 0;
    padding-left: 1.8rem;
    color: rgba(var(--color-foreground));
    line-height: 1.6;
  }

  .xo-section--{{ section.id }} .qt__bullets li {
    margin: 0.6rem 0;
  }

  .xo-section--{{ section.id }} .qt__verify-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .xo-section--{{ section.id }} .qt__verify {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.3rem 1rem;
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
    border-radius: var(--button-radius);
    background: color-mix(in srgb, rgba(var(--color-accent)) 8%, transparent);
    font-size: calc(var(--font-body-scale, 1) * 1.1rem);
    font-weight: 600;
    color: rgba(var(--color-foreground));
  }

  .xo-section--{{ section.id }} .qt__verify svg {
    width: 1.2rem;
    height: 1.2rem;
  }

  .xo-section--{{ section.id }} .qt__coa-link {
    text-decoration: none;
    font-weight: 600;
    color: rgba(var(--color-foreground));
    border-bottom: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 20%, transparent);
    transition: border-color 0.2s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .qt__coa-link:hover {
    border-color: rgba(var(--color-foreground));
  }

  .xo-section--{{ section.id }} .qt__coa-link:focus-visible {
    outline: 2px solid rgba(var(--color-accent));
    outline-offset: 2px;
    border-radius: 4px;
  }

  .xo-section--{{ section.id }} .qt__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.8rem;
  }

  @media (min-width: 768px) {
    .xo-section--{{ section.id }} .qt__grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .xo-section--{{ section.id }} .qt__item {
    background: color-mix(in srgb, rgba(var(--color-foreground)) 2%, rgba(var(--color-background)));
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 6%, transparent);
    border-radius: var(--general-radius-1);
    padding: 1.2rem 1.4rem;
    color: rgba(var(--color-foreground));
  }

  .xo-section--{{ section.id }} .qt__item--warn {
    background: color-mix(in srgb, rgba(var(--color-accent)) 6%, rgba(var(--color-background)));
  }

  .xo-section--{{ section.id }} .qt__item--small {
    font-size: calc(var(--font-body-scale, 1) * 1.3rem);
    opacity: 0.85;
  }

  .xo-section--{{ section.id }} .qt__label {
    font-weight: 600;
    margin-right: 0.6rem;
  }

  @media (prefers-reduced-motion: reduce) {
    .xo-section--{{ section.id }} summary,
    .xo-section--{{ section.id }} .qt__caret {
      transition: none;
    }
  }
{%- endstyle -%}

<section id="pep-storage" {% render 'section-attr' %}>
  <xo-container>
    <details {% if section.settings.default_open %}open{% endif %}>
      <summary>
        <span class="qt__left">
          {% if section.settings.icon == 'shield' %}
            <svg class="qt__ico" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 3l7 3v6c0 4.418-3.582 7.5-7 9-3.418-1.5-7-4.582-7-9V6l7-3z" stroke="currentColor" stroke-width="1.6" fill="none"/></svg>
          {% else %}
            <svg class="qt__ico" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M7 10h10M7 14h10M9 3h6l1 3h3v15H5V6h3l1-3z" stroke="currentColor" stroke-width="1.6" fill="none" stroke-linecap="round"/></svg>
          {% endif %}
          <span class="qt__title">{{ section.settings.title | default: 'Quality & Testing' }}</span>
          <span class="qt__chips">
            <span class="qt__chip">≥{{ section.settings.assay_floor | default: '99' }}% purity</span>
            <span class="qt__chip">HPLC verified</span>
            {% if coa_url and section.settings.show_coa_link %}<span class="qt__chip">Batch COA available</span>{% endif %}
          </span>
        </span>
        <svg class="qt__caret" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </summary>

      <div class="qt__panel">
        {% if section.settings.use_bullets %}
          <ul class="qt__bullets">
            <li>Each batch is tested for identity and purity (HPLC), targeting ≥{{ section.settings.assay_floor | default: '99' }}% assay.</li>
            {% if coa_url and section.settings.show_coa_link %}
              <li>Independent Certificate of Analysis available: <a class="qt__coa-link" href="{{ coa_url }}" target="_blank" rel="noopener">View COA</a>.</li>
            {% else %}
              <li>COA available on request for current batches.</li>
            {% endif %}
            <li>Zero-substitution policy — batches that don't meet spec are never released.</li>
          </ul>
        {% elsif section.settings.fallback_note != blank %}
          <div>{{ section.settings.fallback_note }}</div>
        {% endif %}

        <div class="qt__verify-row">
          {% render 'pep-verify-badge', class: 'qt__verify', label: 'Verified' %}
          {% if coa_url and section.settings.show_coa_link %}
            <a class="qt__coa-link" href="{{ coa_url }}" target="_blank" rel="noopener">View Verified COA</a>
          {% endif %}
        </div>

        <div class="qt__grid">
          {% if form_mf %}
            <div class="qt__item"><span class="qt__label">Form:</span> {{ form_mf | metafield_tag }}</div>
          {% endif %}
          {% if storage_mf %}
            <div class="qt__item"><span class="qt__label">Storage:</span> {{ storage_mf | metafield_tag }}</div>
          {% endif %}
          {% if recon_mf %}
            <div class="qt__item"><span class="qt__label">Reconstitution:</span> {{ recon_mf | metafield_tag }}</div>
          {% endif %}
          {% if research_disc %}
            <div class="qt__item qt__item--warn">{{ research_disc | metafield_tag }}</div>
          {% endif %}
          {% if safety_imp %}
            <div class="qt__item qt__item--warn">{{ safety_imp | metafield_tag }}</div>
          {% endif %}
          {% if safety_gen %}
            <div class="qt__item">{{ safety_gen | metafield_tag }}</div>
          {% endif %}
          {% if disclaimer_mf %}
            <div class="qt__item qt__item--small">{{ disclaimer_mf | metafield_tag }}</div>
          {% endif %}
          {% if form_mf == blank and storage_mf == blank and recon_mf == blank and research_disc == blank and safety_imp == blank and safety_gen == blank and disclaimer_mf == blank and section.settings.fallback_note != blank %}
            <div class="qt__item">{{ section.settings.fallback_note }}</div>
          {% endif %}
        </div>
      </div>
    </details>
  </xo-container>
</section>

{% endif %}

{% schema %}
{
  "name": "Quality & Test",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "background-1"
    },
    {
      "type": "checkbox",
      "id": "default_open",
      "label": "Open by default",
      "default": true
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Quality & Testing"
    },
    {
      "type": "select",
      "id": "icon",
      "label": "Icon",
      "default": "flask",
      "options": [
        { "value": "flask", "label": "Lab flask" },
        { "value": "shield", "label": "Shield" }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_coa_link",
      "label": "Show COA links in this section",
      "default": true,
      "info": "Turn off if the COA band appears on the same page to avoid duplicate CTAs."
    },
    {
      "type": "checkbox",
      "id": "use_bullets",
      "label": "Show default proof-point bullets",
      "default": true
    },
    {
      "type": "text",
      "id": "assay_floor",
      "label": "Assay proof-point floor (%)",
      "default": "99"
    },
    {
      "type": "richtext",
      "id": "fallback_note",
      "label": "Fallback note (if no metafields present and bullets disabled)",
      "default": "<p>Lyophilized research peptide. Keep cold and away from light. For laboratory research only — not for human or veterinary use.</p>"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "Desktop top padding",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 24,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Desktop bottom padding",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 24,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Mobile top padding",
      "min": 0,
      "max": 60,
      "step": 4,
      "default": 20,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Mobile bottom padding",
      "min": 0,
      "max": 60,
      "step": 4,
      "default": 20,
      "unit": "px"
    }
  ],
  "presets": [{ "name": "Quality & Testing (Accordion)" }]
}
{% endschema %}
