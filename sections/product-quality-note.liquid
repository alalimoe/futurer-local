{% comment %}
───────────────────────────────────────────────
SECTION: Quality & Testing (Accordion)
Replaces: Product Quality Note
Wires to metafields (same as previous):
- peptide.form                 (single_line_text_field)
- peptide.storage              (multi_line_text_field)
- peptide.reconstitution       (multi_line_text_field)
- peptide.research_disclaimer  (multi_line_text_field)
- npx.safety_important         (multi_line_text_field)
- npx.safety_general           (multi_line_text_field)
- npx.disclaimer               (multi_line_text_field)

Also auto-resolves COA link identical to peptide hero logic:
- pdp.coa_url (string/url) > pep.coa_pdf (file) > peptide.coa_file[0]
───────────────────────────────────────────────
{% endcomment %}

{%- liquid
  assign form_mf        = product.metafields.peptide.form
  assign storage_mf     = product.metafields.peptide.storage
  assign recon_mf       = product.metafields.peptide.reconstitution
  assign research_disc  = product.metafields.peptide.research_disclaimer

  assign safety_imp     = product.metafields.npx.safety_important
  assign safety_gen     = product.metafields.npx.safety_general
  assign disclaimer_mf  = product.metafields.npx.disclaimer

  assign has_any = false
  if form_mf or storage_mf or recon_mf or research_disc or safety_imp or safety_gen or disclaimer_mf
    assign has_any = true
  endif

  # ---------- Resolve COA URL (priority: pdp.coa_url → pep.coa_pdf → peptide.coa_file[0]) ----------
  assign pdp_coa_override    = product.metafields.pdp.coa_url
  assign coa_pdf_mf          = product.metafields.pep.coa_pdf
  assign coa_files_mf        = product.metafields.peptide.coa_file

  assign coa_url = nil
  if pdp_coa_override and pdp_coa_override != blank
    assign coa_url = pdp_coa_override
  elsif coa_pdf_mf and coa_pdf_mf.value and coa_pdf_mf.value.url
    assign coa_url = coa_pdf_mf.value.url
  elsif coa_files_mf and coa_files_mf.value and coa_files_mf.value.size > 0
    assign first_file = coa_files_mf.value.first
    if first_file and first_file.url
      assign coa_url = first_file.url
    endif
  endif
-%}

{% if has_any or section.settings.fallback_note != blank %}
<section id="quality-testing" class="qt-wrap" data-qt>
  <style>
    #quality-testing{
      --qt-maxw: {{ section.settings.max_width | default: 1200 }}px;
      --qt-border: {{ section.settings.border_color | default: '#E7E9ED' }};
      --qt-bg: {{ section.settings.bg_color | default: '#FAFAFB' }};
      --qt-card-bg: #FFFFFF;
      --qt-muted: #6B7280;
      --qt-text: #111111;
      --qt-accent: {{ section.settings.accent_color | default: '#FBBF24' }};
      --qt-radius: 14px;
    }
    .qt-wrap{padding:22px var(--page-gutter);background:var(--qt-bg);border-top:none;border-bottom:none;font-family:var(--font-body-family,sans-serif)}
    .qt-container{max-width:var(--qt-maxw);margin:0 auto}

    /* Header button (accordion trigger) */
    .qt-head{
      display:flex;align-items:center;justify-content:space-between;width:100%;
      border:none;border-radius:var(--qt-radius);background:rgba(255,255,255,0.75);
      -webkit-backdrop-filter:blur(12px);backdrop-filter:blur(12px);
      padding:14px 16px;min-height:44px;cursor:pointer;box-shadow:var(--shadow-sm);
      transition:var(--transition-premium);
    }
    .qt-head:focus-visible{outline:2px solid var(--qt-accent);outline-offset:2px}
    .qt-head:hover{box-shadow:var(--shadow-md-hover);transform:translateY(-1px)}
    .qt-left{display:flex;align-items:center;gap:10px}
    .qt-ico{width:22px;height:22px;flex:0 0 22px;color:var(--color-text-primary)}
    .qt-title{font-family:var(--font-heading-family,sans-serif);font-weight:800;font-size:clamp(0.9rem,1.3vw,1rem);color:var(--qt-text);letter-spacing:-0.01em}
    .qt-points{display:flex;flex-wrap:wrap;gap:8px;margin-left:16px}
    .qt-chip{border:none;border-radius:999px;padding:5px 12px;background:rgba(255,255,255,0.6);-webkit-backdrop-filter:blur(8px);backdrop-filter:blur(8px);font-size:12px;box-shadow:var(--shadow-xs)}
    .qt-right .qt-caret{transition:transform .2s ease; color:var(--color-text-primary)}
    .qt-head[aria-expanded="true"] .qt-caret{transform:rotate(180deg)}

    /* Panel */
    .qt-panel{display:none;margin-top:12px}
    .qt-panel.is-open{display:block}
    .qt-card{border:none;border-radius:var(--qt-radius);background:var(--qt-card-bg);padding:16px;box-shadow:var(--shadow-sm)}
    .qt-bullets{margin:0 0 12px 0;padding-left:18px;color:#1f2937}
    .qt-bullets li{margin:6px 0}

    /* K/V grid */
    .qt-grid{display:grid;grid-template-columns:1fr;gap:8px}
    @media(min-width:860px){ .qt-grid{grid-template-columns:1fr 1fr} }
    .qt-item{background:rgba(255,255,255,0.7);border:none;border-radius:12px;padding:12px 14px;color:#1f2937;box-shadow:var(--shadow-xs);transition:var(--transition-premium)}
    .qt-item:hover{box-shadow:var(--shadow-sm-hover);transform:translateY(-1px)}
    .qt-item.warn{background:rgba(255,247,242,0.85)}
    .qt-item.small{font-size:.92rem;color:#374151}
    .qt-label{font-weight:600;margin-right:6px;color:var(--qt-text)}
    .qt-text{color:var(--qt-text);opacity:0.85}

    /* Verified badge */
    .qt-verify{display:inline-flex;align-items:center;gap:6px;padding:3px 10px;border:none;border-radius:999px;background:rgba(16,163,50,0.08);-webkit-backdrop-filter:blur(8px);backdrop-filter:blur(8px);font-size:11px;font-weight:600;color:#0f5132}
    .qt-verify svg{width:12px;height:12px;display:block}

    /* Hover underline for COA */
    .qt-coa a{ position:relative; text-decoration:none; font-weight:600; color:var(--qt-text); }
    .qt-coa a:focus-visible{outline:2px solid var(--qt-accent);outline-offset:2px;border-radius:4px}
    .qt-coa a::after{content:""; position:absolute; left:50%; right:50%; bottom:-2px; height:1px; background: currentColor; transition:left .18s ease,right .18s ease;}
    .qt-coa a:hover::after{ left:0; right:0; }

    /* Micro-motions (respect reduced motion) */
    @media (prefers-reduced-motion:no-preference){
      .qt-verify.is-in{ animation: qtPulse 520ms cubic-bezier(0.22,1,0.36,1) 1; }
      @keyframes qtPulse{0%{transform:scale(.96);opacity:.9}60%{transform:scale(1.02)}100%{transform:scale(1);opacity:1}}
      .qt-head.is-in{ box-shadow:0 0 0 2px color-mix(in srgb, var(--qt-accent) 14%, transparent) inset; transition: box-shadow .7s ease; }
    }
    @media (prefers-reduced-motion:reduce){
      .qt-head,.qt-item{transition:none}
      .qt-head:hover,.qt-item:hover{transform:none}
    }
  </style>

  <div class="qt-container">

    <!-- Accordion header -->
    <button class="qt-head"
            type="button"
            aria-expanded="{{ section.settings.default_open | default: true }}"
            aria-controls="qt-panel">
      <span class="qt-left">
        {% if section.settings.icon == 'shield' %}
          <svg class="qt-ico" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 3l7 3v6c0 4.418-3.582 7.5-7 9-3.418-1.5-7-4.582-7-9V6l7-3z" stroke="currentColor" stroke-width="1.6" fill="none"/></svg>
        {% else %}
          <svg class="qt-ico" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M7 10h10M7 14h10M9 3h6l1 3h3v15H5V6h3l1-3z" stroke="currentColor" stroke-width="1.6" fill="none" stroke-linecap="round"/></svg>
        {% endif %}
        <span class="qt-title">{{ section.settings.title | default: 'Quality & Testing' }}</span>
        <span class="qt-points">
          <span class="qt-chip">≥{{ section.settings.assay_floor | default: '99' }}% purity</span>
          <span class="qt-chip">HPLC verified</span>
          {% if coa_url %}<span class="qt-chip">Batch COA available</span>{% endif %}
        </span>
      </span>
      <span class="qt-right">
        <svg class="qt-caret" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </span>
    </button>

    <!-- Accordion panel -->
    <div id="qt-panel"
         class="qt-panel {% if section.settings.default_open %}is-open{% endif %}"
         role="region"
         aria-labelledby="quality-testing">
      <div class="qt-card">
        {% if section.settings.use_bullets %}
          <ul class="qt-bullets">
            <li>Each batch is tested for identity and purity (HPLC), targeting ≥{{ section.settings.assay_floor | default: '99' }}% assay.</li>
            {% if coa_url %}
              <li class="qt-coa">Independent Certificate of Analysis available: <a href="{{ coa_url }}" target="_blank" rel="noopener">View COA</a>.</li>
            {% else %}
              <li>COA available on request for current batches.</li>
            {% endif %}
            <li>Zero-substitution policy — batches that don’t meet spec are never released.</li>
          </ul>
        {% elsif section.settings.fallback_note != blank %}
          <div class="qt-fallback">{{ section.settings.fallback_note }}</div>
        {% endif %}

        <!-- Verify badge row -->
        <div class="qt-verify-row" style="display:flex;align-items:center;gap:10px;margin-bottom:10px">
          <span class="qt-verify" data-qt-verify>
            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M9.5 12.5l2 2 4-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Verified
          </span>
          {% if coa_url %}
            <span class="qt-coa"><a href="{{ coa_url }}" target="_blank" rel="noopener">View Verified COA</a></span>
          {% endif %}
        </div>

        <!-- Spec / safety grid -->
        <div class="qt-grid">
          {% if form_mf %}
            <div class="qt-item"><span class="qt-label">Form:</span> <span class="qt-text">{{ form_mf | metafield_tag }}</span></div>
          {% endif %}
          {% if storage_mf %}
            <div class="qt-item"><span class="qt-label">Storage:</span> <span class="qt-text">{{ storage_mf | metafield_tag }}</span></div>
          {% endif %}
          {% if recon_mf %}
            <div class="qt-item"><span class="qt-label">Reconstitution:</span> <span class="qt-text">{{ recon_mf | metafield_tag }}</span></div>
          {% endif %}

          {% if research_disc %}
            <div class="qt-item warn">{{ research_disc | metafield_tag }}</div>
          {% endif %}
          {% if safety_imp %}
            <div class="qt-item warn">{{ safety_imp | metafield_tag }}</div>
          {% endif %}
          {% if safety_gen %}
            <div class="qt-item">{{ safety_gen | metafield_tag }}</div>
          {% endif %}
          {% if disclaimer_mf %}
            <div class="qt-item small">{{ disclaimer_mf | metafield_tag }}</div>
          {% endif %}

          {% if form_mf == blank and storage_mf == blank and recon_mf == blank and research_disc == blank and safety_imp == blank and safety_gen == blank and disclaimer_mf == blank and section.settings.fallback_note != blank %}
            <div class="qt-item">{{ section.settings.fallback_note }}</div>
          {% endif %}
        </div>
      </div>
    </div>

  </div>
</section>
{% endif %}

<script>
document.addEventListener('DOMContentLoaded', function(){
  var root = document.querySelector('#quality-testing');
  if(!root) return;

  var btn = root.querySelector('.qt-head');
  var panel = root.querySelector('#qt-panel');
  var verify = root.querySelector('[data-qt-verify]');

  // Scroll entry highlight (once)
  try{
    if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      var io = new IntersectionObserver(function(entries){
        entries.forEach(function(e){
          if(e.isIntersecting){
            btn.classList.add('is-in');
            verify && verify.classList.add('is-in');
            io.disconnect();
          }
        });
      }, { threshold: 0.35 });
      io.observe(btn);
    }
  }catch(e){}

  // Accordion toggle
  btn.addEventListener('click', function(){
    var open = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!open));
    panel.classList.toggle('is-open', !open);
  });
});
</script>

{% schema %}
{
  "name": "Quality & Test",
  "settings": [
    { "type": "range", "id": "max_width", "min": 800, "max": 1600, "step": 10, "unit": "px", "label": "Container max width", "default": 1200 },
    { "type": "color", "id": "bg_color", "label": "Section background", "default": "#FAFAFB" },
    { "type": "color", "id": "border_color", "label": "Border color", "default": "#E7E9ED" },
    { "type": "color", "id": "accent_color", "label": "Accent color", "default": "#FBBF24" },
    { "type": "checkbox", "id": "default_open", "label": "Open by default", "default": true },

    { "type": "text", "id": "title", "label": "Title", "default": "Quality & Testing" },
    { "type": "select", "id": "icon", "label": "Icon", "default": "flask", "options": [
      { "value": "flask", "label": "Lab flask" },
      { "value": "shield", "label": "Shield" }
    ]},

    { "type": "checkbox", "id": "use_bullets", "label": "Show default proof-point bullets", "default": true },
    { "type": "text", "id": "assay_floor", "label": "Assay proof-point floor (%)", "default": "99" },

    { "type": "richtext", "id": "fallback_note", "label": "Fallback note (if no metafields present and bullets disabled)", "default": "<p>Lyophilized research peptide. Keep cold and away from light. For laboratory research only — not for human or veterinary use.</p>" }
  ],
  "presets": [
    { "name": "Quality & Testing (Accordion)" }
  ]
}
{% endschema %}
