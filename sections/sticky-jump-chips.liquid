{% comment %}
  Sticky jump chips: on-page nav with scroll-spy; configurable section targets.
{% endcomment %}

{%- style -%}
  .xo-section--{{ section.id }} {
    position: sticky;
    top: {{ section.settings.sticky_top | default: 64 }}px;
    z-index: 20;
    background: color-mix(in srgb, rgba(var(--color-background)) 75%, transparent);
    -webkit-backdrop-filter: blur(16px) saturate(180%);
    backdrop-filter: blur(16px) saturate(180%);
  }

  .xo-section--{{ section.id }} .sjc__wrap {
    position: relative;
  }

  .xo-section--{{ section.id }} .sjc__wrap::after {
    content: '';
    position: absolute;
    right: 0;
    top: 0;
    bottom: 0;
    width: 4rem;
    background: linear-gradient(to right, transparent, color-mix(in srgb, rgba(var(--color-background)) 85%, transparent));
    pointer-events: none;
    z-index: 1;
  }

  .xo-section--{{ section.id }} .sjc__row {
    display: flex;
    gap: 0.8rem;
    align-items: center;
    flex-wrap: nowrap;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding: 0.8rem 0;
  }

  .xo-section--{{ section.id }} .sjc__row::-webkit-scrollbar {
    display: none;
  }

  .xo-section--{{ section.id }} .sjc__chip {
    flex: 0 0 auto;
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
    border-radius: var(--button-radius);
    background: rgba(var(--color-background));
    color: rgba(var(--color-foreground));
    padding: 0.8rem 1.4rem;
    min-height: 44px;
    font-family: var(--font-body-family, sans-serif);
    font-weight: 600;
    font-size: calc(var(--font-body-scale, 1) * 1.4rem);
    line-height: 1.1;
    text-decoration: none;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    transition: border-color 0.3s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .sjc__chip:focus-visible {
    outline: 2px solid rgba(var(--color-accent));
    outline-offset: 2px;
  }

  .xo-section--{{ section.id }} .sjc__chip:hover {
    border-color: color-mix(in srgb, rgba(var(--color-accent)) 50%, transparent);
  }

  .xo-section--{{ section.id }} .sjc__chip.is-active {
    border-color: rgba(var(--color-accent));
    background: color-mix(in srgb, rgba(var(--color-accent)) 8%, rgba(var(--color-background)));
  }

  .xo-section--{{ section.id }} .sjc__dot {
    width: 0.6rem;
    height: 0.6rem;
    border-radius: 50%;
    background: rgba(var(--color-accent));
    display: inline-block;
    margin-right: 0.8rem;
  }

  @media (prefers-reduced-motion: reduce) {
    .xo-section--{{ section.id }} .sjc__chip {
      transition: none;
    }
  }
{%- endstyle -%}

<section {% render 'section-attr' %}>
  <xo-container>
    <div class="sjc__wrap">
    <nav class="sjc__row" role="navigation" aria-label="On-page navigation">
      <button class="sjc__chip" type="button" data-target="#peptide-research"><span class="sjc__dot" aria-hidden="true"></span>{{ section.settings.label_overview | default: 'Overview' }}</button>
      <button class="sjc__chip" type="button" data-target="#pep-coa-band"><span class="sjc__dot" aria-hidden="true"></span>{{ section.settings.label_coa | default: 'COA' }}</button>
      <button class="sjc__chip" type="button" data-target="#pep-refs"><span class="sjc__dot" aria-hidden="true"></span>{{ section.settings.label_refs | default: 'References' }}</button>
      <button class="sjc__chip" type="button" data-target="#pep-storage"><span class="sjc__dot" aria-hidden="true"></span>{{ section.settings.label_storage | default: 'Storage' }}</button>
      <button class="sjc__chip" type="button" data-target="#peptide-compare"><span class="sjc__dot" aria-hidden="true"></span>{{ section.settings.label_compare | default: 'Compare' }}</button>
    </nav>
    </div>
  </xo-container>
</section>

<script>
(function(){
  var wrap = document.querySelector('.xo-section--{{ section.id }}');
  if (!wrap) return;
  var chips = wrap.querySelectorAll('.sjc__chip');
  var topOffset = {{ section.settings.sticky_top | default: 64 }};

  chips.forEach(function(btn) {
    var sel = btn.getAttribute('data-target');
    if (!sel || !document.querySelector(sel)) {
      btn.style.display = 'none';
      btn.setAttribute('aria-hidden', 'true');
      btn.setAttribute('tabindex', '-1');
    }
  });

  function scrollToTarget(sel) {
    var el = document.querySelector(sel);
    if (!el) return;
    var y = el.getBoundingClientRect().top + window.pageYOffset - (topOffset + 12);
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      window.scrollTo(0, y);
    } else {
      window.scrollTo({ top: y, behavior: 'smooth' });
    }
  }

  function visibleChips() {
    return Array.from(chips).filter(function(c) { return c.getAttribute('aria-hidden') !== 'true'; });
  }

  chips.forEach(function(btn) {
    btn.addEventListener('click', function() {
      if (btn.getAttribute('aria-hidden') === 'true') return;
      scrollToTarget(btn.getAttribute('data-target'));
    });
    btn.addEventListener('keydown', function(e) {
      if (e.key === 'ArrowRight' || e.key === 'ArrowLeft') {
        var all = visibleChips();
        if (all.length < 2) return;
        var i = all.indexOf(btn);
        if (i < 0) return;
        var next = e.key === 'ArrowRight' ? (i + 1) % all.length : (i - 1 + all.length) % all.length;
        all[next].focus();
        e.preventDefault();
      }
    });
  });

  var targets = [
    ['#peptide-research', chips[0]],
    ['#pep-coa-band', chips[1]],
    ['#pep-refs', chips[2]],
    ['#pep-storage', chips[3]],
    ['#peptide-compare', chips[4]]
  ].filter(function(t) { return document.querySelector(t[0]); });

  try {
    var io = new IntersectionObserver(function(entries) {
      var vis = entries.filter(function(e) { return e.isIntersecting; }).sort(function(a, b) { return a.boundingClientRect.top - b.boundingClientRect.top; });
      if (vis.length) {
        var id = '#' + (vis[0].target.id || '');
        targets.forEach(function(t) { t[1].classList.toggle('is-active', t[0] === id); });
      }
    }, { rootMargin: '-' + topOffset + 'px 0px 0px 0px', threshold: 0.25 });
    targets.forEach(function(t) { var el = document.querySelector(t[0]); if (el) io.observe(el); });
  } catch (e) {}
})();
</script>

{% schema %}
{
  "name": "Sticky jump chips",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "range",
      "id": "sticky_top",
      "min": 0,
      "max": 160,
      "step": 2,
      "unit": "px",
      "label": "Sticky top offset (header height)",
      "default": 64
    },
    {
      "type": "text",
      "id": "label_overview",
      "label": "Overview label",
      "default": "Overview"
    },
    {
      "type": "text",
      "id": "label_coa",
      "label": "COA label",
      "default": "COA"
    },
    {
      "type": "text",
      "id": "label_refs",
      "label": "References label",
      "default": "References"
    },
    {
      "type": "text",
      "id": "label_storage",
      "label": "Storage label",
      "default": "Storage"
    },
    {
      "type": "text",
      "id": "label_compare",
      "label": "Compare label",
      "default": "Compare"
    }
  ],
  "presets": [{ "name": "Sticky jump chips" }]
}
{% endschema %}
