{% schema %}
{
  "name": "Nootropics hero",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "select", "id": "product_media_style", "label": "Gallery layout", "options": [
      { "value": "style-1", "label": "Carousel" },
      { "value": "style-2", "label": "Slide (wide)" }
    ], "default": "style-1" },

    { "type": "checkbox", "id": "hide_variants", "default": false, "label": "Hide variants" },
    { "type": "checkbox", "id": "show_image_variants_grouping", "default": false, "label": "Group media by variant" },
    { "type": "checkbox", "id": "enable_sticky_cart", "default": true, "label": "Enable sticky cart" },

    { "type": "select", "id": "gallery_type", "label": "Gallery type", "options": [
      { "value": "carousel", "label": "Carousel" },
      { "value": "scroll", "label": "Scroll" }
    ], "default": "carousel" },

    { "type": "select", "id": "media_column", "options": [
      { "value": "3", "label": "3" },
      { "value": "4", "label": "4" },
      { "value": "5", "label": "5" },
      { "value": "6", "label": "6" }
    ], "label": "Media columns (desktop)", "default": "6" },

    { "type": "header", "content": "General settings" },
    { "type": "number", "id": "max_width", "label": "Max width (px)", "default": 1400 },
    { "type": "range", "id": "padding_top_desktop", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding top (desktop)", "default": 48 },
    { "type": "range", "id": "padding_bottom_desktop", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding bottom (desktop)", "default": 48 },
    { "type": "range", "id": "padding_top_mobile", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding top (mobile)", "default": 48 },
    { "type": "range", "id": "padding_bottom_mobile", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding bottom (mobile)", "default": 48 },

    { "type": "color_scheme", "id": "color_scheme", "label": "Section color scheme" },
    { "type": "color", "id": "background_color", "label": "Background color" },
    { "type": "color_background", "id": "background_gradient", "label": "Background gradient" }
  ],
  "blocks": [
    { "type": "@app" },
    { "type": "custom_liquid", "name": "Custom Liquid", "settings": [ { "type": "liquid", "id": "custom_liquid", "label": "Liquid" } ] },
    { "type": "vendor", "name": "Vendor", "limit": 1 },
    { "type": "title", "name": "Title", "limit": 1 },
    { "type": "price", "name": "Price", "limit": 1 },
    { "type": "description", "name": "Description", "limit": 1 },
    {
      "type": "variants",
      "name": "Variants",
      "limit": 1,
      "settings": [
        { "type": "paragraph", "content": "Choose how variants are displayed" },
        { "type": "select", "id": "variant_style", "label": "Variant style", "options": [
          { "value": "radio", "label": "Radio" },
          { "value": "boxed", "label": "Boxed" },
          { "value": "select", "label": "Select" }
