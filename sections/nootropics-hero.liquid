  var root = document.getElementById('nootropics-hero'); if(!root) return;
  try{
    if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      var io = new IntersectionObserver(function(entries){
        entries.forEach(function(e){
          if(e.isIntersecting){
            root.querySelectorAll('.nh-chip, .nh-disclaimer').forEach(function(n,i){
              n.style.transitionDelay = (i*30)+'ms';
              n.classList.add('nx_in');
            });
            io.disconnect();
          }
        });
      }, { threshold: 0.35 });
      io.observe(root);
    } else {
      root.querySelectorAll('.nh-chip, .nh-disclaimer').forEach(function(n){ n.classList.add('nx_in'); });
    }
  }catch(e){}
});
</script>


{% schema %}
{
  "name": "Nootropics hero",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "select", "id": "product_media_style", "label": "Gallery layout", "options": [
      { "value": "style-1", "label": "Carousel" },
      { "value": "style-2", "label": "Slide (wide)" }
    ], "default": "style-1" },

    { "type": "checkbox", "id": "hide_variants", "default": false, "label": "Hide variants" },
    { "type": "checkbox", "id": "show_image_variants_grouping", "default": false, "label": "Group media by variant" },
    { "type": "checkbox", "id": "enable_sticky_cart", "default": true, "label": "Enable sticky cart" },

    { "type": "select", "id": "gallery_type", "label": "Gallery type", "options": [
      { "value": "carousel", "label": "Carousel" },
      { "value": "scroll", "label": "Scroll" }
    ], "default": "carousel" },

    { "type": "select", "id": "media_column", "options": [
      { "value": "3", "label": "3" },
      { "value": "4", "label": "4" },
      { "value": "5", "label": "5" },
      { "value": "6", "label": "6" }
    ], "label": "Media columns (desktop)", "default": "6" },

    { "type": "header", "content": "General settings" },
    { "type": "number", "id": "max_width", "label": "Max width (px)", "default": 1400 },
    { "type": "number", "id": "padding_top_desktop", "label": "Padding top (desktop, px)", "default": 50 },
    { "type": "number", "id": "padding_bottom_desktop", "label": "Padding bottom (desktop, px)", "default": 50 },
    { "type": "number", "id": "padding_top_mobile", "label": "Padding top (mobile, px)", "default": 50 },
    { "type": "number", "id": "padding_bottom_mobile", "label": "Padding bottom (mobile, px)", "default": 50 },

    { "type": "color_scheme", "id": "color_scheme", "label": "Section color scheme" },
    { "type": "color", "id": "background_color", "label": "Background color" },
    { "type": "color_background", "id": "background_gradient", "label": "Background gradient" }
  ],
  "blocks": [
    { "type": "@app" },
    { "type": "custom_liquid", "name": "Custom Liquid", "settings": [ { "type": "liquid", "id": "custom_liquid", "label": "Liquid" } ] },
    { "type": "vendor", "name": "Vendor", "limit": 1 },
    { "type": "title", "name": "Title", "limit": 1 },
    { "type": "price", "name": "Price", "limit": 1 },
    { "type": "description", "name": "Description", "limit": 1 },
    {
      "type": "variants",
      "name": "Variants",
      "limit": 1,
      "settings": [
        { "type": "paragraph", "content": "Choose how variants are displayed" },
        { "type": "select", "id": "variant_style", "label": "Variant style", "options": [
          { "value": "radio", "label": "Radio" },
          { "value": "boxed", "label": "Boxed" },
          { "value": "select", "label": "Select" }
        ], "default": "select" },
        { "type": "select", "id": "variant_color_style", "label": "Color style", "options": [
          { "value": "radio", "label": "Radio" },
          { "value": "boxed", "label": "Boxed" },
          { "value": "select", "label": "Select" },
          { "value": "color", "label": "Color swatch" },
          { "value": "variant_image", "label": "Variant image" }
        ], "default": "color" }
      ]
    },
    {
      "type": "buy_button",
      "name": "Buy buttons",
      "limit": 1,
      "settings": [
        { "type": "checkbox", "id": "show_dynamic_checkout", "label": "Show dynamic checkout", "default": true },
        { "type": "checkbox", "id": "show_gift_card_recipient", "label": "Gift card recipient", "default": false }
      ]
    },
    { "type": "collapse", "name": "Collapsible tab", "settings": [
      { "type": "text", "id": "collapse_text", "label": "Heading", "default": "More details" },
      { "type": "richtext", "id": "collapse_content", "label": "Content", "default": "<p>More information</p>" }
    ]},
    { "type": "line", "name": "Line" },
    { "type": "pickup", "name": "Pickup availability" },
    { "type": "share", "name": "Share", "limit": 1, "settings": [
      { "type": "select", "id": "share_option", "label": "Share option", "options": [
        { "value": "link", "label": "Link" },
        { "value": "social", "label": "Social" }
      ], "default": "link" }
    ]},
    { "type": "complementary", "name": "Complementary products", "limit": 1, "settings": [
      { "type": "richtext", "id": "heading", "label": "Heading", "default": "<p>Heading</p>" },
      { "type": "header", "content": "Carousel" },
      { "type": "select", "id": "autoplay", "label": "Autoplay", "options": [
