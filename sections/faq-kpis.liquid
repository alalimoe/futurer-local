{%- style -%}
  .xo-section--{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .xo-section--{{ section.id }} .kpis__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 8px;
    flex-wrap: wrap;
  }

  .xo-section--{{ section.id }} .kpis__title {
    font-size: clamp(1.1rem, 2vw, 1.35rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.2;
    color: rgba(var(--color-foreground));
    margin: 0;
  }

  .xo-section--{{ section.id }} .kpis__sub {
    font-size: clamp(0.7rem, 1vw, 0.8rem);
    color: color-mix(in srgb, rgba(var(--color-foreground)) 55%, transparent);
  }

  .xo-section--{{ section.id }} .kpis__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }

  .xo-section--{{ section.id }} .kpi {
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 8%, transparent);
    border-radius: var(--general-radius-3, 2rem);
    padding: 16px;
    text-align: center;
    transition: border-color 0.3s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .kpi:hover {
    border-color: color-mix(in srgb, rgba(var(--color-foreground)) 20%, transparent);
  }

  .xo-section--{{ section.id }} .kpi__value {
    font-size: clamp(1.5rem, 3vw, 1.75rem);
    font-weight: 600;
    letter-spacing: -0.025em;
    color: rgba(var(--color-foreground));
  }

  .xo-section--{{ section.id }} .kpi__label {
    font-size: clamp(0.65rem, 1vw, 0.75rem);
    color: color-mix(in srgb, rgba(var(--color-foreground)) 55%, transparent);
    margin-top: 6px;
  }

  .xo-section--{{ section.id }} .kpis__note {
    font-size: clamp(0.65rem, 1vw, 0.75rem);
    color: color-mix(in srgb, rgba(var(--color-foreground)) 55%, transparent);
    margin-top: 10px;
  }

  @media (min-width: 768px) {
    .xo-section--{{ section.id }} .kpis__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .xo-section--{{ section.id }} .kpi {
      transition: none;
    }
  }
{%- endstyle -%}

<section {% render 'section-attr' %}>
  <xo-container>
    <div class="kpis__header">
      <h2 class="kpis__title">{{ section.settings.heading }}</h2>
      <p class="kpis__sub">Updated {{ section.settings.last_updated }}</p>
    </div>
    <div class="kpis__grid">
      <div class="kpi">
        <div class="kpi__value">{{ section.settings.on_time_attempt }}%</div>
        <div class="kpi__label">On-time first attempt (Local)</div>
      </div>
      <div class="kpi">
        <div class="kpi__value">{{ section.settings.on_time_delivery }}%</div>
        <div class="kpi__label">On-time delivery (Local)</div>
      </div>
      <div class="kpi">
        <div class="kpi__value">{{ section.settings.completion_rate }}%</div>
        <div class="kpi__label">Delivered successfully</div>
      </div>
      <div class="kpi">
        <div class="kpi__value">{{ section.settings.best_days }}</div>
        <div class="kpi__label">Best days lately</div>
      </div>
    </div>
    {% if section.settings.note != blank %}
      <p class="kpis__note">{{ section.settings.note }}</p>
    {% endif %}
  </xo-container>
</section>

{% schema %}
{
  "name": "FAQ KPI Tiles",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "default" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Fast Local Delivery — At a Glance" },
    { "type": "text", "id": "last_updated", "label": "Last updated", "default": "17 Sep 2025" },
    { "type": "text", "id": "on_time_attempt", "label": "On-time first attempt %", "default": "83.3" },
    { "type": "text", "id": "on_time_delivery", "label": "On-time delivery %", "default": "76.2" },
    { "type": "text", "id": "completion_rate", "label": "Completion rate %", "default": "85.7" },
    { "type": "text", "id": "best_days", "label": "Best days", "default": "Thu & Fri" },
    { "type": "text", "id": "note", "label": "Small note", "default": "Based on our latest delivery report. Times can vary on Fridays/holidays and during peak hours." },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding top", "default": 8 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding bottom", "default": 16 }
  ],
  "presets": [{ "name": "FAQ KPI Tiles" }]
}
{% endschema %}
