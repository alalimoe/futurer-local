{% schema %}
{
  "name": "Phenibut TL;DR",
  "tag": "section",
  "class": "section-phenibut-tldr",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Key Takeaways (TL;DR)" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#fafafb" },
    { "type": "color", "id": "accent_color", "label": "Accent (Left Border)", "default": "#FBBF24" }
  ],
  "blocks": [
    {
      "type": "takeaway",
      "name": "Takeaway",
      "settings": [
        { "type": "richtext", "id": "text", "label": "Takeaway text" }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Phenibut TL;DR",
      "blocks": [
        { "type": "takeaway", "settings": { "text": "<p>Phenibut acts at <strong>GABA-B receptors</strong> — use it occasionally, never daily.</p>" } },
        { "type": "takeaway", "settings": { "text": "<p>Start low (<strong>100–250 mg</strong>); effects take 1–3 hours to onset.</p>" } },
        { "type": "takeaway", "settings": { "text": "<p><strong>Never</strong> combine with alcohol, benzodiazepines, or other sedatives.</p>" } },
        { "type": "takeaway", "settings": { "text": "<p>Available as <strong>FAA</strong> (neutral taste) and <strong>HCl</strong> (water-soluble) forms.</p>" } },
        { "type": "takeaway", "settings": { "text": "<p>Limit use to <strong>1–2× per week</strong> max to avoid tolerance.</p>" } }
      ]
    }
  ]
}
{% endschema %}

<div class="phbt-wrapper" id="phbt-{{ section.id }}">
  <div class="phbt-container">
    <div class="phbt-card">
      <h2 class="phbt-heading">{{ section.settings.heading }}</h2>
      {% if section.blocks.size > 0 %}
        <ul class="phbt-list" role="list">
          {% for block in section.blocks %}
            <li class="phbt-item" {{ block.shopify_attributes }}>{{ block.settings.text }}</li>
          {% endfor %}
        </ul>
      {% endif %}
    </div>
  </div>
</div>

{%- style -%}
#phbt-{{ section.id }} {
  --phbt-bg: {{ section.settings.bg_color }};
  --phbt-accent: {{ section.settings.accent_color }};
  --phbt-font: var(--font-body-family, sans-serif);
  --phbt-text: var(--color-text-main, #111827);
  --phbt-muted: var(--color-text-muted, #4b5563);
  --phbt-border: var(--nx-pill-border, #E5E7EB);
  --phbt-radius: var(--nx-radius, 14px);
}
.phbt-wrapper {
  background: var(--phbt-bg);
  padding: 0 var(--page-gutter) 48px;
  font-family: var(--phbt-font);
}
.phbt-container { max-width: 800px; margin: 0 auto; }
.phbt-card {
  background: var(--color-bg-primary, #fff);
  border: 1px solid var(--phbt-border);
  border-left: 4px solid var(--phbt-accent);
  border-radius: var(--phbt-radius);
  padding: 32px 32px 28px;
  box-shadow: var(--shadow-sm, 0 2px 8px rgba(0,0,0,0.04));
}
.phbt-heading {
  font-family: var(--font-heading-family, sans-serif);
  font-size: clamp(20px, 2.5vw, 24px);
  font-weight: 800;
  color: var(--phbt-text);
  margin: 0 0 20px;
  letter-spacing: -0.3px;
}
.phbt-list { margin: 0; padding: 0; list-style: none; }
.phbt-item {
  position: relative;
  padding: 10px 0 10px 24px;
  font-size: 15px; line-height: 1.7;
  color: var(--phbt-muted);
  border-bottom: 1px solid var(--phbt-border);
}
.phbt-item:last-child { border-bottom: none; }
.phbt-item::before {
  content: '';
  position: absolute; left: 0; top: 50%;
  transform: translateY(-50%);
  width: 8px; height: 8px;
  background: var(--phbt-accent);
  border-radius: 50%;
  box-shadow: 0 0 6px var(--phbt-accent);
}
.phbt-item strong { color: var(--phbt-text); font-weight: 700; }
.phbt-item p { margin: 0; }
#phbt-{{ section.id }} :focus-visible {
  outline: 2px solid var(--phbt-accent);
  outline-offset: 2px;
}
@media (prefers-reduced-motion: reduce) {
  #phbt-{{ section.id }} *,
  #phbt-{{ section.id }} *::before,
  #phbt-{{ section.id }} *::after {
    animation-duration: 0.01ms !important;
    transition-duration: 0.01ms !important;
  }
}
@media (max-width: 600px) {
  .phbt-card { padding: 24px 20px 20px; }
}
{%- endstyle -%}
