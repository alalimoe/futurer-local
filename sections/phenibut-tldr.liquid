{%- style -%}
.xo-section--{{ section.id }} {
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
}
.xo-section--{{ section.id }} .phbt-container { max-width: 800px; margin: 0 auto; }
.xo-section--{{ section.id }} .phbt-card {
  background: rgba(var(--color-background));
  border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
  border-left: 4px solid rgba(var(--color-accent));
  border-radius: var(--general-radius-1, 1rem);
  padding: 32px 32px 28px;
}
.xo-section--{{ section.id }} .phbt-heading {
  font-family: var(--font-heading-family);
  font-size: clamp(20px, 2.5vw, 24px);
  font-weight: 600;
  color: rgba(var(--color-foreground));
  margin: 0 0 20px;
  letter-spacing: -0.3px;
}
.xo-section--{{ section.id }} .phbt-list { margin: 0; padding: 0; list-style: none; }
.xo-section--{{ section.id }} .phbt-item {
  position: relative;
  padding: 10px 0 10px 24px;
  font-size: 15px; line-height: 1.7;
  color: color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent);
  border-bottom: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
}
.xo-section--{{ section.id }} .phbt-item:last-child { border-bottom: none; }
.xo-section--{{ section.id }} .phbt-item::before {
  content: '';
  position: absolute; left: 0; top: 50%;
  transform: translateY(-50%);
  width: 8px; height: 8px;
  background: rgba(var(--color-accent));
  border-radius: 50%;
}
.xo-section--{{ section.id }} .phbt-item strong { color: rgba(var(--color-foreground)); font-weight: 600; }
.xo-section--{{ section.id }} .phbt-item p { margin: 0; }
.xo-section--{{ section.id }} :focus-visible {
  outline: 2px solid rgba(var(--color-accent));
  outline-offset: 2px;
}
@media (max-width: 768px) {
  .xo-section--{{ section.id }} .phbt-card { padding: 24px 20px 20px; }
}
@media (prefers-reduced-motion: reduce) {
  .xo-section--{{ section.id }} *,
  .xo-section--{{ section.id }} *::before,
  .xo-section--{{ section.id }} *::after {
    animation-duration: 0.01ms !important;
    transition-duration: 0.01ms !important;
  }
}
{%- endstyle -%}

<section {% render 'section-attr' %}>
  <xo-container>
    <div class="phbt-container">
      <div class="phbt-card">
        <h2 class="phbt-heading">{{ section.settings.heading }}</h2>
        {% if section.blocks.size > 0 %}
          <ul class="phbt-list" role="list">
            {% for block in section.blocks %}
              <li class="phbt-item" {{ block.shopify_attributes }}>{{ block.settings.text }}</li>
            {% endfor %}
          </ul>
        {% endif %}
      </div>
    </div>
  </xo-container>
</section>

{% schema %}
{
  "name": "Phenibut TL;DR",
  "tag": "section",
  "class": "section-phenibut-tldr",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "default" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Key Takeaways (TL;DR)" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding top", "default": 0 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding bottom", "default": 40 }
  ],
  "blocks": [
    {
      "type": "takeaway",
      "name": "Takeaway",
      "settings": [
        { "type": "richtext", "id": "text", "label": "Takeaway text" }
      ]
    },
    { "type": "@app" }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Phenibut TL;DR",
      "blocks": [
        { "type": "takeaway", "settings": { "text": "<p>Phenibut acts at <strong>GABA-B receptors</strong> — use it occasionally, never daily.</p>" } },
        { "type": "takeaway", "settings": { "text": "<p>Start low (<strong>100–250 mg</strong>); effects take 1–3 hours to onset.</p>" } },
        { "type": "takeaway", "settings": { "text": "<p><strong>Never</strong> combine with alcohol, benzodiazepines, or other sedatives.</p>" } },
        { "type": "takeaway", "settings": { "text": "<p>Available as <strong>FAA</strong> (neutral taste) and <strong>HCl</strong> (water-soluble) forms.</p>" } },
        { "type": "takeaway", "settings": { "text": "<p>Limit use to <strong>1–2× per week</strong> max to avoid tolerance.</p>" } }
      ]
    }
  ]
}
{% endschema %}
