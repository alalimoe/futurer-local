{% comment %}
  How It Works — Premium refactored section
  - Mechanism explainer + forms comparison as native <table>
  - Premium design tokens, data-label for mobile, reduced-motion
{% endcomment %}

{%- style -%}
.xo-section--{{ section.id }} {
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
  font-family: var(--font-body-family);
}
.xo-section--{{ section.id }} .phb-works__container { max-width: {{ section.settings.max_width }}px; margin: 0 auto; padding: 0 var(--page-gap); display: grid; gap: 20px; }
.xo-section--{{ section.id }} .phb-works__title {
  font-family: var(--font-heading-family);
  font-size: clamp(22px, 4.2vw, 36px); line-height: 1.2; margin: 0; color: rgba(var(--color-foreground)); font-weight: 600;
}
.xo-section--{{ section.id }} .phb-works__subhead { font-size: clamp(16px, 2.2vw, 18px); color: rgba(var(--color-foreground)); line-height: 1.6; max-width: 72ch; }
.xo-section--{{ section.id }} .phb-works__figure { margin: 8px 0; text-align: center; }
.xo-section--{{ section.id }} .phb-works__figure--hide-m { display: block; }
.xo-section--{{ section.id }} .phb-works__cap { font-size: 13px; color: color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent); margin-top: 6px; }
.xo-section--{{ section.id }} .phb-works__body { color: rgba(var(--color-foreground)); line-height: 1.7; }
.xo-section--{{ section.id }} .phb-works__body p { margin: 0 0 10px; }
.xo-section--{{ section.id }} .phb-works__table-wrap { margin-top: 8px; border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent); border-radius: var(--general-radius-1, 1rem); overflow: hidden; }
.xo-section--{{ section.id }} .phb-works__table { width: 100%; border-collapse: collapse; }
.xo-section--{{ section.id }} .phb-works__table thead { background: rgba(var(--color-background-2)); }
.xo-section--{{ section.id }} .phb-works__table th {
  text-align: left; padding: 10px 12px; font-weight: 600; color: rgba(var(--color-foreground)); font-size: 14px;
}
.xo-section--{{ section.id }} .phb-works__table td {
  padding: 12px; color: rgba(var(--color-foreground)); font-size: 15px; line-height: 1.6;
  border-top: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
}
.xo-section--{{ section.id }} .phb-works__table td p { margin: 0; }
.xo-section--{{ section.id }} .phb-works__note { font-size: 13px; color: color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent); margin-top: 8px; }
.xo-section--{{ section.id }} :focus-visible { outline: 2px solid rgba(var(--color-accent)); outline-offset: 2px; }
@media (max-width: 768px) {
  .xo-section--{{ section.id }} .phb-works__figure { display: {% if section.settings.hide_image_mobile %}none{% else %}block{% endif %}; }
  .xo-section--{{ section.id }} .phb-works__table thead { display: none; }
  .xo-section--{{ section.id }} .phb-works__table tr { display: block; padding: 12px; border-top: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent); }
  .xo-section--{{ section.id }} .phb-works__table tbody tr:first-child { border-top: none; }
  .xo-section--{{ section.id }} .phb-works__table td {
    display: block; padding: 4px 0; border-top: none;
  }
  .xo-section--{{ section.id }} .phb-works__table td::before {
    content: attr(data-label) ": "; font-weight: 600; color: rgba(var(--color-foreground));
  }
}
@media (prefers-reduced-motion: reduce) {
  .xo-section--{{ section.id }} *,
  .xo-section--{{ section.id }} *::before,
  .xo-section--{{ section.id }} *::after {
    animation-duration: 0.01ms !important;
    transition-duration: 0.01ms !important;
  }
}
{%- endstyle -%}

<section {% render 'section-attr' %} aria-labelledby="phb-works-title-{{ section.id }}">
  <xo-container>
    <div class="phb-works__container">
      <header class="phb-works__header">
        <h2 id="phb-works-title-{{ section.id }}" class="phb-works__title">{{ section.settings.heading | escape }}</h2>
        {% if section.settings.subhead != blank %}
          <div class="phb-works__subhead">{{ section.settings.subhead }}</div>
        {% endif %}
      </header>

      {% if section.settings.diagram_image != blank %}
        <figure class="phb-works__figure{% if section.settings.hide_image_mobile %} phb-works__figure--hide-m{% endif %}">
          <img
            src="{{ section.settings.diagram_image | image_url: width: 960 }}"
            srcset="{{ section.settings.diagram_image | image_url: width: 640 }} 640w, {{ section.settings.diagram_image | image_url: width: 960 }} 960w"
            sizes="(max-width: 768px) 100vw, 960px"
            alt="{% unless section.settings.diagram_decorative %}{{ section.settings.diagram_alt | escape }}{% endunless %}"
            {% if section.settings.diagram_decorative %}role="presentation" aria-hidden="true"{% endif %}
            width="960"
            height="{{ 960 | divided_by: section.settings.diagram_image.aspect_ratio | round }}"
            loading="lazy" decoding="async"
          >
          {% if section.settings.diagram_caption != blank %}
            <figcaption class="phb-works__cap">{{ section.settings.diagram_caption }}</figcaption>
          {% endif %}
        </figure>
      {% endif %}

      {% if section.settings.mechanism != blank %}
        <div class="phb-works__body">{{ section.settings.mechanism }}</div>
      {% endif %}

      <div id="{{ section.settings.forms_anchor | default: 'forms' }}" class="phb-works__table-wrap">
        <table class="phb-works__table" aria-label="Phenibut forms comparison">
          <thead>
            <tr>
              <th scope="col">Form</th>
              <th scope="col">Solubility</th>
              <th scope="col">Typical Dose</th>
              <th scope="col">Onset</th>
              <th scope="col">Notes</th>
            </tr>
          </thead>
          <tbody>
            {% for block in section.blocks %}
              {% if block.type == 'form_row' %}
                <tr {{ block.shopify_attributes }}>
                  <td data-label="Form"><strong>{{ block.settings.form_name | escape }}</strong></td>
                  <td data-label="Solubility">{{ block.settings.solubility | escape }}</td>
                  <td data-label="Typical Dose">{{ block.settings.dose | escape }}</td>
                  <td data-label="Onset">{{ block.settings.onset | escape }}</td>
                  <td data-label="Notes">{{ block.settings.notes }}</td>
                </tr>
              {% endif %}
            {% endfor %}
          </tbody>
        </table>
      </div>

      {% if section.settings.note != blank %}
        <p class="phb-works__note">{{ section.settings.note }}</p>
      {% endif %}
    </div>
  </xo-container>
</section>

{% schema %}
{
  "name": "How It Works",
  "tag": "section",
  "class": "section-phenibut-works",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "default" },
    { "type": "text", "id": "anchor_id", "label": "Anchor ID", "default": "how-it-works" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "How Phenibut Works" },
    { "type": "richtext", "id": "subhead", "label": "Intro", "default": "<p>Phenibut primarily acts at <strong>GABA‑B receptors</strong>, helping moderate excitability for a calmer baseline.</p>" },
    { "type": "image_picker", "id": "diagram_image", "label": "Mechanism diagram (optional)" },
    { "type": "text", "id": "diagram_alt", "label": "Diagram alt text", "default": "Simplified diagram of GABA‑B receptor action" },
    { "type": "checkbox", "id": "diagram_decorative", "label": "Mark diagram decorative", "default": false },
    { "type": "checkbox", "id": "hide_image_mobile", "label": "Hide diagram on mobile", "default": false },
    { "type": "text", "id": "diagram_caption", "label": "Diagram caption" },
    { "type": "richtext", "id": "mechanism", "label": "Mechanism body", "default": "<p>The added phenyl ring increases lipid solubility, improving blood‑brain barrier crossing compared to GABA. Effects vary by dose, form, and individual.</p>" },
    { "type": "text", "id": "forms_anchor", "label": "Forms anchor ID", "default": "forms" },
    { "type": "range", "id": "max_width", "label": "Max width (px)", "min": 720, "max": 1400, "step": 20, "default": 1200 },
    { "type": "text", "id": "note", "label": "Footnote", "default": "Informational only. Not medical advice." },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding top", "default": 40 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding bottom", "default": 40 }
  ],
  "blocks": [
    {
      "type": "form_row",
      "name": "Form row",
      "settings": [
        { "type": "text", "id": "form_name", "label": "Form name", "default": "FAA" },
        { "type": "text", "id": "solubility", "label": "Solubility", "default": "Low–moderate (neutral taste when capped)" },
        { "type": "text", "id": "dose", "label": "Typical dose", "default": "100–400 mg (occasional use)" },
        { "type": "text", "id": "onset", "label": "Onset", "default": "1–3 hours" },
        { "type": "richtext", "id": "notes", "label": "Notes", "default": "<p>Often chosen for capsule use. Time your dose carefully.</p>" }
      ]
    },
    { "type": "@app" }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "How It Works",
      "blocks": [
        { "type": "form_row", "settings": { "form_name": "FAA", "solubility": "Low–moderate", "dose": "100–400 mg", "onset": "1–3 hours", "notes": "<p>Neutral taste when encapsulated.</p>" } },
        { "type": "form_row", "settings": { "form_name": "HCl", "solubility": "High (water‑soluble)", "dose": "100–400 mg", "onset": "1–2 hours", "notes": "<p>Mixes fast. Taste can be sharp; capsules preferred.</p>" } },
        { "type": "form_row", "settings": { "form_name": "Capsules", "solubility": "N/A", "dose": "Pre‑measured (e.g., 250–500 mg)", "onset": "1–3 hours", "notes": "<p>Most convenient; follow label guidance.</p>" } }
      ]
    }
  ]
}
{% endschema %}
