{% comment %}
  Reviews — Premium refactored section
  - Blockquote semantics, AggregateRating + Review JSON-LD, design tokens
{% endcomment %}

{%- comment -%} ── JSON-LD: AggregateRating + Reviews ── {%- endcomment -%}
{% if section.blocks.size > 0 %}
  {%- assign total_rating = 0 -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'review' -%}
      {%- assign total_rating = total_rating | plus: block.settings.rating -%}
    {%- endif -%}
  {%- endfor -%}
  {%- assign avg_rating = total_rating | times: 1.0 | divided_by: section.blocks.size -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Phenibut",
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "{{ avg_rating | round: 1 }}",
    "reviewCount": "{{ section.blocks.size }}",
    "bestRating": "5"
  },
  "review": [
    {%- for block in section.blocks -%}
      {%- if block.type == 'review' -%}
        {
          "@type": "Review",
          "reviewRating": { "@type": "Rating", "ratingValue": "{{ block.settings.rating }}", "bestRating": "5" },
          "author": { "@type": "Person", "name": {{ block.settings.author | json }} },
          "reviewBody": {{ block.settings.text | json }}
        }{%- unless forloop.last -%},{%- endunless -%}
      {%- endif -%}
    {%- endfor -%}
  ]
}
</script>
{% endif %}

<section id="phb-rv-{{ section.id }}" class="phb-reviews" aria-labelledby="phb-reviews-title-{{ section.id }}">
  <div class="phb-reviews__container">
    <h2 id="phb-reviews-title-{{ section.id }}" class="phb-reviews__title">{{ section.settings.heading | escape }}</h2>
    {% if section.settings.intro != blank %}
      <div class="phb-reviews__intro">{{ section.settings.intro }}</div>
    {% endif %}

    <div class="phb-reviews__grid">
      {% for block in section.blocks %}
        {% if block.type == 'review' %}
          <article class="phb-review" {{ block.shopify_attributes }}>
            <div class="phb-review__rating" aria-label="{{ block.settings.rating }} out of 5 stars">
              <span aria-hidden="true">
                {% for i in (1..5) %}{% if i <= block.settings.rating %}★{% else %}☆{% endif %}{% endfor %}
              </span>
            </div>
            <blockquote class="phb-review__text" dir="auto">"{{ block.settings.text | escape }}"</blockquote>
            <p class="phb-review__meta" dir="auto">
              — {{ block.settings.author | escape }}{% if block.settings.location != blank %}, {{ block.settings.location | escape }}{% endif %}
              {% if block.settings.verified %}<span class="phb-rv-badge" aria-label="Verified reviewer">Verified</span>{% endif %}
            </p>
          </article>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{%- style -%}
#phb-rv-{{ section.id }} {
  --phb-bg: {{ section.settings.background_color }};
  --phb-max: {{ section.settings.max_width }}px;
  --phb-py: {{ section.settings.padding_y }}px;
  --phb-accent: var(--color-accent-primary, #FBBF24);
  --phb-heading: var(--color-text-main, #0A2342);
  --phb-text: var(--color-text-main, #0e1726);
  --phb-muted: var(--color-text-muted, #6b7280);
  --phb-star: var(--color-accent-primary, #f59e0b);
  --phb-card-bg: var(--color-bg-primary, #fff);
  --phb-card-border: var(--nx-pill-border, rgba(0,0,0,.06));
  --phb-radius: var(--nx-radius, 14px);
  --phb-font: var(--font-body-family, sans-serif);
  --phb-font-heading: var(--font-heading-family, sans-serif);
  --phb-shadow: var(--shadow-sm, 0 1px 2px rgba(0,0,0,.03));
  background: var(--phb-bg);
  font-family: var(--phb-font);
}
#phb-rv-{{ section.id }} .phb-reviews__container { max-width: var(--phb-max); margin: 0 auto; padding: var(--phb-py) 16px; }
#phb-rv-{{ section.id }} .phb-reviews__title {
  font-family: var(--phb-font-heading);
  font-size: clamp(22px, 4.2vw, 36px); line-height: 1.2; color: var(--phb-heading); margin: 0 0 8px;
}
#phb-rv-{{ section.id }} .phb-reviews__intro { color: var(--phb-text); margin-bottom: 16px; }
#phb-rv-{{ section.id }} .phb-reviews__grid { display: grid; gap: 16px; grid-template-columns: repeat(3, 1fr); }
#phb-rv-{{ section.id }} .phb-review {
  background: var(--phb-card-bg); border: 1px solid var(--phb-card-border);
  border-radius: var(--phb-radius); padding: 16px; box-shadow: var(--phb-shadow);
}
#phb-rv-{{ section.id }} .phb-review__rating { color: var(--phb-star); font-size: 16px; letter-spacing: 1px; }
#phb-rv-{{ section.id }} .phb-review__text {
  color: var(--phb-text); line-height: 1.6; margin: 6px 0 8px;
  padding: 0; border: none; font-style: normal; font-size: inherit;
}
#phb-rv-{{ section.id }} .phb-review__meta {
  color: var(--phb-muted); font-size: 14px; margin: 0;
  display: flex; gap: 8px; align-items: center; flex-wrap: wrap;
}
#phb-rv-{{ section.id }} .phb-rv-badge {
  display: inline-block; padding: 2px 8px; font-size: 12px; line-height: 1.2;
  border-radius: 999px; background: var(--phb-heading); color: var(--phb-card-bg);
}
#phb-rv-{{ section.id }} :focus-visible { outline: 2px solid var(--phb-accent); outline-offset: 2px; }
@media (max-width: 989px) { #phb-rv-{{ section.id }} .phb-reviews__grid { grid-template-columns: 1fr 1fr; } }
@media (max-width: 749px) { #phb-rv-{{ section.id }} .phb-reviews__grid { grid-template-columns: 1fr; } }
@media (prefers-reduced-motion: reduce) {
  #phb-rv-{{ section.id }} *,
  #phb-rv-{{ section.id }} *::before,
  #phb-rv-{{ section.id }} *::after {
    animation-duration: 0.01ms !important;
    transition-duration: 0.01ms !important;
  }
}
{%- endstyle -%}

{% schema %}
{
  "name": "Reviews",
  "tag": "section",
  "class": "section-phenibut-reviews",
  "settings": [
    { "type": "text", "id": "anchor_id", "label": "Anchor ID", "default": "reviews" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Customer Stories" },
    { "type": "richtext", "id": "intro", "label": "Intro", "default": "<p>Real experiences from Dubai and beyond—fast delivery, consistent quality.</p>" },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#FFFFFF" },
    { "type": "range", "id": "max_width", "label": "Max width (px)", "min": 720, "max": 1400, "step": 20, "default": 1200 },
    { "type": "range", "id": "padding_y", "label": "Vertical padding (px)", "min": 40, "max": 160, "step": 4, "default": 64 }
  ],
  "blocks": [
    { "type": "review", "name": "Review", "settings": [
      { "type": "range", "id": "rating", "label": "Rating", "min": 1, "max": 5, "step": 1, "default": 5 },
      { "type": "text", "id": "text", "label": "Review text", "default": "Got my order the same day. Exactly what I needed to unwind." },
      { "type": "text", "id": "author", "label": "Author", "default": "A. R." },
      { "type": "text", "id": "location", "label": "Location", "default": "Dubai" },
      { "type": "checkbox", "id": "verified", "label": "Show Verified badge", "default": true }
    ] }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Reviews (Curated)",
      "blocks": [
        { "type": "review", "settings": { "rating": 5, "text": "You can get this in a lot of places, but Nootropix's quality is so much better and their customer service is exceptional.", "author": "Anonymous", "location": "UAE", "verified": true } },
        { "type": "review", "settings": { "rating": 5, "text": "هدوء وراحة نفسية", "author": "A.", "location": "UAE", "verified": true } },
        { "type": "review", "settings": { "rating": 5, "text": "Hidden gem", "author": "M.", "location": "France", "verified": true } },
        { "type": "review", "settings": { "rating": 4, "text": "Motivating, relaxing, sleep friendly", "author": "M.T.", "location": "UAE", "verified": true } },
        { "type": "review", "settings": { "rating": 5, "text": "Good", "author": "O.A.", "location": "UAE", "verified": true } }
      ]
    }
  ]
}
{% endschema %}
