{%- style -%}
  .xo-section--{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    text-align: center;
  }

  .bgh-progress {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 3px;
    z-index: 9999;
    background: color-mix(in srgb, rgba(var(--color-foreground)) 6%, transparent);
    pointer-events: none;
  }

  .bgh-progress__bar {
    height: 100%;
    width: 100%;
    background: rgba(var(--color-accent));
    transform: scaleX(0);
    transform-origin: left;
    will-change: transform;
  }

  .xo-section--{{ section.id }} .bgh-inner {
    max-width: 760px;
    margin: 0 auto;
  }

  .xo-section--{{ section.id }} .bgh-meta {
    display: flex;
    justify-content: center;
    gap: 20px;
    margin-bottom: 20px;
    flex-wrap: wrap;
  }

  .xo-section--{{ section.id }} .bgh-meta-item {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: calc(var(--font-body-scale, 1) * 1.4rem);
    font-weight: 500;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 55%, transparent);
  }

  .xo-section--{{ section.id }} .bgh-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    color: rgba(var(--color-foreground));
    margin: 0 0 20px;
    line-height: 1.1;
  }

  .xo-section--{{ section.id }} .bgh-subtitle {
    font-size: clamp(1rem, 1.5vw, 1.25rem);
    line-height: 1.7;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 55%, transparent);
    margin: 0 0 24px;
    max-width: 620px;
    margin-inline: auto;
  }

  .xo-section--{{ section.id }} .bgh-trust {
    display: flex;
    justify-content: center;
    gap: 10px;
    flex-wrap: wrap;
    margin-bottom: 28px;
  }

  .xo-section--{{ section.id }} .bgh-trust-pill {
    display: inline-flex;
    align-items: center;
    font-size: clamp(0.75rem, 1vw, 0.8125rem);
    font-weight: 600;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 55%, transparent);
    background: rgba(var(--color-background));
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 12%, transparent);
    border-radius: var(--button-radius);
    padding: 6px 14px;
  }

  .xo-section--{{ section.id }} .bgh-ctas {
    display: flex;
    justify-content: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .xo-section--{{ section.id }} .bgh-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 0.75rem 1.5rem;
    font-size: calc(var(--font-body-scale, 1) * 1.5rem);
    font-weight: 600;
    border-radius: var(--button-radius);
    text-decoration: none;
    cursor: pointer;
    border: none;
    transition: opacity 0.3s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .bgh-btn--primary {
    background: rgba(var(--color-accent));
    color: rgba(var(--color-foreground));
  }

  .xo-section--{{ section.id }} .bgh-btn--primary:hover {
    opacity: 0.85;
  }

  .xo-section--{{ section.id }} .bgh-btn--secondary {
    background: rgba(var(--color-background));
    color: rgba(var(--color-foreground));
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 12%, transparent);
  }

  .xo-section--{{ section.id }} .bgh-btn--secondary:hover {
    border-color: color-mix(in srgb, rgba(var(--color-foreground)) 25%, transparent);
  }

  .xo-section--{{ section.id }} .bgh-btn:focus-visible {
    outline: 2px solid rgba(var(--color-accent));
    outline-offset: 2px;
  }

  @media (max-width: 768px) {
    .xo-section--{{ section.id }} .bgh-ctas {
      flex-direction: column;
      align-items: center;
    }

    .xo-section--{{ section.id }} .bgh-btn {
      width: 100%;
      max-width: 320px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .xo-section--{{ section.id }} .bgh-btn,
    .bgh-progress__bar {
      transition: none;
    }
  }
{%- endstyle -%}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": {{ section.settings.heading | json }},
      "description": {{ section.settings.subheading | json }},
      "mainEntityOfPage": "{{ request.origin }}{{ request.path }}",
      "author": { "@type": "Organization", "name": "Nootropix" },
      "publisher": { "@type": "Organization", "name": "Nootropix", "url": "{{ shop.url }}" },
      "datePublished": {{ section.settings.date_published | json }},
      "dateModified": "{{ 'now' | date: '%Y-%m-%d' }}"
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "{{ shop.url }}" },
        { "@type": "ListItem", "position": 2, "name": "Guides", "item": "{{ shop.url }}/pages/guides" },
        { "@type": "ListItem", "position": 3, "name": {{ section.settings.heading | json }}, "item": "{{ request.origin }}{{ request.path }}" }
      ]
    }
  ]
}
</script>

<div class="bgh-progress" aria-hidden="true"><div class="bgh-progress__bar" data-bgh-bar></div></div>

<section {% render 'section-attr' %}>
  <xo-container>
    <div class="bgh-inner">
      <div class="bgh-meta">
        {% if section.settings.author_name != blank %}
          <span class="bgh-meta-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            {{ section.settings.author_name }}
          </span>
        {% endif %}
        {% if section.settings.read_time != blank %}
          <span class="bgh-meta-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            {{ section.settings.read_time }}
          </span>
        {% endif %}
      </div>

      <h1 class="bgh-title">{{ section.settings.heading }}</h1>

      {% if section.settings.subheading != blank %}
        <p class="bgh-subtitle">{{ section.settings.subheading }}</p>
      {% endif %}

      {% if section.settings.trust_1 != blank or section.settings.trust_2 != blank or section.settings.trust_3 != blank %}
        <div class="bgh-trust">
          {% if section.settings.trust_1 != blank %}<span class="bgh-trust-pill">{{ section.settings.trust_1 }}</span>{% endif %}
          {% if section.settings.trust_2 != blank %}<span class="bgh-trust-pill">{{ section.settings.trust_2 }}</span>{% endif %}
          {% if section.settings.trust_3 != blank %}<span class="bgh-trust-pill">{{ section.settings.trust_3 }}</span>{% endif %}
        </div>
      {% endif %}

      {% if section.settings.cta_primary_text != blank or section.settings.cta_secondary_text != blank %}
        <div class="bgh-ctas">
          {% if section.settings.cta_primary_text != blank %}
            <a href="{{ section.settings.cta_primary_url | default: '#' }}" class="bgh-btn bgh-btn--primary">{{ section.settings.cta_primary_text }}</a>
          {% endif %}
          {% if section.settings.cta_secondary_text != blank %}
            <a href="{{ section.settings.cta_secondary_url | default: '#' }}" class="bgh-btn bgh-btn--secondary">{{ section.settings.cta_secondary_text }}</a>
          {% endif %}
        </div>
      {% endif %}
    </div>
  </xo-container>
</section>

<script>
(function() {
  var bar = document.querySelector('[data-bgh-bar]');
  if (!bar) return;
  var ticking = false;
  window.addEventListener('scroll', function() {
    if (!ticking) {
      requestAnimationFrame(function() {
        var scrollTop = window.scrollY || window.pageYOffset;
        var docHeight = document.body.scrollHeight - window.innerHeight;
        var pct = Math.max(0, Math.min(1, scrollTop / (docHeight || 1)));
        bar.style.transform = 'scaleX(' + pct.toFixed(4) + ')';
        ticking = false;
      });
      ticking = true;
    }
  }, { passive: true });
})();
</script>

{% schema %}
{
  "name": "Beginners Guide Hero",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "default" },
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Beginner's Guide to Nootropics" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Start smarter — not stronger. Learn the basics, personalize a safe starting stack, and feel more focused with fewer unknowns." },
    { "type": "text", "id": "author_name", "label": "Author Name", "default": "Nootropix Research Team" },
    { "type": "text", "id": "read_time", "label": "Reading Time", "default": "12 min read" },
    { "type": "text", "id": "date_published", "label": "Date Published (YYYY-MM-DD)", "default": "2025-08-23" },
    { "type": "header", "content": "Trust Signals" },
    { "type": "text", "id": "trust_1", "label": "Trust Signal 1", "default": "5,763+ orders shipped" },
    { "type": "text", "id": "trust_2", "label": "Trust Signal 2", "default": "Evidence-Based Protocols" },
    { "type": "text", "id": "trust_3", "label": "Trust Signal 3", "default": "3rd-Party Lab Tested" },
    { "type": "header", "content": "Call to Action" },
    { "type": "text", "id": "cta_primary_text", "label": "Primary CTA Text", "default": "Build My Starter Stack" },
    { "type": "url", "id": "cta_primary_url", "label": "Primary CTA URL" },
    { "type": "text", "id": "cta_secondary_text", "label": "Secondary CTA Text", "default": "See the 60-Second Summary" },
    { "type": "url", "id": "cta_secondary_url", "label": "Secondary CTA URL" },
    { "type": "header", "content": "Section Padding" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding top", "default": 80 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding bottom", "default": 56 }
  ],
  "presets": [{ "name": "Beginners Guide Hero" }]
}
{% endschema %}
