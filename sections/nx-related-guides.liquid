<style>
  .nx-rel{max-width:var(--container-width-large);margin:0 auto;padding:8px 16px}
  .nx-grid{display:grid;gap:16px}
  @media(min-width:860px){.nx-grid{grid-template-columns:repeat(3,1fr)}}
  .nx-card{border:1px solid rgba(0,0,0,.1);border-radius:var(--nx-radius-md);padding:16px}
  .nx-card a{text-decoration:none}
</style>

<section class="nx-rel" id="related-guides">
  <h2>Related Guides</h2>
  <div class="nx-grid">
    {% for block in section.blocks %}
    <article class="nx-card" {{ block.shopify_attributes }}>
      <h3><a href="{{ block.settings.url }}">{{ block.settings.title }}</a></h3>
      <p>{{ block.settings.desc }}</p>
    </article>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "NX — Related Guides",
  "settings": [],
  "blocks": [
    { "type": "link", "name": "Guide link", "settings": [
      { "type": "text", "id": "title", "label": "Title" },
      { "type": "url", "id": "url", "label": "URL" },
      { "type": "textarea", "id": "desc", "label": "Short description" }
    ]}
  ],
  "presets": [
    {
      "name": "NX — Related Guides",
      "blocks": [
        { "type":"link", "settings": { "title":"Piracetam vs Aniracetam", "url": "/blogs/posts/5-best-racetams", "desc":"Understand the key differences to pick the right racetam for your goals." } },
        { "type":"link", "settings": { "title":"Best Nootropics for Learning & Memory", "url": "/blogs/posts/best-nootropics-for-studying-guide", "desc":"Stack ideas for studying, retention, and recall." } },
        { "type":"link", "settings": { "title":"The Science of Neuroplasticity", "url": "/blogs/posts/nootropics-101", "desc":"How plasticity works and how to support it." } }
      ]
    }
  ]
}
{% endschema %}
