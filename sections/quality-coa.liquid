{%- style -%}
  .xo-section--{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .xo-section--{{ section.id }} .qcoa__hero {
    text-align: center;
    padding: 60px 0;
  }

  .xo-section--{{ section.id }} .qcoa__hero h1 {
    font-size: clamp(28px, 5vw, 42px);
    font-weight: 600;
    margin: 0 0 14px;
    color: rgba(var(--color-foreground));
  }

  .xo-section--{{ section.id }} .qcoa__hero .rte {
    font-size: calc(var(--font-body-scale, 1) * 1.8rem);
    color: color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent);
    max-width: 700px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .xo-section--{{ section.id }} .qcoa__block {
    margin: 60px 0;
  }

  .xo-section--{{ section.id }} .qcoa__block h2 {
    font-size: clamp(22px, 4vw, 28px);
    margin: 0 0 14px;
    font-weight: 600;
    color: rgba(var(--color-foreground));
  }

  .xo-section--{{ section.id }} .qcoa__block > p,
  .xo-section--{{ section.id }} .qcoa__block > .rte {
    font-size: calc(var(--font-body-scale, 1) * 1.7rem);
    color: color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent);
    line-height: 1.6;
  }

  .xo-section--{{ section.id }} .qcoa__grid {
    display: grid;
    gap: 25px;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    margin-top: 25px;
  }

  .xo-section--{{ section.id }} .qcoa__card {
    padding: 25px;
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
    border-radius: var(--general-radius-1, 1rem);
    background: rgba(var(--color-background-2));
    transition: border-color 0.3s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .qcoa__card:hover {
    border-color: rgba(var(--color-accent));
  }

  .xo-section--{{ section.id }} .qcoa__card h3 {
    margin: 0 0 12px;
    font-size: clamp(1.1rem, 1.4vw, 1.25rem);
    font-weight: 600;
    color: rgba(var(--color-foreground));
  }

  .xo-section--{{ section.id }} .qcoa__card p {
    margin: 0;
    font-size: calc(var(--font-body-scale, 1) * 1.5rem);
    color: color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent);
    line-height: 1.6;
  }

  .xo-section--{{ section.id }} .qcoa__links ul {
    padding-left: 20px;
    margin-top: 12px;
  }

  .xo-section--{{ section.id }} .qcoa__links li {
    margin-bottom: 6px;
  }

  .xo-section--{{ section.id }} .qcoa__links a {
    color: rgba(var(--color-accent));
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.3s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .qcoa__links a:hover {
    color: rgba(var(--color-foreground));
  }

  .xo-section--{{ section.id }} .qcoa__links a:focus-visible {
    outline: 2px solid rgba(var(--color-accent));
    outline-offset: 3px;
    border-radius: 2px;
  }

  .xo-section--{{ section.id }} .qcoa__archive {
    margin-top: 20px;
  }

  .xo-section--{{ section.id }} .qcoa__faq details {
    transition: border-color 0.3s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .qcoa__faq details[open] {
    border-bottom-color: rgba(var(--color-accent));
  }

  .xo-section--{{ section.id }} .qcoa__faq summary {
    cursor: pointer;
    padding: 15px 0;
    font-weight: 600;
    border-bottom: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
    min-height: 44px;
    display: flex;
    align-items: center;
    transition: color 0.2s ease;
    color: rgba(var(--color-foreground));
  }

  .xo-section--{{ section.id }} .qcoa__faq summary:hover {
    color: rgba(var(--color-accent));
  }

  .xo-section--{{ section.id }} .qcoa__faq summary:focus-visible {
    outline: 2px solid rgba(var(--color-accent));
    outline-offset: 2px;
    border-radius: 4px;
  }

  .xo-section--{{ section.id }} .qcoa__faq p {
    margin: 12px 0 25px;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent);
    line-height: 1.6;
  }

  .xo-section--{{ section.id }} .qcoa__cta {
    padding: 50px 30px;
    background: rgba(var(--color-background-2));
    border-radius: var(--general-radius-1, 1rem);
    text-align: center;
    margin: 70px 0 20px;
  }

  .xo-section--{{ section.id }} .qcoa__cta h2 {
    margin: 0 0 14px;
    font-size: clamp(22px, 4vw, 28px);
    font-weight: 600;
    color: rgba(var(--color-foreground));
  }

  .xo-section--{{ section.id }} .qcoa__cta > p {
    font-size: calc(var(--font-body-scale, 1) * 1.7rem);
    color: color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent);
    margin: 0 0 20px;
  }

  .xo-section--{{ section.id }} .qcoa__cta-btn {
    padding: 12px 26px;
    background: rgba(var(--color-foreground));
    color: rgba(var(--color-background));
    border-radius: 10rem;
    display: inline-block;
    text-decoration: none;
    font-weight: 600;
    min-height: 44px;
    transition: opacity 0.3s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .qcoa__cta-btn:hover {
    opacity: 0.85;
  }

  .xo-section--{{ section.id }} .qcoa__cta-btn:focus-visible {
    outline: 2px solid rgba(var(--color-accent));
    outline-offset: 3px;
  }

  .xo-section--{{ section.id }} .qcoa__disclaimer {
    text-align: center;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 40%, transparent);
    margin-top: 30px;
    font-size: calc(var(--font-body-scale, 1) * 1.4rem);
  }

  @media (max-width: 768px) {
    .xo-section--{{ section.id }} .qcoa__hero {
      padding: 32px 0;
    }

    .xo-section--{{ section.id }} .qcoa__block {
      margin: 36px 0;
    }

    .xo-section--{{ section.id }} .qcoa__cta {
      padding: 36px 20px;
      margin: 48px 0 16px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .xo-section--{{ section.id }} .qcoa__card,
    .xo-section--{{ section.id }} .qcoa__links a,
    .xo-section--{{ section.id }} .qcoa__faq details,
    .xo-section--{{ section.id }} .qcoa__faq summary,
    .xo-section--{{ section.id }} .qcoa__cta-btn {
      transition: none;
    }
  }
{%- endstyle -%}

<section {% render 'section-attr' %}>
  <xo-container>

    {%- comment -%} HERO {%- endcomment -%}
    <div class="qcoa__hero">
      <h1>{{ section.settings.heading }}</h1>
      {%- if section.settings.description != blank -%}
        <div class="rte">{{ section.settings.description }}</div>
      {%- endif -%}
    </div>

    {%- comment -%} QUALITY STANDARDS {%- endcomment -%}
    <div class="qcoa__block">
      <h2>{{ section.settings.standards_heading }}</h2>
      {%- if section.settings.standards_text != blank -%}
        <div class="rte">{{ section.settings.standards_text }}</div>
      {%- endif -%}

      <div class="qcoa__grid">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'standard_card' -%}
              <div class="qcoa__card" {{ block.shopify_attributes }}>
                <h3>{{ block.settings.title }}</h3>
                <p>{{ block.settings.text }}</p>
              </div>
          {%- endcase -%}
        {%- endfor -%}
      </div>
    </div>

    {%- comment -%} COA LIBRARY ACCESS {%- endcomment -%}
    <div class="qcoa__block qcoa__links">
      <h2>{{ section.settings.library_heading }}</h2>
      {%- if section.settings.library_text != blank -%}
        <div class="rte">{{ section.settings.library_text }}</div>
      {%- endif -%}

      {%- assign has_coa_links = false -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'coa_link' -%}
          {%- assign has_coa_links = true -%}
          {%- break -%}
        {%- endif -%}
      {%- endfor -%}

      {%- if has_coa_links -%}
        <ul>
          {%- for block in section.blocks -%}
            {%- if block.type == 'coa_link' -%}
              <li {{ block.shopify_attributes }}>
                <a href="{{ block.settings.url }}">{{ block.settings.label }}</a>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      {%- endif -%}

      {%- if section.settings.archive_label != blank and section.settings.archive_url != blank -%}
        <p class="qcoa__archive">
          {{ section.settings.archive_prefix }}
          <a href="{{ section.settings.archive_url }}">{{ section.settings.archive_label }}</a>
        </p>
      {%- endif -%}
    </div>

    {%- comment -%} HOW TO READ A COA {%- endcomment -%}
    {%- assign has_read_cards = false -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'read_coa_card' -%}
        {%- assign has_read_cards = true -%}
        {%- break -%}
      {%- endif -%}
    {%- endfor -%}

    {%- if has_read_cards -%}
      <div class="qcoa__block">
        <h2>{{ section.settings.read_coa_heading }}</h2>
        <div class="qcoa__grid">
          {%- for block in section.blocks -%}
            {%- if block.type == 'read_coa_card' -%}
              <div class="qcoa__card" {{ block.shopify_attributes }}>
                <h3>{{ block.settings.title }}</h3>
                <p>{{ block.settings.text }}</p>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}

    {%- comment -%} RELATED GUIDES {%- endcomment -%}
    {%- assign has_guides = false -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'guide_link' -%}
        {%- assign has_guides = true -%}
        {%- break -%}
      {%- endif -%}
    {%- endfor -%}

    {%- if has_guides -%}
      <div class="qcoa__block qcoa__links">
        <h2>{{ section.settings.guides_heading }}</h2>
        <ul>
          {%- for block in section.blocks -%}
            {%- if block.type == 'guide_link' -%}
              <li {{ block.shopify_attributes }}>
                <a href="{{ block.settings.url }}">{{ block.settings.label }}</a>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      </div>
    {%- endif -%}

    {%- comment -%} FAQ {%- endcomment -%}
    {%- assign has_faq = false -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'faq' -%}
        {%- assign has_faq = true -%}
        {%- break -%}
      {%- endif -%}
    {%- endfor -%}

    {%- if has_faq -%}
      <div class="qcoa__block">
        <h2>{{ section.settings.faq_heading }}</h2>
        <div class="qcoa__faq">
          {%- for block in section.blocks -%}
            {%- if block.type == 'faq' -%}
              <details {{ block.shopify_attributes }}>
                <summary>{{ block.settings.question }}</summary>
                <p>{{ block.settings.answer }}</p>
              </details>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}

    {%- comment -%} CTA {%- endcomment -%}
    {%- if section.settings.cta_heading != blank -%}
      <div class="qcoa__cta">
        <h2>{{ section.settings.cta_heading }}</h2>
        {%- if section.settings.cta_text != blank -%}
          <p>{{ section.settings.cta_text }}</p>
        {%- endif -%}
        {%- if section.settings.cta_url != blank -%}
          <a class="qcoa__cta-btn" href="{{ section.settings.cta_url }}">
            {{ section.settings.cta_label | default: 'Contact Support' }}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.settings.disclaimer != blank -%}
      <p class="qcoa__disclaimer">{{ section.settings.disclaimer }}</p>
    {%- endif -%}

  </xo-container>
</section>

{%- assign has_faq_ld = false -%}
{%- for block in section.blocks -%}
  {%- if block.type == 'faq' and block.settings.question != blank and block.settings.answer != blank -%}
    {%- assign has_faq_ld = true -%}
    {%- break -%}
  {%- endif -%}
{%- endfor -%}

{%- if has_faq_ld -%}
  {%- capture faq_json -%}
  [
    {%- assign first = true -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'faq' and block.settings.question != blank and block.settings.answer != blank -%}
        {%- if first == false -%},{%- endif -%}
        {"@type":"Question","name":{{ block.settings.question | strip | json }},"acceptedAnswer":{"@type":"Answer","text":{{ block.settings.answer | strip | json }}}}
        {%- assign first = false -%}
      {%- endif -%}
    {%- endfor -%}
  ]
  {%- endcapture -%}
  <script type="application/ld+json">
  {"@context":"https://schema.org","@type":"FAQPage","mainEntity":{{ faq_json | strip }}}
  </script>
{%- endif -%}

