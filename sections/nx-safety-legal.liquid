{%- assign sid = section.id -%}

{%- style -%}
#nx-safety-{{ sid }} {
  max-width: var(--container-width-narrow);
  margin: 0 auto;
  padding: 8px 16px;
  font-family: var(--font-body-family, sans-serif);
  color: var(--color-text-main, #111827);
  line-height: 1.7;
  content-visibility: auto;
}
#nx-safety-{{ sid }} h2 {
  font-family: var(--font-heading-family, sans-serif);
  font-size: clamp(22px, 3vw, 30px);
  font-weight: 700;
  line-height: 1.2;
  margin: 0 0 12px;
}
#nx-safety-{{ sid }} ul { padding-left: 18px; margin: 0; }
#nx-safety-{{ sid }} li {
  margin: 8px 0;
  color: var(--color-text-muted, #4b5563);
}
#nx-safety-{{ sid }} li strong { color: var(--color-text-main, #111827); }
{%- endstyle -%}

<section id="nx-safety-{{ sid }}" aria-label="Safety, legality and competitive sports">
  <h2>Safety, Legality &amp; Competitive Sports</h2>
  <ul>
    <li>This page is for <strong>educational purposes</strong> and is <strong>not medical advice</strong>.</li>
    <li><strong>Regulations vary</strong> by country/region; ensure compliance with local laws and professional rules.</li>
    <li><strong>Athletes:</strong> phenylpiracetam-class compounds may be restricted — verify before use.</li>
    <li>Avoid if pregnant/nursing. If you have a condition or take medication, <strong>consult a healthcare professional</strong>.</li>
    <li>Avoid alcohol; do not drive/operate machinery until you understand your response.</li>
  </ul>
</section>

{% schema %}
{ "name": "NX — Safety & Legality", "settings": [], "presets": [{ "name": "NX — Safety & Legality" }] }
{% endschema %}
