<script>
  (function() {
    var root = document.getElementById('nx-gh-{{ sid }}');
    if (!root) return;

    var search = root.querySelector('#nx-gh-search-{{ sid }}');
    var clearBtn = root.querySelector('.nx-gh-clear');
    var chips = root.querySelectorAll('.nx-gh-chip');
    var cards = Array.from(root.querySelectorAll('.nx-gh-card'));
    var sortSel = root.querySelector('#nx-gh-sort-{{ sid }}');

    var activeTag = 'all';
    var query = '';

    function norm(s) { return (s || '').toLowerCase().trim(); }

    function matchCard(card, q, tag) {
      var title = norm(card.dataset.title);
      var desc = norm(card.dataset.desc);
      var tags = (card.dataset.tags || '').split(',').map(function(t) { return norm(t); });
      var qok = !q || title.indexOf(q) !== -1 || desc.indexOf(q) !== -1 || tags.some(function(t) { return t.indexOf(q) !== -1; });
      var tok = tag === 'all' || tags.indexOf(norm(tag)) !== -1;
      return qok && tok;
    }

    function apply() {
      var q = norm(query);
      var grid = root.querySelector('.nx-gh-grid');
      var visible = [];

      cards.forEach(function(card) {
        var show = matchCard(card, q, activeTag);
        card.style.display = show ? '' : 'none';
        if (show) visible.push(card);
      });

      if (sortSel) {
        var val = sortSel.value;
        visible.sort(function(a, b) {
          if (val === 'az') return a.dataset.title.localeCompare(b.dataset.title);
          var wa = Number(a.dataset.weight || 9), wb = Number(b.dataset.weight || 9);
          if (wa !== wb) return wa - wb;
          return a.dataset.title.localeCompare(b.dataset.title);
        });
        visible.forEach(function(el) { grid.appendChild(el); });
      }
    }

    if (search) search.addEventListener('input', function(e) { query = e.target.value; apply(); });
    if (clearBtn) clearBtn.addEventListener('click', function() { query = ''; search.value = ''; apply(); search.focus(); });

    chips.forEach(function(chip) {
      chip.addEventListener('click', function() {
        chips.forEach(function(c) {
          c.classList.remove('is-active');
          c.setAttribute('aria-selected', 'false');
        });
        chip.classList.add('is-active');
        chip.setAttribute('aria-selected', 'true');
        activeTag = chip.dataset.chip;
        apply();
      });
    });

    if (sortSel) sortSel.addEventListener('change', apply);

    apply();
  })();
</script>

