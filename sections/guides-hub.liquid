{% comment %}
  =============================================
  Section: Guides Hub — Nootropix Knowledge Center
  File: sections/guides-hub.liquid
  Purpose: Premium hub page — CRO / SEO / UX / A11y
  Theme: Futurer 2.x (OS 2.0) — cascades from global tokens
  =============================================
{% endcomment %}

{%- assign s = section.settings -%}
{%- assign sid = section.id -%}

{%- comment -%} ── JSON-LD: CollectionPage ── {%- endcomment -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": {{ s.hero_title | strip_html | default: "Nootropix Guides" | json }},
  "description": {{ s.hero_subtitle | strip_html | truncate: 160 | default: "Evidence-based nootropic guides for focus, memory, stacking, and more." | json }},
  "url": {{ canonical_url | json }},
  "publisher": {
    "@type": "Organization",
    "name": "Nootropix",
    "url": {{ shop.url | json }}
  }
}
</script>

{%- comment -%} ── JSON-LD: BreadcrumbList ── {%- endcomment -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": {{ shop.url | json }} },
    { "@type": "ListItem", "position": 2, "name": "Guides", "item": {{ canonical_url | json }} }
  ]
}
</script>

{%- comment -%} ── JSON-LD: ItemList (guide blocks) ── {%- endcomment -%}
{%- assign guide_blocks = section.blocks | where: 'type', 'guide' -%}
{% if guide_blocks.size > 0 %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "Nootropix Guides",
    "numberOfItems": {{ guide_blocks.size }},
    "itemListElement": [
      {%- for b in guide_blocks -%}
        {
          "@type": "ListItem",
          "position": {{ forloop.index }},
          "name": {{ b.settings.title | json }},
          "url": {{ b.settings.url | json }}
        }{%- unless forloop.last -%},{%- endunless -%}
      {%- endfor -%}
    ]
  }
  </script>
{% endif %}

<section id="nx-gh-{{ sid }}" class="nx-gh-section" aria-labelledby="nx-gh-title-{{ sid }}">
  <div class="nx-gh-inner">

    {%- comment -%} ── HERO ── {%- endcomment -%}
    <header class="nx-gh-hero">
      {% if s.hero_pill_text != blank %}
        <div class="nx-gh-pill" role="note">
          <svg viewBox="0 0 24 24" width="14" height="14" aria-hidden="true"><path fill="currentColor" d="M11 2l1.7 3.4L16 6l-3 2.9.7 4.1L11 11l-3.7 2L8 8.9 5 6l3.3-.6L11 2z"/></svg>
          <span>{{ s.hero_pill_text }}</span>
        </div>
      {% endif %}

      <nav class="nx-gh-breadcrumbs" aria-label="Breadcrumb">
        <a href="{{ routes.root_url }}">Home</a>
        <span aria-hidden="true">/</span>
        <span aria-current="page">Guides</span>
      </nav>

      <h1 id="nx-gh-title-{{ sid }}" class="nx-gh-title">{{ s.hero_title | escape }}</h1>
      {% if s.hero_subtitle != blank %}
        <p class="nx-gh-sub">{{ s.hero_subtitle }}</p>
      {% endif %}

      <div class="nx-gh-quick">
        <a class="nx-gh-btn nx-gh-btn--primary" href="{{ s.start_here_url | default: '/pages/guides-beginners-nootropics' }}">Start here (Beginner's Guide)</a>
        <a class="nx-gh-btn nx-gh-btn--ghost" href="{{ s.shipping_url | default: '/pages/nootropics-dubai-shipping' }}">Shipping & delivery</a>
        <a class="nx-gh-btn nx-gh-btn--ghost" href="{{ s.contact_url | default: '/pages/help-faq' }}">Help / FAQs</a>
      </div>
    </header>

    {%- comment -%} ── SEARCH + FILTERS (glassmorphism bar) ── {%- endcomment -%}
    <section class="nx-gh-filters" aria-label="Search and filters">
      <div class="nx-gh-search">
        <label for="nx-gh-search-{{ sid }}" class="visually-hidden">Search guides</label>
        <input id="nx-gh-search-{{ sid }}" type="search" class="nx-gh-search-input" placeholder="{{ s.search_placeholder | default: 'Search guides…' | escape }}" autocomplete="off" />
        <button class="nx-gh-clear" type="button" aria-label="Clear search" title="Clear">&times;</button>
      </div>

      {% assign tags_raw = '' %}
      {% for block in section.blocks %}
        {% if block.type == 'guide' and block.settings.tag != blank %}
          {% assign taglist = block.settings.tag | split: ',' %}
          {% for tg in taglist %}
            {% assign tags_raw = tags_raw | append: tg | append: ',' %}
          {% endfor %}
        {% endif %}
      {% endfor %}
      {% assign tags = tags_raw | split: ',' | uniq | sort %}

      {% if s.show_tags and tags.size > 0 %}
        <div class="nx-gh-chips" role="tablist" aria-label="Filter by topic">
          <button class="nx-gh-chip is-active" data-chip="all" role="tab" aria-selected="true">All</button>
          {% for t in tags %}
            {% assign t_trim = t | strip %}
            {% if t_trim != blank %}
              <button class="nx-gh-chip" data-chip="{{ t_trim | escape }}" role="tab" aria-selected="false">{{ t_trim }}</button>
            {% endif %}
          {% endfor %}
        </div>
      {% endif %}

      {% if s.show_sort %}
        <div class="nx-gh-sort">
          <label class="visually-hidden" for="nx-gh-sort-{{ sid }}">Sort guides</label>
          <select id="nx-gh-sort-{{ sid }}" class="nx-gh-sort-select" aria-label="Sort guides">
            <option value="featured">Featured</option>
            <option value="az">A–Z</option>
          </select>
        </div>
      {% endif %}
    </section>

    {%- comment -%} ── FEATURED HERO CARD ── {%- endcomment -%}
    {% assign featured_block = nil %}
    {% for b in section.blocks %}
      {% if b.type == 'guide' and b.settings.featured %}
        {% assign featured_block = b %}
        {% break %}
      {% endif %}
    {% endfor %}

    {% if featured_block %}
      {% assign f = featured_block %}
      {% assign f_tags = f.settings.tag | default: 'Guide' %}
      <section class="nx-gh-feature" aria-label="Featured guide">
        <article class="nx-gh-hero-card" data-title="{{ f.settings.title | escape }}" data-desc="{{ f.settings.desc | strip_html | escape }}" data-tags="{{ f_tags | downcase }}">
          <div class="nx-gh-hero-content">
            <div class="nx-gh-hero-meta">
              <span class="nx-gh-badge-pop">{{ f.settings.badge | default: 'Most Popular' }}</span>
            </div>
            <h2 class="nx-gh-hero-heading">{{ f.settings.title | escape }}</h2>
            {% if f.settings.desc != blank %}<p class="nx-gh-hero-desc">{{ f.settings.desc }}</p>{% endif %}
            <div class="nx-gh-hero-cta">
              <a class="nx-gh-btn nx-gh-btn--primary" href="{{ f.settings.url | default: '#' }}">Read the Guide</a>
              {% if f.settings.read_time != blank %}<span class="nx-gh-time">{{ f.settings.read_time }} min read</span>{% endif %}
            </div>
          </div>
          <div class="nx-gh-hero-illu">
            {% if f.settings.image != blank %}
              <div class="nx-gh-illu-wrap">
                <img loading="lazy" src="{{ f.settings.image | image_url: width: 800 }}" alt="{{ f.settings.image_alt | default: f.settings.title | escape }}" width="800" height="533">
              </div>
            {% else %}
              <div class="nx-gh-illu-placeholder" aria-hidden="true">
                <svg viewBox="0 0 48 48" width="80" height="80" aria-hidden="true"><circle cx="24" cy="24" r="22" fill="none" stroke="currentColor" stroke-width="1.5" opacity=".3"/><path d="M16 26h16M16 20h16M16 32h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity=".3"/></svg>
              </div>
            {% endif %}
          </div>
        </article>
      </section>
    {% endif %}

    {%- comment -%} ── GUIDE CARDS GRID ── {%- endcomment -%}
    <section class="nx-gh-grid" aria-label="All guides">
      {% for block in section.blocks %}
        {% if block.type == 'guide' %}
          {% assign tags_attr = block.settings.tag | replace: ' ,', ',' | replace: ', ', ',' | downcase %}
          <article
            class="nx-gh-card{% if block.settings.featured %} is-featured{% endif %}"
            data-title="{{ block.settings.title | escape }}"
            data-desc="{{ block.settings.desc | strip_html | escape }}"
            data-tags="{{ tags_attr | escape }}"
            data-weight="{% if block.settings.featured %}1{% else %}9{% endif %}"
            {{ block.shopify_attributes }}
          >
            <a href="{{ block.settings.url | default: '#' }}" class="nx-gh-card-link" aria-label="{{ block.settings.title | escape }}">
              <div class="nx-gh-card-media">
                {% if block.settings.image != blank %}
                  <img loading="lazy" src="{{ block.settings.image | image_url: width: 540 }}" alt="{{ block.settings.image_alt | default: block.settings.title | escape }}" width="540" height="360">
                {% else %}
                  <svg viewBox="0 0 48 48" class="nx-gh-icon" aria-hidden="true"><circle cx="24" cy="24" r="22" fill="none" stroke="currentColor" stroke-width="2"/><path d="M16 26h16M16 20h16M16 32h10" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                {% endif %}
                {% if block.settings.featured %}
                  <span class="nx-gh-card-badge">Featured</span>
                {% endif %}
              </div>
              <div class="nx-gh-card-body">
                {% assign primary_tag = block.settings.tag | split: ',' | first | strip %}
                <div class="nx-gh-card-top">
                  <span class="nx-gh-tag">{{ primary_tag }}</span>
                  {% if block.settings.read_time != blank %}<span class="nx-gh-read-time">{{ block.settings.read_time }} min</span>{% endif %}
                </div>
                <h3 class="nx-gh-card-title">{{ block.settings.title }}</h3>
                {% if block.settings.desc != blank %}
                  <p class="nx-gh-card-desc">{{ block.settings.desc }}</p>
                {% endif %}
                <span class="nx-gh-card-cta">Read guide<span aria-hidden="true"> &rarr;</span></span>
              </div>
            </a>
          </article>
        {% endif %}
      {% endfor %}
    </section>

    {%- comment -%} ── BUNDLES / STACKS ── {%- endcomment -%}
    {% assign bundle_blocks = section.blocks | where: 'type', 'bundle' %}
    {% if bundle_blocks.size > 0 %}
      <section class="nx-gh-bundles" aria-label="Recommended stacks">
        <h2 class="nx-gh-section-heading">Recommended Stacks</h2>
        <div class="nx-gh-bundle-grid">
          {% for block in bundle_blocks %}
            <article class="nx-gh-bundle-card" {{ block.shopify_attributes }}>
              <div class="nx-gh-bundle-media">
                {% if block.settings.image != blank %}
                  <img loading="lazy" src="{{ block.settings.image | image_url: width: 540 }}" alt="{{ block.settings.image_alt | default: block.settings.title | escape }}" width="540" height="360">
                {% else %}
                  <svg viewBox="0 0 48 48" class="nx-gh-icon" aria-hidden="true"><rect x="8" y="10" width="32" height="24" rx="3" fill="none" stroke="currentColor" stroke-width="2"/></svg>
                {% endif %}
              </div>
              <div class="nx-gh-bundle-body">
                <h3 class="nx-gh-bundle-title">{{ block.settings.title }}</h3>
                {% if block.settings.desc != blank %}
                  <p class="nx-gh-bundle-desc">{{ block.settings.desc }}</p>
                {% endif %}
                <div class="nx-gh-bundle-ctas">
                  <a class="nx-gh-btn nx-gh-btn--primary" href="{{ block.settings.url | default: '/collections/all' }}">Shop now</a>
                  {% if block.settings.learn_url != blank %}
                    <a class="nx-gh-btn nx-gh-btn--ghost" href="{{ block.settings.learn_url }}">Learn more</a>
                  {% endif %}
                </div>
              </div>
            </article>
          {% endfor %}
        </div>
      </section>
    {% endif %}

    {%- comment -%} ── TRUST BAR ── {%- endcomment -%}
    <section class="nx-gh-trust" aria-label="Why Nootropix">
      <div class="nx-gh-trust-grid">
        <div class="nx-gh-trust-item">
          <span class="nx-gh-trust-icon" aria-hidden="true">&#9889;</span>
          <div><strong>Fast UAE delivery</strong><br><span class="nx-gh-trust-detail">4-hour Dubai city limits; same/next-day UAE.</span></div>
        </div>
        <div class="nx-gh-trust-item">
          <span class="nx-gh-trust-icon" aria-hidden="true">&#128666;</span>
          <div><strong>Free UAE shipping</strong><br><span class="nx-gh-trust-detail">Orders &ge; 300 AED.</span></div>
        </div>
        <div class="nx-gh-trust-item">
          <span class="nx-gh-trust-icon" aria-hidden="true">&#127758;</span>
          <div><strong>Express international</strong><br><span class="nx-gh-trust-detail">Same-day dispatch.</span></div>
        </div>
        <div class="nx-gh-trust-item">
          <span class="nx-gh-trust-icon" aria-hidden="true">&#128260;</span>
          <div><strong>Easy returns</strong><br><span class="nx-gh-trust-detail">Unopened items, quick refunds.</span></div>
        </div>
      </div>
    </section>

    {%- comment -%} ── FOOTER CTA ── {%- endcomment -%}
    <section class="nx-gh-footer-cta">
      <h2 class="nx-gh-section-heading">Need a hand choosing?</h2>
      <p class="nx-gh-footer-desc">Start with the Beginner's Guide or message us — we'll point you to the right path.</p>
      <div class="nx-gh-footer-btns">
        <a class="nx-gh-btn nx-gh-btn--primary" href="{{ s.start_here_url | default: '/pages/guides-beginners-nootropics' }}">Beginner's Guide</a>
        <a class="nx-gh-btn nx-gh-btn--ghost" href="{{ s.contact_url | default: '/pages/help-faq' }}">Chat with us</a>
      </div>
    </section>

  </div>

  {%- comment -%} ── STICKY MOBILE CTA ── {%- endcomment -%}
  <div class="nx-gh-sticky" data-sticky>
    <a class="nx-gh-sticky-btn" href="{{ s.start_here_url | default: '/pages/guides-beginners-nootropics' }}">Start here</a>
    <a class="nx-gh-sticky-btn" href="{{ s.shipping_url | default: '/pages/nootropics-dubai-shipping' }}">Shipping</a>
    <a class="nx-gh-sticky-btn" href="{{ s.contact_url | default: '/pages/help-faq' }}">Help</a>
  </div>
</section>

{%- style -%}
/* ═══════════════════════════════════════════════════════
   GUIDES HUB — Premium Design Tokens & Styles
   ═══════════════════════════════════════════════════════ */

#nx-gh-{{ sid }} {
  --gh-max: {{ s.max_width | default: 1200 }}px;
  --gh-py: {{ s.padding_y | default: 48 }}px;
  --gh-accent: var(--color-accent-primary, #FBBF24);
  --gh-accent-hover: var(--color-accent-hover, #D97706);
  --gh-accent-dark: var(--color-accent-dark, #92400e);
  --gh-accent-glass: rgba(251, 191, 36, 0.08);
  --gh-accent-glass-strong: rgba(251, 191, 36, 0.14);
  --gh-text: var(--color-text-main, #111827);
  --gh-muted: var(--color-text-muted, #4b5563);
  --gh-bg: {{ s.background_color | default: '#ffffff' }};
  --gh-bg-alt: var(--color-bg-secondary, #f9fafb);
  --gh-radius: var(--radius-premium, 14px);
  --gh-radius-sm: var(--nx-radius-md);
  --gh-transition: var(--transition-premium, all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1));
  --gh-shadow-rest: var(--shadow-sm, 0 2px 8px rgba(0, 0, 0, 0.04));
  --gh-shadow-hover: var(--shadow-md, 0 12px 30px rgba(0, 0, 0, 0.06));
  --gh-shadow-elevated: var(--shadow-lg, 0 20px 46px rgba(0, 0, 0, 0.10));
  --gh-gold-glow: var(--shadow-gold-glow, 0 4px 14px rgba(251, 191, 36, 0.25));
  --gh-gold-glow-hover: var(--shadow-gold-glow-hover, 0 8px 24px rgba(251, 191, 36, 0.35));
  --gh-font: var(--font-body-family, sans-serif);
  --gh-font-heading: var(--font-heading-family, sans-serif);
  --gh-gap: 18px;

  background: var(--gh-bg);
  color: var(--gh-text);
  font-family: var(--gh-font);
  line-height: 1.6;
  content-visibility: auto;
  contain-intrinsic-size: 1px 4000px;
}

/* ── Utility ── */
#nx-gh-{{ sid }} .visually-hidden {
  position: absolute !important;
  height: 1px; width: 1px;
  overflow: hidden;
  clip: rect(1px, 1px, 1px, 1px);
  white-space: nowrap;
}

/* ── Inner container ── */
#nx-gh-{{ sid }} .nx-gh-inner {
  max-width: var(--gh-max);
  margin: 0 auto;
  padding: var(--gh-py) var(--page-gutter);
  display: flex;
  flex-direction: column;
  gap: 32px;
}
@media (min-width: 990px) {
  #nx-gh-{{ sid }} .nx-gh-inner { gap: 48px; }
}

/* ═══════════════════════════════════════════════════════
   HERO
   ═══════════════════════════════════════════════════════ */
#nx-gh-{{ sid }} .nx-gh-hero {
  text-align: center;
  padding-top: 8px;
}
#nx-gh-{{ sid }} .nx-gh-pill {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  border-radius: var(--nx-radius-pill);
  padding: 5px 14px;
  font-size: 0.82rem;
  font-weight: 600;
  background: var(--gh-accent-glass);
  -webkit-backdrop-filter: blur(8px);
  backdrop-filter: blur(8px);
  color: var(--gh-accent-dark);
  margin-bottom: 10px;
}
#nx-gh-{{ sid }} .nx-gh-breadcrumbs {
  display: flex;
  gap: 8px;
  justify-content: center;
  align-items: center;
  font-size: 0.88rem;
  color: var(--gh-muted);
  margin-bottom: 10px;
}
#nx-gh-{{ sid }} .nx-gh-breadcrumbs a {
  color: var(--gh-muted);
  text-decoration: none;
  transition: var(--gh-transition);
}
#nx-gh-{{ sid }} .nx-gh-breadcrumbs a:hover {
  color: var(--gh-accent-hover);
}
#nx-gh-{{ sid }} .nx-gh-title {
  font-family: var(--gh-font-heading);
  font-size: clamp(30px, 4.5vw, 52px);
  font-weight: 800;
  letter-spacing: -0.02em;
  line-height: 1.1;
  color: var(--gh-text);
  margin: 0 0 12px;
}
#nx-gh-{{ sid }} .nx-gh-sub {
  font-size: clamp(15px, 1.5vw, 18px);
  color: var(--gh-muted);
  max-width: 720px;
  margin: 0 auto 16px;
  line-height: 1.6;
}
#nx-gh-{{ sid }} .nx-gh-quick {
  display: flex;
  gap: 12px;
  justify-content: center;
  flex-wrap: wrap;
}

/* ═══════════════════════════════════════════════════════
   BUTTONS — Ghost + Primary
   ═══════════════════════════════════════════════════════ */
#nx-gh-{{ sid }} .nx-gh-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  padding: 11px 20px;
  border-radius: var(--gh-radius-sm);
  font-family: var(--gh-font);
  font-weight: 600;
  font-size: 15px;
  text-decoration: none;
  min-height: var(--touch-min, 44px);
  transition: var(--gh-transition);
  cursor: pointer;
}
#nx-gh-{{ sid }} .nx-gh-btn--ghost {
  background: transparent;
  border: 1.5px solid var(--gh-accent);
  color: var(--gh-text);
}
#nx-gh-{{ sid }} .nx-gh-btn--ghost:hover {
  background: var(--gh-accent);
  color: var(--color-text-primary);
  transform: translateY(-2px);
  box-shadow: var(--gh-shadow-hover);
}
#nx-gh-{{ sid }} .nx-gh-btn--primary {
  background: var(--gh-accent);
  color: var(--color-text-primary);
  border: 1.5px solid var(--gh-accent);
  box-shadow: var(--gh-gold-glow);
}
#nx-gh-{{ sid }} .nx-gh-btn--primary:hover {
  background: var(--gh-accent-hover);
  border-color: var(--gh-accent-hover);
  transform: translateY(-2px);
  box-shadow: var(--gh-gold-glow-hover);
}
#nx-gh-{{ sid }} .nx-gh-btn:active {
  transform: scale(0.98);
}

/* ═══════════════════════════════════════════════════════
   SEARCH + FILTERS — Glassmorphism bar
   ═══════════════════════════════════════════════════════ */
#nx-gh-{{ sid }} .nx-gh-filters {
  display: flex;
  flex-wrap: wrap;
  gap: 14px;
  align-items: center;
  padding: 18px 20px;
  border-radius: var(--gh-radius);
  background: rgba(255, 255, 255, 0.65);
  -webkit-backdrop-filter: blur(12px);
  backdrop-filter: blur(12px);
  box-shadow: var(--gh-shadow-rest);
}
#nx-gh-{{ sid }} .nx-gh-search {
  position: relative;
  flex: 1 1 260px;
}
#nx-gh-{{ sid }} .nx-gh-search-input {
  width: 100%;
  padding: 12px 40px 12px 14px;
  border: none;
  border-radius: var(--gh-radius-sm);
  background: var(--gh-bg);
  box-shadow: var(--gh-shadow-rest);
  font-family: var(--gh-font);
  font-size: 15px;
  color: var(--gh-text);
  transition: var(--gh-transition);
}
#nx-gh-{{ sid }} .nx-gh-search-input:focus {
  box-shadow: var(--gh-shadow-hover);
}
#nx-gh-{{ sid }} .nx-gh-clear {
  position: absolute;
  right: 8px;
  top: 50%;
  transform: translateY(-50%);
  border: none;
  background: var(--gh-bg-alt);
  border-radius: var(--nx-radius-sm);
  padding: 4px 8px;
  cursor: pointer;
  font-size: 16px;
  color: var(--gh-muted);
  transition: var(--gh-transition);
  min-height: 32px;
  min-width: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
}
#nx-gh-{{ sid }} .nx-gh-clear:hover {
  background: var(--gh-accent-glass-strong);
  color: var(--gh-text);
}
#nx-gh-{{ sid }} .nx-gh-chips {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
  flex: 1 1 100%;
}
#nx-gh-{{ sid }} .nx-gh-chip {
  border: none;
  border-radius: var(--nx-radius-pill);
  padding: 8px 16px;
  background: var(--gh-bg);
  box-shadow: var(--gh-shadow-rest);
  cursor: pointer;
  font-family: var(--gh-font);
  font-size: 14px;
  font-weight: 500;
  color: var(--gh-muted);
  transition: var(--gh-transition);
  min-height: var(--touch-min, 44px);
  display: inline-flex;
  align-items: center;
}
#nx-gh-{{ sid }} .nx-gh-chip:hover {
  box-shadow: var(--gh-shadow-hover);
  color: var(--gh-text);
  transform: translateY(-2px);
}
#nx-gh-{{ sid }} .nx-gh-chip.is-active {
  background: var(--gh-accent);
  color: var(--color-text-primary);
  font-weight: 600;
  box-shadow: var(--gh-gold-glow);
}
