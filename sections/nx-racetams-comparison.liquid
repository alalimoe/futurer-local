{% comment %} Nootropix — Quick Comparison (Premium) {% endcomment %}
{%- assign s = section.settings -%}
{%- assign sid = section.id -%}
{%- assign alpha = s.alpha_gpc -%}
{%- assign cdp = s.cdp_choline -%}

{%- assign anir_caps = s.aniracetam_caps -%}
{%- assign anir_pow = s.aniracetam_powder -%}
{%- assign faso_caps = s.fasoracetam_caps -%}
{%- assign phenh_caps = s.phenyl_hydrazide_caps -%}
{%- assign phenh_pow = s.phenyl_hydrazide_powder -%}
{%- assign pram_caps = s.pramiracetam_caps -%}
{%- assign pram_pow = s.pramiracetam_powder -%}

{%- style -%}
#nx-comp-{{ sid }} {
  --nx-accent: var(--color-accent-primary, #FBBF24);
  --nx-accent-dark: var(--color-accent-dark, #92400e);
  --nx-accent-glass: rgba(251, 191, 36, 0.06);
  --nx-text: var(--color-text-main, #111827);
  --nx-muted: var(--color-text-muted, #4b5563);
  --nx-radius: var(--radius-premium, 14px);
  --nx-transition: var(--transition-premium, all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1));
  --nx-shadow-rest: var(--shadow-sm, 0 2px 8px rgba(0,0,0,0.04));
  --nx-shadow-hover: var(--shadow-md, 0 12px 30px rgba(0,0,0,0.06));
  --nx-gold-glow: var(--shadow-gold-glow, 0 4px 14px rgba(251,191,36,0.25));
  --nx-font: var(--font-body-family, sans-serif);
  --nx-font-heading: var(--font-heading-family, sans-serif);

  max-width: var(--container-width-medium);
  margin: 0 auto;
  padding: 8px var(--page-gutter);
  font-family: var(--nx-font);
  color: var(--nx-text);
  content-visibility: auto;
}

#nx-comp-{{ sid }} h2 {
  font-family: var(--nx-font-heading);
  font-size: clamp(22px, 3vw, 30px);
  font-weight: 700;
  line-height: 1.2;
  margin: 0 0 16px;
}

#nx-comp-{{ sid }} .nx-table-wrap {
  border-radius: var(--nx-radius);
  box-shadow: var(--nx-shadow-rest);
  overflow: hidden;
  background: #fff;
  transition: var(--nx-transition);
}

#nx-comp-{{ sid }} .nx-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 14px;
  line-height: 1.6;
}

#nx-comp-{{ sid }} .nx-table thead th {
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: var(--nx-muted);
  padding: 12px 12px;
  text-align: left;
  border-bottom: 1px solid transparent;
  background: rgba(249, 250, 251, 0.6);
}

#nx-comp-{{ sid }} .nx-table tbody tr {
  transition: var(--nx-transition);
  border-bottom: 1px solid transparent;
}
#nx-comp-{{ sid }} .nx-table tbody tr:not(:last-child) {
  border-bottom-color: rgba(0, 0, 0, 0.04);
}
#nx-comp-{{ sid }} .nx-table tbody tr:nth-child(even) {
  background: rgba(249, 250, 251, 0.35);
}
#nx-comp-{{ sid }} .nx-table tbody tr:hover {
  background: var(--nx-accent-glass);
}

#nx-comp-{{ sid }} .nx-table td {
  padding: 12px 12px;
  vertical-align: top;
  text-align: left;
  color: var(--nx-muted);
}
#nx-comp-{{ sid }} .nx-table td strong { color: var(--nx-text); }

#nx-comp-{{ sid }} .nx-table a {
  color: var(--nx-accent-dark);
  text-decoration: none;
  font-weight: 600;
  transition: var(--nx-transition);
}
#nx-comp-{{ sid }} .nx-table a:hover { color: var(--nx-text); }

#nx-comp-{{ sid }} .nx-shop { display: flex; gap: 8px; flex-wrap: wrap; }

#nx-comp-{{ sid }} .nx-chip-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 6px 12px;
  border-radius: 10px;
  text-decoration: none;
  font-size: 13px;
  font-weight: 600;
  min-height: 36px;
  border: 1.5px solid var(--nx-accent);
  background: transparent;
  color: var(--nx-text);
  transition: var(--nx-transition);
}
#nx-comp-{{ sid }} .nx-chip-btn:hover {
  background: var(--nx-accent);
  color: var(--color-text-primary);
  box-shadow: var(--nx-gold-glow);
  transform: translateY(-1px);
}
#nx-comp-{{ sid }} .nx-chip-btn:active { transform: scale(0.98); }

#nx-comp-{{ sid }} .nx-footnote {
  font-size: 13px;
  color: var(--nx-muted);
  margin-top: 12px;
  font-style: italic;
}

#nx-comp-{{ sid }} a:focus-visible,
#nx-comp-{{ sid }} button:focus-visible {
  outline: 2px solid var(--nx-accent);
  outline-offset: 2px;
}

@media (max-width: 768px) {
  #nx-comp-{{ sid }} .nx-table,
  #nx-comp-{{ sid }} .nx-table thead,
  #nx-comp-{{ sid }} .nx-table tbody,
  #nx-comp-{{ sid }} .nx-table th,
  #nx-comp-{{ sid }} .nx-table td,
  #nx-comp-{{ sid }} .nx-table tr { display: block; }

  #nx-comp-{{ sid }} .nx-table thead { display: none; }

  #nx-comp-{{ sid }} .nx-table tbody tr {
    margin-bottom: 12px;
    padding: 16px;
    border-radius: var(--nx-radius);
    background: rgba(249, 250, 251, 0.5);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    border: 1px solid transparent;
    box-shadow: var(--nx-shadow-rest);
  }

  #nx-comp-{{ sid }} .nx-table td {
    padding: 4px 0;
    text-align: left;
  }
  #nx-comp-{{ sid }} .nx-table td::before {
    content: attr(data-label);
    display: block;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--nx-muted);
    margin-bottom: 2px;
  }
}

@media (prefers-reduced-motion: reduce) {
  #nx-comp-{{ sid }},
  #nx-comp-{{ sid }} * {
    transition: none !important;
    animation: none !important;
    transform: none !important;
  }
}
{%- endstyle -%}

<section id="nx-comp-{{ sid }}" aria-label="Racetam quick comparison">
  <h2>Quick Comparison</h2>
  <div class="nx-table-wrap">
    <table class="nx-table">
      <thead>
        <tr>
          <th>Compound</th>
          <th>Feel &amp; Use Case</th>
          <th>Onset / Duration*</th>
          <th>Pairing</th>
          <th>Quick Shop</th>
        </tr>
      </thead>
      <tbody>
        {% if anir_caps != blank or anir_pow != blank %}
        <tr>
          <td data-label="Compound"><strong>Aniracetam</strong></td>
          <td data-label="Feel & Use Case">Fast focus with mood support; great for creative work and short sprints.</td>
          <td data-label="Onset / Duration">30-60 min / 2-4 h (fat-soluble)</td>
          <td data-label="Pairing">{% if cdp != blank %}<a href="{{ cdp.url }}">CDP-Choline</a>{% else %}CDP-Choline{% endif %}</td>
          <td data-label="Quick Shop" class="nx-shop">
            {% if anir_caps != blank %}<a class="nx-chip-btn" href="{{ anir_caps.url }}">Capsules</a>{% endif %}
            {% if anir_pow != blank %}<a class="nx-chip-btn" href="{{ anir_pow.url }}">Powder</a>{% endif %}
          </td>
        </tr>
        {% endif %}

        {% if faso_caps != blank %}
        <tr>
          <td data-label="Compound"><strong>Fasoracetam</strong></td>
          <td data-label="Feel & Use Case">Calm, clean focus without a buzzy edge; popular with stimulus-sensitive users.</td>
          <td data-label="Onset / Duration">30-60 min / 2-4 h (water-soluble)</td>
          <td data-label="Pairing">{% if alpha != blank %}<a href="{{ alpha.url }}">Alpha-GPC</a>{% else %}Alpha-GPC{% endif %}{% if cdp != blank %} or <a href="{{ cdp.url }}">CDP-Choline</a>{% endif %}</td>
          <td data-label="Quick Shop" class="nx-shop">
            <a class="nx-chip-btn" href="{{ faso_caps.url }}">Capsules</a>
          </td>
        </tr>
        {% endif %}

        {% if phenh_caps != blank or phenh_pow != blank %}
        <tr>
          <td data-label="Compound"><strong>Phenylpiracetam Hydrazide</strong></td>
          <td data-label="Feel & Use Case">High-gear days — presentations, exams, demanding sprints. Use selectively.</td>
          <td data-label="Onset / Duration">30-60 min / 3-5 h</td>
          <td data-label="Pairing">{% if alpha != blank %}<a href="{{ alpha.url }}">Alpha-GPC</a>{% else %}Alpha-GPC{% endif %}</td>
          <td data-label="Quick Shop" class="nx-shop">
            {% if phenh_caps != blank %}<a class="nx-chip-btn" href="{{ phenh_caps.url }}">Capsules</a>{% endif %}
            {% if phenh_pow != blank %}<a class="nx-chip-btn" href="{{ phenh_pow.url }}">Powder</a>{% endif %}
          </td>
        </tr>
        {% endif %}

        {% if pram_caps != blank or pram_pow != blank %}
        <tr>
          <td data-label="Compound"><strong>Pramiracetam</strong></td>
          <td data-label="Feel & Use Case">Multi-hour study &amp; retention; "lock-in" for complex material.</td>
          <td data-label="Onset / Duration">60-120 min / 5-8+ h (lipophilic)</td>
          <td data-label="Pairing">{% if cdp != blank %}<a href="{{ cdp.url }}">CDP-Choline</a>{% else %}CDP-Choline{% endif %}</td>
          <td data-label="Quick Shop" class="nx-shop">
            {% if pram_caps != blank %}<a class="nx-chip-btn" href="{{ pram_caps.url }}">Capsules</a>{% endif %}
            {% if pram_pow != blank %}<a class="nx-chip-btn" href="{{ pram_pow.url }}">Powder</a>{% endif %}
          </td>
        </tr>
        {% endif %}
      </tbody>
    </table>
  </div>
  <p class="nx-footnote">*Generalized windows; individuals vary. Start low and evaluate your response.</p>
</section>

{% schema %}
{
  "name": "NX — Quick Comparison",
  "settings": [
    { "type": "product", "id": "alpha_gpc", "label": "Alpha-GPC (optional)" },
    { "type": "product", "id": "cdp_choline", "label": "CDP-Choline (optional)" },

    { "type": "header", "content": "Aniracetam" },
    { "type": "product", "id": "aniracetam_caps", "label": "Aniracetam (capsules)" },
    { "type": "product", "id": "aniracetam_powder", "label": "Aniracetam Powder" },

    { "type": "header", "content": "Fasoracetam" },
    { "type": "product", "id": "fasoracetam_caps", "label": "Fasoracetam (capsules)" },

    { "type": "header", "content": "Phenylpiracetam Hydrazide" },
    { "type": "product", "id": "phenyl_hydrazide_caps", "label": "Phenylpiracetam Hydrazide (capsules)" },
    { "type": "product", "id": "phenyl_hydrazide_powder", "label": "Phenylpiracetam Hydrazide Powder" },

    { "type": "header", "content": "Pramiracetam" },
    { "type": "product", "id": "pramiracetam_caps", "label": "Pramiracetam (capsules)" },
    { "type": "product", "id": "pramiracetam_powder", "label": "Pramiracetam Powder" }
  ],
  "presets": [{ "name": "NX — Quick Comparison" }]
}
{% endschema %}
