{%- style -%}
.xo-section--{{ section.id }} {
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
  font-family: var(--font-body-family);
}
.xo-section--{{ section.id }} .phb-goal-chips__title {
  font-family: var(--font-heading-family);
  font-size: clamp(18px, 3.2vw, 22px); margin: 0 0 8px;
  color: rgba(var(--color-foreground)); font-weight: 600;
  text-align: {% if section.settings.center_on_mobile %}center{% else %}left{% endif %};
}
.xo-section--{{ section.id }} .phb-goal-chips__row {
  max-width: {{ section.settings.max_width }}px; margin: 0 auto; padding: 0 16px;
  display: flex; flex-wrap: wrap; gap: 10px;
  justify-content: {% if section.settings.center_on_mobile %}center{% else %}flex-start{% endif %};
}
.xo-section--{{ section.id }} .phb-gc-chip {
  display: inline-flex; align-items: center; justify-content: center;
  padding: 8px 12px; border-radius: var(--button-radius);
  background: rgba(var(--color-background-2)); color: rgba(var(--color-foreground));
  text-decoration: none; font-weight: 600; font-size: 14px;
  border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
  transition: background 0.2s var(--out-soft, ease);
}
.xo-section--{{ section.id }} .phb-gc-chip:focus-visible {
  outline: 2px solid rgba(var(--color-accent)); outline-offset: 2px;
}
[id^="benefit-"] { scroll-margin-top: 96px; }
@media (max-width: 768px) { [id^="benefit-"] { scroll-margin-top: 80px; } }
@media (prefers-reduced-motion: reduce) {
  .xo-section--{{ section.id }} *,
  .xo-section--{{ section.id }} *::before,
  .xo-section--{{ section.id }} *::after {
    animation-duration: 0.01ms !important;
    transition-duration: 0.01ms !important;
  }
}
{%- endstyle -%}

<section {% render 'section-attr' %} aria-label="Benefit shortcuts">
  <xo-container>
    {% if section.settings.show_heading %}
      <h2 class="phb-goal-chips__title">{{ section.settings.heading | escape }}</h2>
    {% endif %}

    <nav class="phb-goal-chips__row" role="navigation" aria-label="Jump to benefit">
      {% for block in section.blocks %}
        {% if block.type == 'chip' %}
          <a class="phb-gc-chip" href="{{ block.settings.href | escape }}" {{ block.shopify_attributes }}>
            {{ block.settings.label | escape }}
          </a>
        {% endif %}
      {% endfor %}
    </nav>
  </xo-container>
</section>

{% schema %}
{
  "name": "Goal Chips",
  "tag": "section",
  "class": "section-phb-goal-chips",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "default" },
    { "type": "checkbox", "id": "show_heading", "label": "Show small heading", "default": false },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Find your goal" },
    { "type": "range", "id": "max_width", "label": "Max width (px)", "min": 720, "max": 1400, "step": 20, "default": 1200 },
    { "type": "checkbox", "id": "center_on_mobile", "label": "Center chips on mobile", "default": true },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding top", "default": 12 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding bottom", "default": 12 }
  ],
  "blocks": [
    { "type": "chip", "name": "Chip", "settings": [
      { "type": "text", "id": "label", "label": "Label", "default": "Calm" },
      { "type": "text", "id": "href", "label": "Link (anchor or URL)", "default": "#benefit-calm-relaxation" }
    ] },
    { "type": "@app" }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Goal Chips",
      "blocks": [
        { "type": "chip", "settings": { "label": "Calm", "href": "#benefit-calm-relaxation" } },
        { "type": "chip", "settings": { "label": "Sleep", "href": "#benefit-better-sleep-quality" } },
        { "type": "chip", "settings": { "label": "Social Ease", "href": "#benefit-social-ease-confidence" } }
      ]
    }
  ]
}
{% endschema %}
