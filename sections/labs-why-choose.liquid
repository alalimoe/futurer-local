{% comment %} Why Labs Choose Nootropix {% endcomment %}
{%- assign sid = section.id | replace:'_','' | downcase -%}
<style>
#why-{{ sid }}{ --b:var(--color-border-default); --text:var(--color-text-primary); }
#why-{{ sid }} .w-wrap{ padding:24px var(--page-gutter); border-top:1px solid var(--b); background:var(--color-surface-secondary); }
#why-{{ sid }} .w-container{ max-width:{{ section.settings.maxw | default:1200 }}px; margin:0 auto; }
#why-{{ sid }} .w-grid{ display:grid; grid-template-columns:1fr 1fr; gap:18px; }
@media(max-width:900px){ #why-{{ sid }} .w-grid{ grid-template-columns:1fr; } }
#why-{{ sid }} .w-title{ margin:0 0 6px; font-weight:800; color:var(--text); }
#why-{{ sid }} .w-list{ display:grid; gap:10px; }
#why-{{ sid }} .w-item{ display:flex; gap:10px; align-items:flex-start; }
#why-{{ sid }} .w-ico{ width:18px; height:18px; color:var(--color-success); flex:0 0 18px; }
#why-{{ sid }} .w-cta{ margin-top:10px; }
</style>

<section id="why-{{ sid }}" class="pdp-section" aria-label="Why labs choose Nootropix">
  <div class="w-wrap">
    <div class="w-container">
      <div class="w-grid">
        <div>
          <h2 class="w-title">{{ section.settings.title | default: 'Why Labs Choose Nootropix' }}</h2>
          <p>{{ section.settings.sub | default: 'Trusted by research teams for COA-verified batches, fast UAE fulfillment, and dedicated B2B support.' }}</p>
          <div class="w-cta">
            {% if section.settings.cta_label and section.settings.cta_link %}<a class="btn btn--primary" href="{{ section.settings.cta_link }}">{{ section.settings.cta_label }}</a>{% endif %}
          </div>
        </div>
        <div class="w-list">
          {% assign bullets = section.settings.bullets %}
          {% if bullets == blank %}{% assign bullets = 'COA-verified BT Labs testing|Batch consistency & traceability|Bulk vial pricing|Same-day Dubai fulfillment|Dedicated B2B support' %}{% endif %}
          {% assign list = bullets | split:'|' %}
          {% for b in list %}
            {% assign t = b | strip %}{% if t != blank %}
            <div class="w-item">
              <span class="w-ico" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
              <div>{{ t }}</div>
            </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name":"Labs · Why choose",
  "settings":[
    { "type":"range","id":"maxw","min":800,"max":1600,"step":10,"unit":"px","label":"Max width","default":1200 },
    { "type":"text","id":"title","label":"Heading","default":"Why Labs Choose Nootropix" },
    { "type":"textarea","id":"sub","label":"Subtext" },
    { "type":"text","id":"bullets","label":"Bullets (| separated)","default":"COA-verified BT Labs testing|Batch consistency & traceability|Bulk vial pricing|Same-day Dubai fulfillment|Dedicated B2B support" },
    { "type":"text","id":"cta_label","label":"Primary CTA label","default":"Request Lab Pricing" },
{ "type":"url","id":"cta_link","label":"Primary CTA link" }
  ],
  "presets":[{ "name":"Labs · Why choose" }]
}
{% endschema %}
