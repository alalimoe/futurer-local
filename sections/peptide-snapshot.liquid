{% comment %}
  Evidence snapshot: COA / HPLC / MS / assay badges from metafields.
{% endcomment %}

{%- liquid
  assign pep_ref = product.metafields.pep.reference
  assign pep = nil
  if pep_ref and pep_ref.value
    assign pep = pep_ref.value
  endif

  assign pdp_coa_override = product.metafields.pdp.coa_url
  assign coa_pdf_mf = product.metafields.pep.coa_pdf
  assign coa_files_mf = product.metafields.peptide.coa_file

  assign coa_url = nil
  if pdp_coa_override and pdp_coa_override != blank
    assign coa_url = pdp_coa_override
  elsif coa_pdf_mf and coa_pdf_mf.value and coa_pdf_mf.value.url
    assign coa_url = coa_pdf_mf.value.url
  elsif coa_files_mf and coa_files_mf.value and coa_files_mf.value.size > 0
    assign first_file = coa_files_mf.value.first
    if first_file and first_file.url
      assign coa_url = first_file.url
    endif
  endif

  assign hplc_mf = product.metafields.pep.hplc_image
  assign ms_mf = product.metafields.pep.ms_image

  assign hplc_img = nil
  if hplc_mf and hplc_mf.value
    assign hplc_img = hplc_mf.value
  elsif pep and pep.hplc_image
    assign hplc_img = pep.hplc_image
  endif

  assign ms_img = nil
  if ms_mf and ms_mf.value
    assign ms_img = ms_mf.value
  elsif pep and pep.ms_image
    assign ms_img = pep.ms_image
  endif

  assign assay = product.metafields.pdp.assay_percent

  assign has_coa = false
  if coa_url and coa_url != blank
    assign has_coa = true
  endif
  assign has_hplc = false
  if hplc_img
    assign has_hplc = true
  endif
  assign has_ms = false
  if ms_img
    assign has_ms = true
  endif
-%}

{%- style -%}
  .xo-section--{{ section.id }} .evs__row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    align-items: center;
  }

  .xo-section--{{ section.id }} .evs__chip {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
    border-radius: var(--button-radius);
    padding: 0.8rem 1.4rem;
    min-height: 44px;
    background: rgba(var(--color-background));
    color: rgba(var(--color-foreground));
    font-weight: 600;
    font-size: calc(var(--font-body-scale, 1) * 1.4rem);
    line-height: 1.1;
    text-decoration: none;
    transition: border-color 0.3s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .evs__chip:focus-visible {
    outline: 2px solid rgba(var(--color-accent));
    outline-offset: 2px;
  }

  .xo-section--{{ section.id }} .evs__chip .ico {
    width: 1.4rem;
    height: 1.4rem;
    display: block;
  }

  .xo-section--{{ section.id }} .evs__chip--on {
    border-color: color-mix(in srgb, rgba(var(--color-accent)) 40%, transparent);
    background: color-mix(in srgb, rgba(var(--color-accent)) 6%, rgba(var(--color-background)));
  }

  .xo-section--{{ section.id }} .evs__chip--off {
    color: color-mix(in srgb, rgba(var(--color-foreground)) 45%, transparent);
  }

  .xo-section--{{ section.id }} .evs__chip:hover {
    border-color: color-mix(in srgb, rgba(var(--color-accent)) 50%, transparent);
  }

  @media (prefers-reduced-motion: reduce) {
    .xo-section--{{ section.id }} .evs__chip {
      transition: none;
    }
  }
{%- endstyle -%}

<section {% render 'section-attr' %}>
  <xo-container>
    <xo-animate xo-animation="fade-up" xo-cascade>
    <div class="evs__row" role="status" aria-label="Quality evidence snapshot">
      {% if has_coa %}
        <a href="{{ coa_url }}" target="_blank" rel="noopener"
           class="evs__chip evs__chip--on"
           aria-label="Certificate of Analysis — view document">
          <svg class="ico" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M6 4h12v16H6z" stroke="currentColor" stroke-width="1.6"/>
            <path d="M9 8h6M9 12h6M9 16h4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
          </svg>
          <span>COA</span><span aria-hidden="true">✓</span>
        </a>
      {% endif %}

      {% if has_hplc %}
        <span class="evs__chip evs__chip--on" aria-label="HPLC chromatogram verified">
          <svg class="ico" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M5 17h14M7 17V7m4 10V9m4 8V5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
          </svg>
          <span>HPLC</span><span aria-hidden="true">✓</span>
        </span>
      {% endif %}

      {% if has_ms %}
        <span class="evs__chip evs__chip--on" aria-label="Mass spectrometry confirmed">
          <svg class="ico" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M4 12h4l2 6 3-12 2 6h5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span>MS</span><span aria-hidden="true">✓</span>
        </span>
      {% endif %}

      {% if assay %}
        <span class="evs__chip evs__chip--on" aria-label="Assay result">
          <svg class="ico" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M8 5h8l1 3-9 11H6l9-11H7l1-3z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span>Assay</span><span aria-hidden="true">≥{{ assay }}%</span>
        </span>
      {% endif %}

      {% unless has_coa or has_hplc or has_ms or assay %}
        <span class="evs__chip evs__chip--off" aria-label="Quality documentation pending">
          <svg class="ico" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.6"/>
            <path d="M12 8v4m0 4h.01" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
          </svg>
          <span>QC pending</span>
        </span>
      {% endunless %}
    </div>
    </xo-animate>
  </xo-container>
</section>

{% schema %}
{
  "name": "Evidence snapshot",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "background-1"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "Desktop top padding",
      "min": 0,
      "max": 60,
      "step": 4,
      "default": 8,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Desktop bottom padding",
      "min": 0,
      "max": 60,
      "step": 4,
      "default": 8,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Mobile top padding",
      "min": 0,
      "max": 40,
      "step": 4,
      "default": 8,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Mobile bottom padding",
      "min": 0,
      "max": 40,
      "step": 4,
      "default": 8,
      "unit": "px"
    }
  ],
  "presets": [{ "name": "Evidence snapshot" }]
}
{% endschema %}
