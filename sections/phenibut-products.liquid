{% comment %}
  Products — Premium refactored section
  - Design tokens, srcset, ItemList JSON-LD, focus-visible
{% endcomment %}

{%- comment -%} ── JSON-LD: ItemList (products) ── {%- endcomment -%}
{% assign product_blocks = section.blocks | where: "type", "product_card" %}
{% if product_blocks.size > 0 %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": {{ section.settings.heading | json }},
  "numberOfItems": {{ product_blocks.size }},
  "itemListElement": [
    {%- for block in product_blocks -%}
      {%- assign prod = all_products[block.settings.product] -%}
      {%- if prod -%}
        {
          "@type": "ListItem",
          "position": {{ forloop.index }},
          "url": "{{ shop.url }}{{ prod.url }}",
          "name": {{ prod.title | json }}{% if prod.featured_image %},
          "image": "{{ prod.featured_image | image_url: width: 600 }}"{% endif %}
        }{%- unless forloop.last -%},{%- endunless -%}
      {%- endif -%}
    {%- endfor -%}
  ]
}
</script>
{% endif %}

<section id="phb-pr-{{ section.id }}" class="phb-products" aria-labelledby="phb-products-title-{{ section.id }}">
  <div class="phb-products__container">
    <h2 id="phb-products-title-{{ section.id }}" class="phb-products__title">{{ section.settings.heading | escape }}</h2>
    {% if section.settings.intro != blank %}
      <div class="phb-products__intro">{{ section.settings.intro }}</div>
    {% endif %}

    <div class="phb-products__grid">
      {% for block in section.blocks %}
        {% if block.type == 'product_card' and block.settings.product != blank %}
          {% assign prod = all_products[block.settings.product] %}
          {% if prod %}
            <article class="phb-prod" {{ block.shopify_attributes }}>
              <a class="phb-prod__imglink" href="{{ prod.url }}">
                {% if prod.featured_image %}
                  <img
                    src="{{ prod.featured_image | image_url: width: 600 }}"
                    srcset="{{ prod.featured_image | image_url: width: 300 }} 300w, {{ prod.featured_image | image_url: width: 600 }} 600w, {{ prod.featured_image | image_url: width: 900 }} 900w"
                    sizes="(max-width: 749px) 100vw, (max-width: 1199px) 50vw, 33vw"
                    alt="{{ prod.title | escape }}"
                    width="600"
                    height="{{ 600 | divided_by: prod.featured_image.aspect_ratio | round }}"
                    loading="lazy" decoding="async"
                    class="phb-prod__img"
                  >
                {% endif %}
              </a>
              <h3 class="phb-prod__title"><a href="{{ prod.url }}">{{ prod.title }}</a></h3>
              <div class="phb-prod__price">
                {% if prod.compare_at_price_max > prod.price %}
                  <span class="phb-prod__price--sale">{{ prod.price | money }}</span>
                  <span class="phb-prod__price--compare">{{ prod.compare_at_price_max | money }}</span>
                {% else %}
                  <span>{{ prod.price | money }}</span>
                {% endif %}
              </div>
              <div class="phb-prod__cta">
                <a class="phb-prod__btn" href="{{ prod.url }}">{{ block.settings.cta_label | escape }}</a>
              </div>
            </article>
          {% endif %}
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{%- style -%}
#phb-pr-{{ section.id }} {
  --phb-bg: {{ section.settings.background_color }};
  --phb-max: {{ section.settings.max_width }}px;
  --phb-py: {{ section.settings.padding_y }}px;
  --phb-accent: var(--color-accent-primary, #FBBF24);
  --phb-heading: var(--color-text-main, #0A2342);
  --phb-text: var(--color-text-main, #0e1726);
  --phb-muted: var(--color-text-muted, #6b7280);
  --phb-card-bg: var(--color-bg-primary, #fff);
  --phb-card-border: var(--nx-pill-border, rgba(0,0,0,.06));
  --phb-radius: var(--nx-radius, 14px);
  --phb-font: var(--font-body-family, sans-serif);
  --phb-font-heading: var(--font-heading-family, sans-serif);
  --phb-transition: var(--transition-smooth, all 0.3s cubic-bezier(0.25,0.8,0.25,1));
  --phb-touch: var(--touch-min, 44px);
  background: var(--phb-bg);
  font-family: var(--phb-font);
}
#phb-pr-{{ section.id }} .phb-products__container { max-width: var(--phb-max); margin: 0 auto; padding: var(--phb-py) var(--page-gutter); }
#phb-pr-{{ section.id }} .phb-products__title {
  font-family: var(--phb-font-heading);
  font-size: clamp(22px, 4.2vw, 36px); line-height: 1.2; color: var(--phb-heading); margin: 0 0 8px;
}
#phb-pr-{{ section.id }} .phb-products__intro { color: var(--phb-text); margin-bottom: 16px; }
#phb-pr-{{ section.id }} .phb-products__grid {
  display: grid; gap: 20px;
  grid-template-columns: repeat({{ section.settings.columns_desktop }}, minmax(220px, 1fr));
}
#phb-pr-{{ section.id }} .phb-prod {
  display: grid; gap: 10px;
  border: 1px solid var(--phb-card-border); border-radius: var(--phb-radius);
  padding: 12px; background: var(--phb-card-bg);
}
#phb-pr-{{ section.id }} .phb-prod__img { width: 100%; height: auto; border-radius: var(--nx-radius-md); object-fit: cover; }
#phb-pr-{{ section.id }} .phb-prod__title { font-size: 16px; margin: 4px 0 0; font-family: var(--phb-font-heading); }
#phb-pr-{{ section.id }} .phb-prod__title a { color: var(--phb-heading); text-decoration: none; }
#phb-pr-{{ section.id }} .phb-prod__title a:focus-visible { outline: 2px solid var(--phb-accent); outline-offset: 2px; }
#phb-pr-{{ section.id }} .phb-prod__price { font-weight: 700; display: flex; gap: 8px; align-items: center; color: var(--phb-heading); }
#phb-pr-{{ section.id }} .phb-prod__price--compare { text-decoration: line-through; color: var(--phb-muted); font-weight: 400; }
#phb-pr-{{ section.id }} .phb-prod__btn {
  display: inline-flex; align-items: center; justify-content: center;
  padding: 10px 14px; min-height: var(--phb-touch);
  border-radius: var(--nx-radius-sm); background: var(--phb-heading); color: var(--phb-card-bg);
  text-decoration: none; font-weight: 600; transition: var(--phb-transition);
}
#phb-pr-{{ section.id }} .phb-prod__btn:focus-visible { outline: 2px solid var(--phb-accent); outline-offset: 2px; }
@media (max-width: 1199px) {
  #phb-pr-{{ section.id }} .phb-products__grid {
    grid-template-columns: repeat({{ section.settings.columns_tablet }}, minmax(220px, 1fr));
  }
}
@media (max-width: 749px) {
  #phb-pr-{{ section.id }} .phb-products__grid { grid-template-columns: 1fr; }
}
@media (prefers-reduced-motion: reduce) {
  #phb-pr-{{ section.id }} *,
  #phb-pr-{{ section.id }} *::before,
  #phb-pr-{{ section.id }} *::after {
    animation-duration: 0.01ms !important;
    transition-duration: 0.01ms !important;
  }
}
{%- endstyle -%}

{% schema %}
{
  "name": "Products",
  "tag": "section",
  "class": "section-phenibut-products",
  "settings": [
    { "type": "text", "id": "anchor_id", "label": "Anchor ID", "default": "shop-phenibut" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Our Phenibut Products" },
    { "type": "richtext", "id": "intro", "label": "Intro", "default": "<p>Capsules, powders, and bundles—clearly dosed and shipped fast from Dubai.</p>" },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#FFFFFF" },
    { "type": "range", "id": "max_width", "label": "Max width (px)", "min": 720, "max": 1400, "step": 20, "default": 1200 },
    { "type": "range", "id": "padding_y", "label": "Vertical padding (px)", "min": 40, "max": 160, "step": 4, "default": 64 },
    { "type": "range", "id": "columns_desktop", "label": "Columns desktop", "min": 2, "max": 4, "step": 1, "default": 3 },
    { "type": "range", "id": "columns_tablet", "label": "Columns tablet", "min": 1, "max": 3, "step": 1, "default": 2 }
  ],
  "blocks": [
    { "type": "product_card", "name": "Product", "settings": [
      { "type": "product", "id": "product", "label": "Product" },
      { "type": "text", "id": "cta_label", "label": "CTA label", "default": "View product" }
    ] }
  ],
  "max_blocks": 6,
  "presets": [ { "name": "Products" } ]
}
{% endschema %}
