{% comment %}
  Products — XO theme design system
  - srcset, ItemList JSON-LD, focus-visible, reduced-motion
{% endcomment %}

{%- comment -%} ── JSON-LD: ItemList (products) ── {%- endcomment -%}
{% assign product_blocks = section.blocks | where: "type", "product_card" %}
{% if product_blocks.size > 0 %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": {{ section.settings.heading | json }},
  "numberOfItems": {{ product_blocks.size }},
  "itemListElement": [
    {%- for block in product_blocks -%}
      {%- assign prod = all_products[block.settings.product] -%}
      {%- if prod -%}
        {
          "@type": "ListItem",
          "position": {{ forloop.index }},
          "url": "{{ shop.url }}{{ prod.url }}",
          "name": {{ prod.title | json }}{% if prod.featured_image %},
          "image": "{{ prod.featured_image | image_url: width: 600 }}"{% endif %}
        }{%- unless forloop.last -%},{%- endunless -%}
      {%- endif -%}
    {%- endfor -%}
  ]
}
</script>
{% endif %}

{%- style -%}
  .xo-section--{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .xo-section--{{ section.id }} .phb-products__title {
    font-size: clamp(22px, 4.2vw, 36px);
    line-height: 1.2;
    color: rgba(var(--color-foreground));
    margin: 0 0 8px;
    font-weight: 600;
  }

  .xo-section--{{ section.id }} .phb-products__intro {
    color: rgba(var(--color-foreground));
    margin-bottom: 16px;
  }

  .xo-section--{{ section.id }} .phb-products__grid {
    display: grid;
    gap: var(--grid-desktop-horizontal-spacing, 24px);
    grid-template-columns: repeat({{ section.settings.columns_desktop }}, minmax(220px, 1fr));
  }

  .xo-section--{{ section.id }} .phb-prod {
    display: grid;
    gap: 10px;
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 10%, transparent);
    border-radius: var(--general-radius-1, 1rem);
    padding: 12px;
    background: rgba(var(--color-background));
  }

  .xo-section--{{ section.id }} .phb-prod__img {
    width: 100%;
    height: auto;
    border-radius: var(--general-radius-small, 1rem);
    object-fit: cover;
  }

  .xo-section--{{ section.id }} .phb-prod__title {
    font-size: 16px;
    margin: 4px 0 0;
    font-weight: 600;
  }

  .xo-section--{{ section.id }} .phb-prod__title a {
    color: rgba(var(--color-foreground));
    text-decoration: none;
  }

  .xo-section--{{ section.id }} .phb-prod__title a:focus-visible {
    outline: 2px solid rgba(var(--color-accent));
    outline-offset: 2px;
  }

  .xo-section--{{ section.id }} .phb-prod__price {
    font-weight: 600;
    display: flex;
    gap: 8px;
    align-items: center;
    color: rgba(var(--color-foreground));
  }

  .xo-section--{{ section.id }} .phb-prod__price--sale {
    color: rgba(var(--color-error));
  }

  .xo-section--{{ section.id }} .phb-prod__price--compare {
    text-decoration: line-through;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 60%, transparent);
    font-weight: 400;
  }

  .xo-section--{{ section.id }} .phb-prod__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 10px 14px;
    min-height: 44px;
    border-radius: var(--button-radius, 10rem);
    background: rgba(var(--color-foreground));
    color: rgba(var(--color-background));
    text-decoration: none;
    font-weight: 600;
    transition: opacity 0.3s var(--out-soft, ease);
  }

  .xo-section--{{ section.id }} .phb-prod__btn:hover {
    opacity: 0.85;
  }

  .xo-section--{{ section.id }} .phb-prod__btn:focus-visible {
    outline: 2px solid rgba(var(--color-accent));
    outline-offset: 2px;
  }

  @media (max-width: 992px) {
    .xo-section--{{ section.id }} .phb-products__grid {
      grid-template-columns: repeat({{ section.settings.columns_tablet }}, minmax(220px, 1fr));
    }
  }

  @media (max-width: 768px) {
    .xo-section--{{ section.id }} .phb-products__grid {
      grid-template-columns: 1fr;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .xo-section--{{ section.id }} *,
    .xo-section--{{ section.id }} *::before,
    .xo-section--{{ section.id }} *::after {
      animation-duration: 0.01ms !important;
      transition-duration: 0.01ms !important;
    }
  }
{%- endstyle -%}

<section {% render 'section-attr' %} aria-labelledby="phb-products-title-{{ section.id }}">
  <xo-container>
    <h2 id="phb-products-title-{{ section.id }}" class="phb-products__title">{{ section.settings.heading | escape }}</h2>
    {% if section.settings.intro != blank %}
      <div class="phb-products__intro">{{ section.settings.intro }}</div>
    {% endif %}

    <div class="phb-products__grid">
      {% for block in section.blocks %}
        {% if block.type == 'product_card' and block.settings.product != blank %}
          {% assign prod = all_products[block.settings.product] %}
          {% if prod %}
            <article class="phb-prod" {{ block.shopify_attributes }}>
              <a class="phb-prod__imglink" href="{{ prod.url }}">
                {% if prod.featured_image %}
                  <img
                    src="{{ prod.featured_image | image_url: width: 600 }}"
                    srcset="{{ prod.featured_image | image_url: width: 300 }} 300w, {{ prod.featured_image | image_url: width: 600 }} 600w, {{ prod.featured_image | image_url: width: 900 }} 900w"
                    sizes="(max-width: 768px) 100vw, (max-width: 992px) 50vw, 33vw"
                    alt="{{ prod.title | escape }}"
                    width="600"
                    height="{{ 600 | divided_by: prod.featured_image.aspect_ratio | round }}"
                    loading="lazy" decoding="async"
                    class="phb-prod__img"
                  >
                {% endif %}
              </a>
              <h3 class="phb-prod__title"><a href="{{ prod.url }}">{{ prod.title }}</a></h3>
              <div class="phb-prod__price">
                {% if prod.compare_at_price_max > prod.price %}
                  <span class="phb-prod__price--sale">{{ prod.price | money }}</span>
                  <span class="phb-prod__price--compare">{{ prod.compare_at_price_max | money }}</span>
                {% else %}
                  <span>{{ prod.price | money }}</span>
                {% endif %}
              </div>
              <div class="phb-prod__cta">
                <a class="phb-prod__btn" href="{{ prod.url }}">{{ block.settings.cta_label | escape }}</a>
              </div>
            </article>
          {% endif %}
        {% endif %}
      {% endfor %}
    </div>
  </xo-container>
</section>

{% schema %}
{
  "name": "Products",
  "tag": "section",
  "class": "section-phenibut-products",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "default" },
    { "type": "text", "id": "anchor_id", "label": "Anchor ID", "default": "shop-phenibut" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Our Phenibut Products" },
    { "type": "richtext", "id": "intro", "label": "Intro", "default": "<p>Capsules, powders, and bundles—clearly dosed and shipped fast from Dubai.</p>" },
    { "type": "range", "id": "columns_desktop", "label": "Columns desktop", "min": 2, "max": 4, "step": 1, "default": 3 },
    { "type": "range", "id": "columns_tablet", "label": "Columns tablet", "min": 1, "max": 3, "step": 1, "default": 2 },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding top", "default": 40 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding bottom", "default": 40 }
  ],
  "blocks": [
    { "type": "product_card", "name": "Product", "settings": [
      { "type": "product", "id": "product", "label": "Product" },
      { "type": "text", "id": "cta_label", "label": "CTA label", "default": "View product" }
    ] },
    { "type": "@app" }
  ],
  "max_blocks": 6,
  "presets": [ { "name": "Products" } ]
}
{% endschema %}
