{% schema %}
{
  "name": "Prep Kit (Premium)",
  "tag": "section",
  "class": "section-peptide-kit",
  "settings": [
    {
      "type": "header",
      "content": "Theme Colors"
    },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#fafafb" },
    { "type": "color", "id": "card_bg", "label": "Card Background", "default": "rgba(255, 255, 255, 0.7)" },
    { "type": "color", "id": "text_color", "label": "Main Text", "default": "#0f172a" },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max Width (px)",
      "min": 800,
      "max": 1400,
      "step": 10,
      "default": 1050
    },
    {
      "type": "range",
      "id": "padding_y",
      "label": "Vertical Padding (px)",
      "min": 20,
      "max": 160,
      "step": 4,
      "default": 80
    }
  ],
  "presets": [{"name": "Prep Kit (Premium)"}]
}
{% endschema %}

{%- assign s = section.settings -%}
{%- assign sid = section.id -%}

<div class="pk-wrapper" id="pk-{{ sid }}">
  <div class="pk-ambient-grid"></div>

  <div class="pk-container">

    <header class="pk-header">
      <div class="pk-badge">Requirements</div>
      <h2 class="pk-title">Gather Your Supplies</h2>
      <p class="pk-subtitle">To start the step-by-step peptide reconstitution process below, you will first double check that you have the following 5 items ready:</p>
    </header>

    <div class="pk-grid">

      <div class="pk-card">
        <div class="pk-icon-wrap">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M10 2v3"/><path d="M14 2v3"/><path d="M8 5h8v3H8z"/><path d="M7 8v12a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V8"/><line x1="10" y1="14" x2="14" y2="14"/><line x1="10" y1="18" x2="14" y2="18"/>
          </svg>
        </div>
        <h3>Peptide Vial</h3>
        <p>Your freeze-dried compound.</p>
      </div>

      <div class="pk-card">
        <div class="pk-icon-wrap">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/>
          </svg>
        </div>
        <h3>BAC Water</h3>
        <p>Contains a preservative—never use plain water!</p>
      </div>

      <div class="pk-card">
        <div class="pk-icon-wrap">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="9" y1="9" x2="15" y2="15"/><line x1="15" y1="9" x2="9" y2="15"/>
          </svg>
        </div>
        <h3>Alcohol Pads</h3>
        <p>Crucial for sanitizing your vials.</p>
      </div>

      <div class="pk-card">
        <div class="pk-icon-wrap pk-icon-rotate">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="10" width="14" height="4" rx="1"/><path d="M17 10v4"/><path d="M20 11v2"/><path d="M1 12h2"/><path d="M6 10v4"/><path d="M10 10v4"/><path d="M14 10v4"/>
          </svg>
        </div>
        <h3>Mixing Syringe</h3>
        <p>A larger syringe (3mL - 5mL) for moving water.</p>
      </div>

      <div class="pk-card">
        <div class="pk-icon-wrap pk-icon-rotate">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="11" width="18" height="2" rx="0.5"/><path d="M21 11v2"/><path d="M23 11.5v1"/><path d="M1 12h2"/><path d="M7 11v2"/><path d="M11 11v2"/><path d="M15 11v2"/>
          </svg>
        </div>
        <h3>Dosing Syringe</h3>
        <p>A small insulin syringe for your actual dose.</p>
      </div>

    </div>
  </div>
</div>

{%- style -%}
  #pk-{{ sid }} {
    --pk-bg: {{ s.bg_color }};
    --pk-card: {{ s.card_bg }};
    --pk-text: {{ s.text_color }};
    --pk-max: {{ s.max_width | default: 1050 }}px;
    --pk-py: {{ s.padding_y | default: 80 }}px;
    --pk-font: var(--font-body-family, sans-serif);
    --pk-shadow-sm: var(--shadow-sm, 0 2px 8px rgba(0,0,0,0.04));
    --pk-shadow-hover: var(--shadow-lg, 0 20px 46px rgba(0,0,0,0.10));
    --pk-radius: var(--nx-radius, 14px);
    --pk-transition: var(--transition-premium);
    content-visibility: auto;
  }

  .pk-wrapper {
    background-color: var(--pk-bg);
    color: var(--pk-text);
    padding: 20px 20px var(--pk-py);
    font-family: var(--pk-font);
    position: relative;
    overflow: hidden;
  }

  .pk-ambient-grid {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(rgba(15,23,42,0.04) 1px, transparent 1px);
    background-size: 24px 24px;
    mask-image: linear-gradient(to bottom, black 0%, transparent 100%);
    -webkit-mask-image: linear-gradient(to bottom, black 0%, transparent 100%);
    z-index: 0;
  }

  .pk-container {
    max-width: var(--pk-max);
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .pk-header {
    text-align: center;
    max-width: 600px;
    margin: 0 auto 50px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .pk-badge {
    font-size: 11px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--color-text-muted, #4b5563);
    background: var(--color-bg-secondary, #f9fafb);
    padding: 6px 14px;
    border-radius: var(--nx-radius-pill);
    margin-bottom: 16px;
    box-shadow: var(--pk-shadow-sm);
  }
  .pk-title {
    font-size: 32px;
    font-weight: 800;
    margin: 0 0 16px;
    letter-spacing: -0.5px;
  }
  .pk-subtitle {
    font-size: 16px;
    color: var(--color-text-muted, #4b5563);
    line-height: 1.6;
    margin: 0;
  }

  .pk-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 20px;
  }
  .pk-grid:hover .pk-card:not(:hover) { opacity: 0.6; }

  .pk-card {
    background: var(--pk-card);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-radius: var(--pk-radius);
    padding: 32px 20px;
    text-align: center;
    box-shadow: inset 0 1px 0 rgba(255,255,255,1), var(--pk-shadow-sm);
    transition: var(--pk-transition);
    position: relative;
  }

  .pk-card:hover {
    transform: translateY(-6px);
    box-shadow: inset 0 1px 0 rgba(255,255,255,1), var(--pk-shadow-hover);
    opacity: 1 !important;
  }

  .pk-icon-wrap {
    width: 56px;
    height: 56px;
    background: #ffffff;
    border-radius: var(--nx-radius);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--pk-text);
    margin: 0 auto 20px;
    box-shadow: var(--pk-shadow-sm), inset 0 2px 4px rgba(255,255,255,0.5);
    transition: var(--pk-transition);
  }
  .pk-icon-rotate { transform: rotate(-45deg); }

  .pk-card:hover .pk-icon-wrap {
    color: var(--color-accent-dark, #92400e);
    background: #fffbeb;
    transform: scale(1.05);
  }
  .pk-card:hover .pk-icon-rotate {
    transform: scale(1.05) rotate(-45deg);
  }

  .pk-card h3 {
    font-size: 16px;
    font-weight: 800;
    color: var(--pk-text);
    margin: 0 0 10px;
    letter-spacing: -0.3px;
  }

  .pk-card p {
    font-size: 13.5px;
    color: var(--color-text-muted, #4b5563);
    margin: 0;
    line-height: 1.5;
  }

  .pk-wrapper :focus-visible { outline: 2px solid var(--color-accent-primary, #FBBF24); outline-offset: 2px; }

  @media (prefers-reduced-motion: reduce) {
    .pk-wrapper *, .pk-wrapper *::before, .pk-wrapper *::after { animation-duration: 0.01ms !important; transition-duration: 0.01ms !important; }
  }

  @media(max-width: 600px) {
    .pk-title { font-size: 30px; }
    .pk-grid { grid-template-columns: 1fr 1fr; }
    .pk-card { padding: 24px 16px; }
    .pk-card:last-child { grid-column: span 2; }
  }
{%- endstyle -%}
