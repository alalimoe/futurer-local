{{ 'product-bundle.css' | asset_url | stylesheet_tag }}
{{ 'bundle-box.css' | asset_url | stylesheet_tag }}
{{ 'bundle-modal.css' | asset_url | stylesheet_tag }}
{{ 'bundle-empty.css' | asset_url | stylesheet_tag }}

{% liquid
  assign empty_text = section.settings.empty_text
  assign blocks = section.blocks
  assign discount_blocks = blocks | where: 'type', 'discount'
  assign collection = section.settings.collection
  assign product_list = section.settings.product_list
  assign heading = section.settings.text_heading
%}

<section {% render 'section-attr', style: 'z-index: 11;' %}>
  <div class="xo-bundle-product">
    <xo-container class="xo-bundle-product__container">
      <div class="xo-bundle-product__content">
        {% render 'product-bundle',
          empty_text: empty_text,
          blocks: blocks,
          discount_blocks: discount_blocks,
          product_list: product_list,
          collection: collection,
          heading: heading
        %}
      </div>
    </xo-container>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.bundle_products.name",
  "disabled_on": {
    "groups": [
      "header",
      "footer",
      "custom.overlay",
      "custom.popups",
      "custom.features"
    ]
  },
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "t:sections.bundle_products.settings.collection"
    },
    {
      "type": "product_list",
      "id": "product_list",
      "label": "t:sections.bundle_products.settings.product_list",
      "limit": 20
    },
    {
      "type": "richtext",
      "id": "empty_text",
      "label": "t:sections.bundle_products.settings.empty_text",
      "default": "<p>Limited time: Buy more save more!</p>"
    },
    {
      "type": "header",
      "content": "Text"
    },
    {
      "type": "select",
      "id": "text_tag_name",
      "label": "Tag name",
      "options": [
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        },
        {
          "value": "h4",
          "label": "H4"
        },
        {
          "value": "h5",
          "label": "H5"
        },
        {
          "value": "h6",
          "label": "H6"
        }
      ],
      "default": "h2"
    },
    {
      "type": "textarea",
      "id": "text_heading",
      "label": "Text",
      "default": "Product bundle"
    },
    {
      "type": "select",
      "id": "font_size_heading",
      "label": "Font size heading",
      "default": "h5",
      "options": [
        {
          "value": "h1",
          "label": "Extra extra large"
        },
        {
          "value": "h2",
          "label": "Extra large"
        },
        {
          "value": "h3",
          "label": "Large"
        },
        {
          "value": "h4",
          "label": "Medium"
        },
        {
          "value": "h5",
          "label": "Small"
        },
        {
          "value": "h6",
          "label": "Extra small"
        }
      ]
    },
    {
      "type": "range",
      "id": "text_line_height",
      "label": "Line height",
      "min": 0,
      "max": 3,
      "step": 0.1,
      "default": 1.2
    },
    {
      "type": "select",
      "id": "text_effect",
      "label": "Effect",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "reveal",
          "label": "Blur"
        },
        {
          "value": "split",
          "label": "Split"
        }
      ],
      "default": "split"
    },
    {
      "type": "number",
      "id": "text_duration",
      "label": "Duration (milliseconds)",
      "default": 1000
    },
    {
      "type": "range",
      "id": "text_heading_width_desktop",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "Desktop heading width",
      "default": 100
    },
    {
      "type": "range",
      "id": "text_heading_width_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "Mobile heading width",
      "default": 100
    },
    {
      "type": "header",
      "content": "Product card"
    },
    {
      "type": "select",
      "id": "product_card_aspect_ratio",
      "label": "Aspect ratio",
      "options": [
        {
          "value": "auto",
          "label": "Adapt to image"
        },
        {
          "value": "2/3",
          "label": "2:3"
        },
        {
          "value": "3/4",
          "label": "3:4"
        },
        {
          "value": "3/2",
          "label": "3:2"
        },
        {
          "value": "1",
          "label": "1:1"
        },
        {
          "value": "4/3",
          "label": "4:3"
        },
        {
          "value": "16/9",
          "label": "16:9"
        },
        {
          "value": "21/9",
          "label": "21:9"
        }
      ],
      "default": "1"
    },
    {
      "type": "color_scheme",
      "id": "card_color_scheme",
      "label": "Color scheme"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Section color scheme"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color"
    },
    {
      "type": "color_background",
      "id": "background_gradient",
      "label": "Background gradient"
    },
    {
      "type": "number",
      "id": "padding_top_desktop",
      "label": "Padding top desktop",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_bottom_desktop",
      "label": "Padding bottom desktop",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_top_mobile",
      "label": "Padding top mobile",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom mobile",
      "default": 50
    }
  ],
  "blocks": [
    {
      "name": "t:sections.bundle_products.blocks.discount.name",
      "type": "discount",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "t:sections.bundle_products.blocks.discount.label.label",
          "default": "Add 3+ items to save 10%"
        },
        {
          "type": "select",
          "id": "discount_type",
          "label": "t:sections.bundle_products.blocks.discount.discount_type.label",
          "options": [
            {
              "value": "fixed-amount",
              "label": "t:sections.bundle_products.blocks.discount.discount_type.options.fixed"
            },
            {
              "value": "percentage",
              "label": "t:sections.bundle_products.blocks.discount.discount_type.options.percent"
            }
          ],
          "default": "percentage"
        },
        {
          "type": "number",
          "id": "min_quantity",
          "label": "t:sections.bundle_products.blocks.discount.min_quantity.label",
          "default": 3
        },
        {
          "type": "number",
          "id": "value_discount",
          "label": "t:sections.bundle_products.blocks.discount.value_discount.label",
          "default": 10
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.bundle_products.presets.name",
      "settings": {
        "product_list": [],
        "text_tag_name": "h2",
        "text_heading": "Product bundle",
        "font_size_heading": "h5",
        "text_duration": 1000,
        "text_effect": "split",
        "text_heading_width_desktop": 100,
        "text_heading_width_mobile": 100,
        "product_card_aspect_ratio": "1",
        "card_color_scheme": "inverse",
        "color_scheme": "",
        "background_color": "",
        "background_gradient": "",
        "padding_top_desktop": 50,
        "padding_bottom_desktop": 50,
        "padding_top_mobile": 50,
        "padding_bottom_mobile": 50
      },
      "blocks": [
        {
          "type": "discount",
          "settings": {
            "discount_type": "percentage",
            "min_quantity": 3,
            "value_discount": 10
          }
        }
      ]
    }
  ]
}
{% endschema %}