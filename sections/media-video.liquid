{{ 'section-media-video.css' | asset_url | stylesheet_tag }}

<section {% render 'section-attr' %}>
  <div class="media-video">
    {% if section.settings.layout == 'page-width' %}
      <xo-container class="media-video__container"> <xo-grid>
    {% endif %}
    <div style="--sm: 12; --md: 12; --lg: 10; --start-lg: 2; --xxl: 8; --start-xxl: 3">
      {% render 'video',
        video: section.settings.video,
        video_url: section.settings.video_url,
        enable_video_looping: section.settings.enable_video_looping,
        cover_image: section.settings.cover_image,
        video_alt_text: section.settings.video_alt_text
      %}
    </div>
    {% if section.settings.layout == 'page-width' %}
      </xo-grid>
      </xo-container>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "t:sections.media_video.name",
  "disabled_on": {
    "groups": [
      "header",
      "footer",
      "custom.overlay",
      "custom.popups",
      "custom.features"
    ]
  },
  "settings": [
    {
      "type": "select",
      "id": "layout",
      "label": "t:sections.media_video.settings.layout.label",
      "options": [
        {
          "value": "full-width",
          "label": "t:sections.media_video.settings.layout.option__1.label"
        },
        {
          "value": "page-width",
          "label": "t:sections.media_video.settings.layout.option__2.label"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "checkbox",
      "id": "enable_video_looping",
      "label": "t:sections.media_video.settings.enable_video_looping.label",
      "default": false
    },
    {
      "type": "header",
      "content": "t:sections.media_video.settings.header_1.content"
    },
    {
      "type": "video",
      "id": "video",
      "label": "t:sections.media_video.settings.video.label"
    },
    {
      "type": "header",
      "content": "t:sections.media_video.settings.header_2.content"
    },
    {
      "type": "paragraph",
      "content": "t:sections.media_video.settings.paragraph.content"
    },
    {
      "type": "video_url",
      "id": "video_url",
      "accept": [
        "youtube",
        "vimeo"
      ],
      "label": "t:sections.media_video.settings.video_url.label",
      "default": "https://www.youtube.com/watch?v=_9VUPq3SxOc"
    },
    {
      "type": "image_picker",
      "id": "cover_image",
      "label": "t:sections.media_video.settings.cover_image.label"
    },
    {
      "type": "text",
      "id": "video_alt_text",
      "label": "t:sections.media_video.settings.video_alt_text.label",
      "info": "t:sections.media_video.settings.video_alt_text.info"
    },
    {
      "type": "header",
      "content": "General settings"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Section color scheme"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color"
    },
    {
      "type": "color_background",
      "id": "background_gradient",
      "label": "Background gradient"
    },
    {
      "type": "number",
      "id": "padding_top_desktop",
      "label": "Padding top desktop",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_bottom_desktop",
      "label": "Padding bottom desktop",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_top_mobile",
      "label": "Padding top mobile",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom mobile",
      "default": 50
    }
  ],
  "blocks": [],
  "presets": [
    {
      "name": "t:sections.media_video.presets.name",
      "settings": {
        "video_url": "",
        "video_alt_text": "",
        "color_scheme": "",
        "background_color": "",
        "background_gradient": "",
        "padding_top_desktop": 0,
        "padding_bottom_desktop": 0,
        "padding_top_mobile": 0,
        "padding_bottom_mobile": 0
      },
      "blocks": []
    }
  ]
}
{% endschema %}