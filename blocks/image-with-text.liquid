{{ 'video-button.css' | asset_url | stylesheet_tag }}

{% liquid
  assign layout = block.settings.layout
  assign image_dt = block.settings.image_dt
  assign aspect_ratio_dt = block.settings.aspect_ratio_dt
  if aspect_ratio_dt == 'custom'
    assign aspect_ratio_dt = block.settings.aspect_ratio_dt_width | append: '/' | append: block.settings.aspect_ratio_dt_height
  endif
  assign image_mb = block.settings.image_mb
  assign aspect_ratio_mb = block.settings.aspect_ratio_mb
  if aspect_ratio_mb == 'custom'
    assign aspect_ratio_mb = block.settings.aspect_ratio_mb_width | append: '/' | append: block.settings.aspect_ratio_mb_height
  endif
  assign color_scheme_collection = block.settings.color_scheme_collection
  assign background_overlay = block.settings.background_overlay
  assign heading = block.settings.text_heading
  assign placement = block.settings.placement
  assign alignment = block.settings.alignment
  assign space_between = block.settings.space_between
  assign button = block.settings
  assign video = block.settings.video
  assign video_url = block.settings.video_url
  assign enable_video_looping = block.settings.enable_video_looping
  assign cover_image = block.settings.cover_image
  assign border_radius = block.settings.border_radius

  assign video_enable = false
  if layout == 'video'
    assign video_enable = true
  endif
%}

{% render 'image-with-text-block',
  layout: layout,
  video_enable: video_enable,
  image_dt: image_dt,
  aspect_ratio_dt: aspect_ratio_dt,
  image_mb: image_mb,
  aspect_ratio_mb: aspect_ratio_mb,
  color_scheme: color_scheme_collection,
  heading: heading,
  placement: placement,
  alignment: alignment,
  space_between: space_between,
  button: button,
  background_overlay: background_overlay,
  video: video,
  video_url: video_url,
  enable_video_looping: enable_video_looping,
  cover_image: cover_image,
  border_radius: border_radius
%}


