{% liquid
  assign enabled_parallax = block.settings.enabled_parallax
  assign image_desktop = block.settings.image_desktop
  assign aspect_ratio_desktop = block.settings.aspect_ratio_desktop
  if aspect_ratio_desktop == 'custom'
    assign aspect_ratio_desktop = block.settings.aspect_ratio_desktop_width | append: '/' | append: block.settings.aspect_ratio_desktop_height
  endif
  assign image_mobile = block.settings.image_mobile
  assign aspect_ratio_mobile = block.settings.aspect_ratio_mobile
  if aspect_ratio_mobile == 'custom'
    assign aspect_ratio_mobile = block.settings.aspect_ratio_mobile_width | append: '/' | append: block.settings.aspect_ratio_mobile_height
  endif
  assign button = block.settings
%}

{% render 'image-button-block',
  enabled_parallax: enabled_parallax,
  image_desktop: image_desktop,
  media_aspect_ratio_desktop: aspect_ratio_desktop,
  image_mobile: image_mobile,
  media_aspect_ratio_mobile: aspect_ratio_mobile,
  button: button
%}


{% schema %}
{
  "name": "t:blocks.image_button.name",
  "settings": [
    {
      "type": "header",
      "content": "t:blocks.image_button.settings.header_1.content"
    },
    {
      "type": "image_picker",
      "id": "image_desktop",
      "label": "t:blocks.image_button.settings.image.label"
    },
    {
      "type": "select",
      "id": "aspect_ratio_desktop",
      "label": "Aspect ratio",
      "default": "auto",
      "options": [
        {
          "value": "auto",
          "label": "Auto"
        },
        {
          "value": "2/3",
          "label": "2:3"
        },
        {
          "value": "3/4",
          "label": "3:4"
        },
        {
          "value": "3/2",
          "label": "3:2"
        },
        {
          "value": "1",
          "label": "1:1"
        },
        {
          "value": "4/3",
          "label": "4:3"
        },
        {
          "value": "16/9",
          "label": "16:9"
        },
        {
          "value": "21/9",
          "label": "21:9"
        }
      ]
    },
    {
      "type": "header",
      "content": "t:blocks.image_button.settings.header_2.content"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "t:blocks.image_button.settings.image.label"
    },
    {
      "type": "select",
      "id": "aspect_ratio_mobile",
      "label": "Aspect ratio",
      "default": "auto",
      "options": [
        {
          "value": "auto",
          "label": "Auto"
        },
        {
          "value": "2/3",
          "label": "2:3"
        },
        {
          "value": "3/4",
          "label": "3:4"
        },
        {
          "value": "3/2",
          "label": "3:2"
        },
        {
          "value": "1",
          "label": "1:1"
        },
        {
          "value": "4/3",
          "label": "4:3"
        },
        {
          "value": "16/9",
          "label": "16:9"
        },
        {
          "value": "21/9",
          "label": "21:9"
        }
      ]
    },
    {
      "type": "header",
      "content": "t:blocks.image_button.settings.header_button.content"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Button"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link",
      "default": "/collections/all"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "Button style",
      "options": [
        {
          "value": "primary",
          "label": "Primary"
        },
        {
          "value": "secondary",
          "label": "Secondary"
        },
        {
          "value": "link",
          "label": "Link"
        }
      ],
      "default": "primary"
    },
    {
      "type": "select",
      "id": "button_size",
      "label": "Button size",
      "options": [
        {
          "value": "xs",
          "label": "Extra small"
        },
        {
          "value": "sm",
          "label": "Small"
        },
        {
