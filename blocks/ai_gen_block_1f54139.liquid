{% doc %}
  @prompt
    Create a Quickstart Reference Stack section with 7 blocks, each block has Custom heading text
    
    Anchor ID (for jump links)
    
    A dropdown to choose content source from these keys: tldr, what_it_is, feel_timeline, feel_note, how_it_works, how_to_use, why, safety, faq, custom
    
    Layout style setting: card, accordion, plain
    
    Pull content from product metafields in namespace npx using this mapping:
    
    tldr = npx.tl_dr fallback to npx.tldr (may be JSON list; parse and render as <ul>)
    
    what_it_is = npx.what_it_is
    
    feel_timeline = npx.feel_timeline (list with label/description)
    
    feel_note = npx.feel_note
    
    how_it_works = npx.how_it_works (render with metafield_tag if rich text)
    
    how_to_use = npx.how_to_use (list with label/text)
    
    why = npx.why (list)
    
    safety = npx.safety_important, npx.safety_general, npx.disclaimer combined in a styled callout
    
    faq = npx.faq (list of Q/A)
    
    If any metafield contains legacy JSON string, parse and render readable lists instead of raw JSON.
    
    Add editor controls: max width, spacing, colors, typography, accent color for active states.
    
    Desktop UX: optional 2-column layout with sticky left nav (scroll spy highlighting active section). Mobile UX: collapsible accordion option.
    
    No external libraries; keep JS minimal and accessible. Use section.id to namespace CSS.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{%- style -%}
  .ai-quickstart-stack-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding: {{ block.settings.spacing_vertical }}px {{ block.settings.spacing_horizontal }}px;
    background-color: rgba(var(--color-background));
  }

  .ai-quickstart-stack__heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_font_size }}px;
    color: rgba(var(--color-foreground));
    margin: 0 0 16px 0;
    font-weight: 600;
  }

  .ai-quickstart-stack__body-{{ ai_gen_id }} {
    color: color-mix(in srgb, rgba(var(--color-foreground)) 75%, transparent);
    font-size: {{ block.settings.body_font_size }}px;
    line-height: 1.6;
  }

  .ai-quickstart-stack__body-{{ ai_gen_id }} ul {
    margin: 0;
    padding-left: 20px;
  }

  .ai-quickstart-stack__body-{{ ai_gen_id }} li {
    margin-bottom: 8px;
  }

  .ai-quickstart-stack__body-{{ ai_gen_id }} p {
    margin: 0 0 12px 0;
  }

  .ai-quickstart-stack__body-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  .ai-quickstart-stack__timeline-item-{{ ai_gen_id }} {
    margin-bottom: 16px;
    padding-left: 20px;
    border-left: 2px solid rgba(var(--color-accent));
  }

  .ai-quickstart-stack__timeline-label-{{ ai_gen_id }} {
    font-weight: 600;
    color: rgba(var(--color-foreground));
    margin-bottom: 4px;
  }

  .ai-quickstart-stack__timeline-desc-{{ ai_gen_id }} {
    color: color-mix(in srgb, rgba(var(--color-foreground)) 75%, transparent);
  }

  .ai-quickstart-stack__faq-item-{{ ai_gen_id }} {
    margin-bottom: 16px;
  }

  .ai-quickstart-stack__faq-q-{{ ai_gen_id }} {
    font-weight: 600;
    color: rgba(var(--color-foreground));
    margin-bottom: 8px;
  }

  .ai-quickstart-stack__faq-a-{{ ai_gen_id }} {
    color: color-mix(in srgb, rgba(var(--color-foreground)) 75%, transparent);
  }

  .ai-quickstart-stack__safety-callout-{{ ai_gen_id }} {
    background-color: color-mix(in srgb, rgba(var(--color-accent)) 10%, rgba(var(--color-background)));
    border-left: 4px solid rgba(var(--color-accent));
    padding: 16px;
    border-radius: 4px;
    margin-bottom: 16px;
  }

  .ai-quickstart-stack__safety-title-{{ ai_gen_id }} {
    font-weight: 600;
    color: rgba(var(--color-foreground));
    margin-bottom: 8px;
  }

  .ai-quickstart-stack__card-{{ ai_gen_id }} {
    background-color: rgba(var(--color-background-2));
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 12%, transparent);
    border-radius: 1rem;
    padding: 24px;
  }

  .ai-quickstart-stack__accordion-{{ ai_gen_id }} {
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 12%, transparent);
    border-radius: 1rem;
    overflow: hidden;
  }

  .ai-quickstart-stack__accordion-header-{{ ai_gen_id }} {
    width: 100%;
    padding: 16px 20px;
    background-color: rgba(var(--color-background-2));
    border: none;
    text-align: left;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: {{ block.settings.heading_font_size }}px;
    font-weight: 600;
    color: rgba(var(--color-foreground));
    transition: background-color 0.2s var(--out-soft, ease);
  }

  .ai-quickstart-stack__accordion-header-{{ ai_gen_id }}:hover {
    background-color: color-mix(in srgb, rgba(var(--color-foreground)) 6%, rgba(var(--color-background)));
  }

  .ai-quickstart-stack__accordion-icon-{{ ai_gen_id }} {
    transition: transform 0.3s var(--out-soft, ease);
    flex-shrink: 0;
    margin-left: 12px;
  }

  .ai-quickstart-stack__accordion-header-{{ ai_gen_id }}.active .ai-quickstart-stack__accordion-icon-{{ ai_gen_id }} {
    transform: rotate(180deg);
  }

  .ai-quickstart-stack__accordion-content-{{ ai_gen_id }} {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s var(--out-soft, ease);
  }

  .ai-quickstart-stack__accordion-content-{{ ai_gen_id }}.active {
    max-height: 2000px;
  }

  .ai-quickstart-stack__accordion-body-{{ ai_gen_id }} {
    padding: 20px;
    border-top: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 12%, transparent);
  }

  @media screen and (max-width: 768px) {
    .ai-quickstart-stack-{{ ai_gen_id }} {
      padding: {{ block.settings.spacing_vertical | times: 0.6 }}px {{ block.settings.spacing_horizontal | times: 0.6 }}px;
    }

    .ai-quickstart-stack__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_font_size | times: 0.9 }}px;
    }

    .ai-quickstart-stack__body-{{ ai_gen_id }} {
      font-size: {{ block.settings.body_font_size | times: 0.9 }}px;
    }
  }
{%- endstyle -%}

<quickstart-stack-{{ ai_gen_id }} class="ai-quickstart-stack-{{ ai_gen_id }} color-{{ block.settings.color_scheme }}" {{ block.shopify_attributes }}>
  {% liquid
    assign content_source = block.settings.content_source
    assign layout_style = block.settings.layout_style
    assign content_html = ''

    if content_source == 'tldr'
      assign tl_dr_meta = product.metafields.npx.tl_dr
      if tl_dr_meta == blank
        assign tl_dr_meta = product.metafields.npx.tldr
      endif
      if tl_dr_meta != blank
        assign has_list_items = false
        capture list_output
          for item in tl_dr_meta.value
            echo '<li>'
            echo item
            echo '</li>'
            unless forloop.first
            endunless
            assign has_list_items = true
          endfor
        endcapture
        if has_list_items
          assign content_html = '<ul>' | append: list_output | append: '</ul>'
        else
          assign content_html = tl_dr_meta | metafield_tag
        endif
      endif

    elsif content_source == 'what_it_is'
      assign what_meta = product.metafields.npx.what_it_is
      if what_meta != blank
        if what_meta.type == 'rich_text_field'
          assign content_html = what_meta | metafield_tag
        else
          assign content_html = what_meta
        endif
      endif

    elsif content_source == 'feel_timeline'
      assign feel_meta = product.metafields.npx.feel_timeline
      if feel_meta != blank
        assign has_timeline = false
        capture timeline_output
          for item in feel_meta.value
            echo '<div class="ai-quickstart-stack__timeline-item-'
            echo ai_gen_id
            echo '"><div class="ai-quickstart-stack__timeline-label-'
            echo ai_gen_id
            echo '">'
            echo item.label
            echo '</div><div class="ai-quickstart-stack__timeline-desc-'
            echo ai_gen_id
            echo '">'
            echo item.description
            echo '</div></div>'
            assign has_timeline = true
          endfor
        endcapture
        if has_timeline
          assign content_html = timeline_output
        else
          if feel_meta.type == 'rich_text_field'
            assign content_html = feel_meta | metafield_tag
          else
            assign content_html = feel_meta
          endif
        endif
      endif

    elsif content_source == 'feel_note'
      assign feel_note_meta = product.metafields.npx.feel_note
      if feel_note_meta != blank
        if feel_note_meta.type == 'rich_text_field'
          assign content_html = feel_note_meta | metafield_tag
        else
          assign content_html = feel_note_meta
        endif
      endif

    elsif content_source == 'how_it_works'
      assign how_works_meta = product.metafields.npx.how_it_works
      if how_works_meta != blank
        if how_works_meta.type == 'rich_text_field'
          assign content_html = how_works_meta | metafield_tag
        else
          assign content_html = how_works_meta
        endif
      endif

    elsif content_source == 'how_to_use'
      assign how_to_meta = product.metafields.npx.how_to_use
      if how_to_meta != blank
        assign has_how_items = false
        capture how_output
          for item in how_to_meta.value
            if item.label != blank and item.text != blank
              echo '<li><strong>'
              echo item.label
              echo ':</strong> '
              echo item.text
              echo '</li>'
              assign has_how_items = true
            elsif item.text != blank
              echo '<li>'
              echo item.text
              echo '</li>'
              assign has_how_items = true
            elsif item != blank
              echo '<li>'
              echo item
              echo '</li>'
              assign has_how_items = true
            endif
          endfor
        endcapture
        if has_how_items
          assign content_html = '<ul>' | append: how_output | append: '</ul>'
        else
          if how_to_meta.type == 'rich_text_field'
            assign content_html = how_to_meta | metafield_tag
          else
            assign content_html = how_to_meta
          endif
        endif
      endif

    elsif content_source == 'why'
      assign why_meta = product.metafields.npx.why
      if why_meta != blank
        assign has_why_items = false
        capture why_output
          for item in why_meta.value
            echo '<li>'
            echo item
            echo '</li>'
            assign has_why_items = true
          endfor
        endcapture
        if has_why_items
          assign content_html = '<ul>' | append: why_output | append: '</ul>'
        else
          if why_meta.type == 'rich_text_field'
            assign content_html = why_meta | metafield_tag
          else
            assign content_html = why_meta
          endif
        endif
      endif

    elsif content_source == 'safety'
      assign safety_important = product.metafields.npx.safety_important
      assign safety_general = product.metafields.npx.safety_general
      assign disclaimer = product.metafields.npx.disclaimer
      assign content_html = ''

      if safety_important != blank
        assign content_html = content_html | append: '<div class="ai-quickstart-stack__safety-callout-' | append: ai_gen_id | append: '"><div class="ai-quickstart-stack__safety-title-' | append: ai_gen_id | append: '">Important Safety Information</div>' | append: safety_important | append: '</div>'
      endif

      if safety_general != blank
        assign content_html = content_html | append: '<div class="ai-quickstart-stack__safety-callout-' | append: ai_gen_id | append: '"><div class="ai-quickstart-stack__safety-title-' | append: ai_gen_id | append: '">General Safety</div>' | append: safety_general | append: '</div>'
      endif

      if disclaimer != blank
        assign content_html = content_html | append: '<div class="ai-quickstart-stack__safety-callout-' | append: ai_gen_id | append: '"><div class="ai-quickstart-stack__safety-title-' | append: ai_gen_id | append: '">Disclaimer</div>' | append: disclaimer | append: '</div>'
      endif

    elsif content_source == 'faq'
      assign faq_meta = product.metafields.npx.faq
      if faq_meta != blank
        assign has_faq_items = false
        capture faq_output
          for item in faq_meta.value
            if item.question != blank and item.answer != blank
              echo '<div class="ai-quickstart-stack__faq-item-'
              echo ai_gen_id
              echo '"><div class="ai-quickstart-stack__faq-q-'
              echo ai_gen_id
              echo '">Q: '
              echo item.question
              echo '</div><div class="ai-quickstart-stack__faq-a-'
              echo ai_gen_id
              echo '">A: '
              echo item.answer
              echo '</div></div>'
              assign has_faq_items = true
            elsif item.q != blank and item.a != blank
              echo '<div class="ai-quickstart-stack__faq-item-'
              echo ai_gen_id
              echo '"><div class="ai-quickstart-stack__faq-q-'
              echo ai_gen_id
              echo '">Q: '
              echo item.q
              echo '</div><div class="ai-quickstart-stack__faq-a-'
              echo ai_gen_id
              echo '">A: '
              echo item.a
              echo '</div></div>'
              assign has_faq_items = true
            endif
          endfor
        endcapture
        if has_faq_items
          assign content_html = faq_output
        else
          if faq_meta.type == 'rich_text_field'
            assign content_html = faq_meta | metafield_tag
          else
            assign content_html = faq_meta
          endif
        endif
      endif

    elsif content_source == 'custom'
      assign content_html = block.settings.custom_content
    endif
  %}

  {% if layout_style == 'card' %}
    <div class="ai-quickstart-stack__card-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h3 class="ai-quickstart-stack__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h3>
      {% endif %}
      <div class="ai-quickstart-stack__body-{{ ai_gen_id }}">
        {{ content_html }}
      </div>
    </div>

  {% elsif layout_style == 'accordion' %}
    <div class="ai-quickstart-stack__accordion-{{ ai_gen_id }}">
      <button
        class="ai-quickstart-stack__accordion-header-{{ ai_gen_id }}"
        aria-expanded="false"
        data-accordion-trigger
      >
        <span>{{ block.settings.heading }}</span>
        <svg
          class="ai-quickstart-stack__accordion-icon-{{ ai_gen_id }}"
          width="20"
          height="20"
          viewBox="0 0 20 20"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            d="M5 7.5L10 12.5L15 7.5"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
        </svg>
      </button>
      <div class="ai-quickstart-stack__accordion-content-{{ ai_gen_id }}" data-accordion-content>
        <div class="ai-quickstart-stack__accordion-body-{{ ai_gen_id }}">
          <div class="ai-quickstart-stack__body-{{ ai_gen_id }}">
            {{ content_html }}
          </div>
        </div>
      </div>
    </div>

  {% else %}
    {% if block.settings.heading != blank %}
      <h3 class="ai-quickstart-stack__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h3>
    {% endif %}
    <div class="ai-quickstart-stack__body-{{ ai_gen_id }}">
      {{ content_html }}
    </div>
  {% endif %}
</quickstart-stack-{{ ai_gen_id }}>

<script>
  (function() {
    class QuickstartStack{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.accordionTrigger = this.querySelector('[data-accordion-trigger]');
      }

      connectedCallback() {
        if (this.accordionTrigger) {
          this.setupAccordion();
        }
      }

      setupAccordion() {
        this.accordionTrigger.addEventListener('click', () => {
          const content = this.accordionTrigger.nextElementSibling;
          const isActive = this.accordionTrigger.classList.contains('active');

          this.accordionTrigger.classList.toggle('active');
          content.classList.toggle('active');
          this.accordionTrigger.setAttribute('aria-expanded', !isActive);
        });
      }
    }

    customElements.define('quickstart-stack-{{ ai_gen_id }}', QuickstartStack{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Quickstart block",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "default"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Section heading"
    },
    {
      "type": "text",
      "id": "anchor_id",
      "label": "Anchor ID",
      "info": "Used for jump links (e.g., tldr, what-it-is)"
    },
    {
      "type": "select",
      "id": "content_source",
      "label": "Content source",
      "options": [
        { "value": "tldr", "label": "TL;DR" },
        { "value": "what_it_is", "label": "What it is" },
        { "value": "feel_timeline", "label": "Feel timeline" },
        { "value": "feel_note", "label": "Feel note" },
        { "value": "how_it_works", "label": "How it works" },
        { "value": "how_to_use", "label": "How to use" },
        { "value": "why", "label": "Why" },
        { "value": "safety", "label": "Safety" },
        { "value": "faq", "label": "FAQ" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "tldr"
    },
    {
      "type": "select",
      "id": "layout_style",
      "label": "Layout style",
      "options": [
        { "value": "plain", "label": "Plain" },
        { "value": "card", "label": "Card" },
        { "value": "accordion", "label": "Accordion" }
      ],
      "default": "plain"
    },
    {
      "type": "richtext",
      "id": "custom_content",
      "label": "Custom content",
      "info": "Only used when content source is set to Custom"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Maximum width",
      "min": 800,
      "max": 1600,
      "step": 50,
      "unit": "px",
      "default": 1200
    },
    {
      "type": "range",
      "id": "spacing_vertical",
      "label": "Vertical spacing",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "spacing_horizontal",
      "label": "Horizontal spacing",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "label": "Heading size",
      "min": 16,
      "max": 36,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "body_font_size",
      "label": "Body size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 16
    }
  ],
  "presets": [
    {
      "name": "Quickstart block"
    }
  ]
}
{% endschema %}
