{% doc %}
  @prompt
    Create a modern and visually striking collection category section for displaying 5 prominent product collections with the following features:
    
    1. Contemporary grid layout that works beautifully on both desktop and mobile
    2. Each collection card should include:
       - Large, high-quality collection image with hover effects
       - Collection title overlay with elegant typography
       - Smooth transitions and animations on hover
       - Click-through to collection page
    3. Responsive design:
       - Desktop: Display all 5 collections in an asymmetric or masonry-style grid
       - Mobile: Stack vertically or 2-column grid without horizontal scrolling
    4. Modern design elements:
       - Subtle shadows or borders for depth
       - Gradient overlays on images for text readability
       - Clean spacing with proper padding that prevents mobile overflow
       - Hover states that lift or zoom images slightly
    5. Premium, minimal aesthetic suitable for health/lifestyle brand
    6. Customizable settings to select which 5 collections to display
    7. Optional: Product count or "Shop Now" CTA on each card
    8. Mobile-safe layout with no fixed widths that cause overflow
    
    The design should be conversion-focused, visually appealing, and maintain brand consistency with clean lines and modern interactions., add 1 more collection total of 6, change it so on desktop its a horizontal section and on mobile its grid of 2 columns, add a section headline "Categories", add padding controls to heading text
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-collection-grid-{{ ai_gen_id }} {
    width: 100%;
    max-width: 100%;
    padding: {{ block.settings.section_padding_top }}px {{ block.settings.section_padding_horizontal }}px {{ block.settings.section_padding_bottom }}px;
    box-sizing: border-box;
  }

  .ai-collection-grid__header-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.header_spacing }}px;
    text-align: {{ block.settings.header_alignment }};
    padding: {{ block.settings.heading_padding_top }}px {{ block.settings.heading_padding_horizontal }}px {{ block.settings.heading_padding_bottom }}px;
  }

  .ai-collection-grid__heading-{{ ai_gen_id }} {
    font-weight: {{ block.settings.heading_weight }};
    color: {{ block.settings.heading_color }};
    margin: 0;
    line-height: 1.2;
  }

  .ai-collection-grid__container-{{ ai_gen_id }} {
    display: grid;
    gap: {{ block.settings.grid_gap }}px;
    width: 100%;
    max-width: 100%;
  }

  @media screen and (min-width: 750px) {
    .ai-collection-grid__container-{{ ai_gen_id }} {
      grid-template-columns: repeat(6, 1fr);
      grid-auto-rows: 1fr;
    }

    .ai-collection-card-{{ ai_gen_id }} {
      grid-column: span 1;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-collection-grid__container-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }

  }

  .ai-collection-card-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.card_border_radius }}px;
    aspect-ratio: {{ block.settings.card_aspect_ratio }};
    cursor: pointer;
    box-shadow: {{ block.settings.card_shadow_horizontal }}px {{ block.settings.card_shadow_vertical }}px {{ block.settings.card_shadow_blur }}px rgba(0, 0, 0, {{ block.settings.card_shadow_opacity | divided_by: 100.0 }});
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-collection-card-{{ ai_gen_id }}:hover {
    {% if block.settings.hover_effect == 'lift' %}
      transform: translateY(-8px);
      box-shadow: {{ block.settings.card_shadow_horizontal }}px {{ block.settings.card_shadow_vertical | plus: 8 }}px {{ block.settings.card_shadow_blur | plus: 8 }}px rgba(0, 0, 0, {{ block.settings.card_shadow_opacity | divided_by: 100.0 | times: 1.5 }});
    {% endif %}
  }

  .ai-collection-card__link-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }

  .ai-collection-card__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .ai-collection-card__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  {% if block.settings.hover_effect == 'zoom' %}
    .ai-collection-card-{{ ai_gen_id }}:hover .ai-collection-card__image-{{ ai_gen_id }} {
      transform: scale(1.1);
    }
  {% endif %}

  .ai-collection-card__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: var(--color-surface-secondary);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-collection-card__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 200px;
    max-height: 200px;
    opacity: 0.3;
  }

  .ai-collection-card__overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      {{ block.settings.gradient_direction }},
      {{ block.settings.gradient_color_start }} {{ block.settings.gradient_start_position }}%,
      {{ block.settings.gradient_color_end }} {{ block.settings.gradient_end_position }}%
    );
    transition: opacity 0.3s ease;
  }

  .ai-collection-card__content-{{ ai_gen_id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    padding: {{ block.settings.content_padding }}px;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: 8px;
    box-sizing: border-box;
  }

  .ai-collection-card__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: {{ block.settings.title_weight }};
    color: {{ block.settings.title_color }};
    margin: 0;
    line-height: 1.2;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-collection-card__count-{{ ai_gen_id }} {
    font-size: {{ block.settings.count_size }}px;
    color: {{ block.settings.count_color }};
    margin: 0;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-collection-card__cta-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: {{ block.settings.cta_padding_vertical }}px {{ block.settings.cta_padding_horizontal }}px;
    background-color: {{ block.settings.cta_background }};
    color: {{ block.settings.cta_text_color }};
    border-radius: {{ block.settings.cta_border_radius }}px;
    font-size: {{ block.settings.cta_font_size }}px;
    font-weight: 600;
    text-decoration: none;
    transition: background-color 0.3s ease, transform 0.3s ease;
    {% if block.settings.text_alignment == 'center' %}
      align-self: center;
    {% elsif block.settings.text_alignment == 'right' %}
      align-self: flex-end;
    {% else %}
      align-self: flex-start;
    {% endif %}
  }

  .ai-collection-card__cta-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.cta_hover_background }};
    transform: translateX(4px);
  }

  .ai-collection-card__cta-arrow-{{ ai_gen_id }} {
    width: 16px;
    height: 16px;
    transition: transform 0.3s ease;
  }

  .ai-collection-card__cta-{{ ai_gen_id }}:hover .ai-collection-card__cta-arrow-{{ ai_gen_id }} {
    transform: translateX(4px);
  }

  .ai-collection-card__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    background-color: rgba(255, 255, 255, 0.9);
    border-radius: var(--nx-radius-sm);
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
    z-index: 3;
  }

  @media screen and (max-width: 749px) {
    .ai-collection-card__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.8 }}px;
    }

    .ai-collection-card__count-{{ ai_gen_id }} {
      font-size: {{ block.settings.count_size | times: 0.8 }}px;
    }

    .ai-collection-card__content-{{ ai_gen_id }} {
      padding: {{ block.settings.content_padding | times: 0.7 }}px;
    }
  }
{% endstyle %}

<collection-grid-{{ ai_gen_id }} class="ai-collection-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.show_heading %}
    <div class="ai-collection-grid__header-{{ ai_gen_id }}">
      <h2 class="ai-collection-grid__heading-{{ ai_gen_id }} {{ block.settings.heading_size }}">{{ block.settings.heading_text }}</h2>
    </div>
  {% endif %}

  <div class="ai-collection-grid__container-{{ ai_gen_id }}">
    {% for i in (1..6) %}
      {% liquid
        assign collection_key = 'collection_' | append: i
        assign collection = block.settings[collection_key]
      %}

      <div class="ai-collection-card-{{ ai_gen_id }}">
        {% if collection != blank %}
          <a href="{{ collection.url }}" class="ai-collection-card__link-{{ ai_gen_id }}">
            <div class="ai-collection-card__image-wrapper-{{ ai_gen_id }}">
              {% if collection.featured_image %}
                <img
                  src="{{ collection.featured_image | image_url: width: 1000 }}"
                  alt="{{ collection.featured_image.alt | default: collection.title | escape }}"
                  class="ai-collection-card__image-{{ ai_gen_id }}"
                  loading="lazy"
                  width="{{ collection.featured_image.width }}"
                  height="{{ collection.featured_image.height }}"
                >
              {% else %}
                <div class="ai-collection-card__placeholder-{{ ai_gen_id }}">
                  {{ 'collection-1' | placeholder_svg_tag }}
                </div>
              {% endif %}
              <div class="ai-collection-card__overlay-{{ ai_gen_id }}"></div>
            </div>

            <div class="ai-collection-card__content-{{ ai_gen_id }}">
              <h3 class="ai-collection-card__title-{{ ai_gen_id }}">{{ collection.title }}</h3>
              
              {% if block.settings.show_product_count %}
                <p class="ai-collection-card__count-{{ ai_gen_id }}">
                  {{ collection.products_count }}
                  {% if collection.products_count == 1 %}
                    product
                  {% else %}
                    products
                  {% endif %}
                </p>
              {% endif %}

              {% if block.settings.show_cta %}
                <span class="ai-collection-card__cta-{{ ai_gen_id }}">
                  {{ block.settings.cta_text }}
                  <svg class="ai-collection-card__cta-arrow-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                    <polyline points="12 5 19 12 12 19"></polyline>
                  </svg>
                </span>
              {% endif %}
            </div>
          </a>
        {% else %}
          <div class="ai-collection-card__placeholder-{{ ai_gen_id }}">
            {{ 'collection-1' | placeholder_svg_tag }}
          </div>
          <div class="ai-collection-card__empty-state-{{ ai_gen_id }}">
            Select collection {{ i }}
          </div>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</collection-grid-{{ ai_gen_id }}>

<script>
  (function() {
    class CollectionGrid{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.cards = this.querySelectorAll('.ai-collection-card-{{ ai_gen_id }}');
        this.setupAccessibility();
      }

      setupAccessibility() {
        this.cards.forEach((card) => {
          const link = card.querySelector('.ai-collection-card__link-{{ ai_gen_id }}');
          if (link) {
            link.setAttribute('aria-label', link.querySelector('.ai-collection-card__title-{{ ai_gen_id }}').textContent);
          }
        });
      }
    }

    customElements.define('collection-grid-{{ ai_gen_id }}', CollectionGrid{{ ai_gen_id }});
  })();
</script>

