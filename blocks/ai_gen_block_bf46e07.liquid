{% doc %}
  @name Breadcrumbs
  @desc Collection-based breadcrumbs: Home / Collection / Product. Supports product, collection, blog, article, page, search, cart, and account templates.
{% enddoc %}

{%- style -%}
  .xo-block--{{ block.id }} {
    padding: {{ block.settings.padding_top }}px 0 {{ block.settings.padding_bottom }}px;
  }

  .xo-block--{{ block.id }} .bc__list {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: {{ block.settings.spacing }}px;
    list-style: none;
    margin: 0;
    padding: 0;
    font-size: calc(var(--font-body-scale, 1) * 1.4rem);
    line-height: 1.3;
    justify-content: {{ block.settings.alignment }};
  }

  .xo-block--{{ block.id }} .bc__item {
    display: flex;
    align-items: center;
    gap: {{ block.settings.spacing }}px;
  }

  .xo-block--{{ block.id }} .bc__link {
    color: color-mix(in srgb, rgba(var(--color-foreground)) 55%, transparent);
    text-decoration: none;
    position: relative;
    transition: color 0.3s var(--out-soft, ease);
  }

  .xo-block--{{ block.id }} .bc__link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 1px;
    background: currentColor;
    transition: width 0.3s var(--out-soft, ease);
  }

  .xo-block--{{ block.id }} .bc__link:hover {
    color: rgba(var(--color-foreground));
  }

  .xo-block--{{ block.id }} .bc__link:hover::after {
    width: 100%;
  }

  .xo-block--{{ block.id }} .bc__link:focus-visible {
    outline: 2px solid rgba(var(--color-accent));
    outline-offset: 2px;
    border-radius: 4px;
  }

  .xo-block--{{ block.id }} .bc__current {
    color: rgba(var(--color-foreground));
    font-weight: 600;
  }

  .xo-block--{{ block.id }} .bc__sep {
    color: color-mix(in srgb, rgba(var(--color-foreground)) 30%, transparent);
    user-select: none;
  }

  @media (max-width: 768px) {
    .xo-block--{{ block.id }} {
      padding: {{ block.settings.padding_top | times: 0.7 }}px 0 {{ block.settings.padding_bottom | times: 0.7 }}px;
    }

    .xo-block--{{ block.id }} .bc__list {
      font-size: calc(var(--font-body-scale, 1) * 1.3rem);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .xo-block--{{ block.id }} .bc__link,
    .xo-block--{{ block.id }} .bc__link::after {
      transition: none;
    }
  }
{%- endstyle -%}

<nav class="xo-block--{{ block.id }}" aria-label="Breadcrumb" {{ block.shopify_attributes }}>
  <ol class="bc__list">
    <li class="bc__item">
      <a href="{{ routes.root_url }}" class="bc__link">
        {% if block.settings.show_home_icon %}
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M2 6L8 1L14 6V13C14 13.2652 13.8946 13.5196 13.7071 13.7071C13.5196 13.8946 13.2652 14 13 14H3C2.73478 14 2.48043 13.8946 2.29289 13.7071C2.10536 13.5196 2 13.2652 2 13V6Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M6 14V8H10V14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        {% else %}
          {{ block.settings.home_text }}
        {% endif %}
      </a>
      <span class="bc__sep" aria-hidden="true">{{ block.settings.separator }}</span>
    </li>

    {% if template.name == 'collection' and collection %}
      <li class="bc__item">
        <span class="bc__current" aria-current="page">{{ collection.title }}</span>
      </li>
    {% elsif template.name == 'product' and product %}
      {% if product.collections.size > 0 %}
        {% assign breadcrumb_collection = collection %}
        {% if breadcrumb_collection == blank %}
          {% assign breadcrumb_collection = product.collections.first %}
        {% endif %}
        <li class="bc__item">
          <a href="{{ breadcrumb_collection.url }}" class="bc__link">{{ breadcrumb_collection.title }}</a>
          <span class="bc__sep" aria-hidden="true">{{ block.settings.separator }}</span>
        </li>
      {% endif %}
      <li class="bc__item">
        <span class="bc__current" aria-current="page">{{ product.title }}</span>
      </li>
    {% elsif template.name == 'blog' and blog %}
      <li class="bc__item">
        <span class="bc__current" aria-current="page">{{ blog.title }}</span>
      </li>
    {% elsif template.name == 'article' and article %}
      <li class="bc__item">
        <a href="{{ blog.url }}" class="bc__link">{{ blog.title }}</a>
        <span class="bc__sep" aria-hidden="true">{{ block.settings.separator }}</span>
      </li>
      <li class="bc__item">
        <span class="bc__current" aria-current="page">{{ article.title }}</span>
      </li>
    {% elsif template.name == 'page' and page %}
      <li class="bc__item">
        <span class="bc__current" aria-current="page">{{ page.title }}</span>
      </li>
    {% elsif template.name == 'search' %}
      <li class="bc__item">
        <span class="bc__current" aria-current="page">Search results</span>
      </li>
    {% elsif template.name == 'cart' %}
      <li class="bc__item">
        <span class="bc__current" aria-current="page">Cart</span>
      </li>
    {% elsif template.name == 'account' %}
      <li class="bc__item">
        <span class="bc__current" aria-current="page">Account</span>
      </li>
    {% endif %}
  </ol>
</nav>

{% schema %}
{
  "name": "Breadcrumbs",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alignment",
      "options": [
        { "value": "flex-start", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "flex-end", "label": "Right" }
      ],
      "default": "flex-start"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 12
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 8
    },
    {
      "type": "header",
      "content": "Home link"
    },
    {
      "type": "checkbox",
      "id": "show_home_icon",
      "label": "Show home icon",
      "default": true
    },
    {
      "type": "text",
      "id": "home_text",
      "label": "Home text",
      "default": "Home"
    },
    {
      "type": "header",
      "content": "Separator"
    },
    {
      "type": "text",
      "id": "separator",
      "label": "Separator",
      "default": "/"
    },
    {
      "type": "range",
      "id": "spacing",
      "min": 4,
      "max": 20,
      "step": 2,
      "unit": "px",
      "label": "Spacing",
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "Breadcrumbs"
    }
  ]
}
{% endschema %}
