{% doc %}
  @prompt
    Quickstart Hero (new block)
    
    Content:
    
    Eyebrow: "Quickstart guide"
    
    H1: Dynamic product title
    
    Subtext: 1–2 lines: "Save this page for dosing, timing, and safety."
    
    Optional: product image (small), dosage form badge (Capsules / Powder)
    
    Controls to add (editor settings):
    
    Product selector (or page metafield fallback — see note below)
    
    Show/hide product image
    
    Show/hide "Back to product" button
    
    Optional "Copy link" / "Email me this guide" button (can just be a button link for now)
    
    UX notes:
    
    Keep it simple: centered max-width, premium whitespace, no clutter.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{%- style -%}
  .ai-quickstart-hero-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 60px var(--page-gutter);
    background-color: rgba(var(--color-background-2));
  }

  .ai-quickstart-hero__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    text-align: center;
  }

  .ai-quickstart-hero__eyebrow-{{ ai_gen_id }} {
    font-size: 14px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 40%, transparent);
    margin: 0 0 16px;
  }

  .ai-quickstart-hero__heading-{{ ai_gen_id }} {
    font-weight: 600;
    color: rgba(var(--color-foreground));
    margin: 0 0 20px;
    line-height: 1.2;
  }

  .ai-quickstart-hero__subtext-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtext_size }}px;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 75%, transparent);
    margin: 0 0 32px;
    line-height: 1.5;
  }

  .ai-quickstart-hero__product-info-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-bottom: 32px;
  }

  .ai-quickstart-hero__product-image-{{ ai_gen_id }} {
    width: 80px;
    height: 80px;
    border-radius: 1rem;
    overflow: hidden;
    flex-shrink: 0;
  }

  .ai-quickstart-hero__product-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-quickstart-hero__badge-{{ ai_gen_id }} {
    display: inline-block;
    padding: 6px 16px;
    background-color: rgba(var(--color-accent));
    color: rgba(var(--color-foreground));
    border-radius: 2rem;
    font-size: 13px;
    font-weight: 500;
  }

  .ai-quickstart-hero__buttons-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: center;
    align-items: center;
  }

  .ai-quickstart-hero__button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 12px 24px;
    background-color: rgba(var(--color-accent));
    color: rgba(var(--color-foreground));
    border: 1px solid rgba(var(--color-accent));
    border-radius: 6px;
    font-size: 15px;
    font-weight: 500;
    text-decoration: none;
    transition: 0.3s var(--out-soft, ease);
  }

  .ai-quickstart-hero__button-{{ ai_gen_id }}:hover {
    background-color: color-mix(in srgb, rgba(var(--color-accent)) 85%, transparent);
    color: rgba(var(--color-foreground));
  }

  .ai-quickstart-hero__button--secondary-{{ ai_gen_id }} {
    background-color: transparent;
    color: rgba(var(--color-foreground));
    border-color: color-mix(in srgb, rgba(var(--color-foreground)) 20%, transparent);
  }

  .ai-quickstart-hero__button--secondary-{{ ai_gen_id }}:hover {
    background-color: rgba(var(--color-background-2));
    color: rgba(var(--color-foreground));
  }

  @media screen and (max-width: 768px) {
    .ai-quickstart-hero-{{ ai_gen_id }} {
      padding: 40px var(--page-gutter);
    }

    .ai-quickstart-hero__product-info-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-quickstart-hero__buttons-{{ ai_gen_id }} {
      flex-direction: column;
      width: 100%;
    }

    .ai-quickstart-hero__button-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{%- endstyle -%}

<quickstart-hero-{{ ai_gen_id }}
  class="ai-quickstart-hero-{{ ai_gen_id }} color-{{ block.settings.color_scheme }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-quickstart-hero__container-{{ ai_gen_id }}">
    {% if block.settings.eyebrow != blank %}
      <div class="ai-quickstart-hero__eyebrow-{{ ai_gen_id }}">
        {{ block.settings.eyebrow }}
      </div>
    {% endif %}

    {% if block.settings.product != blank %}
      <h1 class="ai-quickstart-hero__heading-{{ ai_gen_id }} {{ block.settings.heading_size }}">
        {{ block.settings.product.title }}
      </h1>
    {% else %}
      <h1 class="ai-quickstart-hero__heading-{{ ai_gen_id }} {{ block.settings.heading_size }}">
        {{ block.settings.heading }}
      </h1>
    {% endif %}

    {% if block.settings.subtext != blank %}
      <div class="ai-quickstart-hero__subtext-{{ ai_gen_id }}">
        {{ block.settings.subtext }}
      </div>
    {% endif %}

    {% if block.settings.show_product_image or block.settings.dosage_form != blank %}
      <div class="ai-quickstart-hero__product-info-{{ ai_gen_id }}">
        {% if block.settings.show_product_image and block.settings.product != blank and block.settings.product.featured_image %}
          <div class="ai-quickstart-hero__product-image-{{ ai_gen_id }}">
            <img
              src="{{ block.settings.product.featured_image | image_url: width: 160 }}"
              alt="{{ block.settings.product.featured_image.alt | escape }}"
              loading="lazy"
              width="80"
              height="80"
            >
          </div>
        {% endif %}

        {% if block.settings.dosage_form != blank %}
          <div class="ai-quickstart-hero__badge-{{ ai_gen_id }}">
            {{ block.settings.dosage_form }}
          </div>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-quickstart-hero__buttons-{{ ai_gen_id }}">
      {% if block.settings.show_back_button and block.settings.product != blank %}
        <a
          href="{{ block.settings.product.url }}"
          class="ai-quickstart-hero__button-{{ ai_gen_id }} ai-quickstart-hero__button--secondary-{{ ai_gen_id }}"
        >
          {{ block.settings.back_button_text }}
        </a>
      {% endif %}

      {% if block.settings.show_action_button and block.settings.action_button_link != blank %}
        <a
          href="{{ block.settings.action_button_link }}"
          class="ai-quickstart-hero__button-{{ ai_gen_id }}"
        >
          {{ block.settings.action_button_text }}
        </a>
      {% endif %}
    </div>
  </div>
</quickstart-hero-{{ ai_gen_id }}>

{% schema %}
{
  "name": "Quickstart hero",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "default"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Quickstart guide"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Fallback heading",
      "default": "Product quickstart guide"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Save this page for dosing, timing, and safety information."
    },
    {
      "type": "text",
      "id": "dosage_form",
      "label": "Dosage form badge"
    },
    {
      "type": "header",
      "content": "Product display"
    },
    {
      "type": "checkbox",
      "id": "show_product_image",
      "label": "Show product image",
      "default": true
    },
    {
      "type": "header",
      "content": "Buttons"
    },
    {
      "type": "checkbox",
      "id": "show_back_button",
      "label": "Show back to product button",
      "default": true
    },
    {
      "type": "text",
      "id": "back_button_text",
      "label": "Back button text",
      "default": "Back to product"
    },
    {
      "type": "checkbox",
      "id": "show_action_button",
      "label": "Show action button",
      "default": true
    },
    {
      "type": "text",
      "id": "action_button_text",
      "label": "Action button text",
      "default": "Email me this guide"
    },
    {
      "type": "url",
      "id": "action_button_link",
      "label": "Action button link"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Maximum width",
      "min": 400,
      "max": 1000,
      "step": 50,
      "unit": "px",
      "default": 700
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        {"value": "h1", "label": "Display"},
        {"value": "h2", "label": "XL"},
        {"value": "h3", "label": "L"},
        {"value": "h4", "label": "M"},
        {"value": "h5", "label": "S"},
        {"value": "h6", "label": "XS"}
      ],
      "default": "h2"
    },
    {
      "type": "range",
      "id": "subtext_size",
      "label": "Subtext size",
      "min": 14,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 16
    }
  ],
  "presets": [
    {
      "name": "Quickstart hero"
    }
  ]
}
{% endschema %}
