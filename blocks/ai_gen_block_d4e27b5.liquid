{% doc %}
  @prompt
    Create a premium homepage hero section for a nootropics and peptides e-commerce store with the following elements:
    
    1. Main headline: "Premium Nootropics & Peptides for Peak Performance"
    2. Subheadline: "Research-backed cognitive enhancers and peptides, sustainably packaged and delivered with care"
    3. Trust badge row with three items: "Lab Tested • Eco-Friendly Packaging • Fast Shipping"
    4. Two prominent call-to-action buttons side by side:
       - "Shop Nootropics" button
       - "Shop Peptides" button
    5. Background image support with overlay for text readability
    6. Fully responsive design that works on mobile without horizontal scrolling
    7. Clean, minimal aesthetic suitable for a premium health/lifestyle brand
    8. Proper spacing and padding that prevents mobile overflow issues
    
    The design should be modern, trustworthy, and conversion-focused with clear hierarchy and mobile-safe layout.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-section-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    min-height: {{ block.settings.section_height_desktop }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .ai-hero-background-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .ai-hero-background-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-hero-background-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.background_color }};
  }

  .ai-hero-background-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-hero-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};
    z-index: 2;
  }

  .ai-hero-content-{{ ai_gen_id }} {
    position: relative;
    z-index: 3;
    max-width: {{ block.settings.content_max_width }}px;
    width: 100%;
    padding: 40px var(--page-gutter);
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-hero-headline-{{ ai_gen_id }} {
    font-size: {{ block.settings.headline_size }}px;
    font-weight: 700;
    color: {{ block.settings.headline_color }};
    margin: 0 0 16px;
    line-height: 1.2;
  }

  .ai-hero-subheadline-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheadline_size }}px;
    color: {{ block.settings.subheadline_color }};
    margin: 0 0 32px;
    line-height: 1.5;
  }

  .ai-hero-trust-badges-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    justify-content: {{ block.settings.text_alignment }};
    margin-bottom: 32px;
  }

  .ai-hero-trust-badge-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: {{ block.settings.trust_badge_size }}px;
    color: {{ block.settings.trust_badge_color }};
    font-weight: 500;
  }

  .ai-hero-trust-badge-icon-{{ ai_gen_id }} {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  .ai-hero-trust-badge-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    fill: {{ block.settings.trust_badge_color }};
  }

  .ai-hero-buttons-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    justify-content: {{ block.settings.text_alignment }};
  }

  .ai-hero-button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 600;
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    transition: var(--transition-smooth);
    border: none;
    cursor: pointer;
    min-width: 180px;
  }

  .ai-hero-button-primary-{{ ai_gen_id }} {
    background-color: {{ block.settings.primary_button_bg }};
    color: {{ block.settings.primary_button_text_color }};
  }

  .ai-hero-button-primary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.primary_button_bg_hover }};
    color: {{ block.settings.primary_button_text_hover }};
  }

  .ai-hero-button-secondary-{{ ai_gen_id }} {
    background-color: {{ block.settings.secondary_button_bg }};
    color: {{ block.settings.secondary_button_text_color }};
  }

  .ai-hero-button-secondary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.secondary_button_bg_hover }};
    color: {{ block.settings.secondary_button_text_hover }};
  }

  @media screen and (max-width: 749px) {
    .ai-hero-section-{{ ai_gen_id }} {
      min-height: {{ block.settings.section_height_mobile }}px;
    }

    .ai-hero-content-{{ ai_gen_id }} {
      padding: 32px var(--page-gutter);
    }

    .ai-hero-headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.headline_size | times: 0.6 }}px;
      margin-bottom: 12px;
    }

    .ai-hero-subheadline-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheadline_size | times: 0.8 }}px;
      margin-bottom: 24px;
    }

    .ai-hero-trust-badges-{{ ai_gen_id }} {
      gap: 12px;
      margin-bottom: 24px;
      justify-content: center;
    }

    .ai-hero-trust-badge-{{ ai_gen_id }} {
      font-size: {{ block.settings.trust_badge_size | times: 0.85 }}px;
    }

    .ai-hero-buttons-{{ ai_gen_id }} {
      flex-direction: column;
      gap: 12px;
      justify-content: center;
    }

    .ai-hero-button-{{ ai_gen_id }} {
      width: 100%;
      max-width: 100%;
      min-width: auto;
    }
  }

  @media screen and (min-width: 750px) and (max-width: 989px) {
    .ai-hero-headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.headline_size | times: 0.75 }}px;
    }

    .ai-hero-subheadline-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheadline_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-hero-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-hero-background-{{ ai_gen_id }}">
    {% if block.settings.background_image %}
      <img
        src="{{ block.settings.background_image | image_url: width: 2000 }}"
        alt="{{ block.settings.background_image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.background_image.width }}"
        height="{{ block.settings.background_image.height }}"
      >
    {% else %}
      <div class="ai-hero-background-placeholder-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
      </div>
    {% endif %}
  </div>

  <div class="ai-hero-overlay-{{ ai_gen_id }}"></div>

  <div class="ai-hero-content-{{ ai_gen_id }}">
    {% if block.settings.headline != blank %}
      <h1 class="ai-hero-headline-{{ ai_gen_id }}">{{ block.settings.headline }}</h1>
    {% endif %}

    {% if block.settings.subheadline != blank %}
      <p class="ai-hero-subheadline-{{ ai_gen_id }}">{{ block.settings.subheadline }}</p>
    {% endif %}

    {% if block.settings.show_trust_badges %}
      <div class="ai-hero-trust-badges-{{ ai_gen_id }}">
        {% if block.settings.trust_badge_1 != blank %}
          <div class="ai-hero-trust-badge-{{ ai_gen_id }}">
            <div class="ai-hero-trust-badge-icon-{{ ai_gen_id }}">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
            </div>
            <span>{{ block.settings.trust_badge_1 }}</span>
          </div>
        {% endif %}

        {% if block.settings.trust_badge_2 != blank %}
          <div class="ai-hero-trust-badge-{{ ai_gen_id }}">
            <div class="ai-hero-trust-badge-icon-{{ ai_gen_id }}">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
            </div>
            <span>{{ block.settings.trust_badge_2 }}</span>
          </div>
        {% endif %}

        {% if block.settings.trust_badge_3 != blank %}
          <div class="ai-hero-trust-badge-{{ ai_gen_id }}">
            <div class="ai-hero-trust-badge-icon-{{ ai_gen_id }}">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
            </div>
            <span>{{ block.settings.trust_badge_3 }}</span>
          </div>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-hero-buttons-{{ ai_gen_id }}">
      {% if block.settings.primary_button_label != blank %}
        <a
          href="{{ block.settings.primary_button_link }}"
          class="ai-hero-button-{{ ai_gen_id }} ai-hero-button-primary-{{ ai_gen_id }}"
        >
          {{ block.settings.primary_button_label }}
        </a>
      {% endif %}

      {% if block.settings.secondary_button_label != blank %}
        <a
          href="{{ block.settings.secondary_button_link }}"
          class="ai-hero-button-{{ ai_gen_id }} ai-hero-button-secondary-{{ ai_gen_id }}"
        >
          {{ block.settings.secondary_button_label }}
        </a>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Premium hero section",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#f6f6f6"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Overlay opacity",
      "default": 40
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "section_height_desktop",
      "min": 400,
      "max": 900,
      "step": 50,
      "unit": "px",
      "label": "Desktop height",
      "default": 600
    },
    {
      "type": "range",
      "id": "section_height_mobile",
      "min": 400,
      "max": 800,
      "step": 50,
      "unit": "px",
      "label": "Mobile height",
      "default": 550
    },
    {
      "type": "range",
      "id": "content_max_width",
      "min": 600,
      "max": 1200,
      "step": 50,
      "unit": "px",
      "label": "Content max width",
      "default": 900
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Headline"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "Premium Nootropics & Peptides for Peak Performance"
    },
    {
      "type": "range",
      "id": "headline_size",
      "min": 24,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Headline size",
      "default": 56
    },
    {
      "type": "color",
      "id": "headline_color",
      "label": "Headline color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Subheadline"
    },
    {
      "type": "textarea",
      "id": "subheadline",
      "label": "Subheadline",
      "default": "Research-backed cognitive enhancers and peptides, sustainably packaged and delivered with care"
    },
    {
      "type": "range",
      "id": "subheadline_size",
      "min": 14,
      "max": 32,
      "step": 1,
      "unit": "px",
      "label": "Subheadline size",
      "default": 20
    },
    {
      "type": "color",
      "id": "subheadline_color",
      "label": "Subheadline color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Trust badges"
    },
    {
      "type": "checkbox",
      "id": "show_trust_badges",
      "label": "Show trust badges",
      "default": true
    },
    {
      "type": "text",
      "id": "trust_badge_1",
      "label": "Trust badge 1",
      "default": "Lab Tested"
    },
    {
      "type": "text",
      "id": "trust_badge_2",
      "label": "Trust badge 2",
      "default": "Eco-Friendly Packaging"
    },
    {
      "type": "text",
      "id": "trust_badge_3",
      "label": "Trust badge 3",
      "default": "Fast Shipping"
    },
    {
      "type": "range",
      "id": "trust_badge_size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Badge text size",
      "default": 16
    },
    {
      "type": "color",
      "id": "trust_badge_color",
      "label": "Badge color",
      "default": "#FBBF24"
    },
    {
      "type": "header",
      "content": "Primary button"
    },
    {
      "type": "text",
      "id": "primary_button_label",
      "label": "Button text",
      "default": "Shop Nootropics"
    },
    {
      "type": "url",
      "id": "primary_button_link",
      "label": "Button link"
    },
    {
      "type": "color",
      "id": "primary_button_bg",
      "label": "Background color",
      "default": "#FBBF24"
    },
    {
      "type": "color",
      "id": "primary_button_text_color",
      "label": "Text color",
      "default": "#1e1e1e"
    },
    {
      "type": "color",
      "id": "primary_button_bg_hover",
      "label": "Hover background color",
      "default": "#f8c500"
    },
    {
      "type": "color",
      "id": "primary_button_text_hover",
      "label": "Hover text color",
      "default": "#1e1e1e"
    },
    {
      "type": "header",
      "content": "Secondary button"
    },
    {
      "type": "text",
      "id": "secondary_button_label",
      "label": "Button text",
      "default": "Shop Peptides"
    },
    {
      "type": "url",
      "id": "secondary_button_link",
      "label": "Button link"
    },
    {
      "type": "color",
      "id": "secondary_button_bg",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "secondary_button_text_color",
      "label": "Text color",
      "default": "#1e1e1e"
    },
    {
      "type": "color",
      "id": "secondary_button_bg_hover",
      "label": "Hover background color",
      "default": "#f6f6f6"
    },
    {
      "type": "color",
      "id": "secondary_button_text_hover",
      "label": "Hover text color",
      "default": "#1e1e1e"
    },
    {
      "type": "header",
      "content": "Button style"
    },
    {
      "type": "range",
      "id": "button_font_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Font size",
      "default": 16
    },
    {
      "type": "range",
      "id": "button_padding_vertical",
      "min": 8,
      "max": 24,
      "step": 2,
      "unit": "px",
      "label": "Vertical padding",
      "default": 16
    },
    {
      "type": "range",
      "id": "button_padding_horizontal",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Horizontal padding",
      "default": 32
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Border radius",
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "Premium hero section"
    }
  ]
}
{% endschema %}