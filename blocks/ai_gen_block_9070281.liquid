{% doc %}
  @prompt
    create product description section that renders the data from peptide.metafield 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-peptide-description-{{ ai_gen_id }} {
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-peptide-description__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-peptide-description__heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-peptide-description__content-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: {{ block.settings.line_height }};
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-peptide-description__content-{{ ai_gen_id }} p {
    margin: 0 0 {{ block.settings.paragraph_spacing }}px;
  }

  .ai-peptide-description__content-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  .ai-peptide-description__content-{{ ai_gen_id }} h1,
  .ai-peptide-description__content-{{ ai_gen_id }} h2,
  .ai-peptide-description__content-{{ ai_gen_id }} h3,
  .ai-peptide-description__content-{{ ai_gen_id }} h4,
  .ai-peptide-description__content-{{ ai_gen_id }} h5,
  .ai-peptide-description__content-{{ ai_gen_id }} h6 {
    color: {{ block.settings.heading_color }};
    margin: {{ block.settings.heading_spacing }}px 0;
  }

  .ai-peptide-description__content-{{ ai_gen_id }} ul,
  .ai-peptide-description__content-{{ ai_gen_id }} ol {
    margin: 0 0 {{ block.settings.paragraph_spacing }}px;
    padding-left: 20px;
  }

  .ai-peptide-description__content-{{ ai_gen_id }} li {
    margin-bottom: 8px;
  }

  .ai-peptide-description__content-{{ ai_gen_id }} strong {
    font-weight: 600;
  }

  .ai-peptide-description__empty-{{ ai_gen_id }} {
    padding: 40px 20px;
    text-align: center;
    color: #999;
    font-style: italic;
    background-color: var(--color-surface-secondary);
    border-radius: var(--nx-radius-sm);
  }

  @media screen and (max-width: 749px) {
    .ai-peptide-description-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top | times: 0.7 }}px {{ block.settings.padding_horizontal | times: 0.7 }}px {{ block.settings.padding_bottom | times: 0.7 }}px;
    }

    .ai-peptide-description__content-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-peptide-description-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-peptide-description__container-{{ ai_gen_id }}">
    {% if block.settings.show_heading and block.settings.heading != blank %}
      <h2 class="ai-peptide-description__heading-{{ ai_gen_id }} {{ block.settings.heading_size }}">
        {{ block.settings.heading }}
      </h2>
    {% endif %}

    {% if product.metafields.peptide %}
      <div class="ai-peptide-description__content-{{ ai_gen_id }}">
        {{ product.metafields.peptide }}
      </div>
    {% else %}
      <div class="ai-peptide-description__empty-{{ ai_gen_id }}">
        No peptide information available for this product. Add content to the peptide metafield.
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Peptide description",
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "checkbox",
      "id": "show_heading",
      "label": "Show heading",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading text",
      "default": "Product Information"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#1e1e1e"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        {"value": "h1", "label": "Display"},
        {"value": "h2", "label": "XL"},
        {"value": "h3", "label": "L"},
        {"value": "h4", "label": "M"},
        {"value": "h5", "label": "S"},
        {"value": "h6", "label": "XS"}
      ],
      "default": "h4"
    },
    {
      "type": "range",
      "id": "heading_spacing",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "label": "Heading spacing",
      "default": 20
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#1e1e1e"
    },
    {
      "type": "range",
      "id": "text_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Text size",
      "default": 16
    },
    {
      "type": "range",
      "id": "line_height",
      "min": 1,
      "max": 2,
      "step": 0.1,
      "label": "Line height",
      "default": 1.6
    },
    {
      "type": "range",
      "id": "paragraph_spacing",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "label": "Paragraph spacing",
      "default": 16
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 600,
      "max": 1400,
      "step": 50,
      "unit": "px",
      "label": "Maximum width",
      "default": 1000
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Horizontal padding",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "Peptide description"
    }
  ]
}
{% endschema %}