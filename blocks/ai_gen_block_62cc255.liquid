{% doc %}
  @prompt
    create modern, clean Section: 'What our COAs are meant to prove'
    
    Heading: What a COA should prove (and what it shouldn’t)
    
    Copy:
    A COA is documentation that connects a specific batch to lab analysis. At a minimum, a useful COA should help answer:
    
    Identity: Is it the right compound? (common methods: FTIR, LC‑MS/MS, MS, etc.)
    
    Purity / assay: How much of it is the target compound? (common method: HPLC)
    
    Traceability: Does the document match your batch/lot?
    
    Scope clarity: What was tested—and what wasn’t
    
    Callout box:
    Not every COA includes every possible contaminant panel. Some reports focus on identity/purity only. If you need a specific panel (metals/solvents/micro, etc.), ask support and we’ll tell you what documentation exists for your batch.
{% enddoc %}

{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-coa-info-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding_top }}px var(--page-gutter) {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-coa-info-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-coa-info-heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    text-align: {{ block.settings.text_alignment }};
    line-height: 1.2;
  }

  .ai-coa-info-intro-{{ ai_gen_id }} {
    font-size: {{ block.settings.intro_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 {{ block.settings.intro_spacing }}px;
    line-height: 1.6;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-coa-info-list-{{ ai_gen_id }} {
    list-style: none;
    padding: 0;
    margin: 0 0 {{ block.settings.list_spacing }}px;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.list_item_gap }}px;
  }

  .ai-coa-info-list-item-{{ ai_gen_id }} {
    padding: {{ block.settings.list_item_padding }}px;
    background-color: {{ block.settings.list_item_bg }};
    border-radius: {{ block.settings.list_item_radius }}px;
    border-left: {{ block.settings.list_item_border_width }}px solid {{ block.settings.accent_color }};
  }

  .ai-coa-info-list-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.list_title_size }}px;
    font-weight: 600;
    color: {{ block.settings.heading_color }};
    margin: 0 0 8px;
  }

  .ai-coa-info-list-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.list_text_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
    line-height: 1.5;
  }

  .ai-coa-info-callout-{{ ai_gen_id }} {
    padding: {{ block.settings.callout_padding }}px;
    background-color: {{ block.settings.callout_bg }};
    border-radius: {{ block.settings.callout_radius }}px;
    border: {{ block.settings.callout_border_width }}px solid {{ block.settings.callout_border_color }};
  }

  .ai-coa-info-callout-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.callout_text_size }}px;
    color: {{ block.settings.callout_text_color }};
    margin: 0;
    line-height: 1.6;
  }

  @media screen and (max-width: 749px) {
    .ai-coa-info-intro-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.intro_size }}px * 0.9);
    }

    .ai-coa-info-list-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.list_title_size }}px * 0.9);
    }

    .ai-coa-info-list-text-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.list_text_size }}px * 0.9);
    }

    .ai-coa-info-callout-text-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.callout_text_size }}px * 0.9);
    }
  }
{% endstyle %}

<div class="ai-coa-info-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-coa-info-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-coa-info-heading-{{ ai_gen_id }} {{ block.settings.heading_size }}">{{ block.settings.heading }}</h2>
    {% endif %}

    {% if block.settings.intro_text != blank %}
      <div class="ai-coa-info-intro-{{ ai_gen_id }}">{{ block.settings.intro_text }}</div>
    {% endif %}

    <ul class="ai-coa-info-list-{{ ai_gen_id }}">
      {% if block.settings.item_1_title != blank %}
        <li class="ai-coa-info-list-item-{{ ai_gen_id }}">
          <div class="ai-coa-info-list-title-{{ ai_gen_id }}">{{ block.settings.item_1_title }}</div>
          {% if block.settings.item_1_text != blank %}
            <div class="ai-coa-info-list-text-{{ ai_gen_id }}">{{ block.settings.item_1_text }}</div>
          {% endif %}
        </li>
      {% endif %}

      {% if block.settings.item_2_title != blank %}
        <li class="ai-coa-info-list-item-{{ ai_gen_id }}">
          <div class="ai-coa-info-list-title-{{ ai_gen_id }}">{{ block.settings.item_2_title }}</div>
          {% if block.settings.item_2_text != blank %}
            <div class="ai-coa-info-list-text-{{ ai_gen_id }}">{{ block.settings.item_2_text }}</div>
          {% endif %}
        </li>
      {% endif %}

      {% if block.settings.item_3_title != blank %}
        <li class="ai-coa-info-list-item-{{ ai_gen_id }}">
          <div class="ai-coa-info-list-title-{{ ai_gen_id }}">{{ block.settings.item_3_title }}</div>
          {% if block.settings.item_3_text != blank %}
            <div class="ai-coa-info-list-text-{{ ai_gen_id }}">{{ block.settings.item_3_text }}</div>
          {% endif %}
        </li>
      {% endif %}

      {% if block.settings.item_4_title != blank %}
        <li class="ai-coa-info-list-item-{{ ai_gen_id }}">
          <div class="ai-coa-info-list-title-{{ ai_gen_id }}">{{ block.settings.item_4_title }}</div>
          {% if block.settings.item_4_text != blank %}
            <div class="ai-coa-info-list-text-{{ ai_gen_id }}">{{ block.settings.item_4_text }}</div>
          {% endif %}
        </li>
      {% endif %}
    </ul>

    {% if block.settings.callout_text != blank %}
      <div class="ai-coa-info-callout-{{ ai_gen_id }}">
        <div class="ai-coa-info-callout-text-{{ ai_gen_id }}">{{ block.settings.callout_text }}</div>
      </div>
    {% endif %}
  </div>
</div>

