{% doc %}
  @prompt
    Create a theme section "Quickstart Header + Navigation" with product picker + page metafield fallback quickstart_product, includes hero + jump-link chips, modern card design, responsive and accessible.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% liquid
  if block.settings.quickstart_product != blank
    assign quickstart_product = block.settings.quickstart_product
  elsif page.metafields.custom.quickstart_product != blank
    assign quickstart_product = page.metafields.custom.quickstart_product
  else
    assign quickstart_product = null
  endif
%}

{%- style -%}
  .ai-quickstart-header-{{ ai_gen_id }} {
    width: 100%;
    display: block;
    background: rgba(var(--color-background-2));
    padding: {{ block.settings.section_padding_top }}px var(--page-gutter) {{ block.settings.section_padding_bottom }}px;
  }

  .ai-quickstart-header__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-quickstart-header__hero-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ block.settings.hero_gap }}px;
    align-items: center;
    margin-bottom: {{ block.settings.hero_margin_bottom }}px;
  }

  .ai-quickstart-header__content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.content_gap }}px;
  }

  .ai-quickstart-header__heading-{{ ai_gen_id }} {
    line-height: 1.2;
    color: rgba(var(--color-foreground));
    margin: 0;
    font-weight: 600;
  }

  .ai-quickstart-header__description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    line-height: 1.6;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 75%, transparent);
    margin: 0;
  }

  .ai-quickstart-header__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    border-radius: {{ block.settings.image_border_radius }}px;
    overflow: hidden;
    background: rgba(var(--color-background));
  }

  .ai-quickstart-header__image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .ai-quickstart-header__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 16 / 9;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(var(--color-background-2));
  }

  .ai-quickstart-header__image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 400px;
    max-height: 400px;
    opacity: 0.3;
  }

  .ai-quickstart-header__nav-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: {{ block.settings.chip_gap }}px;
    justify-content: {{ block.settings.chip_alignment }};
  }

  .ai-quickstart-header__chip-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    padding: {{ block.settings.chip_padding_vertical }}px {{ block.settings.chip_padding_horizontal }}px;
    background: rgba(var(--color-background));
    color: rgba(var(--color-foreground));
    border: {{ block.settings.chip_border_width }}px solid color-mix(in srgb, rgba(var(--color-foreground)) 12%, transparent);
    border-radius: {{ block.settings.chip_border_radius }}px;
    font-size: {{ block.settings.chip_font_size }}px;
    font-weight: 500;
    text-decoration: none;
    transition: 0.3s var(--out-soft, ease);
    cursor: pointer;
  }

  .ai-quickstart-header__chip-{{ ai_gen_id }}:hover {
    background: rgba(var(--color-accent));
    color: rgba(var(--color-foreground));
    border-color: rgba(var(--color-accent));
    transform: translateY(-2px);
  }

  .ai-quickstart-header__empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 40px 20px;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 40%, transparent);
    font-size: 14px;
  }

  @media screen and (max-width: 768px) {
    .ai-quickstart-header__hero-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.hero_gap | times: 0.75 }}px;
    }

    .ai-quickstart-header__description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size | times: 0.9 }}px;
    }

    .ai-quickstart-header__nav-{{ ai_gen_id }} {
      justify-content: center;
    }
  }
{%- endstyle -%}

<quickstart-header-{{ ai_gen_id }}
  class="ai-quickstart-header-{{ ai_gen_id }} color-{{ block.settings.color_scheme }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-quickstart-header__container-{{ ai_gen_id }}">
    {% if quickstart_product != blank %}
      <div class="ai-quickstart-header__hero-{{ ai_gen_id }}">
        <div class="ai-quickstart-header__content-{{ ai_gen_id }}">
          {% if block.settings.heading != blank %}
            <h1 class="ai-quickstart-header__heading-{{ ai_gen_id }} {{ block.settings.heading_size }}">
              {{ block.settings.heading }}
            </h1>
          {% endif %}

          {% if block.settings.description != blank %}
            <div class="ai-quickstart-header__description-{{ ai_gen_id }}">
              {{ block.settings.description }}
            </div>
          {% endif %}
        </div>

        <div class="ai-quickstart-header__image-wrapper-{{ ai_gen_id }}">
          {% if quickstart_product.featured_image %}
            <img
              src="{{ quickstart_product.featured_image | image_url: width: 1200 }}"
              alt="{{ quickstart_product.featured_image.alt | escape }}"
              loading="lazy"
              width="{{ quickstart_product.featured_image.width }}"
              height="{{ quickstart_product.featured_image.height }}"
              class="ai-quickstart-header__image-{{ ai_gen_id }}"
            >
          {% else %}
            <div class="ai-quickstart-header__image-placeholder-{{ ai_gen_id }}">
              {{ 'product-1' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>
      </div>

      {% if block.settings.show_navigation %}
        <nav
          class="ai-quickstart-header__nav-{{ ai_gen_id }}"
          aria-label="Quick navigation"
        >
          {% for i in (1..6) %}
            {% liquid
              assign section_enabled_key = 'section_' | append: i | append: '_enabled'
              assign section_label_key = 'section_' | append: i | append: '_label'
              assign section_anchor_key = 'section_' | append: i | append: '_anchor'

              assign section_enabled = block.settings[section_enabled_key]
              assign section_label = block.settings[section_label_key]
              assign section_anchor = block.settings[section_anchor_key]
            %}

            {% if section_enabled and section_label != blank and section_anchor != blank %}
              <a
                href="#{{ section_anchor }}"
                class="ai-quickstart-header__chip-{{ ai_gen_id }}"
                data-anchor="{{ section_anchor }}"
              >
                {{ section_label }}
              </a>
            {% endif %}
          {% endfor %}
        </nav>
      {% endif %}
    {% else %}
      <div class="ai-quickstart-header__empty-state-{{ ai_gen_id }}">
        <p>Select a product in the block settings or set the page metafield "quickstart_product" to display the quickstart header.</p>
      </div>
    {% endif %}
  </div>
</quickstart-header-{{ ai_gen_id }}>

<script>
  (function() {
    class QuickstartHeader{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupSmoothScroll();
      }

      setupSmoothScroll() {
        const chips = this.querySelectorAll('.ai-quickstart-header__chip-{{ ai_gen_id }}');

        chips.forEach((chip) => {
          chip.addEventListener('click', (e) => {
            e.preventDefault();
            const anchor = chip.getAttribute('data-anchor');
            const targetElement = document.getElementById(anchor);

            if (targetElement) {
              const offset = {{ block.settings.scroll_offset }};
              const elementPosition = targetElement.getBoundingClientRect().top;
              const offsetPosition = elementPosition + window.pageYOffset - offset;

              window.scrollTo({
                top: offsetPosition,
                behavior: 'smooth'
              });

              targetElement.focus({ preventScroll: true });
            }
          });
        });
      }
    }

    customElements.define('quickstart-header-{{ ai_gen_id }}', QuickstartHeader{{ ai_gen_id }});
  })();
</script>

{% schema %}
