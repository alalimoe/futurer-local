{% doc %}
  @prompt
    add a trust row with 4 inline items, each with an icon, headline, subtext. e.g.: shield icon, Lab Tested, Third-party verified purity. Medal icon, Premium Quality, Pharmaceutical grade. Icon, Pure Formula, No fillers or additives. Bolt icon, Fast Acting, Optimized bioavailibility (all customizable)
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-trust-row-{{ ai_gen_id }} {
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-trust-row-container-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: {{ block.settings.item_gap }}px;
    justify-content: center;
    align-items: flex-start;
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-trust-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    flex: 1 1 {{ block.settings.item_min_width }}px;
    min-width: {{ block.settings.item_min_width }}px;
    gap: {{ block.settings.content_gap }}px;
  }

  .ai-trust-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    flex-shrink: 0;
  }

  .ai-trust-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    stroke: {{ block.settings.icon_color }};
    fill: none;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .ai-trust-content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.text_gap }}px;
  }

  .ai-trust-headline-{{ ai_gen_id }} {
    font-size: {{ block.settings.headline_size }}px;
    font-weight: {{ block.settings.headline_weight }};
    color: {{ block.settings.headline_color }};
    margin: 0;
  }

  .ai-trust-subtext-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtext_size }}px;
    color: {{ block.settings.subtext_color }};
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-trust-row-container-{{ ai_gen_id }} {
      gap: {{ block.settings.item_gap_mobile }}px;
    }

    .ai-trust-item-{{ ai_gen_id }} {
      flex: 1 1 100%;
      min-width: 100%;
    }

    .ai-trust-icon-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size_mobile }}px;
      height: {{ block.settings.icon_size_mobile }}px;
    }

    .ai-trust-headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.headline_size_mobile }}px;
    }

    .ai-trust-subtext-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtext_size_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-trust-row-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-trust-row-container-{{ ai_gen_id }}">
    {% if block.settings.item_1_enabled %}
      <div class="ai-trust-item-{{ ai_gen_id }}">
        <div class="ai-trust-icon-{{ ai_gen_id }}">
          {% if block.settings.item_1_icon == 'shield' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
            </svg>
          {% elsif block.settings.item_1_icon == 'medal' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <circle cx="12" cy="15" r="7"></circle>
              <polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"></polyline>
            </svg>
          {% elsif block.settings.item_1_icon == 'check-circle' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
              <polyline points="22 4 12 14.01 9 11.01"></polyline>
            </svg>
          {% elsif block.settings.item_1_icon == 'bolt' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
            </svg>
          {% elsif block.settings.item_1_icon == 'star' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
            </svg>
          {% elsif block.settings.item_1_icon == 'heart' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
            </svg>
          {% endif %}
        </div>
        <div class="ai-trust-content-{{ ai_gen_id }}">
          <h3 class="ai-trust-headline-{{ ai_gen_id }}">{{ block.settings.item_1_headline }}</h3>
          <p class="ai-trust-subtext-{{ ai_gen_id }}">{{ block.settings.item_1_subtext }}</p>
        </div>
      </div>
    {% endif %}

