{% doc %}
  @prompt
    16:9 hero section with background image, breadcrumbs, headline, sub headline, 4 badges, 2 CTA buttons. all styling customizable, align breadcrumbs, headline, subheadline, badges, and buttons to the left, reduce cta buttons padding by 40%
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{%- style -%}
  .ai-hero-section-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    display: flex;
    align-items: {{ block.settings.content_vertical_alignment }};
    justify-content: {{ block.settings.content_horizontal_alignment }};
  }

  .ai-hero-background-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .ai-hero-background-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-hero-background-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: rgba(var(--color-background-2));
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-hero-background-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-hero-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};
    z-index: 2;
  }

  .ai-hero-content-{{ ai_gen_id }} {
    position: relative;
    z-index: 3;
    max-width: {{ block.settings.content_max_width }}px;
    padding: {{ block.settings.content_padding }}px;
    text-align: left;
    width: 100%;
  }

  .ai-hero-breadcrumbs-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.breadcrumb_spacing }}px;
    font-size: {{ block.settings.breadcrumb_font_size }}px;
    color: rgba(var(--color-background));
  }

  .ai-hero-breadcrumbs-{{ ai_gen_id }} a {
    color: rgba(var(--color-accent));
    text-decoration: none;
  }

  .ai-hero-breadcrumbs-{{ ai_gen_id }} a:hover {
    text-decoration: underline;
  }

  .ai-hero-breadcrumbs-{{ ai_gen_id }} span {
    margin: 0 8px;
  }

  .ai-hero-headline-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.headline_spacing }}px;
    font-size: {{ block.settings.headline_font_size }}px;
    font-weight: {{ block.settings.headline_font_weight }};
    color: rgba(var(--color-background));
    line-height: 1.2;
  }

  .ai-hero-subheadline-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.subheadline_spacing }}px;
    font-size: {{ block.settings.subheadline_font_size }}px;
    color: rgba(var(--color-background));
    line-height: 1.5;
  }

  .ai-hero-badges-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.badge_gap }}px;
    margin-bottom: {{ block.settings.badge_spacing }}px;
    flex-wrap: wrap;
    justify-content: flex-start;
  }

  .ai-hero-badge-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: {{ block.settings.badge_padding_vertical }}px {{ block.settings.badge_padding_horizontal }}px;
    background-color: rgba(var(--color-accent));
    color: rgba(var(--color-foreground));
    border-radius: {{ block.settings.badge_border_radius }}px;
    font-size: {{ block.settings.badge_font_size }}px;
    font-weight: {{ block.settings.badge_font_weight }};
  }

  .ai-hero-badge-icon-{{ ai_gen_id }} {
    width: {{ block.settings.badge_icon_size }}px;
    height: {{ block.settings.badge_icon_size }}px;
    flex-shrink: 0;
  }

  .ai-hero-badge-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    fill: currentColor;
  }

  .ai-hero-buttons-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.button_gap }}px;
    flex-wrap: wrap;
    justify-content: flex-start;
  }

  .ai-hero-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical | times: 0.6 }}px {{ block.settings.button_padding_horizontal | times: 0.6 }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: {{ block.settings.button_font_weight }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    transition: 0.3s var(--out-soft, ease);
    border: {{ block.settings.button_border_width }}px solid transparent;
  }

  .ai-hero-button-primary-{{ ai_gen_id }} {
    background-color: rgba(var(--color-accent));
    color: rgba(var(--color-foreground));
    border-color: rgba(var(--color-accent));
  }

  .ai-hero-button-primary-{{ ai_gen_id }}:hover {
    background-color: rgba(var(--color-accent-2));
    color: rgba(var(--color-foreground));
    border-color: rgba(var(--color-accent-2));
  }

  .ai-hero-button-secondary-{{ ai_gen_id }} {
    background-color: transparent;
    color: rgba(var(--color-background));
    border-color: rgba(var(--color-background));
  }

  .ai-hero-button-secondary-{{ ai_gen_id }}:hover {
    background-color: rgba(var(--color-background));
    color: rgba(var(--color-foreground));
    border-color: rgba(var(--color-background));
  }

  @media screen and (max-width: 768px) {
    .ai-hero-section-{{ ai_gen_id }} {
      aspect-ratio: {{ block.settings.mobile_aspect_ratio }};
    }

    .ai-hero-content-{{ ai_gen_id }} {
      padding: {{ block.settings.mobile_content_padding }}px;
    }

    .ai-hero-headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.headline_font_size | times: 0.7 }}px;
    }

    .ai-hero-subheadline-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheadline_font_size | times: 0.85 }}px;
    }

    .ai-hero-buttons-{{ ai_gen_id }} {
      flex-direction: column;
      align-items: stretch;
    }

    .ai-hero-button-{{ ai_gen_id }} {
      text-align: center;
    }
  }
{%- endstyle -%}

<div class="ai-hero-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-hero-background-{{ ai_gen_id }}">
    {% if block.settings.background_image %}
      <img
        src="{{ block.settings.background_image | image_url: width: 2000 }}"
        alt="{{ block.settings.background_image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.background_image.width }}"
        height="{{ block.settings.background_image.height }}"
      >
    {% else %}
      <div class="ai-hero-background-placeholder-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
      </div>
    {% endif %}
  </div>

  {% if block.settings.show_overlay %}
    <div class="ai-hero-overlay-{{ ai_gen_id }}"></div>
  {% endif %}

  <div class="ai-hero-content-{{ ai_gen_id }}">
    {% if block.settings.show_breadcrumbs %}
      <div class="ai-hero-breadcrumbs-{{ ai_gen_id }}">
        <a href="{{ routes.root_url }}">Home</a>
        <span>/</span>
        <span>{{ block.settings.breadcrumb_current }}</span>
      </div>
    {% endif %}

    {% if block.settings.headline != blank %}
      <h1 class="ai-hero-headline-{{ ai_gen_id }}">{{ block.settings.headline }}</h1>
    {% endif %}

    {% if block.settings.subheadline != blank %}
      <div class="ai-hero-subheadline-{{ ai_gen_id }}">{{ block.settings.subheadline }}</div>
    {% endif %}

    {% if block.settings.show_badges %}
      <div class="ai-hero-badges-{{ ai_gen_id }}">
        {% if block.settings.badge_1_text != blank %}
          <div class="ai-hero-badge-{{ ai_gen_id }}">
            {% if block.settings.badge_1_show_icon %}
              <span class="ai-hero-badge-icon-{{ ai_gen_id }}">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                  <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
                </svg>
              </span>
            {% endif %}
            {{ block.settings.badge_1_text }}
          </div>
        {% endif %}

        {% if block.settings.badge_2_text != blank %}
          <div class="ai-hero-badge-{{ ai_gen_id }}">
            {% if block.settings.badge_2_show_icon %}
              <span class="ai-hero-badge-icon-{{ ai_gen_id }}">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                  <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
                </svg>
              </span>
            {% endif %}
            {{ block.settings.badge_2_text }}
          </div>
        {% endif %}

        {% if block.settings.badge_3_text != blank %}
          <div class="ai-hero-badge-{{ ai_gen_id }}">
            {% if block.settings.badge_3_show_icon %}
              <span class="ai-hero-badge-icon-{{ ai_gen_id }}">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                  <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
                </svg>
              </span>
            {% endif %}
            {{ block.settings.badge_3_text }}
          </div>
        {% endif %}

        {% if block.settings.badge_4_text != blank %}
          <div class="ai-hero-badge-{{ ai_gen_id }}">
            {% if block.settings.badge_4_show_icon %}
              <span class="ai-hero-badge-icon-{{ ai_gen_id }}">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                  <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
                </svg>
              </span>
            {% endif %}
            {{ block.settings.badge_4_text }}
          </div>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-hero-buttons-{{ ai_gen_id }}">
      {% if block.settings.button_1_text != blank %}
        <a
          href="{{ block.settings.button_1_link }}"
          class="ai-hero-button-{{ ai_gen_id }} ai-hero-button-primary-{{ ai_gen_id }}"
        >
          {{ block.settings.button_1_text }}
        </a>
      {% endif %}

      {% if block.settings.button_2_text != blank %}
        <a
          href="{{ block.settings.button_2_link }}"
          class="ai-hero-button-{{ ai_gen_id }} ai-hero-button-secondary-{{ ai_gen_id }}"
        >
          {{ block.settings.button_2_text }}
        </a>
      {% endif %}
    </div>
  </div>
</div>

