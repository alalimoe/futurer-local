{% liquid
  assign sub_heading = block.settings.sub_heading
  assign image_desktop = block.settings.image_desktop
  assign aspect_ratio_desktop = block.settings.aspect_ratio_desktop
  if aspect_ratio_desktop == 'custom'
    assign aspect_ratio_desktop = block.settings.aspect_ratio_desktop_width | append: '/' | append: block.settings.aspect_ratio_desktop_height
  endif
  assign image_mobile = block.settings.image_mobile
  assign aspect_ratio_mobile = block.settings.aspect_ratio_mobile
  if aspect_ratio_mobile == 'custom'
    assign aspect_ratio_mobile = block.settings.aspect_ratio_mobile_width | append: '/' | append: block.settings.aspect_ratio_mobile_height
  endif
  assign collection_list = block.settings.collection_list
  assign color_schema_box = block.settings.color_schema_box
  assign button = block.settings
%}

{% render 'category-2-block',
  block: block,
  sub_heading: sub_heading,
  image_desktop: image_desktop,
  aspect_ratio_desktop: aspect_ratio_desktop,
  image_mobile: image_mobile,
  aspect_ratio_mobile: aspect_ratio_mobile,
  button: button,
  collection_list: collection_list,
  color_schema_box: color_schema_box
%}


{% schema %}
{
  "name": "t:blocks.category_2.name",
  "settings": [
    {
      "type": "collection_list",
      "id": "collection_list",
      "label": "t:blocks.category_2.blocks.settings.collection.label",
      "limit": 4
    },
    {
      "type": "color_scheme",
      "id": "color_schema_box",
      "label": "t:blocks.category_2.blocks.settings.color_schema_box.label"
    },
    {
      "type": "header",
      "content": "Text"
    },
    {
      "type": "select",
      "id": "text_tag_name",
      "label": "Tag name",
      "options": [
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        },
        {
          "value": "h4",
          "label": "H4"
        },
        {
          "value": "h5",
          "label": "H5"
        },
        {
          "value": "h6",
          "label": "H6"
        }
      ],
      "default": "h2"
    },
    {
      "type": "textarea",
      "id": "text_heading",
      "label": "Text",
      "default": "Category list"
    },
    {
      "type": "select",
      "id": "font_size_heading",
      "label": "Font size heading",
      "default": "h6",
      "options": [
        {
          "value": "h1",
          "label": "Extra extra large"
        },
        {
          "value": "h2",
          "label": "Extra large"
        },
        {
          "value": "h3",
          "label": "Large"
        },
        {
          "value": "h4",
          "label": "Medium"
        },
        {
          "value": "h5",
          "label": "Small"
        },
        {
          "value": "h6",
          "label": "Extra small"
        }
      ]
    },
    {
      "type": "range",
      "id": "text_line_height",
      "label": "Line height",
      "min": 0,
      "max": 3,
      "step": 0.1,
      "default": 1.2
