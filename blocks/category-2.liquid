    },
    {
      "type": "image_picker",
      "id": "image_desktop",
      "label": "t:blocks.category_2.blocks.settings.image.label"
    },
    {
      "type": "select",
      "id": "aspect_ratio_desktop",
      "label": "Aspect ratio",
