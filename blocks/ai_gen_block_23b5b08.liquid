{% doc %}
  @prompt
    clean, future‑friendly blog post template inspired by Futurer, with a Table of Contents on the upper‑left that stays with the reader as they scroll and ability to dynamically connect tag, title, feature image, published, content from existing blog posts 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-blog-post-{{ ai_gen_id }} {
    max-width: {{ settings.page_width }}px;
    margin: 0 auto;
    padding: 0 var(--page-gutter);
    font-family: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
    color: rgb({{ settings.color_schemes[block.settings.color_scheme].settings.text | color_extract: 'red' }}, {{ settings.color_schemes[block.settings.color_scheme].settings.text | color_extract: 'green' }}, {{ settings.color_schemes[block.settings.color_scheme].settings.text | color_extract: 'blue' }});
    background-color: rgb({{ settings.color_schemes[block.settings.color_scheme].settings.background | color_extract: 'red' }}, {{ settings.color_schemes[block.settings.color_scheme].settings.background | color_extract: 'green' }}, {{ settings.color_schemes[block.settings.color_scheme].settings.background | color_extract: 'blue' }});
    line-height: 1.6;
  }

  .ai-blog-post-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 60px;
    align-items: start;
    margin-top: 40px;
  }

  .ai-blog-toc-{{ ai_gen_id }} {
    position: sticky;
    top: 100px;
    background: rgb({{ settings.color_schemes[block.settings.color_scheme].settings.background_2 | color_extract: 'red' }}, {{ settings.color_schemes[block.settings.color_scheme].settings.background_2 | color_extract: 'green' }}, {{ settings.color_schemes[block.settings.color_scheme].settings.background_2 | color_extract: 'blue' }});
    border-radius: {{ block.settings.border_radius }}px;
    padding: 24px;
    border: 1px solid rgba({{ settings.color_schemes[block.settings.color_scheme].settings.border | color_extract: 'red' }}, {{ settings.color_schemes[block.settings.color_scheme].settings.border | color_extract: 'green' }}, {{ settings.color_schemes[block.settings.color_scheme].settings.border | color_extract: 'blue' }}, 0.1);
    max-height: calc(100vh - 140px);
    overflow-y: auto;
  }

  .ai-blog-toc-title-{{ ai_gen_id }} {
    font-family: {{ settings.type_header_font.family }}, {{ settings.type_header_font.fallback_families }};
    font-size: 18px;
    font-weight: 600;
    margin: 0 0 16px;
    color: rgb({{ settings.color_schemes[block.settings.color_scheme].settings.text | color_extract: 'red' }}, {{ settings.color_schemes[block.settings.color_scheme].settings.text | color_extract: 'green' }}, {{ settings.color_schemes[block.settings.color_scheme].settings.text | color_extract: 'blue' }});
  }

  .ai-blog-toc-list-{{ ai_gen_id }} {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .ai-blog-toc-item-{{ ai_gen_id }} {
    margin-bottom: 8px;
  }

  .ai-blog-toc-link-{{ ai_gen_id }} {
    display: block;
    padding: 8px 12px;
    text-decoration: none;
    color: rgb({{ settings.color_schemes[block.settings.color_scheme].settings.text_3 | color_extract: 'red' }}, {{ settings.color_schemes[block.settings.color_scheme].settings.text_3 | color_extract: 'green' }}, {{ settings.color_schemes[block.settings.color_scheme].settings.text_3 | color_extract: 'blue' }});
    border-radius: 6px;
    transition: var(--transition-fast);
    font-size: 14px;
    border-left: 3px solid transparent;
  }

  .ai-blog-toc-link-{{ ai_gen_id }}:hover {
    background: rgba({{ settings.color_schemes[block.settings.color_scheme].settings.accent | color_extract: 'red' }}, {{ settings.color_schemes[block.settings.color_scheme].settings.accent | color_extract: 'green' }}, {{ settings.color_schemes[block.settings.color_scheme].settings.accent | color_extract: 'blue' }}, 0.1);
    color: rgb({{ settings.color_schemes[block.settings.color_scheme].settings.text | color_extract: 'red' }}, {{ settings.color_schemes[block.settings.color_scheme].settings.text | color_extract: 'green' }}, {{ settings.color_schemes[block.settings.color_scheme].settings.text | color_extract: 'blue' }});
  }

  .ai-blog-toc-link-{{ ai_gen_id }}.active {
    background: rgba({{ settings.color_schemes[block.settings.color_scheme].settings.accent | color_extract: 'red' }}, {{ settings.color_schemes[block.settings.color_scheme].settings.accent | color_extract: 'green' }}, {{ settings.color_schemes[block.settings.color_scheme].settings.accent | color_extract: 'blue' }}, 0.15);
    color: rgb({{ settings.color_schemes[block.settings.color_scheme].settings.text | color_extract: 'red' }}, {{ settings.color_schemes[block.settings.color_scheme].settings.text | color_extract: 'green' }}, {{ settings.color_schemes[block.settings.color_scheme].settings.text | color_extract: 'blue' }});
    border-left-color: rgb({{ settings.color_schemes[block.settings.color_scheme].settings.accent | color_extract: 'red' }}, {{ settings.color_schemes[block.settings.color_scheme].settings.accent | color_extract: 'green' }}, {{ settings.color_schemes[block.settings.color_scheme].settings.accent | color_extract: 'blue' }});
  }

  .ai-blog-content-{{ ai_gen_id }} {
    min-width: 0;
  }

  .ai-blog-header-{{ ai_gen_id }} {
    margin-bottom: 40px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-blog-meta-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 16px;
    font-size: 14px;
    color: rgb({{ settings.color_schemes[block.settings.color_scheme].settings.text_3 | color_extract: 'red' }}, {{ settings.color_schemes[block.settings.color_scheme].settings.text_3 | color_extract: 'green' }}, {{ settings.color_schemes[block.settings.color_scheme].settings.text_3 | color_extract: 'blue' }});
    {% if block.settings.text_alignment == 'center' %}
      justify-content: center;
    {% elsif block.settings.text_alignment == 'right' %}
      justify-content: flex-end;
    {% endif %}
  }

  .ai-blog-tag-{{ ai_gen_id }} {
    background: rgb({{ settings.color_schemes[block.settings.color_scheme].settings.accent | color_extract: 'red' }}, {{ settings.color_schemes[block.settings.color_scheme].settings.accent | color_extract: 'green' }}, {{ settings.color_schemes[block.settings.color_scheme].settings.accent | color_extract: 'blue' }});
    color: rgb({{ settings.color_schemes[block.settings.color_scheme].settings.button_label | color_extract: 'red' }}, {{ settings.color_schemes[block.settings.color_scheme].settings.button_label | color_extract: 'green' }}, {{ settings.color_schemes[block.settings.color_scheme].settings.button_label | color_extract: 'blue' }});
    padding: 4px 12px;
    border-radius: var(--nx-radius-lg);
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ai-blog-date-{{ ai_gen_id }} {
    font-weight: 500;
  }

  .ai-blog-title-{{ ai_gen_id }} {
    font-family: {{ settings.type_header_font.family }}, {{ settings.type_header_font.fallback_families }};
    font-size: {{ block.settings.title_size }}px;
    font-weight: 700;
    line-height: 1.2;
    margin: 0 0 24px;
    color: rgb({{ settings.color_schemes[block.settings.color_scheme].settings.text | color_extract: 'red' }}, {{ settings.color_schemes[block.settings.color_scheme].settings.text | color_extract: 'green' }}, {{ settings.color_schemes[block.settings.color_scheme].settings.text | color_extract: 'blue' }});
  }

  .ai-blog-featured-image-{{ ai_gen_id }} {
    width: 100%;
    border-radius: {{ block.settings.image_border_radius }}px;
    margin-bottom: 40px;
    overflow: hidden;
    aspect-ratio: {{ block.settings.image_aspect_ratio }};
  }

  .ai-blog-featured-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .ai-blog-featured-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background: rgb({{ settings.color_schemes[block.settings.color_scheme].settings.background_2 | color_extract: 'red' }}, {{ settings.color_schemes[block.settings.color_scheme].settings.background_2 | color_extract: 'green' }}, {{ settings.color_schemes[block.settings.color_scheme].settings.background_2 | color_extract: 'blue' }});
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-blog-featured-image-placeholder-{{ ai_gen_id }} svg {
    width: 80px;
    height: 80px;
    opacity: 0.3;
  }

  .ai-blog-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 14px;
    color: rgb({{ settings.color_schemes[block.settings.color_scheme].settings.text_3 | color_extract: 'red' }}, {{ settings.color_schemes[block.settings.color_scheme].settings.text_3 | color_extract: 'green' }}, {{ settings.color_schemes[block.settings.color_scheme].settings.text_3 | color_extract: 'blue' }});
    text-align: center;
    pointer-events: none;
  }

  .ai-blog-article-content-{{ ai_gen_id }} {
    font-size: {{ block.settings.content_font_size }}px;
    line-height: 1.7;
  }

  .ai-blog-article-content-{{ ai_gen_id }} h1,
  .ai-blog-article-content-{{ ai_gen_id }} h2,
  .ai-blog-article-content-{{ ai_gen_id }} h3,
  .ai-blog-article-content-{{ ai_gen_id }} h4,
  .ai-blog-article-content-{{ ai_gen_id }} h5,
  .ai-blog-article-content-{{ ai_gen_id }} h6 {
    font-family: {{ settings.type_header_font.family }}, {{ settings.type_header_font.fallback_families }};
    color: rgb({{ settings.color_schemes[block.settings.color_scheme].settings.text | color_extract: 'red' }}, {{ settings.color_schemes[block.settings.color_scheme].settings.text | color_extract: 'green' }}, {{ settings.color_schemes[block.settings.color_scheme].settings.text | color_extract: 'blue' }});
    margin: 32px 0 16px;
    scroll-margin-top: 120px;
  }

  .ai-blog-article-content-{{ ai_gen_id }} h2 {
    font-size: 32px;
    font-weight: 600;
  }

  .ai-blog-article-content-{{ ai_gen_id }} h3 {
    font-size: 24px;
    font-weight: 600;
  }

  .ai-blog-article-content-{{ ai_gen_id }} h4 {
    font-size: 20px;
    font-weight: 600;
  }

  .ai-blog-article-content-{{ ai_gen_id }} p {
    margin: 0 0 20px;
  }

  .ai-blog-article-content-{{ ai_gen_id }} a {
    color: rgb({{ settings.color_schemes[block.settings.color_scheme].settings.accent | color_extract: 'red' }}, {{ settings.color_schemes[block.settings.color_scheme].settings.accent | color_extract: 'green' }}, {{ settings.color_schemes[block.settings.color_scheme].settings.accent | color_extract: 'blue' }});
    text-decoration: underline;
    transition: opacity 0.2s ease;
  }

  .ai-blog-article-content-{{ ai_gen_id }} a:hover {
    opacity: 0.8;
  }

  .ai-blog-article-content-{{ ai_gen_id }} blockquote {
    border-left: 4px solid rgb({{ settings.color_schemes[block.settings.color_scheme].settings.accent | color_extract: 'red' }}, {{ settings.color_schemes[block.settings.color_scheme].settings.accent | color_extract: 'green' }}, {{ settings.color_schemes[block.settings.color_scheme].settings.accent | color_extract: 'blue' }});
    padding: 16px 24px;
    margin: 24px 0;
    background: rgba({{ settings.color_schemes[block.settings.color_scheme].settings.background_2 | color_extract: 'red' }}, {{ settings.color_schemes[block.settings.color_scheme].settings.background_2 | color_extract: 'green' }}, {{ settings.color_schemes[block.settings.color_scheme].settings.background_2 | color_extract: 'blue' }}, 0.5);
    border-radius: var(--nx-radius-sm);
    font-style: italic;
  }

  .ai-blog-article-content-{{ ai_gen_id }} ul,
  .ai-blog-article-content-{{ ai_gen_id }} ol {
    margin: 16px 0;
    padding-left: 24px;
  }

  .ai-blog-article-content-{{ ai_gen_id }} li {
    margin-bottom: 8px;
  }

  .ai-blog-empty-content-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: rgb({{ settings.color_schemes[block.settings.color_scheme].settings.text_3 | color_extract: 'red' }}, {{ settings.color_schemes[block.settings.color_scheme].settings.text_3 | color_extract: 'green' }}, {{ settings.color_schemes[block.settings.color_scheme].settings.text_3 | color_extract: 'blue' }});
  }

  .ai-blog-empty-content-{{ ai_gen_id }} h3 {
    font-family: {{ settings.type_header_font.family }}, {{ settings.type_header_font.fallback_families }};
    font-size: 24px;
    margin-bottom: 12px;
  }

  @media screen and (max-width: 1024px) {
    .ai-blog-post-container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .ai-blog-toc-{{ ai_gen_id }} {
      position: relative;
      top: auto;
      order: 2;
      max-height: none;
    }

    .ai-blog-content-{{ ai_gen_id }} {
      order: 1;
    }
  }

  @media screen and (max-width: 768px) {
    .ai-blog-post-{{ ai_gen_id }} {
      padding: 0 var(--page-gutter);
    }

    .ai-blog-post-container-{{ ai_gen_id }} {
      gap: 32px;
      margin-top: 24px;
    }

    .ai-blog-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.8 }}px;
    }

    .ai-blog-meta-{{ ai_gen_id }} {
      flex-direction: column;
      align-items: flex-start;
      gap: 8px;
      {% if block.settings.text_alignment == 'center' %}
        align-items: center;
      {% elsif block.settings.text_alignment == 'right' %}
        align-items: flex-end;
      {% endif %}
    }

    .ai-blog-article-content-{{ ai_gen_id }} {
      font-size: {{ block.settings.content_font_size | minus: 2 }}px;
    }

    .ai-blog-article-content-{{ ai_gen_id }} h2 {
      font-size: 28px;
    }

    .ai-blog-article-content-{{ ai_gen_id }} h3 {
      font-size: 22px;
    }
  }
{% endstyle %}

<blog-post-template-{{ ai_gen_id }}
  class="ai-blog-post-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-blog-post-container-{{ ai_gen_id }}">
    <aside class="ai-blog-toc-{{ ai_gen_id }}">
      <h3 class="ai-blog-toc-title-{{ ai_gen_id }}">{{ block.settings.toc_title }}</h3>
      <ul class="ai-blog-toc-list-{{ ai_gen_id }}" id="ai-blog-toc-list-{{ ai_gen_id }}">
      </ul>
    </aside>

    <main class="ai-blog-content-{{ ai_gen_id }}">
      {% if block.settings.selected_article != blank %}
        <header class="ai-blog-header-{{ ai_gen_id }}">
          <div class="ai-blog-meta-{{ ai_gen_id }}">
            {% if block.settings.selected_article.tags.size > 0 and block.settings.show_tags %}
              <span class="ai-blog-tag-{{ ai_gen_id }}">{{ block.settings.selected_article.tags.first }}</span>
            {% endif %}
            {% if block.settings.show_date %}
              <time class="ai-blog-date-{{ ai_gen_id }}" datetime="{{ block.settings.selected_article.published_at | date: '%Y-%m-%d' }}">
                {{ block.settings.selected_article.published_at | date: '%B %d, %Y' }}
              </time>
            {% endif %}
          </div>
          
          <h1 class="ai-blog-title-{{ ai_gen_id }}">{{ block.settings.selected_article.title }}</h1>
        </header>

        {% if block.settings.show_featured_image and block.settings.selected_article.image %}
          <div class="ai-blog-featured-image-{{ ai_gen_id }}">
            <img
              src="{{ block.settings.selected_article.image | image_url: width: 1200 }}"
              alt="{{ block.settings.selected_article.image.alt | escape }}"
              loading="lazy"
              width="{{ block.settings.selected_article.image.width }}"
              height="{{ block.settings.selected_article.image.height }}"
            >
          </div>
        {% elsif block.settings.show_featured_image %}
          <div class="ai-blog-featured-image-{{ ai_gen_id }}">
            <div class="ai-blog-featured-image-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
              <div class="ai-blog-empty-state-{{ ai_gen_id }}">
                Add a featured image to the article
              </div>
            </div>
          </div>
        {% endif %}

        <article class="ai-blog-article-content-{{ ai_gen_id }}" id="ai-blog-article-content-{{ ai_gen_id }}">
          {{ block.settings.selected_article.content }}
        </article>
      {% else %}
        <div class="ai-blog-empty-content-{{ ai_gen_id }}">
          <h3>Select an article to display</h3>
          <p>Choose an article from your blog to showcase in this template.</p>
        </div>
      {% endif %}
    </main>
  </div>
</blog-post-template-{{ ai_gen_id }}>

<script>
  (function() {
    class BlogPostTemplate{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.tocList = this.querySelector('#ai-blog-toc-list-{{ ai_gen_id }}');
        this.articleContent = this.querySelector('#ai-blog-article-content-{{ ai_gen_id }}');
        this.headings = [];
        this.tocLinks = [];
        this.currentActiveIndex = -1;
      }

      connectedCallback() {
        if (this.articleContent) {
          this.generateTOC();
          this.setupScrollSpy();
        }
      }

      generateTOC() {
        this.headings = this.articleContent.querySelectorAll('h1, h2, h3, h4, h5, h6');
        
        if (this.headings.length === 0) {
          this.tocList.innerHTML = '<li style="color: #999; font-style: italic; padding: 8px 12px;">No headings found</li>';
          return;
        }

        this.tocList.innerHTML = '';
        
        this.headings.forEach((heading, index) => {
          const id = `heading-${index}-{{ ai_gen_id }}`;
          heading.id = id;
          
          const li = document.createElement('li');
          li.className = 'ai-blog-toc-item-{{ ai_gen_id }}';
          
          const link = document.createElement('a');
          link.href = `#${id}`;
          link.className = 'ai-blog-toc-link-{{ ai_gen_id }}';
          link.textContent = heading.textContent;
          link.style.paddingLeft = `${(parseInt(heading.tagName.charAt(1)) - 1) * 12 + 12}px`;
          
          link.addEventListener('click', (e) => {
            e.preventDefault();
            heading.scrollIntoView({
              behavior: 'smooth',
              block: 'start'
            });
          });
          
          li.appendChild(link);
          this.tocList.appendChild(li);
          this.tocLinks.push(link);
        });
      }

      setupScrollSpy() {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              const index = Array.from(this.headings).indexOf(entry.target);
              
              if (entry.isIntersecting) {
                this.setActiveLink(index);
              }
            });
          },
          {
            rootMargin: '-120px 0px -60% 0px',
            threshold: 0
          }
        );

        this.headings.forEach((heading) => {
          observer.observe(heading);
        });
      }

      setActiveLink(index) {
        if (this.currentActiveIndex !== -1 && this.tocLinks[this.currentActiveIndex]) {
          this.tocLinks[this.currentActiveIndex].classList.remove('active');
        }
        
        if (index !== -1 && this.tocLinks[index]) {
          this.tocLinks[index].classList.add('active');
          this.currentActiveIndex = index;
        }
      }
    }

    customElements.define('blog-post-template-{{ ai_gen_id }}', BlogPostTemplate{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Blog post template",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Article selection"
    },
    {
      "type": "article",
      "id": "selected_article",
      "label": "Select article"
    },
    {
      "type": "header",
      "content": "Display options"
    },
    {
      "type": "checkbox",
      "id": "show_featured_image",
      "label": "Show featured image",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_tags",
      "label": "Show tags",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_date",
      "label": "Show published date",
      "default": true
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Header text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Table of contents"
    },
    {
      "type": "text",
      "id": "toc_title",
      "label": "Table of contents title",
      "default": "Table of Contents"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "title_size",
      "min": 24,
      "max": 72,
      "step": 2,
      "unit": "px",
      "label": "Title size",
      "default": 48
    },
    {
      "type": "range",
      "id": "content_font_size",
      "min": 14,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Content font size",
      "default": 16
    },
    {
      "type": "header",
      "content": "Image settings"
    },
    {
      "type": "select",
      "id": "image_aspect_ratio",
      "label": "Featured image aspect ratio",
      "options": [
        {
          "value": "16/9",
          "label": "16:9"
        },
        {
          "value": "4/3",
          "label": "4:3"
        },
        {
          "value": "3/2",
          "label": "3:2"
        },
        {
          "value": "1/1",
          "label": "1:1"
        }
      ],
      "default": "16/9"
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Image border radius",
      "default": 12
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "background-1"
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "label": "Border radius",
      "default": 12
    }
  ],
  "presets": [
    {
      "name": "Blog post template"
    }
  ]
}
{% endschema %}