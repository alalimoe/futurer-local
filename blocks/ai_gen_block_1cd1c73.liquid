{% doc %}
  @prompt
    create a clean, modern 'COA Library' section with heading, intro copy, most requested coas (table with product, form, last verified, COA link, direct download). small text under the table: Testing panels can differ by compound and lab. Always defer to the Methods / Scope section on the COA for what was (and wasn’t) tested. Below that, 'COAs by category (browse)' with 3-card row: Peptides — “COAs are listed on each product page. We’re also consolidating them here for easier lookup.” (Button: Shop Peptides / Peptides collection)
    
    Nootropics — “COAs are shown where applicable. Look for the COA block on the product page.” (Button: Shop Nootropics)
    
    Phenibut — “COAs + batch verification + shipping restrictions.” (Buttons: Phenibut hub + Shipping restrictions)
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-coa-library-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding_top }}px var(--page-gutter) {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-coa-library-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
  }

  .ai-coa-library-header-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
    margin-bottom: 40px;
  }

  .ai-coa-library-heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    margin: 0 0 16px;
    font-weight: 600;
  }

  .ai-coa-library-intro-{{ ai_gen_id }} {
    font-size: {{ block.settings.intro_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
    margin: 0;
  }

  .ai-coa-library-table-wrapper-{{ ai_gen_id }} {
    margin-bottom: 12px;
    overflow-x: auto;
    border-radius: {{ block.settings.table_border_radius }}px;
    border: {{ block.settings.table_border_width }}px solid {{ block.settings.table_border_color }};
  }

  .ai-coa-library-table-{{ ai_gen_id }} {
    width: 100%;
    border-collapse: collapse;
    background-color: {{ block.settings.table_background }};
  }

  .ai-coa-library-table-{{ ai_gen_id }} thead {
    background-color: {{ block.settings.table_header_background }};
  }

  .ai-coa-library-table-{{ ai_gen_id }} th {
    padding: 16px 12px;
    text-align: left;
    font-size: {{ block.settings.table_header_size }}px;
    font-weight: 600;
    color: {{ block.settings.table_header_color }};
    border-bottom: 2px solid {{ block.settings.table_border_color }};
  }

  .ai-coa-library-table-{{ ai_gen_id }} td {
    padding: 14px 12px;
    font-size: {{ block.settings.table_text_size }}px;
    color: {{ block.settings.text_color }};
    border-bottom: 1px solid {{ block.settings.table_border_color }};
  }

  .ai-coa-library-table-{{ ai_gen_id }} tbody tr:last-child td {
    border-bottom: none;
  }

  .ai-coa-library-table-{{ ai_gen_id }} tbody tr:hover {
    background-color: {{ block.settings.table_row_hover }};
  }

  .ai-coa-library-table-link-{{ ai_gen_id }} {
    color: {{ block.settings.link_color }};
    text-decoration: none;
    font-weight: 500;
  }

  .ai-coa-library-table-link-{{ ai_gen_id }}:hover {
    text-decoration: underline;
  }

  .ai-coa-library-disclaimer-{{ ai_gen_id }} {
    font-size: {{ block.settings.disclaimer_size }}px;
    color: {{ block.settings.disclaimer_color }};
    line-height: 1.5;
    margin: 0 0 48px;
    font-style: italic;
  }

  .ai-coa-library-browse-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.browse_heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 24px;
    font-weight: 600;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-coa-library-cards-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px;
  }

  .ai-coa-library-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border: {{ block.settings.card_border_width }}px solid {{ block.settings.card_border_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ai-coa-library-card-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_title_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0;
    font-weight: 600;
  }

  .ai-coa-library-card-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_text_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
    margin: 0;
    flex-grow: 1;
  }

  .ai-coa-library-card-buttons-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .ai-coa-library-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 12px 20px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    font-weight: 500;
    text-align: center;
    transition: background-color 0.3s ease;
  }

  .ai-coa-library-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
  }

  .ai-coa-library-button-secondary-{{ ai_gen_id }} {
    background-color: {{ block.settings.button_secondary_background }};
    color: {{ block.settings.button_secondary_text_color }};
  }

  .ai-coa-library-button-secondary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_secondary_hover_background }};
  }

  @media screen and (max-width: 749px) {
    .ai-coa-library-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top | times: 0.6 }}px var(--page-gutter) {{ block.settings.section_padding_bottom | times: 0.6 }}px;
    }

    .ai-coa-library-browse-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.browse_heading_size | times: 0.8 }}px;
    }

    .ai-coa-library-cards-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-coa-library-table-{{ ai_gen_id }} th,
    .ai-coa-library-table-{{ ai_gen_id }} td {
      padding: 10px 8px;
      font-size: {{ block.settings.table_text_size | times: 0.9 }}px;
    }
  }

  @media screen and (min-width: 750px) {
    .ai-coa-library-{{ ai_gen_id }} {
      width: {{ block.settings.desktop_width_percent }}%;
      margin-left: auto;
      margin-right: auto;
    }
  }
{% endstyle %}

<coa-library-{{ ai_gen_id }} class="ai-coa-library-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-coa-library-container-{{ ai_gen_id }}">
    <div class="ai-coa-library-header-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-coa-library-heading-{{ ai_gen_id }} {{ block.settings.heading_size }}">{{ block.settings.heading }}</h2>
      {% endif %}
      {% if block.settings.intro_text != blank %}
        <div class="ai-coa-library-intro-{{ ai_gen_id }}">{{ block.settings.intro_text }}</div>
      {% endif %}
    </div>

    {% if block.settings.show_table %}
      <div class="ai-coa-library-table-wrapper-{{ ai_gen_id }}">
        <table class="ai-coa-library-table-{{ ai_gen_id }}">
          <thead>
            <tr>
              <th>{{ block.settings.table_col_1 }}</th>
              <th>{{ block.settings.table_col_2 }}</th>
              <th>{{ block.settings.table_col_3 }}</th>
              <th>{{ block.settings.table_col_4 }}</th>
              <th>{{ block.settings.table_col_5 }}</th>
            </tr>
          </thead>
          <tbody>
            {% for i in (1..5) %}
              {% liquid
                assign product_key = 'table_row_' | append: i | append: '_product'
                assign form_key = 'table_row_' | append: i | append: '_form'
                assign date_key = 'table_row_' | append: i | append: '_date'
                assign link_key = 'table_row_' | append: i | append: '_link'
                assign download_key = 'table_row_' | append: i | append: '_download'

                assign product_name = block.settings[product_key]
                assign form_name = block.settings[form_key]
                assign date_verified = block.settings[date_key]
                assign coa_link = block.settings[link_key]
                assign download_link = block.settings[download_key]
              %}
              {% if product_name != blank %}
                <tr>
                  <td>{{ product_name }}</td>
                  <td>{{ form_name }}</td>
                  <td>{{ date_verified }}</td>
                  <td>
                    {% if coa_link != blank %}
                      <a href="{{ coa_link }}" class="ai-coa-library-table-link-{{ ai_gen_id }}" target="_blank">View COA</a>
                    {% endif %}
                  </td>
                  <td>
                    {% if download_link != blank %}
                      <a href="{{ download_link }}" class="ai-coa-library-table-link-{{ ai_gen_id }}" download>Download</a>
                    {% endif %}
                  </td>
                </tr>
              {% endif %}
            {% endfor %}
          </tbody>
        </table>
      </div>

      {% if block.settings.disclaimer_text != blank %}
        <p class="ai-coa-library-disclaimer-{{ ai_gen_id }}">{{ block.settings.disclaimer_text }}</p>
      {% endif %}
    {% endif %}

    {% if block.settings.show_browse_section %}
      <h3 class="ai-coa-library-browse-heading-{{ ai_gen_id }}">{{ block.settings.browse_heading }}</h3>

      <div class="ai-coa-library-cards-{{ ai_gen_id }}">
        <div class="ai-coa-library-card-{{ ai_gen_id }}">
          <h4 class="ai-coa-library-card-title-{{ ai_gen_id }}">{{ block.settings.card_1_title }}</h4>
          <p class="ai-coa-library-card-description-{{ ai_gen_id }}">{{ block.settings.card_1_description }}</p>
          <div class="ai-coa-library-card-buttons-{{ ai_gen_id }}">
            {% if block.settings.card_1_button_1_text != blank and block.settings.card_1_button_1_link != blank %}
              <a href="{{ block.settings.card_1_button_1_link }}" class="ai-coa-library-button-{{ ai_gen_id }}">
                {{ block.settings.card_1_button_1_text }}
              </a>
            {% endif %}
          </div>
        </div>

        <div class="ai-coa-library-card-{{ ai_gen_id }}">
          <h4 class="ai-coa-library-card-title-{{ ai_gen_id }}">{{ block.settings.card_2_title }}</h4>
          <p class="ai-coa-library-card-description-{{ ai_gen_id }}">{{ block.settings.card_2_description }}</p>
          <div class="ai-coa-library-card-buttons-{{ ai_gen_id }}">
            {% if block.settings.card_2_button_1_text != blank and block.settings.card_2_button_1_link != blank %}
              <a href="{{ block.settings.card_2_button_1_link }}" class="ai-coa-library-button-{{ ai_gen_id }}">
                {{ block.settings.card_2_button_1_text }}
              </a>
            {% endif %}
          </div>
        </div>

        <div class="ai-coa-library-card-{{ ai_gen_id }}">
          <h4 class="ai-coa-library-card-title-{{ ai_gen_id }}">{{ block.settings.card_3_title }}</h4>
          <p class="ai-coa-library-card-description-{{ ai_gen_id }}">{{ block.settings.card_3_description }}</p>
          <div class="ai-coa-library-card-buttons-{{ ai_gen_id }}">
            {% if block.settings.card_3_button_1_text != blank and block.settings.card_3_button_1_link != blank %}
              <a href="{{ block.settings.card_3_button_1_link }}" class="ai-coa-library-button-{{ ai_gen_id }}">
                {{ block.settings.card_3_button_1_text }}
              </a>
            {% endif %}
            {% if block.settings.card_3_button_2_text != blank and block.settings.card_3_button_2_link != blank %}
              <a href="{{ block.settings.card_3_button_2_link }}" class="ai-coa-library-button-{{ ai_gen_id }} ai-coa-library-button-secondary-{{ ai_gen_id }}">
                {{ block.settings.card_3_button_2_text }}
              </a>
            {% endif %}
          </div>
        </div>
      </div>
    {% endif %}
  </div>
</coa-library-{{ ai_gen_id }}>

<script>
  (function() {
    class CoaLibrary{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('coa-library-{{ ai_gen_id }}', CoaLibrary{{ ai_gen_id }});
  })();
</script>

{% schema %}
