{% doc %}
  @prompt
    generate a premium, visual "Products Mentioned in This Article" carousel that displays the products mentioned / linked to in the article, include the product image within the card
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-article-products-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
    display: block;
  }

  .ai-article-products__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 var(--page-gutter);
  }

  .ai-article-products__header-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.header_spacing }}px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-article-products__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 600;
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.subtitle_spacing }}px;
    letter-spacing: -0.02em;
  }

  .ai-article-products__subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0;
    line-height: 1.5;
  }

  .ai-article-products__carousel-wrapper-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
  }

  .ai-article-products__carousel-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.card_gap }}px;
    overflow-x: auto;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding: {{ block.settings.carousel_padding }}px 0;
  }

  .ai-article-products__carousel-{{ ai_gen_id }}::-webkit-scrollbar {
    display: none;
  }

  .ai-article-products__card-{{ ai_gen_id }} {
    flex: 0 0 {{ block.settings.card_width }}px;
    background: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    border: {{ block.settings.card_border_width }}px solid {{ block.settings.card_border_color }};
    display: flex;
    flex-direction: column;
  }

  .ai-article-products__card-{{ ai_gen_id }}:hover {
    transform: translateY(-{{ block.settings.hover_lift }}px);
    box-shadow: 0 {{ block.settings.hover_shadow_y }}px {{ block.settings.hover_shadow_blur }}px {{ block.settings.hover_shadow_color }};
  }

  .ai-article-products__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: {{ block.settings.image_aspect_ratio }}%;
    background: {{ block.settings.image_background }};
    overflow: hidden;
    display: block;
  }

  .ai-article-products__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: {{ block.settings.image_fit }};
  }

  .ai-article-products__image-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: {{ block.settings.image_background }};
  }

  .ai-article-products__image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-article-products__content-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding }}px;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .ai-article-products__vendor-{{ ai_gen_id }} {
    font-size: {{ block.settings.vendor_size }}px;
    color: {{ block.settings.vendor_color }};
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0 0 8px;
    font-weight: 500;
  }

  .ai-article-products__product-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_title_size }}px;
    font-weight: 600;
    color: {{ block.settings.product_title_color }};
    margin: 0 0 12px;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .ai-article-products__price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size }}px;
    color: {{ block.settings.price_color }};
    font-weight: 600;
    margin: 0 0 16px;
  }

  .ai-article-products__price-compare-{{ ai_gen_id }} {
    text-decoration: line-through;
    opacity: 0.6;
    margin-left: 8px;
    font-weight: 400;
  }

  .ai-article-products__button-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 12px 20px;
    background: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_size }}px;
    font-weight: 600;
    text-align: center;
    text-decoration: none;
    cursor: pointer;
    transition: background 0.3s ease, transform 0.2s ease;
    margin-top: auto;
  }

  .ai-article-products__button-{{ ai_gen_id }}:hover {
    background: {{ block.settings.button_hover_background }};
    transform: scale(1.02);
  }

  .ai-article-products__nav-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 12px;
    margin-top: {{ block.settings.nav_spacing }}px;
  }

  .ai-article-products__nav-button-{{ ai_gen_id }} {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: {{ block.settings.nav_button_background }};
    border: {{ block.settings.nav_button_border_width }}px solid {{ block.settings.nav_button_border_color }};
    color: {{ block.settings.nav_button_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .ai-article-products__nav-button-{{ ai_gen_id }}:hover {
    background: {{ block.settings.nav_button_hover_background }};
    color: {{ block.settings.nav_button_hover_color }};
    transform: scale(1.1);
  }

  .ai-article-products__nav-button-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
    transform: scale(1);
  }

  .ai-article-products__empty-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: {{ block.settings.subtitle_color }};
    font-size: 16px;
  }

  @media screen and (max-width: 749px) {
    .ai-article-products__card-{{ ai_gen_id }} {
      flex: 0 0 {{ block.settings.card_width_mobile }}px;
    }

    .ai-article-products__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.8 }}px;
    }

    .ai-article-products__carousel-{{ ai_gen_id }} {
      gap: {{ block.settings.card_gap | times: 0.7 }}px;
    }
  }
{% endstyle %}

<article-products-carousel-{{ ai_gen_id }}
  class="ai-article-products-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-article-products__container-{{ ai_gen_id }}">
    {% if block.settings.show_header %}
      <div class="ai-article-products__header-{{ ai_gen_id }}">
        {% if block.settings.title != blank %}
          <h2 class="ai-article-products__title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
        {% endif %}
        {% if block.settings.subtitle != blank %}
          <p class="ai-article-products__subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</p>
        {% endif %}
      </div>
    {% endif %}

    {% assign product_list = block.settings.products %}

    {% if product_list.count > 0 %}
      <div class="ai-article-products__carousel-wrapper-{{ ai_gen_id }}">
        <div class="ai-article-products__carousel-{{ ai_gen_id }}" data-carousel>
          {% for product in product_list %}
            <div class="ai-article-products__card-{{ ai_gen_id }}">
              <a href="{{ product.url }}" class="ai-article-products__image-wrapper-{{ ai_gen_id }}">
                {% if product.featured_image %}
                  <img
                    src="{{ product.featured_image | image_url: width: 600 }}"
                    alt="{{ product.featured_image.alt | escape }}"
                    class="ai-article-products__image-{{ ai_gen_id }}"
                    loading="lazy"
                    width="600"
                    height="{{ 600 | times: block.settings.image_aspect_ratio | divided_by: 100 }}"
                  >
                {% else %}
                  <div class="ai-article-products__image-placeholder-{{ ai_gen_id }}">
                    {{ 'product-1' | placeholder_svg_tag }}
                  </div>
                {% endif %}
              </a>

              <div class="ai-article-products__content-{{ ai_gen_id }}">
                {% if block.settings.show_vendor and product.vendor != blank %}
                  <p class="ai-article-products__vendor-{{ ai_gen_id }}">{{ product.vendor }}</p>
                {% endif %}

                <h3 class="ai-article-products__product-title-{{ ai_gen_id }}">
                  <a href="{{ product.url }}" style="color: inherit; text-decoration: none;">
                    {{ product.title }}
                  </a>
                </h3>

                {% if block.settings.show_price %}
                  <div class="ai-article-products__price-{{ ai_gen_id }}">
                    {{ product.price | money }}
                    {% if product.compare_at_price > product.price %}
                      <span class="ai-article-products__price-compare-{{ ai_gen_id }}">
                        {{ product.compare_at_price | money }}
                      </span>
                    {% endif %}
                  </div>
                {% endif %}

                {% if block.settings.show_button %}
                  <a href="{{ product.url }}" class="ai-article-products__button-{{ ai_gen_id }}">
                    {{ block.settings.button_text }}
                  </a>
                {% endif %}
              </div>
            </div>
          {% endfor %}
        </div>
      </div>

      {% if block.settings.show_navigation %}
        <div class="ai-article-products__nav-{{ ai_gen_id }}">
          <button
            class="ai-article-products__nav-button-{{ ai_gen_id }}"
            data-nav-prev
            aria-label="Previous products"
          >
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 4L6 10L12 16" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <button
            class="ai-article-products__nav-button-{{ ai_gen_id }}"
            data-nav-next
            aria-label="Next products"
          >
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M8 4L14 10L8 16" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>
      {% endif %}
    {% else %}
      <div class="ai-article-products__empty-{{ ai_gen_id }}">
        Add products to showcase items mentioned in this article
      </div>
    {% endif %}
  </div>
</article-products-carousel-{{ ai_gen_id }}>

<script>
  (function() {
    class ArticleProductsCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.carousel = this.querySelector('[data-carousel]');
        this.prevButton = this.querySelector('[data-nav-prev]');
        this.nextButton = this.querySelector('[data-nav-next]');

        if (!this.carousel) return;

        this.cardWidth = {{ block.settings.card_width }};
        this.cardGap = {{ block.settings.card_gap }};
        this.scrollAmount = this.cardWidth + this.cardGap;

        this.setupNavigation();
        this.updateNavigationState();

        this.carousel.addEventListener('scroll', () => {
          this.updateNavigationState();
        });
      }

      setupNavigation() {
        if (this.prevButton) {
          this.prevButton.addEventListener('click', () => {
            this.carousel.scrollBy({
              left: -this.scrollAmount,
              behavior: 'smooth'
            });
          });
        }

        if (this.nextButton) {
          this.nextButton.addEventListener('click', () => {
            this.carousel.scrollBy({
              left: this.scrollAmount,
              behavior: 'smooth'
            });
          });
        }
      }

      updateNavigationState() {
        if (!this.prevButton || !this.nextButton) return;

        const scrollLeft = this.carousel.scrollLeft;
        const maxScroll = this.carousel.scrollWidth - this.carousel.clientWidth;

        this.prevButton.disabled = scrollLeft <= 0;
        this.nextButton.disabled = scrollLeft >= maxScroll - 1;
      }
    }

    customElements.define('article-products-carousel-{{ ai_gen_id }}', ArticleProductsCarousel{{ ai_gen_id }});
  })();
</script>

