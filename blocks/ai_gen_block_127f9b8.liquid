{% doc %}
  @prompt
    create product section with breadcrumbs, with 50% left product image & thumbnail underneath it. 50% right product information: title, price, custom code field, quantity + add to cart button, underneath it 3 badges (1 per line), underneath them a crertificate of analysis download link / thumbnail, all customizable 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-section-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding: {{ block.settings.section_padding }}px var(--page-gutter);
  }

  .ai-breadcrumbs-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.breadcrumb_spacing }}px;
    font-size: 14px;
  }

  .ai-breadcrumbs-{{ ai_gen_id }} a {
    color: {{ block.settings.breadcrumb_color }};
    text-decoration: none;
  }

  .ai-breadcrumbs-{{ ai_gen_id }} a:hover {
    text-decoration: underline;
  }

  .ai-breadcrumbs-{{ ai_gen_id }} span {
    color: {{ block.settings.breadcrumb_text_color }};
    margin: 0 8px;
  }

  .ai-product-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ block.settings.column_gap }}px;
  }

  .ai-product-images-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ai-main-image-{{ ai_gen_id }} {
    width: 100%;
    border-radius: {{ block.settings.image_border_radius }}px;
    overflow: hidden;
    background-color: {{ block.settings.image_background }};
  }

  .ai-main-image-{{ ai_gen_id }} img {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-thumbnails-{{ ai_gen_id }} {
    display: flex;
    gap: 12px;
    overflow-x: auto;
  }

  .ai-thumbnail-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.thumbnail_size }}px;
    height: {{ block.settings.thumbnail_size }}px;
    border-radius: {{ block.settings.thumbnail_border_radius }}px;
    overflow: hidden;
    cursor: pointer;
    border: 2px solid transparent;
    transition: border-color 0.3s ease;
  }

  .ai-thumbnail-{{ ai_gen_id }}.active {
    border-color: {{ block.settings.thumbnail_active_border }};
  }

  .ai-thumbnail-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-product-info-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.info_spacing }}px;
  }

  .ai-product-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 600;
    color: {{ block.settings.title_color }};
    margin: 0;
  }

  .ai-product-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size }}px;
    color: {{ block.settings.price_color }};
    font-weight: 500;
  }

  .ai-product-price-{{ ai_gen_id }} .compare-at {
    text-decoration: line-through;
    color: {{ block.settings.compare_price_color }};
    margin-left: 8px;
  }

  .ai-custom-code-{{ ai_gen_id }} {
    padding: {{ block.settings.custom_code_padding }}px;
    background-color: {{ block.settings.custom_code_bg }};
    border-radius: {{ block.settings.custom_code_border_radius }}px;
  }

  .ai-quantity-cart-{{ ai_gen_id }} {
    display: flex;
    gap: 12px;
    align-items: center;
  }

  .ai-quantity-selector-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    border: 1px solid {{ block.settings.quantity_border_color }};
    border-radius: {{ block.settings.quantity_border_radius }}px;
    overflow: hidden;
  }

  .ai-quantity-button-{{ ai_gen_id }} {
    width: 40px;
    height: 40px;
    border: none;
    background-color: {{ block.settings.quantity_button_bg }};
    color: {{ block.settings.quantity_button_color }};
    cursor: pointer;
    font-size: 18px;
    transition: background-color 0.3s ease;
  }

  .ai-quantity-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.quantity_button_hover_bg }};
  }

  .ai-quantity-input-{{ ai_gen_id }} {
    width: 60px;
    height: 40px;
    border: none;
    text-align: center;
    font-size: 16px;
  }

  .ai-add-to-cart-{{ ai_gen_id }} {
    flex: 1;
    height: 50px;
    background-color: {{ block.settings.button_bg }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.3s ease;
  }

  .ai-add-to-cart-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg }};
  }

  .ai-badges-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .ai-badge-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: {{ block.settings.badge_padding }}px;
    background-color: {{ block.settings.badge_bg }};
    border-radius: {{ block.settings.badge_border_radius }}px;
    font-size: {{ block.settings.badge_font_size }}px;
  }

  .ai-badge-icon-{{ ai_gen_id }} {
    width: {{ block.settings.badge_icon_size }}px;
    height: {{ block.settings.badge_icon_size }}px;
    flex-shrink: 0;
  }

  .ai-badge-icon-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .ai-badge-text-{{ ai_gen_id }} {
    color: {{ block.settings.badge_text_color }};
  }

  .ai-certificate-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: {{ block.settings.certificate_padding }}px;
    background-color: {{ block.settings.certificate_bg }};
    border-radius: {{ block.settings.certificate_border_radius }}px;
    text-decoration: none;
    transition: background-color 0.3s ease;
  }

  .ai-certificate-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.certificate_hover_bg }};
  }

  .ai-certificate-thumbnail-{{ ai_gen_id }} {
    width: {{ block.settings.certificate_thumbnail_size }}px;
    height: {{ block.settings.certificate_thumbnail_size }}px;
    flex-shrink: 0;
    border-radius: 4px;
    overflow: hidden;
  }

  .ai-certificate-thumbnail-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-certificate-text-{{ ai_gen_id }} {
    color: {{ block.settings.certificate_text_color }};
    font-size: {{ block.settings.certificate_font_size }}px;
    font-weight: 500;
  }

  @media screen and (max-width: 768px) {
    .ai-product-container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .ai-quantity-cart-{{ ai_gen_id }} {
      flex-direction: column;
      align-items: stretch;
    }

    .ai-quantity-selector-{{ ai_gen_id }} {
      justify-content: center;
    }
  }
{% endstyle %}

<div class="ai-product-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.show_breadcrumbs %}
    <nav class="ai-breadcrumbs-{{ ai_gen_id }}" aria-label="Breadcrumb">
      <a href="{{ routes.root_url }}">Home</a>
      <span>/</span>
      {% if product.collections.size > 0 %}
        <a href="{{ product.collections.first.url }}">{{ product.collections.first.title }}</a>
        <span>/</span>
      {% endif %}
      <span>{{ product.title }}</span>
    </nav>
  {% endif %}

  <div class="ai-product-container-{{ ai_gen_id }}">
    <div class="ai-product-images-{{ ai_gen_id }}">
      <div class="ai-main-image-{{ ai_gen_id }}" id="ai-main-image-{{ ai_gen_id }}">
        {% if product.featured_image %}
          <img
            src="{{ product.featured_image | image_url: width: 1000 }}"
            alt="{{ product.featured_image.alt | escape }}"
            width="{{ product.featured_image.width }}"
            height="{{ product.featured_image.height }}"
            loading="eager"
          >
        {% else %}
          <div class="ai-image-placeholder-{{ ai_gen_id }}">
            {{ 'product-1' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>

      {% if product.images.size > 1 %}
        <div class="ai-thumbnails-{{ ai_gen_id }}">
          {% for image in product.images limit: 6 %}
            <div
              class="ai-thumbnail-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}"
              data-image-url="{{ image | image_url: width: 1000 }}"
              data-image-alt="{{ image.alt | escape }}"
            >
              <img
                src="{{ image | image_url: width: 200 }}"
                alt="{{ image.alt | escape }}"
                width="200"
                height="200"
                loading="lazy"
              >
            </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>

    <div class="ai-product-info-{{ ai_gen_id }}">
      <h1 class="ai-product-title-{{ ai_gen_id }}">{{ product.title }}</h1>

      <div class="ai-product-price-{{ ai_gen_id }}">
        <span class="price">{{ product.price | money }}</span>
        {% if product.compare_at_price > product.price %}
          <span class="compare-at">{{ product.compare_at_price | money }}</span>
        {% endif %}
      </div>

      {% if block.settings.custom_code != blank %}
        <div class="ai-custom-code-{{ ai_gen_id }}">
          {{ block.settings.custom_code }}
        </div>
      {% endif %}

      {%- form 'product', product, id: 'ai-product-form-' | append: ai_gen_id -%}
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">

        <div class="ai-quantity-cart-{{ ai_gen_id }}">
          <div class="ai-quantity-selector-{{ ai_gen_id }}">
            <button
              type="button"
              class="ai-quantity-button-{{ ai_gen_id }}"
              aria-label="Decrease quantity"
              data-action="decrease"
            >
              −
            </button>
            <input
              type="number"
              name="quantity"
              value="1"
              min="1"
              inputmode="numeric"
              pattern="[0-9]*"
              class="ai-quantity-input-{{ ai_gen_id }}"
              aria-label="Quantity"
            >
            <button
              type="button"
              class="ai-quantity-button-{{ ai_gen_id }}"
              aria-label="Increase quantity"
              data-action="increase"
            >
              +
            </button>
          </div>

          <button
            type="submit"
            class="ai-add-to-cart-{{ ai_gen_id }}"
            {% unless product.available %}disabled{% endunless %}
          >
            {% if product.available %}
              {{ block.settings.button_text }}
            {% else %}
              Sold Out
            {% endif %}
          </button>
        </div>
      {%- endform -%}

      {% if block.settings.show_badges %}
        <div class="ai-badges-{{ ai_gen_id }}">
          {% if block.settings.badge_1_text != blank %}
            <div class="ai-badge-{{ ai_gen_id }}">
              {% if block.settings.badge_1_icon %}
                <div class="ai-badge-icon-{{ ai_gen_id }}">
                  <img
                    src="{{ block.settings.badge_1_icon | image_url: width: 100 }}"
                    alt="Badge icon"
                    width="100"
                    height="100"
                    loading="lazy"
                  >
                </div>
              {% endif %}
              <div class="ai-badge-text-{{ ai_gen_id }}">{{ block.settings.badge_1_text }}</div>
            </div>
          {% endif %}

          {% if block.settings.badge_2_text != blank %}
            <div class="ai-badge-{{ ai_gen_id }}">
              {% if block.settings.badge_2_icon %}
                <div class="ai-badge-icon-{{ ai_gen_id }}">
                  <img
                    src="{{ block.settings.badge_2_icon | image_url: width: 100 }}"
                    alt="Badge icon"
                    width="100"
                    height="100"
                    loading="lazy"
                  >
                </div>
              {% endif %}
              <div class="ai-badge-text-{{ ai_gen_id }}">{{ block.settings.badge_2_text }}</div>
            </div>
          {% endif %}

          {% if block.settings.badge_3_text != blank %}
            <div class="ai-badge-{{ ai_gen_id }}">
              {% if block.settings.badge_3_icon %}
                <div class="ai-badge-icon-{{ ai_gen_id }}">
                  <img
                    src="{{ block.settings.badge_3_icon | image_url: width: 100 }}"
                    alt="Badge icon"
                    width="100"
                    height="100"
                    loading="lazy"
                  >
                </div>
              {% endif %}
              <div class="ai-badge-text-{{ ai_gen_id }}">{{ block.settings.badge_3_text }}</div>
            </div>
          {% endif %}
        </div>
      {% endif %}

      {% if block.settings.show_certificate and block.settings.certificate_link != blank %}
        <a
          href="{{ block.settings.certificate_link }}"
          class="ai-certificate-{{ ai_gen_id }}"
          {% if block.settings.certificate_download %}download{% endif %}
          target="_blank"
        >
          {% if block.settings.certificate_thumbnail %}
            <div class="ai-certificate-thumbnail-{{ ai_gen_id }}">
              <img
                src="{{ block.settings.certificate_thumbnail | image_url: width: 200 }}"
                alt="Certificate"
                width="200"
                height="200"
                loading="lazy"
              >
            </div>
          {% endif %}
          <div class="ai-certificate-text-{{ ai_gen_id }}">
            {{ block.settings.certificate_text }}
          </div>
        </a>
      {% endif %}
    </div>
  </div>
</div>

<script>
  (function() {
    class ProductSection{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.thumbnails = this.querySelectorAll('.ai-thumbnail-{{ ai_gen_id }}');
        this.mainImage = this.querySelector('#ai-main-image-{{ ai_gen_id }} img');
        this.quantityInput = this.querySelector('.ai-quantity-input-{{ ai_gen_id }}');
        this.quantityButtons = this.querySelectorAll('.ai-quantity-button-{{ ai_gen_id }}');
      }

      connectedCallback() {
        this.setupThumbnails();
        this.setupQuantity();
      }

      setupThumbnails() {
        this.thumbnails.forEach((thumbnail) => {
          thumbnail.addEventListener('click', () => {
            const imageUrl = thumbnail.dataset.imageUrl;
            const imageAlt = thumbnail.dataset.imageAlt;

            if (this.mainImage) {
              this.mainImage.src = imageUrl;
              this.mainImage.alt = imageAlt;
            }

            this.thumbnails.forEach((t) => t.classList.remove('active'));
            thumbnail.classList.add('active');
          });
        });
      }

      setupQuantity() {
        this.quantityButtons.forEach((button) => {
          button.addEventListener('click', () => {
            const action = button.dataset.action;
            let currentValue = parseInt(this.quantityInput.value) || 1;

            if (action === 'increase') {
              currentValue += 1;
            } else if (action === 'decrease' && currentValue > 1) {
              currentValue -= 1;
            }

            this.quantityInput.value = currentValue;
          });
        });

        this.quantityInput.addEventListener('change', () => {
          let value = parseInt(this.quantityInput.value) || 1;
          if (value < 1) {
            value = 1;
          }
          this.quantityInput.value = value;
        });
      }
    }

    customElements.define('product-section-{{ ai_gen_id }}', ProductSection{{ ai_gen_id }});

    const productSection = document.querySelector('.ai-product-section-{{ ai_gen_id }}');
    if (productSection && !customElements.get('product-section-{{ ai_gen_id }}')) {
      const wrapper = document.createElement('product-section-{{ ai_gen_id }}');
      productSection.parentNode.insertBefore(wrapper, productSection);
      wrapper.appendChild(productSection);
    }
  })();
</script>

