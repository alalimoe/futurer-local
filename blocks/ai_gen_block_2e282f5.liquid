{% doc %}
  @prompt
    create clean, modern "Related guides"
    
    Use a 2x2 grid of cards:
    
    How to Read a COA (HPLC & LC‑MS)
    
    UAE Quality & Trust Guide (Checklist)
    
    Shipping in UAE Heat
    
    Storage & Handling
    
    (Each card links to the targets in the link map above.) followed by FAQs (accordion)
    
    Add 6–8 accordions:
    
    FAQ 1: Are COAs batch-specific?
    COAs only matter when they match a real batch/lot. Always match the lot on your unit to the lot shown on the COA.
    
    FAQ 2: Do COAs guarantee legality or regulatory status?
    No. A COA is a lab document about analysis results. Legality depends on ingredient classification, labeling, and import context.
    
    FAQ 3: What if my label and COA don’t match?
    Pause. Take photos of the label + packaging and contact support with your order number. Don’t “assume” a mismatch is fine.
    
    FAQ 4: Why do some COAs look different?
    Different labs and methods produce different report formats. What matters is: batch match, methods stated, and real results.
    
    FAQ 5: What methods should I expect to see?
    Commonly HPLC for purity/assay and LC‑MS/MS or similar methods for identity confirmation (varies by compound and lab).
    
    FAQ 6: I’m in the UAE—does shipping heat matter?
    Heat and last‑mile delivery conditions can matter. Receive parcels quickly and store as directed. & Small text disclaimer:
    Educational information only. Not medical advice. Follow product labeling, storage guidance, and local regulations. Where products are labeled for research use, they are not intended for human consumption.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-related-guides-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding_top }}px var(--page-gutter) {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-related-guides__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-related-guides__heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-related-guides__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: {{ block.settings.card_gap }}px;
    margin-bottom: {{ block.settings.section_spacing }}px;
  }

  .ai-related-guides__card-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    padding: {{ block.settings.card_padding }}px;
    background-color: {{ block.settings.card_background }};
    border: {{ block.settings.card_border_width }}px solid {{ block.settings.card_border_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    text-decoration: none;
    transition: var(--transition-smooth);
    min-height: 120px;
  }

  .ai-related-guides__card-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.card_hover_background }};
    border-color: {{ block.settings.card_hover_border_color }};
    transform: translateY(-2px);
    box-shadow: var(--shadow-sm);
  }

  .ai-related-guides__card-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_title_size }}px;
    font-weight: 600;
    color: {{ block.settings.card_title_color }};
    margin: 0;
    line-height: 1.4;
  }

  .ai-related-guides__card-{{ ai_gen_id }}:hover .ai-related-guides__card-title-{{ ai_gen_id }} {
    color: {{ block.settings.card_title_hover_color }};
  }

  .ai-related-guides__faq-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.faq_heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.faq_heading_spacing }}px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-related-guides__accordion-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.accordion_gap }}px;
  }

  .ai-related-guides__accordion-item-{{ ai_gen_id }} {
    border: {{ block.settings.accordion_border_width }}px solid {{ block.settings.accordion_border_color }};
    border-radius: {{ block.settings.accordion_border_radius }}px;
    overflow: hidden;
    background-color: {{ block.settings.accordion_background }};
  }

  .ai-related-guides__accordion-button-{{ ai_gen_id }} {
    width: 100%;
    padding: {{ block.settings.accordion_padding }}px;
    background: none;
    border: none;
    text-align: left;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    transition: background-color 0.3s ease;
  }

  .ai-related-guides__accordion-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.accordion_hover_background }};
  }

  .ai-related-guides__accordion-question-{{ ai_gen_id }} {
    font-size: {{ block.settings.accordion_question_size }}px;
    font-weight: 600;
    color: {{ block.settings.accordion_question_color }};
    margin: 0;
    line-height: 1.4;
  }

  .ai-related-guides__accordion-icon-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    transition: transform 0.3s ease;
    color: {{ block.settings.accordion_icon_color }};
  }

  .ai-related-guides__accordion-item-{{ ai_gen_id }}.active .ai-related-guides__accordion-icon-{{ ai_gen_id }} {
    transform: rotate(180deg);
  }

  .ai-related-guides__accordion-content-{{ ai_gen_id }} {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
  }

  .ai-related-guides__accordion-answer-{{ ai_gen_id }} {
    padding: 0 {{ block.settings.accordion_padding }}px {{ block.settings.accordion_padding }}px;
    font-size: {{ block.settings.accordion_answer_size }}px;
    color: {{ block.settings.accordion_answer_color }};
    line-height: 1.6;
  }

  .ai-related-guides__disclaimer-{{ ai_gen_id }} {
    margin-top: {{ block.settings.disclaimer_spacing }}px;
    padding: {{ block.settings.disclaimer_padding }}px;
    background-color: {{ block.settings.disclaimer_background }};
    border-radius: {{ block.settings.disclaimer_border_radius }}px;
    font-size: {{ block.settings.disclaimer_size }}px;
    color: {{ block.settings.disclaimer_color }};
    line-height: 1.5;
  }

  @media screen and (max-width: 749px) {
    .ai-related-guides__grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-related-guides__faq-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.faq_heading_size }}px * 0.85);
    }

    .ai-related-guides__card-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.card_title_size }}px * 0.9);
    }
  }
{% endstyle %}

