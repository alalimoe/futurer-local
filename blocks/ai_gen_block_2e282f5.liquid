<script>
  (function() {
    class RelatedGuides{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.accordionButtons = this.querySelectorAll('.ai-related-guides__accordion-button-{{ ai_gen_id }}');
        this.setupAccordion();
      }

      setupAccordion() {
        this.accordionButtons.forEach((button) => {
          button.addEventListener('click', () => {
            const item = button.closest('.ai-related-guides__accordion-item-{{ ai_gen_id }}');
            const content = item.querySelector('.ai-related-guides__accordion-content-{{ ai_gen_id }}');
            const isActive = item.classList.contains('active');

            if (isActive) {
              item.classList.remove('active');
              content.style.maxHeight = null;
              button.setAttribute('aria-expanded', 'false');
            } else {
              item.classList.add('active');
              content.style.maxHeight = content.scrollHeight + 'px';
              button.setAttribute('aria-expanded', 'true');
            }
          });
        });
      }
    }

    customElements.define('related-guides-{{ ai_gen_id }}', RelatedGuides{{ ai_gen_id }});
  })();
</script>

