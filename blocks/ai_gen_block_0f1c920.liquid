{% doc %}
  @prompt
    Safety banner (new block)
    
    A styled callout that is always visible near top:
    
    "Read safety + interactions before use."
    
    Button anchor: "Jump to Safety"
    
    Controls:
    
    Background color / border
    
    Text + link label
    
    Show/hide
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{%- style -%}
  .ai-safety-banner-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: color-mix(in srgb, rgba(var(--color-accent)) 10%, rgba(var(--color-background)));
    border: {{ block.settings.border_thickness }}px solid rgba(var(--color-accent));
    padding: 16px var(--page-gutter);
  }

  .ai-safety-banner-{{ ai_gen_id }}--hidden {
    display: none;
  }

  .ai-safety-banner__container-{{ ai_gen_id }} {
    max-width: {{ settings.page_width }}px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .ai-safety-banner__text-{{ ai_gen_id }} {
    color: rgba(var(--color-foreground));
    font-size: 16px;
    margin: 0;
    flex-grow: 1;
  }

  .ai-safety-banner__button-{{ ai_gen_id }} {
    background-color: rgba(var(--color-accent));
    color: rgba(var(--color-foreground));
    border: none;
    padding: 10px 20px;
    border-radius: 4px;
    cursor: pointer;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    white-space: nowrap;
    transition: background-color 0.3s var(--out-soft, ease);
  }

  .ai-safety-banner__button-{{ ai_gen_id }}:hover {
    background-color: color-mix(in srgb, rgba(var(--color-accent)) 85%, transparent);
  }

  @media screen and (max-width: 768px) {
    .ai-safety-banner__container-{{ ai_gen_id }} {
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
    }

    .ai-safety-banner__button-{{ ai_gen_id }} {
      width: 100%;
      text-align: center;
    }
  }
{%- endstyle -%}

<safety-banner-{{ ai_gen_id }}
  class="ai-safety-banner-{{ ai_gen_id }} color-{{ block.settings.color_scheme }} {% unless block.settings.show_banner %}ai-safety-banner-{{ ai_gen_id }}--hidden{% endunless %}"
  {{ block.shopify_attributes }}
>
  <div class="ai-safety-banner__container-{{ ai_gen_id }}">
    <p class="ai-safety-banner__text-{{ ai_gen_id }}">
      {{ block.settings.banner_text }}
    </p>
    <a
      href="{{ block.settings.anchor_link }}"
      class="ai-safety-banner__button-{{ ai_gen_id }}"
    >
      {{ block.settings.button_label }}
    </a>
  </div>
</safety-banner-{{ ai_gen_id }}>

<script>
  (function() {
    class SafetyBanner{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupSmoothScroll();
      }

      setupSmoothScroll() {
        const button = this.querySelector('.ai-safety-banner__button-{{ ai_gen_id }}');
        if (!button) return;

        button.addEventListener('click', function(event) {
          const href = this.getAttribute('href');
          if (!href || !href.startsWith('#')) return;

          event.preventDefault();
          const targetId = href.substring(1);
          const targetElement = document.getElementById(targetId);

          if (targetElement) {
            targetElement.scrollIntoView({
              behavior: 'smooth',
              block: 'start'
            });
          }
        });
      }
    }

    customElements.define('safety-banner-{{ ai_gen_id }}', SafetyBanner{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Safety banner",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "default"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "banner_text",
      "label": "Banner text",
      "default": "Read safety + interactions before use."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Jump to Safety"
    },
    {
      "type": "text",
      "id": "anchor_link",
      "label": "Anchor link",
      "default": "#safety",
      "info": "Use format #section-id to link to a section on the page"
    },
    {
      "type": "header",
      "content": "Visibility"
    },
    {
      "type": "checkbox",
      "id": "show_banner",
      "label": "Show banner",
      "default": true
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "range",
      "id": "border_thickness",
      "min": 0,
      "max": 10,
      "step": 1,
      "unit": "px",
      "label": "Border thickness",
      "default": 2
    }
  ],
  "presets": [
    {
      "name": "Safety banner"
    }
  ]
}
{% endschema %}
