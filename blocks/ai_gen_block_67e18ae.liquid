{% doc %}
  @name Trust Information
  @desc Block rendering 1-2 trust/info messages with inline SVG icons. Uses theme tokens exclusively. No hardcoded colors.
{% enddoc %}

{%- style -%}
  .xo-block--{{ block.id }} {
    display: block;
    padding: 2rem;
    background: rgba(var(--color-background-2));
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 8%, transparent);
    border-radius: var(--general-radius-3);
    font-family: var(--font-body-family, sans-serif);
  }

  .xo-block--{{ block.id }} .ti__content {
    display: flex;
    flex-direction: column;
    gap: 1.6rem;
  }

  .xo-block--{{ block.id }} .ti__item {
    display: flex;
    align-items: flex-start;
    gap: 1.2rem;
  }

  .xo-block--{{ block.id }} .ti__icon {
    flex-shrink: 0;
    width: 2.4rem;
    height: 2.4rem;
    margin-top: 0.2rem;
    color: rgba(var(--color-accent));
  }

  .xo-block--{{ block.id }} .ti__icon svg {
    width: 100%;
    height: 100%;
    fill: currentColor;
  }

  .xo-block--{{ block.id }} .ti__text {
    flex: 1;
    color: rgba(var(--color-foreground));
    font-size: calc(var(--font-body-scale, 1) * 1.4rem);
    line-height: 1.6;
  }

  .xo-block--{{ block.id }} .ti__text a {
    color: rgba(var(--color-accent));
    text-decoration: none;
    font-weight: 600;
    border-bottom: 1px solid color-mix(in srgb, rgba(var(--color-accent)) 30%, transparent);
    transition: border-color 0.2s var(--out-soft, ease);
  }

  .xo-block--{{ block.id }} .ti__text a:hover {
    border-color: rgba(var(--color-accent));
  }

  .xo-block--{{ block.id }} .ti__text a:focus-visible {
    outline: 2px solid rgba(var(--color-accent));
    outline-offset: 2px;
    border-radius: 4px;
  }

  @media (prefers-reduced-motion: reduce) {
    .xo-block--{{ block.id }} .ti__text a {
      transition: none;
    }
  }
{%- endstyle -%}

<div class="xo-block--{{ block.id }}" {{ block.shopify_attributes }}>
  <div class="ti__content">
    {% if block.settings.text_1 != blank %}
      <div class="ti__item">
        <div class="ti__icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z"/>
          </svg>
        </div>
        <div class="ti__text">{{ block.settings.text_1 }}</div>
      </div>
    {% endif %}

    {% if block.settings.text_2 != blank %}
      <div class="ti__item">
        <div class="ti__icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M18.92 6.01C18.72 5.42 18.16 5 17.5 5h-11c-.66 0-1.21.42-1.42 1.01L3 12v8c0 .55.45 1 1 1h1c.55 0 1-.45 1-1v-1h12v1c0 .55.45 1 1 1h1c.55 0 1-.45 1-1v-8l-2.08-5.99zM6.5 16c-.83 0-1.5-.67-1.5-1.5S5.67 13 6.5 13s1.5.67 1.5 1.5S7.33 16 6.5 16zm11 0c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zM5 11l1.5-4.5h11L19 11H5z"/>
          </svg>
        </div>
        <div class="ti__text">{{ block.settings.text_2 }}</div>
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Trust information",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "richtext",
      "id": "text_1",
      "label": "First message",
      "default": "<p>To protect yourself from unverified vendors and ensure you are getting pure, lab-tested material, review our comprehensive <a href=\"#\">UAE Quality & Trust Guide</a> before finalizing your purchase.</p>"
    },
    {
      "type": "richtext",
      "id": "text_2",
      "label": "Second message",
      "default": "<p>Because delicate amino acid chains can degrade quickly in extreme temperatures, our logistics team utilizes strict protocols for <a href=\"#\">shipping peptides safely in UAE heat</a> to guarantee product stability upon arrival.</p>"
    }
  ],
  "presets": [
    {
      "name": "Trust information"
    }
  ]
}
{% endschema %}
