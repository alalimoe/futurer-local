{% doc %}
  @prompt
    Template → Section B: “The Reference Stack” (container)
    
    This is the meat: the 7 “reference blocks” you described.
    
    Blocks inside Section B (in this order)
    
    You can do this two ways:
    
    Option 1 (fast + matches your screenshot): repeat your existing Reference content block 7 times
    
    Add 7 blocks and set each to a specific data source.
    
    Block B1 — TL;DR (metafield driven)
    Block B2 — What it is
    Block B3 — What you’ll feel (timeline)
    Block B4 — How it works
    Block B5 — How to use
    Block B6 — Why {form}?
    Block B7 — Safety & interactions
    Block B8 (optional) — FAQ
    
    Controls per block (what you want in the editor):
    
    Heading text (editable)
    
    Data source dropdown (tldr / what_it_is / feel_timeline / feel_note / how_it_works / how_to_use / why / safety / faq)
    
    Layout style:
    
    Card (default)
    
    Accordion (great for Safety + FAQ)
    
    Plain (for short content)
    
    UX notes:
    
    Use card surfaces with subtle borders.
    
    Make Safety + FAQ accordion by default to keep the page scannable.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-reference-block-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    margin-bottom: 24px;
  }

  .ai-reference-block__card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    border-radius: {{ block.settings.border_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    transition: all 0.3s ease;
  }

  .ai-reference-block__plain-{{ ai_gen_id }} {
    background-color: transparent;
    border: none;
    padding: {{ block.settings.plain_padding }}px 0;
  }

  .ai-reference-block__heading-{{ ai_gen_id }} {
    font-weight: {{ block.settings.heading_weight }};
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.heading_spacing }}px 0;
    line-height: 1.3;
  }

  .ai-reference-block__content-{{ ai_gen_id }} {
    font-size: {{ block.settings.content_size }}px;
    line-height: {{ block.settings.content_line_height }};
    color: {{ block.settings.content_color }};
  }

  .ai-reference-block__content-{{ ai_gen_id }} p {
    margin: 0 0 12px 0;
  }

  .ai-reference-block__content-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  .ai-reference-block__content-{{ ai_gen_id }} ul,
  .ai-reference-block__content-{{ ai_gen_id }} ol {
    margin: 0 0 12px 0;
    padding-left: 24px;
  }

  .ai-reference-block__content-{{ ai_gen_id }} li {
    margin-bottom: 8px;
  }

  .ai-reference-block__content-{{ ai_gen_id }} strong {
    font-weight: 600;
  }

  .ai-reference-block__accordion-{{ ai_gen_id }} {
    border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
  }

  .ai-reference-block__accordion-header-{{ ai_gen_id }} {
    width: 100%;
    background-color: {{ block.settings.accordion_header_bg }};
    border: none;
    padding: {{ block.settings.accordion_padding }}px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    transition: background-color 0.3s ease;
    text-align: left;
  }

  .ai-reference-block__accordion-header-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.accordion_header_hover }};
  }

  .ai-reference-block__accordion-title-{{ ai_gen_id }} {
    font-weight: {{ block.settings.heading_weight }};
    color: {{ block.settings.heading_color }};
    margin: 0;
  }

  .ai-reference-block__accordion-icon-{{ ai_gen_id }} {
    width: 20px;
    height: 20px;
    transition: transform 0.3s ease;
    flex-shrink: 0;
    margin-left: 16px;
  }

  .ai-reference-block__accordion-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    stroke: {{ block.settings.heading_color }};
  }

  .ai-reference-block__accordion-header-{{ ai_gen_id }}[aria-expanded="true"] .ai-reference-block__accordion-icon-{{ ai_gen_id }} {
    transform: rotate(180deg);
  }

  .ai-reference-block__accordion-body-{{ ai_gen_id }} {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s ease;
    background-color: {{ block.settings.card_background }};
  }

  .ai-reference-block__accordion-body-{{ ai_gen_id }}.active {
    max-height: 2000px;
  }

  .ai-reference-block__accordion-content-{{ ai_gen_id }} {
    padding: 0 {{ block.settings.accordion_padding }}px {{ block.settings.accordion_padding }}px;
    font-size: {{ block.settings.content_size }}px;
    line-height: {{ block.settings.content_line_height }};
    color: {{ block.settings.content_color }};
  }

  .ai-reference-block__accordion-content-{{ ai_gen_id }} p {
    margin: 0 0 12px 0;
  }

  .ai-reference-block__accordion-content-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  .ai-reference-block__accordion-content-{{ ai_gen_id }} ul,
  .ai-reference-block__accordion-content-{{ ai_gen_id }} ol {
    margin: 0 0 12px 0;
    padding-left: 24px;
  }

  .ai-reference-block__accordion-content-{{ ai_gen_id }} li {
    margin-bottom: 8px;
  }

  .ai-reference-block__empty-{{ ai_gen_id }} {
    padding: 40px 20px;
    text-align: center;
    color: #999;
    font-style: italic;
    background-color: var(--color-surface-secondary);
    border-radius: {{ block.settings.border_radius }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-reference-block__content-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.content_size }}px * 0.95);
    }

    .ai-reference-block__accordion-content-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.content_size }}px * 0.95);
    }
  }
{% endstyle %}

<reference-block-{{ ai_gen_id }}
  class="ai-reference-block-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  {% liquid
    assign data_source = block.settings.data_source
    assign content = ''
    
    case data_source
      when 'tldr'
        assign content = product.metafields.custom.tldr
      when 'what_it_is'
        assign content = product.metafields.custom.what_it_is
      when 'feel_timeline'
        assign content = product.metafields.custom.feel_timeline
      when 'feel_note'
        assign content = product.metafields.custom.feel_note
      when 'how_it_works'
        assign content = product.metafields.custom.how_it_works
      when 'how_to_use'
        assign content = product.metafields.custom.how_to_use
      when 'why'
        assign content = product.metafields.custom.why
      when 'safety'
        assign content = product.metafields.custom.safety
      when 'faq'
        assign content = product.metafields.custom.faq
      when 'custom'
        assign content = block.settings.custom_content
    endcase
  %}

  {% if block.settings.layout_style == 'accordion' %}
    <div class="ai-reference-block__accordion-{{ ai_gen_id }}">
      <button
        class="ai-reference-block__accordion-header-{{ ai_gen_id }}"
        aria-expanded="false"
        aria-controls="accordion-body-{{ ai_gen_id }}"
      >
        <h3 class="ai-reference-block__accordion-title-{{ ai_gen_id }} {{ block.settings.heading_size }}">
          {{ block.settings.heading }}
        </h3>
        <span class="ai-reference-block__accordion-icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
        </span>
      </button>
      <div
        id="accordion-body-{{ ai_gen_id }}"
        class="ai-reference-block__accordion-body-{{ ai_gen_id }}"
      >
        <div class="ai-reference-block__accordion-content-{{ ai_gen_id }}">
          {% if content != blank %}
            {{ content }}
          {% else %}
            <p>Add content to the <strong>{{ block.settings.heading }}</strong> metafield or select a different data source.</p>
          {% endif %}
        </div>
      </div>
    </div>
  {% elsif block.settings.layout_style == 'plain' %}
    <div class="ai-reference-block__plain-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h3 class="ai-reference-block__heading-{{ ai_gen_id }} {{ block.settings.heading_size }}">
          {{ block.settings.heading }}
        </h3>
      {% endif %}
      <div class="ai-reference-block__content-{{ ai_gen_id }}">
        {% if content != blank %}
          {{ content }}
        {% else %}
          <div class="ai-reference-block__empty-{{ ai_gen_id }}">
            Add content to the <strong>{{ block.settings.heading }}</strong> metafield or select a different data source.
          </div>
        {% endif %}
      </div>
    </div>
  {% else %}
    <div class="ai-reference-block__card-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h3 class="ai-reference-block__heading-{{ ai_gen_id }} {{ block.settings.heading_size }}">
          {{ block.settings.heading }}
        </h3>
      {% endif %}
      <div class="ai-reference-block__content-{{ ai_gen_id }}">
        {% if content != blank %}
          {{ content }}
        {% else %}
          <div class="ai-reference-block__empty-{{ ai_gen_id }}">
            Add content to the <strong>{{ block.settings.heading }}</strong> metafield or select a different data source.
          </div>
        {% endif %}
      </div>
    </div>
  {% endif %}
</reference-block-{{ ai_gen_id }}>

<script>
  (function() {
    class ReferenceBlock{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.accordionHeader = this.querySelector('.ai-reference-block__accordion-header-{{ ai_gen_id }}');
        this.accordionBody = this.querySelector('.ai-reference-block__accordion-body-{{ ai_gen_id }}');
        
        if (this.accordionHeader && this.accordionBody) {
          this.setupAccordion();
        }
      }

      setupAccordion() {
        this.accordionHeader.addEventListener('click', () => {
          const isExpanded = this.accordionHeader.getAttribute('aria-expanded') === 'true';
          
          this.accordionHeader.setAttribute('aria-expanded', !isExpanded);
          
          if (!isExpanded) {
            this.accordionBody.classList.add('active');
          } else {
            this.accordionBody.classList.remove('active');
          }
        });
      }
    }

    customElements.define('reference-block-{{ ai_gen_id }}', ReferenceBlock{{ ai_gen_id }});
  })();
</script>

