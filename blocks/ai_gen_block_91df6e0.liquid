{% doc %}
  @name Best Sellers Collection
  @description Displays a product grid from a selected collection using the theme's
    standard product card, grid, and button components. Supports hide-out-of-stock,
    quick-add, and a view-all CTA.
{% enddoc %}

{% liquid
  assign bid = block.id | replace: '_', '' | downcase
  assign collection = block.settings.collection
  assign products_to_show = block.settings.products_to_show
  assign cols_desktop = block.settings.columns_desktop
  assign cols_mobile = block.settings.columns_mobile
  assign aspect = block.settings.aspect_ratio
%}

{% style %}
  .best-sellers-{{ bid }} {
    padding: var(--pt_dt, {{ block.settings.padding_top }}px) 0 var(--pb_dt, {{ block.settings.padding_bottom }}px);
  }

  @media (max-width: 767px) {
    .best-sellers-{{ bid }} {
      padding: var(--pt_mb, {{ block.settings.padding_top_mobile }}px) 0 var(--pb_mb, {{ block.settings.padding_bottom_mobile }}px);
    }
  }

  .best-sellers__header-{{ bid }} {
    margin-bottom: 3.2rem;
  }

  .best-sellers__cta-{{ bid }} {
    display: flex;
    justify-content: center;
    margin-top: 3.2rem;
  }

  .best-sellers__empty-{{ bid }} {
    text-align: center;
    padding: 6rem 2rem;
    color: rgba(var(--color-foreground-3));
    font-size: var(--font-body-desktop-size, 1.6rem);
    line-height: 1.6;
  }
{% endstyle %}

<div
  class="best-sellers-{{ bid }}{% if block.settings.color_scheme %} color-{{ block.settings.color_scheme }}{% endif %}"
  {{ block.shopify_attributes }}
>
  <xo-container>
    {%- if block.settings.heading != blank or block.settings.subheading != blank -%}
      <div class="best-sellers__header-{{ bid }}">
        {% render 'section-heading',
          heading: block.settings.heading,
          description: block.settings.subheading,
          align: block.settings.heading_alignment,
          heading_tag: 'h2'
        %}
      </div>
    {%- endif -%}

    {%- if collection != blank -%}
      {%- assign products_shown = 0 -%}

      <xo-grid style="--lg: {{ cols_desktop }}; --md: 2; --xs: {{ cols_mobile }};">
        {%- for product in collection.products -%}
          {%- if block.settings.hide_out_of_stock and product.available == false -%}
            {%- continue -%}
          {%- endif -%}

          {%- if products_shown >= products_to_show -%}
            {%- break -%}
          {%- endif -%}

          {%- assign products_shown = products_shown | plus: 1 -%}

          {% render 'product-card',
            product: product,
            show_image: true,
            show_secondary_image: settings.product_card_show_secondary_image,
            show_vendor: block.settings.show_vendor,
            show_quick_add: block.settings.enable_quick_add,
            show_quick_view: settings.product_card_show_quick_view,
            show_price: block.settings.show_price,
            show_badge: block.settings.show_badges,
            position_badge: settings.position_badge,
            media_aspect_ratio: aspect,
            animate_enabled: true,
            lazyload: true,
            placeholder_image: 'product-1'
          %}
        {%- endfor -%}
      </xo-grid>

      {%- if products_shown == 0 -%}
        <div class="best-sellers__empty-{{ bid }}">
          {%- if block.settings.hide_out_of_stock -%}
            <p>{{ 'products.product.unavailable' | t | default: 'All products are currently out of stock.' }}</p>
          {%- else -%}
            <p>This collection is empty. Add products to see them here.</p>
          {%- endif -%}
        </div>
      {%- elsif block.settings.show_view_all and collection.url -%}
        <div class="best-sellers__cta-{{ bid }}">
          {% render 'button',
            text: block.settings.view_all_text,
            link: collection.url,
            style: 'primary'
          %}
        </div>
      {%- endif -%}
    {%- else -%}
      <div class="best-sellers__empty-{{ bid }}">
        <p>Select a collection to display your best sellers.</p>
      </div>
    {%- endif -%}
  </xo-container>
</div>

{% schema %}
{
  "name": "Best sellers collection",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "background-1"
    },
    {
      "type": "header",
      "content": "Collection"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "hide_out_of_stock",
      "label": "Hide out of stock products",
      "default": true
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Best Sellers"
    },
    {
      "type": "inline_richtext",
      "id": "subheading",
      "label": "Subheading",
      "default": "Discover our most popular products"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Grid layout"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns (desktop)",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns (mobile)",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "2"
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "Image aspect ratio",
      "options": [
        { "value": "auto", "label": "Adapt to image" },
        { "value": "1", "label": "1:1 Square" },
        { "value": "3/4", "label": "3:4 Portrait" },
        { "value": "4/3", "label": "4:3 Landscape" },
        { "value": "2/3", "label": "2:3 Tall" },
        { "value": "16/9", "label": "16:9 Wide" }
      ],
      "default": "1"
    },
    {
      "type": "header",
      "content": "Product card"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_price",
      "label": "Show price",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_badges",
      "label": "Show badges",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_quick_add",
      "label": "Enable quick add",
      "default": true
    },
    {
      "type": "header",
      "content": "View all button"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show view all button",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_text",
      "label": "Button text",
      "default": "View All Products"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (desktop)",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (desktop)",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top (mobile)",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom (mobile)",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 32
    }
  ],
  "presets": [
    {
      "name": "Best sellers collection"
    }
  ]
}
{% endschema %}
