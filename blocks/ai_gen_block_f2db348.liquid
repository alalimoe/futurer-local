{% doc %}
  @prompt
    An interactive vertical timeline that highlights as the user scrolls, with setting to customize number of tabs + labels (default = 7).
    Tabs pull data from Nootropix product-description-metafields logic (tldr/what_it_is/feel/how_it_works/how/why/safety/faq).
    If data is JSON (legacy), it should be parsed and rendered as readable text/lists (not raw JSON).
{% enddoc %}

{%- liquid
  assign ai_gen_id = block.id | replace: '_', '' | downcase

  comment
    ==========================================
    Nootropix — Product description data layer
    (mirrors your product-description-metafields snippet behavior)
    ==========================================
  endcomment

  assign tldr_src = product.metafields.npx.tl_dr | default: product.metafields.npx.tldr
  assign tldr = nil
  if tldr_src and tldr_src.value
    assign tldr = tldr_src.value
  elsif tldr_src
    assign tldr = tldr_src | parse_json
  endif

  assign what_it_is = product.metafields.npx.what_it_is.value | default: product.metafields.npx.what_it_is
  assign feel = product.metafields.npx.feel_timeline.value
  assign feel_note = product.metafields.npx.feel_note.value | default: product.metafields.npx.feel_note
  assign how = product.metafields.npx.how_to_use.value
  assign why = product.metafields.npx.why.value
  assign safety_important = product.metafields.npx.safety_important.value | default: product.metafields.npx.safety_important
  assign safety_general = product.metafields.npx.safety_general.value | default: product.metafields.npx.safety_general
  assign disclaimer = product.metafields.npx.disclaimer.value | default: product.metafields.npx.disclaimer
  assign faq = product.metafields.npx.faq.value
  assign how_it_works_text = product.metafields.npx.how_it_works.value | default: product.metafields.npx.how_it_works

  assign form_label = 'capsules'
  if product.title contains 'Powder'
    assign form_label = 'powder'
  endif
-%}

{% style %}
  .ai-timeline-container-{{ ai_gen_id }}{
    display:block;
    width:100%;
    padding:40px var(--page-gutter);
    background-color:{{ block.settings.background_color }};
  }

  .ai-timeline-wrapper-{{ ai_gen_id }}{
    max-width:{{ block.settings.max_width }}px;
    margin:0 auto;
    position:relative;
  }

  .ai-timeline-line-{{ ai_gen_id }}{
    position:absolute;
    left:{{ block.settings.dot_size | divided_by: 2 }}px;
    top:0;
    bottom:0;
    width:{{ block.settings.line_width }}px;
    background-color:{{ block.settings.line_color }};
    transform:translateX(-50%);
  }

  .ai-timeline-progress-{{ ai_gen_id }}{
    position:absolute;
    left:0;
    top:0;
    width:100%;
    height:0%;
    background-color:{{ block.settings.active_line_color }};
    transition:height .3s ease;
  }

  .ai-timeline-items-{{ ai_gen_id }}{
    position:relative;
    z-index:1;
  }

  .ai-timeline-item-{{ ai_gen_id }}{
    display:flex;
    gap:{{ block.settings.item_gap }}px;
    margin-bottom:{{ block.settings.item_spacing }}px;
    opacity:.55;
    transition:opacity .25s ease;
  }

  .ai-timeline-item-{{ ai_gen_id }}.active{ opacity:1; }

  .ai-timeline-dot-wrapper-{{ ai_gen_id }}{
    flex-shrink:0;
    position:relative;
  }

  .ai-timeline-dot-{{ ai_gen_id }}{
    width:{{ block.settings.dot_size }}px;
    height:{{ block.settings.dot_size }}px;
    border-radius:50%;
    background-color:{{ block.settings.dot_color }};
    border:{{ block.settings.dot_border_width }}px solid {{ block.settings.dot_border_color }};
    transition:all .25s ease;
  }

  .ai-timeline-item-{{ ai_gen_id }}.active .ai-timeline-dot-{{ ai_gen_id }}{
    background-color:{{ block.settings.active_dot_color }};
    border-color:{{ block.settings.active_dot_border_color }};
    transform:scale(1.15);
  }

  .ai-timeline-content-{{ ai_gen_id }}{
    flex-grow:1;
    padding-top:{{ block.settings.content_padding_top }}px;
    min-width:0;
  }

  .ai-timeline-label-{{ ai_gen_id }}{
    font-size:{{ block.settings.label_font_size }}px;
    font-weight:{{ block.settings.label_font_weight }};
    color:{{ block.settings.label_color }};
    margin-bottom:8px;
  }

  .ai-timeline-item-{{ ai_gen_id }}.active .ai-timeline-label-{{ ai_gen_id }}{
    color:{{ block.settings.active_label_color }};
  }

  /* Let your product-prose.css drive the inner typography.
     This keeps rendering consistent with the rest of PDP. */
  .ai-timeline-text-{{ ai_gen_id }}{
    color:{{ block.settings.text_color }};
  }
  .ai-timeline-item-{{ ai_gen_id }}.active .ai-timeline-text-{{ ai_gen_id }}{
    color:{{ block.settings.active_text_color }};
  }

  /* Slightly tighten spacing inside timeline so rich text doesn’t feel huge */
  .ai-timeline-text-{{ ai_gen_id }} .product-prose{
    font-size:{{ block.settings.text_font_size }}px;
    line-height:1.7;
  }

  @media screen and (max-width: 749px){
    .ai-timeline-container-{{ ai_gen_id }}{ padding:30px 15px; }
    .ai-timeline-label-{{ ai_gen_id }}{ font-size:{{ block.settings.label_font_size | times: 0.9 }}px; }
    .ai-timeline-text-{{ ai_gen_id }} .product-prose{ font-size:{{ block.settings.text_font_size | times: 0.95 }}px; }
  }
{% endstyle %}

<scroll-timeline-{{ ai_gen_id }}
  class="ai-timeline-container-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
  data-offset="{{ block.settings.scroll_offset }}"
>
  <div class="ai-timeline-wrapper-{{ ai_gen_id }}">
    <div class="ai-timeline-line-{{ ai_gen_id }}">
      <div class="ai-timeline-progress-{{ ai_gen_id }}"></div>
    </div>

    <div class="ai-timeline-items-{{ ai_gen_id }}">
      {%- for i in (1..block.settings.number_of_items) -%}
        {%- liquid
          assign label_key = 'item_' | append: i | append: '_label'
          assign section_key = 'item_' | append: i | append: '_section'

          assign label = block.settings[label_key]
          assign section = block.settings[section_key]

          assign has_content = false
        -%}

        {%- capture content_html -%}
          {%- case section -%}

            {%- when 'tldr' -%}
              {%- if tldr != blank -%}
                {%- assign has_content = true -%}
                <div class="product-prose">
                  <ul>
                    {%- for item in tldr -%}
                      <li>{{ item }}</li>
                    {%- endfor -%}
                  </ul>
                </div>
              {%- endif -%}

            {%- when 'what_it_is' -%}
              {%- if what_it_is != blank -%}
                {%- assign has_content = true -%}
                <div class="product-prose">
                  <p>{{ what_it_is }}</p>
                </div>
              {%- endif -%}

            {%- when 'feel_timeline' -%}
              {%- if feel != blank -%}
                {%- assign has_content = true -%}
                <div class="product-prose">
                  <ul>
                    {%- for f in feel -%}
                      <li>
                        {%- if f.label -%}<strong>{{ f.label }}:</strong> {%- endif -%}{{ f.description }}
                      </li>
                    {%- endfor -%}
                  </ul>
                </div>
              {%- endif -%}

            {%- when 'feel_note' -%}
              {%- if feel_note != blank -%}
                {%- assign has_content = true -%}
                <div class="product-prose">
                  <aside class="npx-note">{{ feel_note }}</aside>
                </div>
              {%- endif -%}

            {%- when 'how_it_works' -%}
              {%- if product.metafields.npx.how_it_works != blank -%}
                {%- assign has_content = true -%}
                <div class="product-prose">
                  {{ product.metafields.npx.how_it_works | metafield_tag }}
                </div>
              {%- endif -%}

            {%- when 'how_to_use' -%}
              {%- if how != blank -%}
                {%- assign has_content = true -%}
                <div class="product-prose">
                  <ul>
                    {%- for h in how -%}
                      <li>
                        {%- if h.label -%}<strong>{{ h.label }}:</strong> {%- endif -%}{{ h.text }}
                      </li>
                    {%- endfor -%}
                  </ul>
                </div>
              {%- endif -%}

            {%- when 'why' -%}
              {%- if why != blank -%}
                {%- assign has_content = true -%}
                <div class="product-prose">
                  <ul>
                    {%- for w in why -%}<li>{{ w }}</li>{%- endfor -%}
                  </ul>
                </div>
              {%- endif -%}

            {%- when 'safety' -%}
              {%- if safety_important != blank or safety_general != blank or disclaimer != blank -%}
                {%- assign has_content = true -%}
                <div class="product-prose">
                  {%- if safety_important != blank -%}
                    <aside class="npx-important"><strong>Important:</strong> {{ safety_important }}</aside>
                  {%- endif -%}
                  {%- if safety_general != blank -%}
                    <p><strong>General safety:</strong> {{ safety_general }}</p>
                  {%- endif -%}
                  {%- if disclaimer != blank -%}
                    <aside class="npx-disclaimer"><strong>Disclaimer:</strong> {{ disclaimer }}</aside>
                  {%- endif -%}
                </div>
              {%- endif -%}

            {%- when 'faq' -%}
              {%- if faq != blank -%}
                {%- assign has_content = true -%}
                <div class="product-prose">
                  {%- for q in faq -%}
                    <p><strong>{{ forloop.index }}. {{ q.q }}</strong><br>{{ q.a }}</p>
                  {%- endfor -%}
                </div>
              {%- endif -%}

            {%- else -%}
              {%- comment -%} none / unconfigured {%- endcomment -%}

          {%- endcase -%}
        {%- endcapture -%}

        {%- liquid
          comment
            If merchant accidentally stored JSON string in a field we render here (rare now),
            try parsing and fallback to readable output rather than raw JSON.
          endcomment
        -%}

        <div class="ai-timeline-item-{{ ai_gen_id }}" data-index="{{ forloop.index0 }}">
          <div class="ai-timeline-dot-wrapper-{{ ai_gen_id }}">
            <div class="ai-timeline-dot-{{ ai_gen_id }}"></div>
          </div>

          <div class="ai-timeline-content-{{ ai_gen_id }}">
            {%- if label != blank -%}
              <div class="ai-timeline-label-{{ ai_gen_id }}">
                
              </div>
            {%- endif -%}

            {%- if content_html != blank -%}
              <div class="ai-timeline-text-{{ ai_gen_id }}">
                {{ content_html }}
              </div>
            {%- else -%}
              <div class="ai-timeline-text-{{ ai_gen_id }}" style="color:#999; font-style:italic;">
                No content for this tab (or not configured).
              </div>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</scroll-timeline-{{ ai_gen_id }}>

<script>
  (function() {
    class ScrollTimeline{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.items = [];
        this.progressBar = null;
        this.offset = 0;
        this.handleScroll = this.handleScroll.bind(this);
      }

      connectedCallback() {
        this.items = Array.from(this.querySelectorAll('.ai-timeline-item-{{ ai_gen_id }}'));
        this.progressBar = this.querySelector('.ai-timeline-progress-{{ ai_gen_id }}');
        this.offset = parseInt(this.dataset.offset, 10) || 0;

        if (this.items.length > 0) {
          window.addEventListener('scroll', this.handleScroll, { passive: true });
          window.addEventListener('resize', this.handleScroll, { passive: true });
          this.handleScroll();
        }
      }

      disconnectedCallback() {
        window.removeEventListener('scroll', this.handleScroll);
        window.removeEventListener('resize', this.handleScroll);
      }

      handleScroll() {
        const viewportHeight = window.innerHeight;
        const triggerPoint = viewportHeight * (this.offset / 100);

        let activeIndex = -1;

        this.items.forEach((item, index) => {
          const itemTop = item.getBoundingClientRect().top;
          if (itemTop <= triggerPoint) {
            activeIndex = index;
            item.classList.add('active');
          } else {
            item.classList.remove('active');
          }
        });

        let progress = 0;
        if (activeIndex >= 0 && this.items.length > 1) {
          const first = this.items[0].getBoundingClientRect().top;
          const last  = this.items[this.items.length - 1].getBoundingClientRect().top;
          const current = this.items[activeIndex].getBoundingClientRect().top;

          const total = last - first;
          const done = current - first;

          if (total > 0) progress = Math.min(100, Math.max(0, (done / total) * 100));
        } else if (activeIndex === 0) {
          progress = 0;
        }

        if (this.progressBar) this.progressBar.style.height = progress + '%';
      }
    }

    customElements.define('scroll-timeline-{{ ai_gen_id }}', ScrollTimeline{{ ai_gen_id }});
  })();
</script>

