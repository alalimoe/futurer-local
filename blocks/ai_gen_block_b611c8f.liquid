{% doc %}
  @prompt
    Quick Actions / Jump Links (new block)
    
    A horizontal "pill" nav that anchors to sections below:
    
    TL;DR
    
    How to use
    
    What you'll feel
    
    Safety
    
    FAQ
    
    Support
    
    Controls:
    
    Toggle: "Sticky on scroll" (desktop on; mobile optional)
    
    Toggle: show icons
    
    Editable labels (but with good defaults)
    
    UX notes:
    
    On mobile, make it a horizontally scrollable row of chips.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{%- style -%}
  .ai-jump-links-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: rgba(var(--color-background));
    border-bottom: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 12%, transparent);
    z-index: 100;
  }

  .ai-jump-links-{{ ai_gen_id }}.sticky {
    position: sticky;
    top: 0;
  }

  .ai-jump-links-container-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.gap }}px;
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .ai-jump-links-container-{{ ai_gen_id }}::-webkit-scrollbar {
    display: none;
  }

  .ai-jump-links-item-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: {{ block.settings.pill_padding_vertical }}px {{ block.settings.pill_padding_horizontal }}px;
    background-color: rgba(var(--color-background-2));
    color: rgba(var(--color-foreground));
    border: 1px solid color-mix(in srgb, rgba(var(--color-foreground)) 12%, transparent);
    border-radius: {{ block.settings.pill_border_radius }}px;
    text-decoration: none;
    white-space: nowrap;
    font-size: {{ block.settings.font_size }}px;
    font-weight: 500;
    transition: 0.3s var(--out-soft, ease);
    cursor: pointer;
  }

  .ai-jump-links-item-{{ ai_gen_id }}:hover {
    background-color: rgba(var(--color-accent));
    color: rgba(var(--color-foreground));
    border-color: rgba(var(--color-accent));
  }

  .ai-jump-links-item-{{ ai_gen_id }}.active {
    background-color: rgba(var(--color-accent));
    color: rgba(var(--color-foreground));
    border-color: rgba(var(--color-accent));
  }

  .ai-jump-links-icon-{{ ai_gen_id }} {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  @media screen and (max-width: 768px) {
    .ai-jump-links-{{ ai_gen_id }}.sticky-mobile {
      position: sticky;
      top: 0;
    }

    .ai-jump-links-container-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_vertical_mobile }}px {{ block.settings.padding_horizontal_mobile }}px;
    }
  }
{%- endstyle -%}

<jump-links-{{ ai_gen_id }}
  class="ai-jump-links-{{ ai_gen_id }} color-{{ block.settings.color_scheme }} {% if block.settings.sticky_desktop %}sticky{% endif %} {% if block.settings.sticky_mobile %}sticky-mobile{% endif %}"
  {{ block.shopify_attributes }}
  data-offset="{{ block.settings.scroll_offset }}"
>
  <nav class="ai-jump-links-container-{{ ai_gen_id }}" role="navigation" aria-label="Quick navigation">
    {% if block.settings.show_link_1 %}
      <a
        href="#{{ block.settings.anchor_1 }}"
        class="ai-jump-links-item-{{ ai_gen_id }}"
        data-anchor="{{ block.settings.anchor_1 }}"
      >
        {% if block.settings.show_icons %}
          <svg class="ai-jump-links-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
        {% endif %}
        {{ block.settings.label_1 }}
      </a>
    {% endif %}

    {% if block.settings.show_link_2 %}
