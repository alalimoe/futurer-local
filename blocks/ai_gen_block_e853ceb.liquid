{% doc %}
  @prompt
    Micro trust row (new block)
    
    A 3–4 item row like:
    
    “Lab tested”
    
    “Fast shipping”
    
    “Support 7 days”
    
    “Transparent labeling”
    
    Controls:
    
    Up to 4 items (icon + title + optional short caption)
    
    Turn on/off per item
    
    Why it matters for Nootropix: this is the “calm the nervous system” moment post‑purchase.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-trust-row-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-trust-row__container-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: {{ block.settings.item_spacing }}px;
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
    background-color: {{ block.settings.background_color }};
    flex-wrap: wrap;
  }

  .ai-trust-row__item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: {{ block.settings.icon_text_spacing }}px;
    flex: 1 1 0;
    min-width: 120px;
    max-width: 280px;
  }

  .ai-trust-row__icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    color: {{ block.settings.icon_color }};
    flex-shrink: 0;
  }

  .ai-trust-row__icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
  }

  .ai-trust-row__text-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .ai-trust-row__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: {{ block.settings.title_weight }};
    color: {{ block.settings.title_color }};
    margin: 0;
    line-height: 1.3;
  }

  .ai-trust-row__caption-{{ ai_gen_id }} {
    font-size: {{ block.settings.caption_size }}px;
    color: {{ block.settings.caption_color }};
    margin: 0;
    line-height: 1.4;
  }

  @media screen and (max-width: 749px) {
    .ai-trust-row__container-{{ ai_gen_id }} {
      gap: {{ block.settings.item_spacing | times: 0.7 }}px;
      padding: {{ block.settings.padding_vertical | times: 0.7 }}px {{ block.settings.padding_horizontal | times: 0.7 }}px;
    }

    .ai-trust-row__item-{{ ai_gen_id }} {
      min-width: 100px;
    }

    .ai-trust-row__icon-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size | times: 0.8 }}px;
      height: {{ block.settings.icon_size | times: 0.8 }}px;
    }

    .ai-trust-row__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.9 }}px;
    }

    .ai-trust-row__caption-{{ ai_gen_id }} {
      font-size: {{ block.settings.caption_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

