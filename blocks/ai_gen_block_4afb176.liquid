{% doc %}
  @prompt
    intro blurb block
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-intro-blurb-{{ ai_gen_id }} {
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
    text-align: {{ block.settings.text_alignment }};
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    {% if block.settings.enable_border_radius %}
      border-radius: var(--nx-radius-sm);
    {% endif %}
  }

  .ai-intro-blurb-heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-weight: {{ block.settings.heading_weight }};
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    line-height: 1.2;
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-style: {{ block.settings.heading_font.style }};
    font-weight: {{ block.settings.heading_font.weight }};
  }

  .ai-intro-blurb-text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: {{ block.settings.text_line_height }};
    margin: 0;
    font-family: {{ block.settings.text_font.family }}, {{ block.settings.text_font.fallback_families }};
    font-style: {{ block.settings.text_font.style }};
    font-weight: {{ block.settings.text_font.weight }};
  }

  .ai-intro-blurb-text-{{ ai_gen_id }} p {
    margin: 0 0 1em;
  }

  .ai-intro-blurb-text-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  .ai-intro-blurb-button-wrapper-{{ ai_gen_id }} {
    margin-top: {{ block.settings.button_spacing }}px;
  }

  .ai-intro-blurb-button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 12px 24px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: 4px;
    font-size: {{ block.settings.button_text_size }}px;
    font-weight: 500;
    transition: var(--transition-smooth);
    border: none;
    cursor: pointer;
  }

  .ai-intro-blurb-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
    color: {{ block.settings.button_hover_text_color }};
    transform: translateY(-1px);
  }

  @media screen and (max-width: 749px) {
    .ai-intro-blurb-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top | times: 0.7 }}px {{ block.settings.padding_horizontal | times: 0.7 }}px {{ block.settings.padding_bottom | times: 0.7 }}px;
    }

    .ai-intro-blurb-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-intro-blurb-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.heading != blank %}
    <h2 class="ai-intro-blurb-heading-{{ ai_gen_id }} {{ block.settings.heading_size }}">
      {{ block.settings.heading }}
    </h2>
  {% endif %}

  {% if block.settings.text != blank %}
    <div class="ai-intro-blurb-text-{{ ai_gen_id }}">
      {{ block.settings.text }}
    </div>
  {% endif %}

  {% if block.settings.button_text != blank and block.settings.button_link != blank %}
    <div class="ai-intro-blurb-button-wrapper-{{ ai_gen_id }}">
      <a href="{{ block.settings.button_link }}" class="ai-intro-blurb-button-{{ ai_gen_id }}">
        {{ block.settings.button_text }}
      </a>
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Intro blurb",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Welcome to our store"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Introduce your brand, share your story, or describe what makes your products special. This is your chance to connect with customers and make a great first impression.</p>"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 400,
      "max": 1200,
      "step": 50,
      "unit": "px",
      "label": "Maximum width",
      "default": 800
    },
    {
      "type": "checkbox",
      "id": "enable_border_radius",
      "label": "Enable border radius",
      "default": true
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Horizontal padding",
      "default": 32
    },
    {
      "type": "range",
      "id": "heading_spacing",
      "min": 0,
      "max": 50,
      "step": 2,
      "unit": "px",
      "label": "Heading bottom spacing",
      "default": 16
    },
    {
      "type": "range",
      "id": "button_spacing",
      "min": 0,
      "max": 50,
      "step": 2,
      "unit": "px",
      "label": "Button top spacing",
      "default": 24
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#1e1e1e"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#666666"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button background color",
      "default": "#FBBF24"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#1e1e1e"
    },
    {
      "type": "color",
      "id": "button_hover_color",
      "label": "Button hover background color",
      "default": "#f8c500"
    },
    {
      "type": "color",
      "id": "button_hover_text_color",
      "label": "Button hover text color",
      "default": "#1e1e1e"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "font_picker",
      "id": "heading_font",
      "label": "Heading font",
      "default": "inter_n6"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        {"value": "h1", "label": "Display"},
        {"value": "h2", "label": "XL"},
        {"value": "h3", "label": "L"},
        {"value": "h4", "label": "M"},
        {"value": "h5", "label": "S"},
        {"value": "h6", "label": "XS"}
      ],
      "default": "h3"
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Heading weight",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semi-bold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "600"
    },
    {
      "type": "font_picker",
      "id": "text_font",
      "label": "Text font",
      "default": "inter_n4"
    },
    {
      "type": "range",
      "id": "text_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Text size",
      "default": 16
    },
    {
      "type": "range",
      "id": "text_line_height",
      "min": 1.0,
      "max": 2.0,
      "step": 0.1,
      "label": "Text line height",
      "default": 1.5
    },
    {
      "type": "range",
      "id": "button_text_size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Button text size",
      "default": 14
    }
  ],
  "presets": [
    {
      "name": "Intro blurb"
    }
  ]
}
{% endschema %}