{% doc %}
  @prompt
    heading blog for the H1/title, matching the rest of the styling, add padding / whitespace so it looks clean aligned left. also add breadcrumbs above it
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-heading-blog-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    max-width: {{ block.settings.desktop_width_percent }}%;
    margin: 0 auto;
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
  }

  .ai-heading-blog__breadcrumbs-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.breadcrumb_spacing }}px;
    font-size: 14px;
    color: {{ block.settings.breadcrumb_color }};
  }

  .ai-heading-blog__breadcrumb-list-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .ai-heading-blog__breadcrumb-item-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .ai-heading-blog__breadcrumb-link-{{ ai_gen_id }} {
    color: {{ block.settings.breadcrumb_color }};
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .ai-heading-blog__breadcrumb-link-{{ ai_gen_id }}:hover {
    opacity: 0.7;
  }

  .ai-heading-blog__breadcrumb-separator-{{ ai_gen_id }} {
    color: {{ block.settings.breadcrumb_color }};
    opacity: 0.5;
  }

  .ai-heading-blog__breadcrumb-current-{{ ai_gen_id }} {
    color: {{ block.settings.breadcrumb_color }};
    opacity: 0.6;
  }

  .ai-heading-blog__title-{{ ai_gen_id }} {
    margin: 0;
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-style: {{ block.settings.heading_font.style }};
    font-size: {{ block.settings.font_size }}px;
    line-height: {{ block.settings.line_height }};
    color: {{ block.settings.text_color }};
    text-align: {{ block.settings.text_alignment }};
    letter-spacing: {{ block.settings.letter_spacing }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-heading-blog-{{ ai_gen_id }} {
      width: 100%;
      padding: {{ block.settings.padding_top }}px var(--page-gutter) {{ block.settings.padding_bottom }}px;
    }

    .ai-heading-blog__title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.font_size }}px * 0.7);
    }

    .ai-heading-blog__breadcrumbs-{{ ai_gen_id }} {
      font-size: 12px;
    }
  }
{% endstyle %}

<div class="ai-heading-blog-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.show_breadcrumbs %}
    <nav class="ai-heading-blog__breadcrumbs-{{ ai_gen_id }}" aria-label="Breadcrumb">
      <ul class="ai-heading-blog__breadcrumb-list-{{ ai_gen_id }}">
        <li class="ai-heading-blog__breadcrumb-item-{{ ai_gen_id }}">
          <a href="{{ routes.root_url }}" class="ai-heading-blog__breadcrumb-link-{{ ai_gen_id }}">Home</a>
          <span class="ai-heading-blog__breadcrumb-separator-{{ ai_gen_id }}">/</span>
        </li>
        
        {% if page %}
          <li class="ai-heading-blog__breadcrumb-item-{{ ai_gen_id }}">
            <span class="ai-heading-blog__breadcrumb-current-{{ ai_gen_id }}">{{ page.title }}</span>
          </li>
        {% elsif blog %}
          <li class="ai-heading-blog__breadcrumb-item-{{ ai_gen_id }}">
            {% if article %}
              <a href="{{ blog.url }}" class="ai-heading-blog__breadcrumb-link-{{ ai_gen_id }}">{{ blog.title }}</a>
              <span class="ai-heading-blog__breadcrumb-separator-{{ ai_gen_id }}">/</span>
            {% else %}
              <span class="ai-heading-blog__breadcrumb-current-{{ ai_gen_id }}">{{ blog.title }}</span>
            {% endif %}
          </li>
          {% if article %}
            <li class="ai-heading-blog__breadcrumb-item-{{ ai_gen_id }}">
              <span class="ai-heading-blog__breadcrumb-current-{{ ai_gen_id }}">{{ article.title }}</span>
            </li>
          {% endif %}
        {% elsif collection %}
          <li class="ai-heading-blog__breadcrumb-item-{{ ai_gen_id }}">
            <span class="ai-heading-blog__breadcrumb-current-{{ ai_gen_id }}">{{ collection.title }}</span>
          </li>
        {% elsif product %}
          {% if collection %}
            <li class="ai-heading-blog__breadcrumb-item-{{ ai_gen_id }}">
              <a href="{{ collection.url }}" class="ai-heading-blog__breadcrumb-link-{{ ai_gen_id }}">{{ collection.title }}</a>
              <span class="ai-heading-blog__breadcrumb-separator-{{ ai_gen_id }}">/</span>
            </li>
          {% endif %}
          <li class="ai-heading-blog__breadcrumb-item-{{ ai_gen_id }}">
            <span class="ai-heading-blog__breadcrumb-current-{{ ai_gen_id }}">{{ product.title }}</span>
          </li>
        {% endif %}
      </ul>
    </nav>
  {% endif %}

  <h1 class="ai-heading-blog__title-{{ ai_gen_id }}">
    {{ block.settings.heading_text }}
  </h1>
</div>

{% schema %}
{
  "name": "Heading blog",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading_text",
      "label": "Heading text",
      "default": "Blog title"
    },
    {
      "type": "header",
      "content": "Breadcrumbs"
    },
    {
      "type": "checkbox",
      "id": "show_breadcrumbs",
      "label": "Show breadcrumbs",
      "default": true
    },
    {
      "type": "color",
      "id": "breadcrumb_color",
      "label": "Breadcrumb color",
      "default": "#666666"
    },
    {
      "type": "range",
      "id": "breadcrumb_spacing",
      "min": 8,
      "max": 40,
      "step": 4,
      "unit": "px",
      "label": "Breadcrumb spacing",
      "default": 16
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "font_picker",
      "id": "heading_font",
      "label": "Font",
      "default": "inter_n6"
    },
    {
      "type": "range",
      "id": "font_size",
      "min": 20,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Font size",
      "default": 48
    },
    {
      "type": "range",
      "id": "line_height",
      "min": 1,
      "max": 2,
      "step": 0.1,
      "label": "Line height",
      "default": 1.2
    },
    {
      "type": "range",
      "id": "letter_spacing",
      "min": -2,
      "max": 4,
      "step": 0.5,
      "label": "Letter spacing",
      "default": 0
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#1e1e1e"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Horizontal padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Heading blog"
    }
  ],
  "tag": null
}
{% endschema %}
