{% doc %}
  @prompt
    create a moden products upsell section that renders products from Peptides collection, ordered by best sellers, maximum 4 products (one row in desktop, 2x2 on mobile) showing 4 products in total with option to load more , change from collection handle to drop down selection of products, change the section from collections to products
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% liquid
  assign selected_products = block.settings.selected_products
  assign initial_products = block.settings.initial_products
%}

{% style %}
  .ai-upsell-container-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
    background-color: {{ block.settings.background_color }};
  }

  .ai-upsell-inner-{{ ai_gen_id }} {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 var(--page-gutter);
  }

  .ai-upsell-header-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
    margin-bottom: 32px;
  }

  .ai-upsell-title-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    margin: 0 0 12px;
    font-weight: 600;
  }

  .ai-upsell-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.subheading_color }};
    margin: 0;
  }

  .ai-upsell-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    margin-bottom: 24px;
  }

  .ai-upsell-product-card-{{ ai_gen_id }} {
    background: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    border: 1px solid {{ block.settings.card_border_color }};
    display: none;
  }

  .ai-upsell-product-card-{{ ai_gen_id }}.visible {
    display: block;
  }

  .ai-upsell-product-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-sm-hover);
  }

  .ai-upsell-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 100%;
    overflow: hidden;
    background-color: var(--color-surface-secondary);
  }

  .ai-upsell-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-upsell-badge-{{ ai_gen_id }} {
    position: absolute;
    top: 12px;
    left: 12px;
    background-color: {{ block.settings.badge_background }};
    color: {{ block.settings.badge_text_color }};
    padding: 4px 12px;
    border-radius: 4px;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
  }

  .ai-upsell-content-{{ ai_gen_id }} {
    padding: 16px;
  }

  .ai-upsell-vendor-{{ ai_gen_id }} {
    font-size: 12px;
    color: {{ block.settings.vendor_color }};
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 8px;
  }

  .ai-upsell-product-title-{{ ai_gen_id }} {
    font-size: 16px;
    color: {{ block.settings.product_title_color }};
    margin: 0 0 12px;
    font-weight: 500;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .ai-upsell-price-wrapper-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 16px;
  }

  .ai-upsell-price-{{ ai_gen_id }} {
    font-size: 18px;
    color: {{ block.settings.price_color }};
    font-weight: 600;
  }

  .ai-upsell-compare-price-{{ ai_gen_id }} {
    font-size: 14px;
    color: {{ block.settings.compare_price_color }};
    text-decoration: line-through;
  }

  .ai-upsell-button-{{ ai_gen_id }} {
    width: 100%;
    padding: 12px 24px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.3s ease;
    text-decoration: none;
    display: block;
    text-align: center;
  }

  .ai-upsell-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
  }

  .ai-upsell-load-more-wrapper-{{ ai_gen_id }} {
    text-align: center;
    margin-top: 32px;
  }

  .ai-upsell-load-more-{{ ai_gen_id }} {
    padding: 14px 32px;
    background-color: {{ block.settings.load_more_background }};
    color: {{ block.settings.load_more_text_color }};
    border: 2px solid {{ block.settings.load_more_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .ai-upsell-load-more-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.load_more_hover_background }};
    border-color: {{ block.settings.load_more_hover_border }};
    color: {{ block.settings.button_text_color }};
  }

  .ai-upsell-load-more-{{ ai_gen_id }}.hidden {
    display: none;
  }

  .ai-upsell-empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: #666;
    font-style: italic;
  }

  @media screen and (max-width: 989px) {
    .ai-upsell-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-upsell-subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<product-upsell-{{ ai_gen_id }}
  class="ai-upsell-container-{{ ai_gen_id }}"
  data-initial-products="{{ initial_products }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-upsell-inner-{{ ai_gen_id }}">
    {% if block.settings.show_heading %}
      <div class="ai-upsell-header-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-upsell-title-{{ ai_gen_id }} {{ block.settings.heading_size }}">{{ block.settings.heading }}</h2>
        {% endif %}
        {% if block.settings.subheading != blank %}
          <p class="ai-upsell-subtitle-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
        {% endif %}
      </div>
    {% endif %}

    {% if selected_products.size > 0 %}
      <div class="ai-upsell-grid-{{ ai_gen_id }}">
        {% for product in selected_products %}
          <div class="ai-upsell-product-card-{{ ai_gen_id }} {% if forloop.index <= initial_products %}visible{% endif %}" data-product-index="{{ forloop.index }}">
            <a href="{{ product.url }}" class="ai-upsell-image-wrapper-{{ ai_gen_id }}">
              {% if product.featured_image %}
                <img
                  src="{{ product.featured_image | image_url: width: 600 }}"
                  alt="{{ product.featured_image.alt | escape }}"
                  class="ai-upsell-image-{{ ai_gen_id }}"
                  loading="lazy"
                  width="600"
                  height="600"
                >
              {% else %}
                <div class="ai-upsell-image-placeholder-{{ ai_gen_id }}">
                  {{ 'product-1' | placeholder_svg_tag }}
                </div>
              {% endif %}

              {% if product.compare_at_price > product.price and block.settings.show_badge %}
                <span class="ai-upsell-badge-{{ ai_gen_id }}">Sale</span>
              {% endif %}
            </a>

            <div class="ai-upsell-content-{{ ai_gen_id }}">
              {% if block.settings.show_vendor and product.vendor != blank %}
                <div class="ai-upsell-vendor-{{ ai_gen_id }}">{{ product.vendor }}</div>
              {% endif %}

              <h3 class="ai-upsell-product-title-{{ ai_gen_id }}">
                <a href="{{ product.url }}" style="color: inherit; text-decoration: none;">
                  {{ product.title }}
                </a>
              </h3>

              {% if block.settings.show_price %}
                <div class="ai-upsell-price-wrapper-{{ ai_gen_id }}">
                  <span class="ai-upsell-price-{{ ai_gen_id }}">{{ product.price | money }}</span>
                  {% if product.compare_at_price > product.price %}
                    <span class="ai-upsell-compare-price-{{ ai_gen_id }}">{{ product.compare_at_price | money }}</span>
                  {% endif %}
                </div>
              {% endif %}

              <a href="{{ product.url }}" class="ai-upsell-button-{{ ai_gen_id }}">
                {{ block.settings.button_text }}
              </a>
            </div>
          </div>
        {% endfor %}
      </div>

      {% if selected_products.size > initial_products %}
        <div class="ai-upsell-load-more-wrapper-{{ ai_gen_id }}">
          <button class="ai-upsell-load-more-{{ ai_gen_id }}" data-total="{{ selected_products.size }}">
            {{ block.settings.load_more_text }}
          </button>
        </div>
      {% endif %}
    {% else %}
      <div class="ai-upsell-empty-state-{{ ai_gen_id }}">
        <p>No products selected. Please add products to display.</p>
      </div>
    {% endif %}
  </div>
</product-upsell-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductUpsell{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.initialProducts = parseInt(this.dataset.initialProducts) || 4;
        this.currentVisible = this.initialProducts;
      }

      connectedCallback() {
        this.loadMoreButton = this.querySelector('.ai-upsell-load-more-{{ ai_gen_id }}');
        this.productCards = this.querySelectorAll('.ai-upsell-product-card-{{ ai_gen_id }}');
        this.totalProducts = this.loadMoreButton ? parseInt(this.loadMoreButton.dataset.total) : 0;

        if (this.loadMoreButton) {
          this.loadMoreButton.addEventListener('click', () => this.loadMore());
        }
      }

      loadMore() {
        const remainingProducts = this.totalProducts - this.currentVisible;
        const productsToLoad = Math.min(remainingProducts, this.initialProducts);

        for (let i = this.currentVisible; i < this.currentVisible + productsToLoad; i++) {
          const card = this.querySelector(`[data-product-index="${i + 1}"]`);
          if (card) {
            card.classList.add('visible');
          }
        }

        this.currentVisible += productsToLoad;

        if (this.currentVisible >= this.totalProducts) {
          this.loadMoreButton.classList.add('hidden');
        }
      }
    }

    customElements.define('product-upsell-{{ ai_gen_id }}', ProductUpsell{{ ai_gen_id }});
  })();
</script>

