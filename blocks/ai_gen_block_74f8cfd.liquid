{% doc %}
  @prompt
    create a modern, clean 'Shop by goal' section with customizable settings to select which collections to display in it (include breadcrumbs, page title, followed by the selected collections
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{%- style -%}
  .ai-shop-by-goal-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
    background-color: rgba(var(--color-background));
  }

  .ai-shop-by-goal-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 var(--page-gutter);
  }

  .ai-shop-by-goal-breadcrumbs-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.breadcrumb_spacing }}px;
    font-size: {{ block.settings.breadcrumb_font_size }}px;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 40%, transparent);
  }

  .ai-shop-by-goal-breadcrumbs-{{ ai_gen_id }} a {
    color: rgba(var(--color-foreground));
    text-decoration: none;
    transition: color 0.3s var(--out-soft, ease);
  }

  .ai-shop-by-goal-breadcrumbs-{{ ai_gen_id }} a:hover {
    color: rgba(var(--color-accent));
  }

  .ai-shop-by-goal-breadcrumbs-{{ ai_gen_id }} .separator {
    margin: 0 8px;
    opacity: 0.5;
  }

  .ai-shop-by-goal-header-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.header_spacing }}px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-shop-by-goal-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_font_size }}px;
    color: rgba(var(--color-foreground));
    margin: 0 0 {{ block.settings.title_margin_bottom }}px;
    font-weight: 600;
    line-height: 1.2;
  }

  .ai-shop-by-goal-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_font_size }}px;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 40%, transparent);
    margin: 0;
    line-height: 1.6;
  }

  .ai-shop-by-goal-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  @media screen and (max-width: 768px) {
    .ai-shop-by-goal-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }

    .ai-shop-by-goal-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_font_size }}px * 0.8);
    }
  }

  .ai-shop-by-goal-card-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.card_border_radius }}px;
    background-color: rgba(var(--color-background));
    transition: transform 0.3s var(--out-soft, ease);
    display: flex;
    flex-direction: column;
  }

  .ai-shop-by-goal-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
  }

  .ai-shop-by-goal-card-link-{{ ai_gen_id }} {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .ai-shop-by-goal-card-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: {{ block.settings.image_aspect_ratio }}%;
    overflow: hidden;
    background-color: rgba(var(--color-background-2));
  }

  .ai-shop-by-goal-card-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-shop-by-goal-card-image-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: rgba(var(--color-background-2));
  }

  .ai-shop-by-goal-card-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-shop-by-goal-card-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: {{ block.settings.overlay_gradient }};
    opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};
    transition: opacity 0.3s ease;
  }

  .ai-shop-by-goal-card-{{ ai_gen_id }}:hover .ai-shop-by-goal-card-overlay-{{ ai_gen_id }} {
    opacity: {{ block.settings.overlay_hover_opacity | divided_by: 100.0 }};
  }

  .ai-shop-by-goal-card-content-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding }}px;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    text-align: {{ block.settings.card_text_alignment }};
  }

  .ai-shop-by-goal-card-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_title_font_size }}px;
    color: rgba(var(--color-foreground));
    margin: 0 0 8px;
    font-weight: 600;
    line-height: 1.3;
  }

  .ai-shop-by-goal-card-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_description_font_size }}px;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 40%, transparent);
    margin: 0;
    line-height: 1.5;
  }

  .ai-shop-by-goal-empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: color-mix(in srgb, rgba(var(--color-foreground)) 40%, transparent);
  }

  .ai-shop-by-goal-empty-state-{{ ai_gen_id }} p {
    font-size: 16px;
    margin: 0;
  }
{%- endstyle -%}

<shop-by-goal-{{ ai_gen_id }}
  class="ai-shop-by-goal-{{ ai_gen_id }} color-{{ block.settings.color_scheme }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-shop-by-goal-container-{{ ai_gen_id }}">
    {% if block.settings.show_breadcrumbs %}
      <nav class="ai-shop-by-goal-breadcrumbs-{{ ai_gen_id }}" aria-label="Breadcrumb">
        <a href="{{ routes.root_url }}">Home</a>
        <span class="separator">›</span>
        <span>{{ block.settings.page_title }}</span>
      </nav>
    {% endif %}

    <div class="ai-shop-by-goal-header-{{ ai_gen_id }}">
      {% if block.settings.page_title != blank %}
        <h1 class="ai-shop-by-goal-title-{{ ai_gen_id }}">{{ block.settings.page_title }}</h1>
      {% endif %}

      {% if block.settings.page_description != blank %}
        <div class="ai-shop-by-goal-description-{{ ai_gen_id }}">
          {{ block.settings.page_description }}
        </div>
      {% endif %}
    </div>

    {% liquid
      assign has_collections = false
      for i in (1..8)
        assign collection_key = 'collection_' | append: i
        assign collection = block.settings[collection_key]
        if collection != blank
          assign has_collections = true
          break
        endif
      endfor
    %}

    {% if has_collections %}
      <div class="ai-shop-by-goal-grid-{{ ai_gen_id }}">
        {% for i in (1..8) %}
          {% liquid
            assign collection_key = 'collection_' | append: i
            assign collection = block.settings[collection_key]
          %}

          {% if collection != blank %}
            <div class="ai-shop-by-goal-card-{{ ai_gen_id }}">
              <a href="{{ collection.url }}" class="ai-shop-by-goal-card-link-{{ ai_gen_id }}">
                <div class="ai-shop-by-goal-card-image-wrapper-{{ ai_gen_id }}">
                  {% if collection.featured_image %}
                    <img
                      src="{{ collection.featured_image | image_url: width: 800 }}"
                      alt="{{ collection.featured_image.alt | escape }}"
                      class="ai-shop-by-goal-card-image-{{ ai_gen_id }}"
                      loading="lazy"
                      width="800"
                      height="{{ 800 | times: block.settings.image_aspect_ratio | divided_by: 100 }}"
                    >
                  {% else %}
                    <div class="ai-shop-by-goal-card-image-placeholder-{{ ai_gen_id }}">
                      {{ 'collection-1' | placeholder_svg_tag }}
                    </div>
                  {% endif %}
                  <div class="ai-shop-by-goal-card-overlay-{{ ai_gen_id }}"></div>
                </div>

                <div class="ai-shop-by-goal-card-content-{{ ai_gen_id }}">
                  <h3 class="ai-shop-by-goal-card-title-{{ ai_gen_id }}">{{ collection.title }}</h3>
                  {% if block.settings.show_collection_description and collection.description != blank %}
                    <div class="ai-shop-by-goal-card-description-{{ ai_gen_id }}">
                      {{ collection.description | strip_html | truncate: 120 }}
                    </div>
                  {% endif %}
                </div>
              </a>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    {% else %}
      <div class="ai-shop-by-goal-empty-state-{{ ai_gen_id }}">
        <p>Select collections to display in the block settings</p>
      </div>
    {% endif %}
  </div>
</shop-by-goal-{{ ai_gen_id }}>

<script>
  (function() {
    class ShopByGoal{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.init();
      }

      init() {
        const cards = this.querySelectorAll('.ai-shop-by-goal-card-{{ ai_gen_id }}');
        cards.forEach((card, index) => {
          card.style.animationDelay = `${index * 0.1}s`;
        });
      }
    }

    customElements.define('shop-by-goal-{{ ai_gen_id }}', ShopByGoal{{ ai_gen_id }});
  })();
</script>

{% schema %}
