{% comment %}
  Page template: nootropix-faq-jsonld
  Renders normal page content + adds FAQ JSON-LD section.
{% endcomment %}

<article class="page-width" aria-labelledby="page-title-{{ page.id }}">
  <header class="page-header">
    <h1 id="page-title-{{ page.id }}">{{ page.title }}</h1>
  </header>

  <div class="rte">
    {{ page.content }}
  </div>
</article>

{% section 'faq-jsonld' %}
