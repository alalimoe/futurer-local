          "settings": {
            "category": "Local Delivery (UAE – Quiqup)",
            "tags": "same day,next day,delivery speed,uae",
            "question": "How fast will my order arrive in the UAE?",
            "answer": "<p><strong>Usually the same day or next day.</strong> The fastest options for your address show at checkout. Watch for your tracking link by SMS/email.</p><p><a href=\"/pages/track-order\" target=\"_blank\" rel=\"noopener\">Track your order</a></p>",
            "sources": ""
          }
        },
        "local-2": {
          "type": "faq",
          "settings": {
            "category": "Local Delivery (UAE – Quiqup)",
            "tags": "plan,realistic,timeframe,expectations",
            "question": "When should I expect my order?",
            "answer": "<p>Most local orders reach you <strong>by the end of the day</strong> (if placed before the cut‑off). If we’re running behind, we’ll update you and re‑book the earliest window.</p><p><em>Recent snapshot:</em> solid on‑time performance and successful deliveries, with the best days lately being Thu & Fri.</p>",
            "sources": ""
          }
        },
        "local-3": {
          "type": "faq",
          "settings": {
            "category": "Local Delivery (UAE – Quiqup)",
            "tags": "cutoff,same day,4-hour,windows",
            "question": "Order cut‑offs for same‑day & 4‑hour",
            "answer": "<p>If you order before the cut‑off, we aim to deliver <strong>today</strong>. A faster <strong>4‑hour</strong> option may show at checkout during the day. If you miss the cut‑off, we’ll book the next available window (often next day).</p>",
            "sources": ""
          }
        },
        "local-4": {
          "type": "faq",
          "settings": {
            "category": "Local Delivery (UAE – Quiqup)",
            "tags": "call,whatsapp,contact,courier",
            "question": "Will the driver call or WhatsApp me?",
            "answer": "<p>Yes. Keep your phone handy in your delivery window. Add gate/building notes at checkout so the driver can reach you easily.</p>",
            "sources": ""
          }
        },
        "local-5": {
          "type": "faq",
          "settings": {
            "category": "Local Delivery (UAE – Quiqup)",
            "tags": "missed,not home,reattempt,reschedule",
            "question": "Missed the courier?",
            "answer": "<p>No stress—reply to the tracking SMS/email with your preferred time (e.g., 10am–1pm or 5–8pm). We’ll arrange the next attempt. If your building needs access codes, share them so we can reach you on the first try.</p>",
            "sources": ""
          }
        },
        "local-6": {
          "type": "faq",
          "settings": {
            "category": "Local Delivery (UAE – Quiqup)",
            "tags": "cod,cash on delivery",
            "question": "Can I pay cash on delivery (COD)?",
            "answer": "<p>Yes—if COD is available for your address, it will appear at checkout. Please prepare the exact amount. You’ll get proof‑of‑delivery when it’s handed over.</p>",
            "sources": ""
          }
        },
        "local-7": {
          "type": "faq",
          "settings": {
            "category": "Local Delivery (UAE – Quiqup)",
            "tags": "next day,uae coverage",
            "question": "Next‑day delivery across the UAE",
            "answer": "<p>Order before the cut‑off and expect next‑day delivery by evening. Ordering after the cut‑off? We’ll book the next available day.</p>",
            "sources": ""
          }
        },
        "local-8": {
          "type": "faq",
          "settings": {
            "category": "Local Delivery (UAE – Quiqup)",
            "tags": "same day availability,areas,dubai",
            "question": "Is same‑day available where I live?",
            "answer": "<p>Same‑day is widely available in Dubai (and selected nearby areas). You’ll see what’s available at checkout. If you don’t see it, pick next‑day or message us for options.</p>",
            "sources": ""
          }
        },
        "local-tips": {
          "type": "faq",
          "settings": {
            "category": "Local Delivery (UAE – Quiqup)",
            "tags": "tips,faster delivery,notes,contact",
            "question": "Need it fast? Quick tips",
            "answer": "<ul><li><strong>Order earlier</strong> in the day for more delivery options.</li><li><strong>Add building notes</strong> (gate code, reception, landmarks).</li><li><strong>Keep your phone on</strong> during your window—drivers may call/WhatsApp.</li><li><strong>Missed us?</strong> Reply to your tracking message with a new time window.</li></ul>",
            "sources": ""
          }
