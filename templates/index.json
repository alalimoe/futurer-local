          "settings": {
            "title": "<p>How fast is shipping?</p>",
            "content": "<p>We dispatch all orders same day from Dubai. International orders ship express; delivery times vary by region. More on <a href=\"/pages/shipping-and-returns\" target=\"_blank\" title=\"Shipping & Returns Policy\">shipping policy</a>.</p>"
          }
