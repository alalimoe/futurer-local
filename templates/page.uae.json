        "faq_1": {
          "type": "faq",
          "settings": {
            "question": "Are nootropics legal in the UAE?",
            "answer": "Many are sold as dietary supplements. Certain substances may be restricted or require approval. Always check the latest MOHAP guidance."
          }
        },
        "faq_2": {
          "type": "faq",
          "settings": {
            "question": "Do I need approval to import personal meds?",
            "answer": "Some medicines require prior MOHAP approval. Supplements with restricted ingredients may be stopped by customs."
          }
        },
        "faq_3": {
          "type": "faq",
          "settings": {
            "question": "What's the difference between supplements and prescriptions?",
            "answer": "Supplements are sold over-the-counter; prescription medicines require a valid script and may be controlled."
          }
        },
        "faq_4": {
          "type": "faq",
          "settings": {
            "question": "How does customs review shipments?",
            "answer": "Based on HS codes, ingredients, and declarations. Documentation accuracy speeds clearance."
          }
        },
        "faq_5": {
          "type": "faq",
          "settings": {
            "question": "Which ingredients are commonly restricted?",
            "answer": "Examples include certain stimulants or scheduled substances. Ingredients lists are shown on each product page."
          }
        },
        "faq_6": {
          "type": "faq",
          "settings": {
            "question": "Do you provide Certificates of Analysis (COAs)?",
            "answer": "Yes — COAs from industry-leading manufacturers are available on request for eligible products."
