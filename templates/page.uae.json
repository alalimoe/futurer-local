          }
        },
        "faq_3": {
          "type": "faq",
          "settings": {
            "question": "International shipping options?",
            "answer": "DHL International Express with tracking. Free express on orders of +300 AED."
          }
        },
        "faq_4": {
          "type": "faq",
          "settings": {
            "question": "How are orders and parcels packed?",
            "answer": "Tamper-evident + heat-insulated thermal pouches for temperature protection."
