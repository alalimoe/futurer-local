        "d1": {
          "type": "faq",
          "settings": {
            "category": "Dubai Delivery",
            "tags": "dubai,same day,4-hour,cutoff,al quoz",
            "question": "How fast is delivery in Dubai?",
            "answer": "<p><strong>Usually same-day</strong>, with a <strong>4-hour option</strong> shown at checkout during the day. Order before the cut-off and we’ll deliver by evening.</p><p><a href=\"/pages/track-order\" target=\"_blank\" rel=\"noopener\">Track your order</a></p>",
            "sources": ""
          }
        },
        "d2": {
          "type": "faq",
          "settings": {
            "category": "Dubai Delivery",
            "tags": "cutoff,windows,4-hour",
            "question": "What are the cut-offs and delivery windows?",
            "answer": "<p><strong>Same-day</strong>: order before your cut-off to receive by ~10pm. <strong>4-hour</strong>: order before ~6pm (currently served from Al Quoz).</p><p>If you miss a cut-off, we’ll book the next available window.</p>",
            "sources": ""
          }
        },
        "d3": {
          "type": "faq",
          "settings": {
            "category": "Dubai Delivery",
            "tags": "call,whatsapp,driver,notes",
            "question": "Will the driver call or WhatsApp me?",
            "answer": "<p>Yes—keep your phone handy during your window and add building/gate notes at checkout for smooth hand-off.</p>",
            "sources": ""
          }
        },
        "d4": {
          "type": "faq",
          "settings": {
            "category": "Dubai Delivery",
            "tags": "missed,reattempt,reschedule",
            "question": "I wasn’t home—what happens next?",
            "answer": "<p>No worries—reply to your tracking SMS/email with your preferred time (e.g., 10am–1pm or 5–8pm). We’ll arrange the next attempt.</p>",
            "sources": ""
          }
        },
        "d5": {
          "type": "faq",
          "settings": {
            "category": "Dubai Delivery",
            "tags": "cod,cash on delivery",
            "question": "Can I pay Cash on Delivery (COD)?",
            "answer": "<p>Yes, COD is available for eligible Dubai addresses (you’ll see it at checkout). Please prepare the exact amount; proof-of-delivery is provided.</p>",
            "sources": ""
          }
        }
