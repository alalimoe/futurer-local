{% comment %}
  Nootropix — Peptide Wholesale & Research Supply Page
  Purpose: For clinics, labs, and research institutions ordering ≥1 g quantities of peptides.
  Layout: Simple two-column info + form. Matches Nootropix wholesale visual language.
{% endcomment %}

<section class="nx-section peptide-wholesale">
  <div class="container mx-auto px-4 py-12 max-w-6xl">
    <header class="text-center mb-10">
      <h1 class="text-4xl font-semibold mb-3">Peptide Wholesale & Research Supply</h1>
      <p class="text-gray-600 max-w-2xl mx-auto">
        High-purity peptides for research, clinical, and formulation use — available in bulk quantities (≥ 1 g).
        We supply verified peptides directly to research facilities, clinics, and compounding labs across the UAE and internationally.
        Fast response times. COAs on file. Shipments fulfilled from Dubai.
      </p>
    </header>

    <!-- Table: Available Peptides -->
    <div class="bg-gray-50 rounded-xl p-6 shadow-sm mb-10 overflow-x-auto">
      <h2 class="text-xl font-medium mb-4">Bulk Availability (≥ 1 g per peptide)</h2>
      <table class="w-full text-left border-collapse text-sm" aria-label="Bulk peptide availability">
        <thead>
          <tr class="border-b">
            <th class="py-3 font-semibold">Peptide</th>
            <th class="py-3 font-semibold">Purity</th>
            <th class="py-3 font-semibold">Format</th>
            <th class="py-3 font-semibold">MOQ</th>
            <th class="py-3 font-semibold">Lead Time</th>
          </tr>
        </thead>
        <tbody>
          <tr class="border-b">
            <td class="py-3">BPC-157 (Arginate)</td>
            <td>≥ 99%</td>
            <td>Lyophilized powder</td>
            <td>1 g +</td>
            <td>1–3 business days</td>
          </tr>
          <tr class="border-b">
            <td class="py-3">TB-500 (Thymosin β-4 Fragment 17-23)</td>
            <td>≥ 98%</td>
            <td>Lyophilized powder</td>
            <td>1 g +</td>
            <td>1–3 business days</td>
          </tr>
          <tr class="border-b">
            <td class="py-3">GHK-Cu (Copper Peptide)</td>
            <td>≥ 99%</td>
            <td>Lyophilized powder</td>
            <td>1 g +</td>
            <td>1–3 business days</td>
          </tr>
          <tr class="border-b">
            <td class="py-3">CJC-1295 + Ipamorelin (Combo)</td>
            <td>≥ 98%</td>
            <td>Lyophilized powder</td>
            <td>1 g +</td>
            <td>3–5 business days</td>
          </tr>
          <tr>
            <td class="py-3">Melanotan II</td>
            <td>≥ 98%</td>
            <td>Lyophilized powder</td>
            <td>1 g +</td>
            <td>3–5 business days</td>
          </tr>
        </tbody>
      </table>
      <p class="text-gray-500 text-sm mt-4">
        All lots include COA, HPLC + MS data, and are stored under controlled temperature.
        Custom synthesis requests (≥ 5 g or > 99.5% purity) available upon request.
      </p>
    </div>

    <!-- Why Partner -->
    <div class="grid md:grid-cols-2 gap-8 mb-12">
      <div>
        <h2 class="text-xl font-medium mb-4">Why Partner with Nootropix Research Supply</h2>
        <ul class="space-y-2 text-gray-700 text-sm">
          <li>• Local UAE fulfillment — minimize customs friction</li>
          <li>• GMP-compliant suppliers with analytical COA included</li>
          <li>• Fast turnaround — replies within 1 business day</li>
          <li>• Temperature-controlled logistics</li>
          <li>• Confidential B2B handling & documentation</li>
        </ul>
      </div>

      <!-- How It Works -->
      <div>
        <h2 class="text-xl font-medium mb-4">How It Works</h2>
        <ol class="space-y-2 text-gray-700 text-sm list-decimal ml-5">
          <li>Submit the enquiry form with your organization details & target quantities.</li>
          <li>We respond within 1 business day with pricing, COA, and ETA.</li>
          <li>Confirm your quote via bank transfer or card payment.</li>
          <li>Orders ship securely with documentation and tracking provided.</li>
        </ol>
      </div>
    </div>

    <!-- Enquiry Form -->
    <div class="bg-gray-50 rounded-xl p-6 shadow-sm">
      <h2 class="text-xl font-medium mb-4 text-center" id="wholesale-form-heading">Apply for Peptide Supply</h2>
      <form method="post" action="/contact#peptide-wholesale" class="peptide-wholesale__form grid md:grid-cols-2 gap-4" aria-labelledby="wholesale-form-heading">
        <input type="hidden" name="form_type" value="contact">
        <input type="hidden" name="contact[tags]" value="peptide, wholesale, enquiry">

        <div class="peptide-wholesale__field">
          <label for="ws-company" class="sr-only">Company / Lab Name</label>
          <input id="ws-company" type="text" name="contact[company]" placeholder="Company / Lab Name *" required class="border p-3 rounded w-full" autocomplete="organization">
        </div>
        <div class="peptide-wholesale__field">
          <label for="ws-email" class="sr-only">Email</label>
          <input id="ws-email" type="email" name="contact[email]" placeholder="Email *" required class="border p-3 rounded w-full" autocomplete="email">
        </div>
        <div class="peptide-wholesale__field">
          <label for="ws-name" class="sr-only">Contact Person</label>
          <input id="ws-name" type="text" name="contact[name]" placeholder="Contact Person *" required class="border p-3 rounded w-full" autocomplete="name">
        </div>
        <div class="peptide-wholesale__field">
          <label for="ws-phone" class="sr-only">Phone</label>
          <input id="ws-phone" type="tel" name="contact[phone]" placeholder="Phone (optional)" class="border p-3 rounded w-full" autocomplete="tel">
        </div>
        <div class="peptide-wholesale__field peptide-wholesale__field--full">
          <label for="ws-quantity" class="sr-only">Quantity</label>
          <input id="ws-quantity" type="text" name="contact[quantity]" placeholder="Quantity (e.g. 10 × 1 g vials)" class="border p-3 rounded w-full">
        </div>
        <div class="peptide-wholesale__field peptide-wholesale__field--full">
          <label for="ws-products" class="sr-only">Peptides of Interest</label>
          <textarea id="ws-products" name="contact[products]" placeholder="Peptides of Interest (e.g. BPC 157 1 g, TB-500 2 g…)" class="border p-3 rounded w-full" rows="3"></textarea>
        </div>
        <div class="peptide-wholesale__field peptide-wholesale__field--full">
          <label for="ws-message" class="sr-only">Additional Notes</label>
          <textarea id="ws-message" name="contact[message]" placeholder="Additional Notes / Research Use Details" class="border p-3 rounded w-full" rows="3"></textarea>
        </div>

        <div class="text-center peptide-wholesale__field--full mt-4">
          <button type="submit" class="peptide-wholesale__submit">
            Send Enquiry
          </button>
        </div>
      </form>

      <p class="text-center text-sm text-gray-500 mt-4">
        Prefer direct contact? Email us at
        <a href="mailto:research@nootropix.shop" class="underline">research@nootropix.shop</a>
      </p>
    </div>
  </div>
</section>

<style>
  .peptide-wholesale h1,
  .peptide-wholesale h2 { color: var(--color-text-main, #121212); }
  .peptide-wholesale table th,
  .peptide-wholesale table td { padding-right: 1rem; }

  .sr-only {
    position: absolute; width: 1px; height: 1px;
    padding: 0; margin: -1px; overflow: hidden;
    clip: rect(0, 0, 0, 0); white-space: nowrap; border: 0;
  }

  .peptide-wholesale__field--full { grid-column: 1 / -1; }

  .peptide-wholesale__form input,
  .peptide-wholesale__form textarea {
    min-height: var(--touch-min, 44px);
    transition: var(--transition-smooth, border-color 0.3s ease, box-shadow 0.3s ease);
  }
  .peptide-wholesale__form input:focus-visible,
  .peptide-wholesale__form textarea:focus-visible {
    outline: 2px solid var(--color-accent-dark, #92400e);
    outline-offset: 2px;
    border-color: var(--color-accent-primary, #FBBF24);
  }

  .peptide-wholesale__submit {
    background: var(--color-accent-primary, #FBBF24);
    color: var(--color-accent-on-gold, #000);
    font-weight: 700;
    min-height: var(--touch-min, 44px);
    padding: 0.75rem 2rem;
    border: 2px solid transparent;
    border-radius: var(--radius-premium, 8px);
    cursor: pointer;
    transition: var(--transition-premium, all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1));
  }
  .peptide-wholesale__submit:hover {
    background: var(--color-accent-hover, #fbbf24);
  }
  .peptide-wholesale__submit:active {
    transform: scale(0.98);
  }
  .peptide-wholesale__submit:focus-visible {
    outline: 2px solid var(--color-accent-dark, #92400e);
    outline-offset: 3px;
  }

  @media (prefers-reduced-motion: reduce) {
    .peptide-wholesale__form input,
    .peptide-wholesale__form textarea,
    .peptide-wholesale__submit {
      transition: none;
    }
    .peptide-wholesale__submit:active { transform: none; }
  }
</style>
